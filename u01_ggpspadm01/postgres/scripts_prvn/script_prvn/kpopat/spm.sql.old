create table kpopat.spm_sql_id_stats as
select 'C01' cluster_id,
       sql_id, 
       plan_hash_value ,
       sql_profile, 
       sql_plan_baseline, 
       executions, 
       rows_processed avg_rows_returned,       
       round(elapsed_time/1000/executions/1000,4) elapsed_time_per_exec , 
       round(disk_reads/executions) avg_pio, 
       round (buffer_gets / executions) avg_lio,
       round (cpu_time / executions / 1000/1000,4) avg_cpu_time_per_exec,
       round(concurrency_wait_time/1000/executions/1000,4) concurrency_wait_time,
       round(user_io_wait_time/1000/executions/1000,4) user_io_wait_time,
       command_type,
       last_active_time,
       sysdate create_date 
  from gv$sql 
  where 1=2 ;

-- 2,3,6,7, 189 (I, S, U, D,UPSERT)

alter table kpopat.spm_sql_id_stats modify (cluster_id varchar2(10));
alter table kpopat.spm_sql_id_stats add (run_id number);
alter table kpopat.spm_sql_id_stats add (sql_id_handle varchar2(512));
create index kpopat.spm_sql_id_stats_sql_id_run_id on spm_sql_id_stats(sql_id, run_id);  
create table kpopat.spm_qbo_clusters
             (
             cluster_id varchar2(10), 
             cluster_sid_qcy varchar2(10), 
             cluster_sid_las varchar2(10), 
             cluster_type varchar2(10));
alter table kpopat.spm_qbo_clusters add (cluster_sid_uw2 varchar2(10));
alter table kpopat.spm_qbo_clusters add (cluster_ip_qcy varchar2(30),
             cluster_ip_las varchar2(30));
delete kpopat.spm_qbo_clusters;       
