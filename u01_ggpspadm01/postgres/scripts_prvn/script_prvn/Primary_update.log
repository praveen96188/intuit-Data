SQL> SELECT /*+ PARALLEL(8) */
  2      mmt.initiation_date,
  3      edr.initiation_date,
  4      offload_date,
  5      mmt.offload_batch_fk, edr.SETTLEMENT_DATE, edr.N_A_C_H_A_FILE_TYPE
  6  FROM PSPADM.psp_money_movement_transaction mmt,
  7       PSPADM.psp_entry_detail_record edr,
  8       PSPADM.psp_offload_batch ob
  9  WHERE mmt.initiation_date = TO_DATE('2021-07-05 07:00:00', 'yyyy-mm-dd hh:mi:ss')
 10    AND edr.initiation_date = TO_DATE('2021-07-05 07:00:00', 'yyyy-mm-dd hh:mi:ss')
 11    AND n_a_c_h_a_file_type in ('CCD', 'PPD')
 12    AND ob.offload_batch_seq = mmt.offload_batch_fk
 13    AND money_movement_payment_method = 'ACHDirectDeposit'
 14    AND mmt.money_movement_transaction_seq = edr.money_movement_transaction_fk
 15  --   AND (offload_batch_fk IS NOT NULL AND n_a_c_h_a_file_fk IS NULL)
 16  GROUP BY mmt.initiation_date,
 17           edr.initiation_date,
 18           mmt.offload_batch_fk,
 19           offload_date,edr.SETTLEMENT_DATE, edr.N_A_C_H_A_FILE_TYPE
 20  ORDER BY mmt.initiation_date;--60989a90-ddd3-5eff-e053-5a048f0a4ea8;
ORDER BY mmt.initiation_date;--60989a90-ddd3-5eff-e053-5a048f0a4ea8
