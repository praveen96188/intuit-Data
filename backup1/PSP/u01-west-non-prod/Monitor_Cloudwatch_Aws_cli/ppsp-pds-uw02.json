#1.CPUUtilization-Warning - ppsp-pds-uw02 - ppsp-pds-uw022

aws cloudwatch put-metric-alarm \
--alarm-name 'CPUUtilization-Warning - ppsp-pds-uw02 - ppsp-pds-uw022' \
--alarm-description 'Alarm/page when # of db CPU utilization exceed this threshold' \
--region us-west-2 \
--actions-enabled \
--ok-actions 'arn:aws:sns:us-west-2:152430470825:DB-sbg-psp-warning-ppd-a-intuit-com' \
--alarm-actions 'arn:aws:sns:us-west-2:152430470825:DB-sbg-psp-warning-ppd-a-intuit-com' \
--metric-name 'CPUUtilization' \
--namespace 'AWS/RDS' \
--statistic 'Average' \
--dimensions '[{"Name":"DBInstanceIdentifier","Value":"ppsp-pds-uw022"}]' \
--period 300 \
--evaluation-periods 1 \
--datapoints-to-alarm 1 \
--threshold 60 \
--comparison-operator 'GreaterThanThreshold' \
--treat-missing-data 'missing'

