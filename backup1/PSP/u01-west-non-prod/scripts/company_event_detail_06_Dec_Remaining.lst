SQL> DECLARE
  2  
  3    RECORD_COUNT	  INTEGER   := 0;
  4    MAX_RECORDS	  INTEGER   := 1100000;
  5    PROCESSED_RECORDS  INTEGER   := 0;
  6    ERROR_RECORDS	  INTEGER   := 0;
  7    MAX_FETCH_RECORDS  INTEGER   := 100;
  8    BATCH_COUNT	  INTEGER   := 0;
  9    START_DATE	  DATE := TO_DATE('2011-07-22', 'yyyy-mm-dd');
 10    END_DATE 	  DATE := TO_DATE('2011-09-30', 'yyyy-mm-dd');
 11    PARTITION_END_DATE DATE := START_DATE + 1;
 12  
 13  BEGIN
 14    SELECT count(*) INTO RECORD_COUNT from PSPADM.PSP_COMPANY_EVENT_DETAIL WHERE COMPANY_FK IS NULL;
 15  
 16    DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
 17  
 18    WHILE (START_DATE < END_DATE AND RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
 19  
 20  	 LOOP
 21  	   DBMS_OUTPUT.PUT_LINE('OUTER LOOP');
 22  	   BATCH_COUNT := 1; --TO ENTER THE LOOP AT LEAST ONCE FOR A DAY.
 23  
 24  	   WHILE (BATCH_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
 25  
 26  	     LOOP
 27  	       BEGIN
 28  		 DBMS_OUTPUT.PUT_LINE('INNER LOOP');
 29  
 30  		 MERGE INTO PSPADM.PSP_COMPANY_EVENT_DETAIL ced
 31  		 using (SELECT cedi.COMPANY_EVENT_DETAIL_SEQ, cei.COMPANY_FK
 32  			FROM PSPADM.PSP_COMPANY_EVENT_DETAIL cedi,
 33  			     PSPADM.PSP_COMPANY_EVENT cei
 34  			WHERE cei.EVENT_TIME_STAMP between START_DATE and PARTITION_END_DATE
 35  			  AND cedi.COMPANY_EVENT_FK = cei.COMPANY_EVENT_SEQ
 36  			  AND cedi.COMPANY_FK is null
 37  			  and ROWNUM <= MAX_FETCH_RECORDS) ce
 38  		 on (ced.COMPANY_EVENT_DETAIL_SEQ = ce.COMPANY_EVENT_DETAIL_SEQ)
 39  		 when matched then
 40  		   update set ced.COMPANY_FK = ce.COMPANY_FK, ced.modified_date=sys_extract_utc(systimestamp);
 41  		 BATCH_COUNT := SQL%ROWCOUNT;
 42  		 COMMIT;
 43  
 44  		 PROCESSED_RECORDS := PROCESSED_RECORDS + BATCH_COUNT;
 45  
 46  		 DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
 47  
 48  	       EXCEPTION
 49  		 WHEN OTHERS THEN
 50  		   ERROR_RECORDS := ERROR_RECORDS + BATCH_COUNT;
 51  		   DBMS_OUTPUT.PUT_LINE('Failed ' || ERROR_RECORDS || ' records');
 52  	       END;
 53  	     END LOOP;
 54  	   START_DATE := START_DATE + 1;
 55  	   PARTITION_END_DATE := START_DATE + 1;
 56  	   DBMS_OUTPUT.PUT_LINE('START-DATE : ' || TO_DATE(START_DATE, 'yyyy-mm-dd') || ' PARTITION-END-DATE : ' || TO_DATE(PARTITION_END_DATE, 'yyyy-mm-dd'));
 57  	 END LOOP;
 58  
 59  EXCEPTION
 60  
 61    WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error in Procedure');
 62  
 63  END;
 64  /
