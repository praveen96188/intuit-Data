##1.MaximumUsedTransactionIDs-Warning - spsp-sys-db - spsp-sys-db1

aws cloudwatch put-metric-alarm \
--alarm-name 'MaximumUsedTransactionIDs-Warning - spsp-sys-db - spsp-sys-db1' \
--alarm-description 'Alarm/page when # of db MaximumUsedTransactionIDs exceed this threshold' \
--region us-west-2 \
--actions-enabled \
--ok-actions 'arn:aws:sns:us-west-2:152430470825:DB-sbg-psp-warning-ppd-a-intuit-com' \
--alarm-actions 'arn:aws:sns:us-west-2:152430470825:DB-sbg-psp-warning-ppd-a-intuit-com' \
--metric-name 'MaximumUsedTransactionIDs' \
--namespace 'AWS/RDS' \
--statistic 'Average' \
--dimensions '[{"Name":"DBInstanceIdentifier","Value":"spsp-sys-db1"}]' \
--period 300 \
--evaluation-periods 1 \
--datapoints-to-alarm 1 \
--threshold 202000000 \
--comparison-operator 'GreaterThanThreshold' \
--treat-missing-data 'missing'

