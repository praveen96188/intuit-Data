<assembly>
  <id>bundle</id>
  <formats>
    <format>tar</format>
  </formats>
  <includeBaseDirectory>false</includeBaseDirectory>
  <fileSets>
    <fileSet>
      <directory>${basedir}</directory>
      <outputDirectory>cookbooks/goldengate_hub</outputDirectory>
      <excludes>
        <exclude>target/**</exclude>
        <exclude>var/**</exclude>
        <exclude>pom.xml</exclude>
        <exclude>assembly.xml</exclude>
      </excludes>
      <includes>
        <include>attributes/**</include>
        <include>recipes/**</include>
        <include>templates/**</include>
        <include>metadata.rb</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${basedir}/var</directory>
      <outputDirectory>config</outputDirectory>
      <includes>
        <include>chef/**</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${basedir}/vendor</directory>
      <outputDirectory>vendor</outputDirectory>
      <includes>
        <include>cookbooks/**</include>
      </includes>
    </fileSet>
  </fileSets>
</assembly>
