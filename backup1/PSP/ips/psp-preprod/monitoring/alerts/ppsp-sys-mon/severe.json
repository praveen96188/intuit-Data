  "wavefrontAlerts": [
    {
      "name" : "SEVERE: High CPU",
      "severity" : "SEVERE",
      "condition" : "ts(aws.rds.cpuutilization, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon) > 75",
      "display_expression" : "ts(aws.rds.cpuutilization, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon)",
      "target_id": "1GVRrrI7XCC9vQFY",
      "minutes": "5",
      "resolve_after_minutes": "5",
      "notification_resend_frequency_minutes": "5",
      "tags": [
        "152430470825",
        "ppsp-sys-mon"
      ]
    },
    {
      "name" : "SEVERE: Database Connections",
      "severity" : "SEVERE",
      "condition" : "ts(aws.rds.databaseconnections, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon) > 3000",
      "display_expression" : "ts(aws.rds.databaseconnections, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon)",
      "target_id": "1GVRrrI7XCC9vQFY",
      "minutes": "5",
      "resolve_after_minutes": "5",
      "notification_resend_frequency_minutes": "5",
      "tags": [
        "152430470825",
        "ppsp-sys-mon",
        "ips-rds"
      ]
    },
    {
      "name" : "SEVERE: Large Amount of Active Connections",
      "severity" : "SEVERE",
      "condition" : "ts(custom.ips.aurora.num_active_connections, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon) > 300",
      "display_expression" : "ts(custom.ips.aurora.num_active_connections, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon)",
      "target_id": "1GVRrrI7XCC9vQFY",
      "minutes": "5",
      "resolve_after_minutes": "5",
      "notification_resend_frequency_minutes": "5",
      "tags": [
        "152430470825",
        "ppsp-sys-mon",
        "ips-rds"
      ]
    },
    {
      "name" : "SEVERE: Low Free Local Storage",
      "severity" : "SEVERE",
      "condition" : "100 - ts(custom.ips.aurora.em.instance_info.local_storage_used_perc, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon) < 25",
      "display_expression" : "100 - ts(custom.ips.aurora.em.instance_info.local_storage_used_perc, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon)",
      "target_id": "1GVRrrI7XCC9vQFY",
      "minutes": "5",
      "resolve_after_minutes": "5",
      "notification_resend_frequency_minutes": "5",
      "tags": [
        "152430470825",
        "ppsp-sys-mon",
        "ips-rds"
      ]
    },
    {
      "name" : "SEVERE: Low Freeable Memory",
      "severity" : "SEVERE",
      "condition" : "avg(ts(aws.rds.freeablememory, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon)) / avg(ts(custom.ips.aurora.em.instance_info.total_memory, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon) * 1000) * 100 < 10 ",
      "display_expression" : "100 - ts(custom.ips.aurora.em.instance_info.local_storage_used_perc, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon)",
      "target_id": "1GVRrrI7XCC9vQFY",
      "minutes": "5",
      "resolve_after_minutes": "5",
      "notification_resend_frequency_minutes": "5",
      "tags": [
        "152430470825",
        "ppsp-sys-mon",
        "ips-rds"
      ]
    },
    {
      "name" : "SEVERE: FATAL or PANIC error triggered",
      "severity" : "SEVERE",
      "condition" : "mcount(1m, ts(custom.ips.aurora.log.errors, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon)) != 0",
      "display_expression" : "mcount(1m, ts(custom.ips.aurora.log.errors, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon, dbinstanceidentifier))",
      "target_id": "1GVRrrI7XCC9vQFY",
      "minutes": "1",
      "resolve_after_minutes": "5",
      "notification_resend_frequency_minutes": "5",
      "tags": [
        "152430470825",
        "ppsp-sys-mon",
        "ips-rds"
      ]
    },
    {
      "name" : "SEVERE: Old Max Transaction Id Age",
      "severity" : "SEVERE",
      "condition" : "max(ts(aws.rds.maximumusedtransactionids, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon), dbinstanceidentifier) / 200000000 = 1",
      "display_expression" : "max(ts(aws.rds.maximumusedtransactionids, accountid=152430470825 and DBInstanceidentifier=ppsp-sys-mon), dbinstanceidentifier) / 200000000",
      "target_id": "1GVRrrI7XCC9vQFY",
