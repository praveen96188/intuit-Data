#1.ReplicationSlotDiskUsage-Critical - ppsp-pds-uw02dr - ppsp-pds-uw02dr1

aws cloudwatch put-metric-alarm \
--alarm-name 'ReplicationSlotDiskUsage-Critical - ppsp-pds-uw02dr - ppsp-pds-uw02dr1' \
--alarm-description 'Alarm/page when # of db replication slots exceed this threshold' \
--region us-east-2 \
--actions-enabled \
--ok-actions 'arn:aws:sns:us-east-2:152430470825:DB-sbg-psp-warning-ppd-a-intuit-com' \
--alarm-actions 'arn:aws:sns:us-east-2:152430470825:DB-sbg-psp-critical-ppd-a-intuit-com' \
--metric-name 'ReplicationSlotDiskUsage' \
--namespace 'AWS/RDS' \
--statistic 'Average' \
--dimensions '[{"Name":"DBInstanceIdentifier","Value":"ppsp-pds-uw02dr1"}]' \
--period 300 \
--evaluation-periods 1 \
--datapoints-to-alarm 1 \
--threshold 107374182400 \
--comparison-operator 'GreaterThanThreshold' \
--treat-missing-data 'missing'


