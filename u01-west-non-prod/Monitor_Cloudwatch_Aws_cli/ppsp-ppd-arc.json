##1.WriteIOPS-Critical - ppsp-ppd-arc - ppsp-ppd-arc1

aws cloudwatch put-metric-alarm \
--alarm-name 'WriteIOPS-Critical - ppsp-ppd-arc - ppsp-ppd-arc1' \
--alarm-description 'Alarm/page when # of db WriteIOPS exceed this threshold' \
--region us-west-2 \
--actions-enabled \
--ok-actions 'arn:aws:sns:us-west-2:152430470825:DB-sbg-psp-warning-ppd-a-intuit-com' \
--alarm-actions 'arn:aws:sns:us-west-2:152430470825:DB-sbg-psp-critical-ppd-a-intuit-com' \
--metric-name 'WriteIOPS' \
--namespace 'AWS/RDS' \
--statistic 'Average' \
--dimensions '[{"Name":"DBInstanceIdentifier","Value":"ppsp-ppd-arc1"}]' \
--period 300 \
--evaluation-periods 1 \
--datapoints-to-alarm 1 \
--threshold 15000 \
--comparison-operator 'GreaterThanThreshold' \
--treat-missing-data 'missing'



