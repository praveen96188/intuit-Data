<?xml version="1.0" encoding="UTF-8"?>
<configurations>
    <!-- Oracle DataSource JNDI name used to get connection in App Server Env only
    <entry key="dataAccess.connection.datasource">java:/XAOracleDS</entry>
    -->
    <entry key="dataAccess.connection.username">@dataAccessSecondary.connection.username@</entry>
    <entry key="dataAccess.connection.password">@dataAccessSecondary.connection.password@</entry>
    <entry key="dataAccess.connection.url">@dataAccessSecondary.connection.url@</entry>
    <entry key="dataAccess.connection.provider"></entry>
    <entry key="dataAccess.connection.driver_class">oracle.jdbc.driver.OracleDriver</entry>
    <entry key="dataAccess.connection.dialect">org.hibernate.dialect.Oracle10gDialect</entry>
    <entry key="dataAccess.authentication.authenticator.library"></entry>
    <entry key="dataAccess.installRoot">@dataAccessSecondary.installRoot@</entry>
    <entry key="dataAccess.installComponents">true</entry>
    <entry key="dataAccess.uninstallComponents">false</entry>
    <entry key="dataAccess.env">@dataAccessSecondary.env@</entry>
</configurations>