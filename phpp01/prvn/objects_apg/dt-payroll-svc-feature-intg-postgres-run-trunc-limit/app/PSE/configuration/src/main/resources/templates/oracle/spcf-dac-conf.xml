<?xml version="1.0" encoding="UTF-8"?>
<configurations>
    <!-- Oracle DataSource JNDI name used to get connection in App Server Env only
    <entry key="dataAccess.connection.datasource">java:/XAOracleDS</entry>
    -->
    <entry key="dataAccess.connection.username">@dataAccess.connection.username@</entry>
    <entry key="dataAccess.connection.password">@dataAccess.connection.password@</entry>
    <entry key="dataAccess.connection.url">@dataAccess.connection.url@</entry>
    <!-- DataSource connection information for Read Replica-->
    <entry key="dataAccess.connection.readOnly.username">@dataAccess.connection.readOnly.username@</entry>
    <entry key="dataAccess.connection.readOnly.password">@dataAccess.connection.readOnly.password@</entry>
    <entry key="dataAccess.connection.readOnly.url">@dataAccess.connection.readOnly.url@</entry>
    <entry key="dataAccess.connection.provider"></entry>
    <entry key="dataAccess.connection.driver_class">oracle.jdbc.driver.OracleDriver</entry>
    <entry key="dataAccess.connection.dialect">org.hibernate.dialect.Oracle10gDialect</entry>
    <entry key="dataAccess.authentication.authenticator.library"></entry>
    <entry key="dataAccess.installRoot">@dataAccess.installRoot@</entry>
    <entry key="dataAccess.installComponents">true</entry>
    <entry key="dataAccess.uninstallComponents">false</entry>
    <entry key="dataAccess.env">@dataAccess.env@</entry>
</configurations>