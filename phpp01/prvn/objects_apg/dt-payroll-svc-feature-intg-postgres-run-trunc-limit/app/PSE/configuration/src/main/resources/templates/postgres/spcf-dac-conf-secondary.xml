<?xml version="1.0" encoding="UTF-8"?>
<configurations>
    <!-- Oracle DataSource JNDI name used to get connection in App Server Env only
    <entry key="dataAccess.connection.datasource">java:/XAOracleDS</entry>
    -->
    <entry key="dataAccess.connection.username">@dataAccessSecondary.postgres.connection.username@</entry>
    <entry key="dataAccess.connection.password">@dataAccessSecondary.postgres.connection.password@</entry>
    <entry key="dataAccess.connection.url">@dataAccessSecondary.postgres.connection.url@</entry>
    <entry key="dataAccess.connection.provider"></entry>
    <entry key="dataAccess.connection.driver_class">org.postgresql.Driver</entry>
    <entry key="dataAccess.connection.dialect">org.hibernate.dialect.PostgreSQLDialect</entry>
    <entry key="dataAccess.authentication.authenticator.library"></entry>
    <entry key="dataAccess.installRoot">@dataAccessSecondary.postgres.installRoot@</entry>
    <entry key="dataAccess.installComponents">true</entry>
    <entry key="dataAccess.uninstallComponents">false</entry>
    <entry key="dataAccess.env">@dataAccessSecondary.postgres.env@</entry>
</configurations>