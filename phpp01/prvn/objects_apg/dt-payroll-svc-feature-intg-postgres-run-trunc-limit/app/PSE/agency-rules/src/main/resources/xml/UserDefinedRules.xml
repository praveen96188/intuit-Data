<AgencyRules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="AgencyRules.xsd">
	<FileName>UserDefinedRules</FileName>
	<Jurisdiction>
		<JurisdictionID>UD</JurisdictionID>
		<UIString>User-defined</UIString>
		<StateID>UD</StateID>
		<Agency>
			<AgencyID>USER</AgencyID>
			<UIString>User-defined</UIString>
			<PaymentTemplate>
				<PaymentTemplateID>USER</PaymentTemplateID>
				<UIString>User-defined</UIString>
				<PaymentFrequency>
					<PaymentFrequencyID>NEXTBANKINGDAY</PaymentFrequencyID>
					<IsObsolete>true</IsObsolete>
					<UIString>After Payroll Run</UIString>
					<UIDescription>After Payroll Run</UIDescription>
					<MnemonicDepositPeriod>
						<PeriodStart>PAYDATE</PeriodStart>
						<PeriodEnd>PAYDATE</PeriodEnd>
						<DueOn>E-1BD</DueOn>
					</MnemonicDepositPeriod>
					<AddHolidayAllowanceToDueDate>false</AddHolidayAllowanceToDueDate>
				</PaymentFrequency>
				<PaymentFrequency>
					<PaymentFrequencyID>WEEKLY</PaymentFrequencyID>
					<IsObsolete>0</IsObsolete>
					<UIString>Weekly</UIString>
					<UIDescription>Weekly.</UIDescription>
					<MnemonicDepositPeriod>
						<PeriodStart>SAT</PeriodStart>
						<PeriodEnd>FRI</PeriodEnd>
						<DueOn>SAT</DueOn>
					</MnemonicDepositPeriod>
					<AddHolidayAllowanceToDueDate>true</AddHolidayAllowanceToDueDate>
					<DisallowQuarterCrossing>true</DisallowQuarterCrossing>
				</PaymentFrequency>
				<PaymentFrequency>
					<PaymentFrequencyID>SEMIWEEKLY</PaymentFrequencyID>
					<IsObsolete>0</IsObsolete>
					<UIString>Semi-weekly</UIString>
					<UIDescription>Semi-weekly payments are due by the following Wednesday or Friday.</UIDescription>
					<MnemonicDepositPeriod>
						<PeriodStart>WED</PeriodStart>
						<PeriodEnd>FRI</PeriodEnd>
						<DueOn>WED</DueOn>
					</MnemonicDepositPeriod>
					<MnemonicDepositPeriod>
						<PeriodStart>SAT</PeriodStart>
						<PeriodEnd>TUE</PeriodEnd>
						<DueOn>FRI</DueOn>
					</MnemonicDepositPeriod>
					<AddHolidayAllowanceToDueDate>true</AddHolidayAllowanceToDueDate>
					<DisallowQuarterCrossing>true</DisallowQuarterCrossing>
				</PaymentFrequency>
				<PaymentFrequency>
					<PaymentFrequencyID>MONTHLY</PaymentFrequencyID>
					<IsObsolete>0</IsObsolete>
					<UIString>Monthly</UIString>
					<UIDescription>Monthly</UIDescription>
					<MnemonicDepositPeriod>
						<PeriodStart>1</PeriodStart>
						<PeriodEnd>EOM</PeriodEnd>
						<DueOn>15</DueOn>
						<UIString>{MMM yyyy}</UIString>
					</MnemonicDepositPeriod>
					<AddHolidayAllowanceToDueDate>false</AddHolidayAllowanceToDueDate>
				</PaymentFrequency>
				<PaymentFrequency>
					<PaymentFrequencyID>QUARTERLY</PaymentFrequencyID>
					<IsObsolete>0</IsObsolete>
					<UIString>Quarterly</UIString>
					<UIDescription>Quarterly</UIDescription>
					<MnemonicDepositPeriod>
						<PeriodStart>JAN-1</PeriodStart>
						<PeriodEnd>MAR-EOM</PeriodEnd>
						<DueOn>APR-EOM</DueOn>
						<UIString>Q1 {yyyy}</UIString>
					</MnemonicDepositPeriod>
					<MnemonicDepositPeriod>
						<PeriodStart>APR-1</PeriodStart>
						<PeriodEnd>JUN-EOM</PeriodEnd>
						<DueOn>JUL-EOM</DueOn>
						<UIString>Q2 {yyyy}</UIString>
					</MnemonicDepositPeriod>
					<MnemonicDepositPeriod>
						<PeriodStart>JUL-1</PeriodStart>
						<PeriodEnd>SEP-EOM</PeriodEnd>
						<DueOn>OCT-EOM</DueOn>
						<UIString>Q3 {yyyy}</UIString>
					</MnemonicDepositPeriod>
					<MnemonicDepositPeriod>
						<PeriodStart>OCT-1</PeriodStart>
						<PeriodEnd>DEC-EOM</PeriodEnd>
						<DueOn>JAN-EOM</DueOn>
						<UIString>Q4 {yyyy}</UIString>
					</MnemonicDepositPeriod>
					<AddHolidayAllowanceToDueDate>false</AddHolidayAllowanceToDueDate>
				</PaymentFrequency>
				<PaymentFrequency>
					<PaymentFrequencyID>ANNUAL</PaymentFrequencyID>
					<IsObsolete>0</IsObsolete>
					<UIString>Annually</UIString>
					<UIDescription>Annual</UIDescription>
					<MnemonicDepositPeriod>
						<PeriodStart>JAN-1</PeriodStart>
						<PeriodEnd>DEC-EOM</PeriodEnd>
						<DueOn>JAN-EOM</DueOn>
						<UIString>{yyyy}</UIString>
					</MnemonicDepositPeriod>
					<AddHolidayAllowanceToDueDate>false</AddHolidayAllowanceToDueDate>
				</PaymentFrequency>
				<DefaultSubmitMethod>PRINT</DefaultSubmitMethod>
				<SubmitMethod>
					<SubmitMethodType>PRINT</SubmitMethodType>
					<IsObsolete>0</IsObsolete>
					<UIString>Check</UIString>
					<AllowNegativeLineItems>true</AllowNegativeLineItems>
				</SubmitMethod>
				<Law>
					<LawID>0</LawID>
					<Description>No law id for user-defined templates.</Description>
				</Law>
				<RollDueDateOnHoliday>forward</RollDueDateOnHoliday>
				<RollDueDateOnWeekend>forward</RollDueDateOnWeekend>
			</PaymentTemplate>
		</Agency>
	</Jurisdiction>
</AgencyRules>
