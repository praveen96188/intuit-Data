<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.intuit.sbg.psp</groupId>
        <artifactId>PSE</artifactId>
        <version>2.2.0-SNAPSHOT</version>
    </parent>

    <artifactId>agency-rules</artifactId>
    <packaging>jar</packaging>

    <name>agency-rules</name>
  
    <dependencies>
        <!-- xalan is used by xslt task to generate the java files from xslt and xml files-->
        <dependency>
            <groupId>xalan</groupId>
            <artifactId>xalan</artifactId>
            <optional>true</optional>
        </dependency>    
    </dependencies>
  
    <build>
        <finalName>psp-agencyrules-${psp.project.version}</finalName>
        <resources>
            <resource>
                <directory>${project.source.dir}</directory>
                <includes>
                    <include>**/myTest.xml</include>
                </includes>                
            </resource>
            <resource>
                <directory>${project.resources.dir}</directory>
                <includes>
                    <include>**/*.*</include>
                </includes>
                <excludes>
                    <exclude>**/*.xslt</exclude>
                    <exclude>**/*.bat</exclude>
                </excludes>
                <targetPath>resources</targetPath>
            </resource>
        </resources> 
      
        <plugins>
            <!-- Plugin to clean the generated files. By default maven deletes only target folder during clean task.
            If the generated files are under any other path, then we have to explicitly clean it -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-clean-plugin</artifactId>
                <version>2.4.1</version>
                <configuration>
                    <filesets>
                        <fileset>
                            <directory>${project.source.dir}/com/intuit/payroll/agency/dao/generated</directory>
                        </fileset>
                    </filesets>
                </configuration>
            </plugin>
            
            <plugin>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>1.8</version>
                <executions>
                    <execution>
                        <phase>generate-sources</phase>
                        <configuration>
                            <target>
                                <xslt style="${project.resources.dir}/com/intuit/payroll/agency/dao/rules.xslt"
                                      basedir="${project.resources.dir}/xml"
                                      includes="AgencyRules.xml UserDefinedRules.xml"
                                      destdir="${project.source.dir}/com/intuit/payroll/agency/dao/generated"
                                      extension=".java"
                                      classpath="xalan.jar"/>
                            </target>
                        </configuration>
                        <goals>
                            <goal>run</goal>
                        </goals>
                    </execution>
                </executions> 
            </plugin> 
            <plugin>
                <artifactId>maven-resources-plugin</artifactId>
                <version>2.7</version>
                <executions>
                    <execution>
                        <id>copy-jars</id>
                        <phase>install</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>

                        <configuration>
                            <outputDirectory>${project.jars.dir}</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>target</directory>
                                    <includes>
                                        <include>${project.build.finalName}.jar</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>                      
        </plugins>
    </build>
</project>
