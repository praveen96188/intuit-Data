<?xml version="1.0" encoding="UTF-8"?>
<assembly
	xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.0 http://maven.apache.org/xsd/assembly-1.1.0.xsd">
	<id>batchdeploy-jss</id>
	<!-- Specifies that our binary distribution is a zip package -->
	<formats>
		<format>zip</format>
	</formats>
	<includeBaseDirectory>false</includeBaseDirectory>

	<dependencySets>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<useProjectArtifact>true</useProjectArtifact>
			<unpack>false</unpack>
			<includes>
			    <include>net.minidev:accessors-smart:jar:1.2</include>
				<include>com.intuit.sbg.psp:qbdt-adapter:jar:classes:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:pgp:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:domain:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:domain-secondary:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:processes-core:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:iop:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:dd-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:salestax-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:efe-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:email-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:ofx:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:utils:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:email-client:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:iop-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:iam-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:tfs-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:amo-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:ers-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:brm-gateway:jar:${psp.project.version}</include>
				<include>com.intuit.sbg.psp:ade-adapter:jar:classes:${psp.project.version}</include>
			</includes>
			<outputFileNameMapping>psp-${artifact.artifactId}-${psp.project.version}.jar</outputFileNameMapping>
		</dependencySet>


		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<useProjectArtifact>true</useProjectArtifact>
			<unpack>false</unpack>
			<includes>
				<include>com.intuit.sbg.psp:payroll-services-api:jar:${psp.project.version}</include>
			</includes>
			<outputFileNameMapping>psp-payrollservicesapi-${psp.project.version}.jar</outputFileNameMapping>
		</dependencySet>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<useProjectArtifact>true</useProjectArtifact>
			<unpack>false</unpack>
			<includes>
				<include>com.intuit.sbg.psp:configuration-manager:jar:${psp.project.version}</include>
			</includes>
			<outputFileNameMapping>psp-configurationmanager-${psp.project.version}.jar</outputFileNameMapping>
		</dependencySet>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<useProjectArtifact>true</useProjectArtifact>
			<unpack>false</unpack>
			<includes>
				<include>com.intuit.sbg.psp:payroll-services-api-impl:jar:${psp.project.version}</include>
			</includes>
			<outputFileNameMapping>psp-payrollservicesapiimpl-${psp.project.version}.jar</outputFileNameMapping>
		</dependencySet>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<useProjectArtifact>true</useProjectArtifact>
			<unpack>false</unpack>
			<includes>
				<include>com.intuit.sbg.psp:agency-rules:jar:${psp.project.version}</include>
			</includes>
			<outputFileNameMapping>psp-agencyrules-${psp.project.version}.jar</outputFileNameMapping>
		</dependencySet>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<useProjectArtifact>true</useProjectArtifact>
			<unpack>false</unpack>
			<includes>
				<include>com.intuit.sbg.psp:echo-sign-gateway:jar:${psp.project.version}</include>
			</includes>
			<outputFileNameMapping>psp-echosign-gateway-${psp.project.version}.jar</outputFileNameMapping>
		</dependencySet>
		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<useProjectArtifact>true</useProjectArtifact>
			<unpack>false</unpack>
			<includes>
				<include>com.intuit.sbg.psp:workers-comp-gateway:jar:${psp.project.version}</include>
			</includes>
			<outputFileNameMapping>psp-workerscomp-gateway-${psp.project.version}.jar</outputFileNameMapping>
		</dependencySet>

		<dependencySet>
			<outputDirectory>lib</outputDirectory>
			<unpack>false</unpack>
			<scope>runtime</scope>
			<includes>
				<include>*:jar:*</include>
			</includes>
			<!-- Excluding only the older version of duplicate jars -->
			<excludes>
				<exclude>*:bcmail-jdk14:jar:*</exclude>
				<exclude>*:bcprov-jdk14:jar:*</exclude>
				<exclude>*:bcprov-jdk15:jar:*</exclude>
				<exclude>*:javassist:jar:3.12.0.GA</exclude>
				<exclude>*:jsch:jar:0.1.54</exclude>
				<exclude>*:mimepull:jar:1.6</exclude>

				<!-- Excluding the below jars to keep the same jars as part of the war 
					file -->
				<exclude>*:avalon-framework:jar:*</exclude>
				<exclude>*:logkit:jar:*</exclude>
				<exclude>*:bctsp-jdk14:jar:*</exclude>
				<exclude>*:istack-commons-runtime:jar:*</exclude>
				<exclude>*:objenesis:jar:*</exclude>
				<exclude>*:relaxngDatatype:jar:*</exclude>
				<exclude>*:txw2:jar:*</exclude>

				<!-- Excluding the below jars because all the PSP jars are copied as 
					part of above dependencySet -->

				<exclude>com.intuit.sbg.psp:amo-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:brm-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:common-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:configuration-manager:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:dd-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:domain:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:domain-secondary:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:echo-sign-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:efe-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:email-client:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:ers-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:filter:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:iam-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:iop:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:iop-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:ofx:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:payroll-services-api:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:payroll-services-api-impl:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:pgp:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:processes-core:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:qbdt-adapter:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:salestax-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:tfs-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:utils:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:workers-comp-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:email-gateway:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:agency-rules:jar:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:ade-adapter:jar:classes:${psp.project.version}</exclude>
				<exclude>com.intuit.sbg.psp:qbdt-adapter:jar:classes:${psp.project.version}</exclude>
				<exclude>*:sjsxp:jar:*</exclude>
			</excludes>
		</dependencySet>
	</dependencySets>
	<fileSets>
		<fileSet>
			<directory>${basedir}/target</directory>
			<outputDirectory>lib</outputDirectory>
			<includes>
				<include>**/batch-jobs-*jss.jar</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${project.resources.dir}/lib</directory>
			<outputDirectory>lib</outputDirectory>
			<includes>
				<include>asm-3.1.jar</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${basedir}/src/main/resources/jss/shell</directory>
			<outputDirectory>shell</outputDirectory>
			<includes>
				<include>**/*.sh</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${basedir}/src/main/resources/sql</directory>
			<outputDirectory>sql</outputDirectory>
			<includes>
				<include>**/*.sql</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${basedir}/src/main/resources</directory>
			<outputDirectory>etc</outputDirectory>
			<excludes>
				<exclude>*/**</exclude>
			</excludes>
		</fileSet>
		<fileSet>
			<directory>${basedir}/src/main/resources</directory>
			<outputDirectory>logs</outputDirectory>
			<excludes>
				<exclude>*/**</exclude>
			</excludes>
		</fileSet>
		<fileSet>
			<directory>${main.dir}/Gateways/ers-gateway/src/main/resources</directory>
			<outputDirectory>lib/resources</outputDirectory>
			<includes>
				<include>*.*</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${main.dir}/Gateways/amo-gateway/src/main/resources</directory>
			<outputDirectory>lib/resources</outputDirectory>
			<includes>
				<include>IntuitCustomerAsset.wsdl</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${main.dir}/Gateways/iam-gateway/src/main/resources/keystore</directory>
			<outputDirectory>lib/resources/keystore</outputDirectory>
			<includes>
				<include>*.*</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${main.dir}/Gateways/efe-gateway/src/main/resources</directory>
			<outputDirectory>lib/resources</outputDirectory>
			<includes>
				<include>*.*</include>
			</includes>
		</fileSet>
		<fileSet>
			<directory>${main.dir}/PSE/batch-jobs/src/main/resources</directory>
			<outputDirectory>lib/resources</outputDirectory>
			<includes>
				<include>intuit.xsd</include>
			</includes>
		</fileSet>
	</fileSets>
</assembly>
