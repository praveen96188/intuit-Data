<xsd:schema xmlns="http://www.irs.gov/efile" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="3.4">
	<xsd:annotation>
		<xsd:documentation>
			<Description>State Employment Schema - This schema lists all return documents that may be included in a state return</Description>
			<TaxYear>2008</TaxYear>
			<Version>Draft</Version>
			<ReleaseDate>Feb 7, 2008</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>
    <!--Updated links manually -->
	<xsd:include schemaLocation="efileTypes.xsd"/>
	<xsd:include schemaLocation="StateWH.xsd"/>
	<xsd:include schemaLocation="StateAnnual.xsd"/>
	<xsd:element name="ReturnDataState">
		<xsd:annotation>
			<xsd:documentation>State Return Contents, including Header, General Information, choice of return type, and optional payment</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:sequence>
				<xsd:element name="SubmissionId" type="String20Type"/>
				<xsd:sequence>
					<xsd:element ref="StateWH">
						<xsd:annotation>
							<xsd:documentation>FSET Employer's Quarterly State Tax Return</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
			</xsd:sequence>
		</xsd:complexType>
	</xsd:element>
</xsd:schema>
