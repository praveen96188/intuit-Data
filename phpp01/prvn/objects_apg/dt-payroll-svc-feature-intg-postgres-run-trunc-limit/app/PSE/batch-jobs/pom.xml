                <version>3.0.0</version>
                <configuration>
                    <packagingExcludes>
                        WEB-INF/lib/javassist-3.12.0.GA.jar,WEB-INF/lib/javax.servlet-servlet-api-2.5.jar,WEB-INF/lib/log4j-log4j-1.2.14.jar,WEB-INF/lib/mimepull-1.6.jar,WEB-INF/lib/org.glassfish.metro-webservices-rt-2.2.1-1.jar,WEB-INF/lib/wstx-services-2.2.1-1.war,WEB-INF/lib/sjsxp-1.0.jar
                    </packagingExcludes>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.0.0</version>
                <executions>
                    <execution>
                        <id>copy-dependencies</id>
                        <phase>prepare-package</phase>
                        <goals>
                            <goal>copy-dependencies</goal>
                        </goals>
                        <configuration>
                            <!-- Excluding only the older version of duplicate jars -->
                            <includeScope>runtime</includeScope>
                            <excludeGroupIds>com.jcraft</excludeGroupIds>
                            <excludeArtifactIds>bcmail-jdk14,bcprov-jdk14:jar,bcprov-jdk15,mimepull,jaxws-ri</excludeArtifactIds>
                            <outputDirectory>${project.basedir}/target/${project.artifactId}-${psp.project.version}/WEB-INF/lib</outputDirectory>
                            <excludeTransitive>false</excludeTransitive>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
