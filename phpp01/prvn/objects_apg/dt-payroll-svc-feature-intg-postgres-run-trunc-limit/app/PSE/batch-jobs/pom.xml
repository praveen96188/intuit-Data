            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>2.1</version>
                <executions>
                    <execution>
                        <id>copy-multi-version dependency</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy</goal>
                        </goals>
                        <configuration>
                            <artifactItems>
                                <artifactItem>
                                    <groupId>xerces</groupId>
                                    <artifactId>xercesImpl</artifactId>
                                    <version>2.12.0</version>
                                    <type>jar</type>
                                </artifactItem>
                                <artifactItem>
                                    <groupId>commons-lang</groupId>
                                    <artifactId>commons-lang</artifactId>
                                    <version>2.6</version>
                                    <type>jar</type>
                                </artifactItem>
                                <artifactItem>
                                    <groupId>commons-logging</groupId>
                                    <artifactId>commons-logging</artifactId>
                                    <version>1.1</version>
                                    <type>jar</type>
                                </artifactItem>
                                <artifactItem>
                                    <groupId>commons-logging</groupId>
                                    <artifactId>commons-logging</artifactId>
                                    <version>1.1.0.jboss</version>
                                    <type>jar</type>
                                </artifactItem>
                                <artifactItem>
                                    <groupId>commons-collections</groupId>
                                    <artifactId>commons-collections</artifactId>
                                    <version>3.2.2</version>
                                    <type>jar</type>
                                </artifactItem>
                                <artifactItem>
                                    <groupId>asm</groupId>
                                    <artifactId>asm</artifactId>
                                    <version>1.5.3</version>
                                    <type>jar</type>
                                </artifactItem>
                            </artifactItems>
                            <outputDirectory>${project.resources.dir}/lib</outputDirectory>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <!-- jaxb plugin -->
                <groupId>org.jvnet.jaxb2.maven2</groupId>
                <artifactId>maven-jaxb2-plugin</artifactId>
                <version>0.10.0</version>
                <executions>
                    <execution>
                        <id>transmission</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <removeOldOutput>true</removeOldOutput>
                            <generateDirectory>${project.target.generated.sources}</generateDirectory>
                            <generatePackage>com.intuit.sbd.payroll.psp.batchjobs.fset.xsd</generatePackage>
                            <bindingDirectory>${project.resources.dir}</bindingDirectory>
                            <schemaIncludes>
                                <include>Transmission.xsd</include>
                                <include>AckTransmission.xsd</include>
                            </schemaIncludes>
                        </configuration>
                    </execution>
                    <!-- multiple schema definition for workers comp.
                      Schema in batch job is for sending WC data via SFTP to Ap Intego servers.
                      Workers comp schema jar used in workers-comp-gateway is used for pushing payroll data to WCCS service.
                      This is an older schema.
                      Workers Comp schema in batch-job is based on the latest xsd provided by Ap Intego.

                      The older schema will be used in the intermediate state till the workers-comp-gateway code is
                      fully decommissioned. As part of decomission, we will be removing the older schema from workers-comp-gateway code.
                     -->
                    <execution>
                        <id>workerscomp</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <removeOldOutput>true</removeOldOutput>
                            <generateDirectory>${project.target.generated.sources}/Workerscomp</generateDirectory>
                            <generatePackage>com.intuit.sbd.payroll.psp.jss.processors.workerscomp.schema</generatePackage>
                            <bindingDirectory>${project.resources.dir}</bindingDirectory>
                            <schemaIncludes>
                                <include>intuit.xsd</include>
                            </schemaIncludes>
                        </configuration>
                    </execution>
                    <execution>
                        <id>workerscomptrupay</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <removeOldOutput>true</removeOldOutput>
                            <generateDirectory>${project.target.generated.sources}/Workerscomptruepay</generateDirectory>
                            <generatePackage>com.intuit.sbd.payroll.psp.jss.processors.workerscomp.trupay.schema</generatePackage>
                            <bindingDirectory>${project.resources.dir}</bindingDirectory>
                            <schemaIncludes>
                                <include>intuit-trupay.xsd</include>
                            </schemaIncludes>
                        </configuration>
                    </execution>
                    <execution>
                        <id>statereport</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <removeOldOutput>true</removeOldOutput>
                            <generateDirectory>${project.target.generated.sources}/NHCRS1</generateDirectory>
                            <generatePackage>com.intuit.sbd.payroll.psp.batchjobs.statereports.states.xsd</generatePackage>
                            <!--<bindingDirectory>${project.resources.dir}</bindingDirectory>-->
                            <schemaIncludes>
                                <include>WWTReturn_XML_1.0.xsd</include>
                            </schemaIncludes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Assembly plugin to create the Zip file-->
            <plugin>
                <artifactId>maven-assembly-plugin</artifactId>
                <version>2.6</version>
                <executions>
                    <execution>
                        <configuration>
                            <finalName>psp-batchjobs-${psp.project.version}</finalName>
                            <descriptors>
                                <descriptor>src/main/assembly/spcfdeploy.xml</descriptor>
                            </descriptors>
                        </configuration>
                        <id>make-spcf-deploy</id> <!-- this is used for inheritance merges -->
                        <phase>package</phase> <!-- append to the packaging phase. -->
                        <goals>
                            <goal>single</goal> <!-- goals == mojos -->
                        </goals>
                    </execution>
                    <execution>
                        <configuration>
                            <finalName>psp-batchjobs-${psp.project.version}</finalName>
                            <descriptors>
                                <descriptor>src/main/assembly/batchdeploy.xml</descriptor>
                            </descriptors>
                        </configuration>
                        <id>make-batch-deploy</id> <!-- this is used for inheritance merges -->
                        <phase>package</phase> <!-- append to the packaging phase. -->
                        <goals>
                            <goal>single</goal> <!-- goals == mojos -->
                        </goals>
                    </execution>
                    <execution>
                        <configuration>
                            <finalName>psp-batchjobs-${psp.project.version}</finalName>
                            <descriptors>
                                <descriptor>src/main/assembly/batchdeploy-jss.xml</descriptor>
                            </descriptors>
                        </configuration>
                        <id>make-batch-deploy-jss</id>
                        <phase>package</phase>
                        <goals>
                            <goal>single</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <artifactId>maven-resources-plugin</artifactId>
                <version>2.7</version>
                <executions>
                    <execution>
                        <id>copy-zips</id>
                        <phase>install</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>

                        <configuration>
                            <outputDirectory>${project.zips.dir}</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>target</directory>
                                    <includes>
                                        <include>psp-batchjobs-${psp.project.version}-batchdeploy.zip</include>
                                        <include>psp-batchjobs-${psp.project.version}-spcfdeploy.zip</include>
                                        <include>psp-batchjobs-${psp.project.version}-batchdeploy-jss.zip</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                    <execution>
                        <id>copy-wars</id>
                        <phase>install</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>

                        <configuration>
                            <outputDirectory>${project.wars.dir}</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>target</directory>
                                    <includes>
                                        <include>batch-jobs-${psp.project.version}.war</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>2.6</version>
                <executions>
                    <execution>
                        <id>make-batch-jobs-flux-jar</id>
                        <phase>prepare-package</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                        <configuration>
                            <includes>
                                <include>**/*</include>
                            </includes>
                            <excludes>
                                <exclude>**/jss/**</exclude>
                                <exclude>job-scheduling-framework.properties</exclude>
                            </excludes>
                            <classifier>classes</classifier>
                        </configuration>
                    </execution>
                    <execution>
                        <id>make-batch-jobs-jss-jar</id>
                        <phase>prepare-package</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                        <configuration>
                            <includes>
                                <include>**/*</include>
                            </includes>
                            <classifier>jss</classifier>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>