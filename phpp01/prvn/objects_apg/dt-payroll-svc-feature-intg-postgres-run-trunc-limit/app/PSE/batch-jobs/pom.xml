    <build>
        <resources>
            <resource>
                <directory>${project.resources.dir}</directory>
                <includes>
                    <include>**/PSIMessage.xsd</include>
                    <include>**/TransactionDTO.xsd</include>
                    <include>**/intuit.xsd</include>
                    <include>**/keystore/Intuit.ems.psp.jks</include>
                </includes>
                <excludes>
                    <exclude>**/.*</exclude>
                </excludes>
                <targetPath>resources</targetPath>
            </resource>
            <resource>
                <directory>${project.resources.dir}</directory>
                <includes>
                    <include>*.yml</include>
                </includes>
            </resource>
            <resource>
                <directory>${project.resources.dir}</directory>
                <includes>
                    <include>META-INF/**</include>
                </includes>
            </resource>
            <resource>
                <directory>${project.resources.dir}/jss</directory>
                <includes>
                    <include>**/job-scheduling-framework.properties</include>
                </includes>
                <excludes>
                    <exclude>**/.*</exclude>
                </excludes>
            </resource>
            <resource>
                <directory>${main.dir}/Gateways/ers-gateway/src/main/resources</directory>
                <includes>
                    <include>*.*</include>
                </includes>
                <targetPath>${project.basedir}/target/${project.artifactId}-${psp.project.version}/WEB-INF/lib/resources</targetPath>
            </resource>
            <resource>
                <directory>${main.dir}/Gateways/amo-gateway/src/main/resources</directory>
                <includes>
                    <include>IntuitCustomerAsset.wsdl</include>
                </includes>
                <targetPath>${project.basedir}/target/${project.artifactId}-${psp.project.version}/WEB-INF/lib/resources</targetPath>
            </resource>
            <resource>
                <directory>${main.dir}/Gateways/efe-gateway/src/main/resources</directory>
                <includes>
                    <include>*.*</include>
                </includes>
                <targetPath>${project.basedir}/target/${project.artifactId}-${psp.project.version}/WEB-INF/lib/resources</targetPath>
            </resource>
            <resource>
                <directory>${main.dir}/Gateways/iam-gateway/src/main/resources/keystore</directory>
                <includes>
                    <include>*.*</include>
                </includes>
                <targetPath>${project.basedir}/target/${project.artifactId}-${psp.project.version}/WEB-INF/lib/resources/keystore</targetPath>
