<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>PSE</artifactId>
        <groupId>com.intuit.sbg.psp</groupId>
        <version>2.2.0-SNAPSHOT</version>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <artifactId>domain-secondary</artifactId>

    <dependencies>
        <!-- Module dependency -->
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>domain</artifactId>
        </dependency>
        <!-- End of Module dependency -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-collections4</artifactId>
        </dependency>
        <!-- Dependencies read from local repository -->
        <!-- End of Dependencies read from local repository -->
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>${project.resources.dir}</directory>
                <excludes>
                    <exclude>**/fortify.xml</exclude>
                    <exclude>**/clover.license</exclude>
                    <exclude>**/build.xml</exclude>
                </excludes>
                <targetPath>resources</targetPath>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <artifactId>maven-remote-resources-plugin</artifactId>
                <version>1.5</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>bundle</goal>
                        </goals>
                        <configuration>
                            <resourcesDirectory>src/main</resourcesDirectory>
                            <includes>
                                <include>resources/TruncateTablesSecondary.sql</include>
                            </includes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <artifactId>maven-assembly-plugin</artifactId>
                <version>2.6</version>
                <executions>
                    <execution>
                        <configuration>
                            <finalName>psp-dbinstall-secondary-${psp.project.version}</finalName>
                            <appendAssemblyId>false</appendAssemblyId>
                            <descriptors>
                                <descriptor>src/main/assembly/dbinstall.xml</descriptor>
                            </descriptors>
                        </configuration>
                        <id>make-dbInstall</id> <!-- this is used for inheritance merges -->
                        <phase>package</phase> <!-- append to the packaging phase. -->
                        <goals>
                            <goal>single</goal> <!-- goals == mojos -->
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.hibernate.orm.tooling</groupId>
                <artifactId>hibernate-enhance-maven-plugin</artifactId>
                <version>${hibernate.version}</version>
                <executions>
                    <execution>
                        <configuration>
                            <enableLazyInitialization>true</enableLazyInitialization>
                        </configuration>
                        <goals>
                            <goal>enhance</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <id>deploy-db</id>
            <activation>
                <file>
                    <missing>skip-install-db.txt</missing>
                </file>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>1.4.0</version>
                        <executions>
                            <execution>
                                <id>drop-db-objects</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>sqlplus</executable>
                                    <workingDirectory>${basedir}/src/main/model/oracle</workingDirectory>
                                    <arguments>
                                        <argument>${databaseSecondary.schema}/${databaseSecondary.password}@XE</argument>
                                        <argument>@DropDBObjects.sql</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>install-db</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>sqlplus</executable>
                                    <workingDirectory>${basedir}/src/main/model/oracle</workingDirectory>
                                    <arguments>
                                        <argument>${databaseSecondary.schema}/${databaseSecondary.password}@XE</argument>
                                        <argument>@InstallDB.sql</argument>
                                        <argument>NONE</argument>
                                        <argument>NONE</argument>
                                        <argument>NONE</argument>
                                        <argument>NONE</argument>
                                        <argument>NONE</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>deploy-db-postgres</id>
            <activation>
                <file>
                    <missing>skip-install-db.txt</missing>
                </file>
                <property>
                    <name>database.audit</name>
                    <value>postgres</value>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>1.4.0</version>
                        <executions>
                            <execution>
                                <id>drop-db-objects-postgres</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>psql</executable>
                                    <workingDirectory>${basedir}/src/main/model/postgres</workingDirectory>
                                    <arguments>
                                        <argument>postgres://psp_local1:psp_local1@localhost:5432/postgres</argument>
                                        <argument>-f</argument>
                                        <argument>DropDBObjects.sql</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>install-db-postgres</id>
                                <phase>generate-sources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>psql</executable>
                                    <workingDirectory>${basedir}/src/main/model/postgres</workingDirectory>
                                    <arguments>
                                        <argument>postgres://psp_local1:psp_local1@localhost:5432/postgres</argument>
                                        <argument>-f</argument>
                                        <argument>InstallDB.sql</argument>
                                        <argument>NONE</argument>
                                        <argument>NONE</argument>
                                        <argument>NONE</argument>
                                        <argument>NONE</argument>
                                        <argument>NONE</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

</project>