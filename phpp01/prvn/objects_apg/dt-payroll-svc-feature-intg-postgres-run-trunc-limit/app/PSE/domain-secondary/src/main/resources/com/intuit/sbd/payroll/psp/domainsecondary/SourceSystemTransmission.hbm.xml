<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domainsecondary" default-cascade="merge" auto-import="false" default-access="com.intuit.sbd.payroll.psp.hibernate.PSPMixedAccessor">
	<class name="com.intuit.sbd.payroll.psp.domainsecondary.SourceSystemTransmission" entity-name="com.intuit.sbd.payroll.psp.domainsecondary.SourceSystemTransmission" table="PSP_SOURCE_SYSTEM_TRANSMISSION" dynamic-update="true">
		<id name="Id" column="SOURCE_SYSTEM_TRANSMISSION_SEQ" type="com.intuit.sbd.payroll.psp.hibernate.SpcfUniqueIdUserType" access="property">
			<generator class="assigned"/>
		</id>

		<!-- SourceSystemTransmission Version Property -->
		<version name="Version" type="long" column="VERSION" unsaved-value="negative" />

		<!-- SourceSystemTransmission Admin Properties -->
		<property name="CreatorId" type="string" column="CREATOR_ID" not-null="false" />
		<property name="CreatedDate" type="com.intuit.sbd.payroll.psp.hibernate.SpcfCalendarUserType" column="CREATED_DATE" not-null="true" />
		<property name="ModifierId" type="string" column="MODIFIER_ID" not-null="false" />
		<property name="ModifiedDate" type="com.intuit.sbd.payroll.psp.hibernate.SpcfCalendarUserType" column="MODIFIED_DATE" not-null="true"/>
		<property name="TempId" type="string" column="SOURCE_SYSTEM_TRANSMISSION_SEQ" update="false" insert="false" access="property"/>
        <property name="RealmId" type="long" column="REALM_ID" not-null="true" insert="true" update="false" access="property"/>

		<!-- SourceSystemTransmission Declared Properties -->
		<property name="Host" type="string" column="HOST"/>

		<property name="FromSourceSystem" column="FROM_SOURCE_SYSTEM" >
			<type name="com.intuit.sbd.payroll.psp.hibernate.SpcfStringEnumUserType">
				<param name="enumClassname">com.intuit.sbd.payroll.psp.domain.SourceSystemCode</param>
			</type>
		</property>

		<property name="FinalizeDateTime" type="com.intuit.sbd.payroll.psp.hibernate.SpcfCalendarUserType" column="FINALIZE_DATE_TIME"/>

		<property name="RequestToken" type="long" column="REQUEST_TOKEN"/>

		<property name="ResponseToken" type="long" column="RESPONSE_TOKEN"/>

		<property name="RequestDocument" type="org.hibernate.type.TextType" column="REQUEST_DOCUMENT" lazy="true"/>

		<property name="ResponseDocument" type="org.hibernate.type.TextType" column="RESPONSE_DOCUMENT" lazy="true"/>

		<property name="Type" column="TYPE" >
			<type name="com.intuit.sbd.payroll.psp.hibernate.SpcfStringEnumUserType">
				<param name="enumClassname">com.intuit.sbd.payroll.psp.domain.TransmissionType</param>
			</type>
		</property>

		<property name="InitializeDateTime" type="com.intuit.sbd.payroll.psp.hibernate.SpcfCalendarUserType" column="INITIALIZE_DATE_TIME"/>

		<property name="Description" type="string" column="DESCRIPTION"/>

		<property name="ToSourceSystem" column="TO_SOURCE_SYSTEM" >
			<type name="com.intuit.sbd.payroll.psp.hibernate.SpcfStringEnumUserType">
				<param name="enumClassname">com.intuit.sbd.payroll.psp.domain.SourceSystemCode</param>
			</type>
		</property>

		<property name="TransmissionIdentifier" type="string" column="TRANSMISSION_IDENTIFIER"/>

		<property name="IPAddress" type="string" column="I_P_ADDRESS"/>

		<property name="ApplicationVersion" type="string" column="APPLICATION_VERSION"/>

		<property name="ApplicationId" type="string" column="APPLICATION_ID"/>

		<property name="TaxTableId" type="string" column="TAX_TABLE_ID"/>

		<property name="CompanyId" type="string" column="COMPANY_ID"/>
	</class>
</hibernate-mapping>