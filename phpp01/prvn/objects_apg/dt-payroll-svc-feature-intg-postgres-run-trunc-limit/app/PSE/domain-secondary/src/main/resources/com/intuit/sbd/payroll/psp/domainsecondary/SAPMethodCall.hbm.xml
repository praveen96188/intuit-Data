<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domainsecondary" default-cascade="merge" auto-import="false" default-access="com.intuit.sbd.payroll.psp.hibernate.PSPMixedAccessor">
    <class name="com.intuit.sbd.payroll.psp.domainsecondary.SAPMethodCall" entity-name="com.intuit.sbd.payroll.psp.domainsecondary.SAPMethodCall" table="PSP_SAP_METHOD_CALL">
        <id name="Id" column="SAP_METHOD_CALL_SEQ" type="com.intuit.sbd.payroll.psp.hibernate.SpcfUniqueIdUserType" access="property">
            <generator class="assigned"/>
        </id>
        <!-- SAPMethodCall Version Property -->
        <version name="Version" type="long" column="VERSION" unsaved-value="negative" />

        <!-- SAPMethodCall Admin Properties -->
        <property name="CreatorId" type="string" column="CREATOR_ID" not-null="false" />
        <property name="CreatedDate" type="com.intuit.sbd.payroll.psp.hibernate.SpcfCalendarUserType" column="CREATED_DATE" not-null="true" />
        <property name="ModifierId" type="string" column="MODIFIER_ID" not-null="false" />
        <property name="ModifiedDate" type="com.intuit.sbd.payroll.psp.hibernate.SpcfCalendarUserType" column="MODIFIED_DATE" not-null="true"/>
        <property name="TempId" type="string" column="SAP_METHOD_CALL_SEQ" update="false" insert="false" access="property"/>
        <property name="RealmId" type="long" column="REALM_ID" not-null="true" insert="true" update="false" access="property"/>

        <!-- SAPMethodCall Declared Properties -->
        <property name="ScreenPath" type="string" column="SCREEN_PATH"/>

        <property name="ServiceName" type="string" column="SERVICE_NAME"/>

        <property name="MethodName" type="string" column="METHOD_NAME"/>

        <property name="Parameters" type="string" column="PARAMETERS"/>

        <property name="ResultSize" type="long" column="RESULT_SIZE"/>

        <property name="ElapsedMillis" type="long" column="ELAPSED_MILLIS"/>

        <property name="ExceptionTrace" type="string" column="EXCEPTION_TRACE"/>

        <property name="SecurityPrincipal" type="string" column="SECURITY_PRINCIPAL"/>

        <property name="SessionId" type="string" column="SESSION_ID"/>

        <property name="Host" type="string" column="HOST"/>
    </class>
</hibernate-mapping>