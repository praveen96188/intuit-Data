<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domainsecondary" default-cascade="merge" auto-import="false" default-access="com.intuit.sbd.payroll.psp.hibernate.PSPMixedAccessor">
	<class name="com.intuit.sbd.payroll.psp.domainsecondary.Hcm401kCompanyPolicy" entity-name="com.intuit.sbd.payroll.psp.domainsecondary.Hcm401kCompanyPolicy" table="PSP_HCM401K_COMPANY_POLICY">
		<id name="Id" column="HCM401K_COMPANY_POLICY_SEQ" type="com.intuit.sbd.payroll.psp.hibernate.SpcfUniqueIdUserType" access="property">
			<generator class="assigned"/>
		</id>

		<!-- Hcm401kCompanyPolicy Version Property -->
		<version name="Version" type="long" column="VERSION" unsaved-value="negative" />

		<!-- Hcm401kCompanyPolicy Admin Properties -->
		<property name="CreatorId" type="string" column="CREATOR_ID" not-null="false" />
		<property name="CreatedDate" type="com.intuit.sbd.payroll.psp.hibernate.SpcfCalendarUserType" column="CREATED_DATE" not-null="true" />
		<property name="ModifierId" type="string" column="MODIFIER_ID" not-null="false" />
		<property name="ModifiedDate" type="com.intuit.sbd.payroll.psp.hibernate.SpcfCalendarUserType" column="MODIFIED_DATE" not-null="true"/>
		<property name="TempId" type="string" column="HCM401K_COMPANY_POLICY_SEQ" update="false" insert="false" access="property"/>
        <property name="RealmId" type="long" column="REALM_ID" not-null="true" insert="true" update="false" access="property"/>

		<!-- Hcm401kCompanyPolicy Declared Properties -->
		<property name="CompanyId" type="string" column="COMPANY_ID"/>

		<property name="Active" type="org.hibernate.type.NumericBooleanType" column="ACTIVE"/>
        <many-to-one name="Hcm401kPolicy" class="com.intuit.sbd.payroll.psp.domainsecondary.Hcm401kPolicy" column="HCM401K_POLICY_FK"  not-null="true"  />
        <set name="Hcm401kCompanyQbdtPitemSet" inverse="true"  access="property" batch-size="100">
        	<key column="HCM401K_COMPANY_POLICY_FK"  not-null="true" />
        	<one-to-many class="com.intuit.sbd.payroll.psp.domainsecondary.Hcm401kCompanyQbdtPitem" />
        </set>

        <set name="Hcm401kEmployeeDeductionSet" inverse="true"  access="property" batch-size="100">
        	<key column="HCM401K_COMPANY_POLICY_FK"  not-null="true" />
        	<one-to-many class="com.intuit.sbd.payroll.psp.domainsecondary.Hcm401kEmployeeDeduction" />
        </set>
	</class>
</hibernate-mapping>