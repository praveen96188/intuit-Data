<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domain">
    <query name="findUsageBillsOnDate">
        <![CDATA[
            select bill.Id
            from com.intuit.sbd.payroll.psp.domain.Bill bill
            where bill.Closed = false
            and bill.BillDate = :billDate
        ]]>
    </query>

    <query name="findUsageBillsDuring">
        <![CDATA[
            select bill.Id
            from com.intuit.sbd.payroll.psp.domain.Bill bill
            where bill.Closed = false
            and bill.BillDate >= :startDate
            and bill.BillDate <= :endDate
        ]]>
    </query>
</hibernate-mapping>
