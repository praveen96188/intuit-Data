<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domain">
      <query name="findLatestATFDataExtractTime">
        <![CDATA[
            Select max(extractBatch.StartDate)
                    from com.intuit.sbd.payroll.psp.domain.ATFDataExtractBatch as extractBatch
                where extractBatch.BatchStatus = :batchStatusCd
             		and extractBatch.RunType = :runType
			]]>
    </query>    
</hibernate-mapping>

