<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domain">

    <!-- Find companies by fraud criteria -->
    <query name="findUnprocessedRequestsForCompaniesNotInError">
        <![CDATA[
                Select unprocessedRequest
    			from com.intuit.sbd.payroll.psp.domain.QbdtUnprocessedRequest as unprocessedRequest
			   	where unprocessedRequest.Status in (:statuses)
                      and not exists (
                                         Select 'T'
                                         From com.intuit.sbd.payroll.psp.domain.QbdtUnprocessedRequest as unprocessedRequestInError
                                         Where unprocessedRequestInError.Company = unprocessedRequest.Company and
                                               unprocessedRequestInError.Status in ('Error', 'Processing')
                                     )
                order by unprocessedRequest.Company, unprocessedRequest.CreatedDate
			]]>
    </query>

</hibernate-mapping>

