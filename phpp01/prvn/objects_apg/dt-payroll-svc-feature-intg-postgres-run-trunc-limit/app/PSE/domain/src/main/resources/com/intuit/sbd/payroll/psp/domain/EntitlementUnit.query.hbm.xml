        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domain">    
    <query name="findDistinctEntitlementUnitsBySubscriptionNumber">
        <![CDATA[
                 select distinct entitlementUnit
                 from com.intuit.sbd.payroll.psp.domain.EntitlementUnit as entitlementUnit
                 where entitlementUnit.Entitlement.SubscriptionNumber = :subNum
 	]]>
    </query>
    <query name="findEntitlementUnitsOnUsageBillingBySubscriptionStartDate">
            <![CDATA[
                 select  eu
                 from com.intuit.sbd.payroll.psp.domain.EntitlementUnit as eu
                 join fetch eu.Entitlement as e
                 join fetch e.EntitlementCode as ec
                 join fetch eu.Company as c
                 where trunc(e.SubscriptionStartDate) = trunc(to_date(:subscriptionStartDate, 'mmddyyyy'))
                 and ec.IsUsageBilling = true
                 and ec.AssetItemNumber not in ('1300009', '1400076')
     	    ]]>
    </query>

    <query name="findEntitlementUnitsOnUsageBillingBySubscriptionStartDate_postgres">
        <![CDATA[
                 select  eu
                 from com.intuit.sbd.payroll.psp.domain.EntitlementUnit as eu
                 join fetch eu.Entitlement as e
                 join fetch e.EntitlementCode as ec
                 join fetch eu.Company as c
                 where date_trunc('day',e.SubscriptionStartDate) = date_trunc('day',to_date(:subscriptionStartDate, 'mmddyyyy'))
                 and ec.IsUsageBilling = true
                 and ec.AssetItemNumber not in ('1300009', '1400076')
     	    ]]>
    </query>
    
    <query name="entitlementunit.query.by.encein">
        <![CDATA[
               SELECT entitlement.SubscriptionNumber AS subscriptionNumber,
                      entitlementUnit.EntitlementUnitStatus AS entitilementUnitStatus,
                      entitlement.LicenseNumber as licenseNumber,
                      entitlement.CustomerId AS customerId,
					  entitlement.EntitlementState AS entitlementState
                FROM com.intuit.sbd.payroll.psp.domain.EntitlementUnit as entitlementUnit
                JOIN entitlementUnit.Entitlement AS entitlement
                WHERE entitlementUnit.FedTaxIdEnc in (:companyFedTaxId)
                AND entitlement.SubscriptionNumber IS NOT NULL
                AND entitlement.CustomerId IS NOT NULL
                  
 	]]>
    </query>

