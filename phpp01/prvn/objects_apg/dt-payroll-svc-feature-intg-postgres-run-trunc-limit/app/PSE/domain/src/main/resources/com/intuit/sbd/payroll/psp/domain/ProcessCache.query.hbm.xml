<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domain">

    <sql-query name="findCurrentProcessCacheId">
        <return-scalar column="processCacheToken" type="java.lang.String"/>
        <![CDATA[
            select SYSTEM_PARAMETER_VALUE as processCacheToken
            from PSP_SYSTEM_PARAMETER
            where SYSTEM_PARAMETER_CD = 'PROCESS_CACHE_REFRESH_TOKEN'
			]]>
    </sql-query>
    
</hibernate-mapping>