<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domain">
    <query name="findAllEntitlementsSortedById">
        <![CDATA[
	        select entitlement.id
	        from com.intuit.sbd.payroll.psp.domain.Entitlement as entitlement
            order by entitlement.Id
			]]>
    </query>

    <query name="findEntitlementById">
        <![CDATA[
	        select entitlement
	        from com.intuit.sbd.payroll.psp.domain.Entitlement as entitlement
	        where entitlement.id = :id
			]]>
    </query>

    <sql-query name="updateEntitlementStartDate">
        <![CDATA[
            UPDATE psp_entitlement pe
            SET pe.SUBSCRIPTION_START_DATE =GREATEST (ADD_MONTHS (PE.SUBSCRIPTION_START_DATE, -12),PE.CREATED_DATE) , pe.modified_date=sys_extract_utc(systimestamp),PE.MODIFIER_ID='PSP-2531'
            WHERE entitlement_offering_code IN ('037893', '145897', '145279')
            AND PE.SUBSCRIPTION_START_DATE > pe.created_date + 60
            AND EXISTS
            (SELECT 1
            FROM psp_entitlement_code pec
            WHERE PE.ENTITLEMENT_CODE_FK = PEC.ENTITLEMENT_CODE_SEQ
            AND PEC.ASSET_ITEM_NUMBER = '1101349')
	]]>
    </sql-query>

    <sql-query name="updateEntitlementStartDate_postgres">
        <![CDATA[
            UPDATE psp_entitlement
            SET SUBSCRIPTION_START_DATE =GREATEST (SUBSCRIPTION_START_DATE - INTERVAL '12 MONTHS',CREATED_DATE) , modified_date=timezone('UTC', cast (CURRENT_TIMESTAMP AS timestamptz)),MODIFIER_ID='PSP-2531'
            WHERE entitlement_offering_code IN ('037893', '145897', '145279')
            AND SUBSCRIPTION_START_DATE > created_date + INTERVAL '60 DAYS'
            AND EXISTS
            (SELECT 1
            FROM psp_entitlement_code pec
            WHERE ENTITLEMENT_CODE_FK = PEC.ENTITLEMENT_CODE_SEQ
            AND PEC.ASSET_ITEM_NUMBER = '1101349')
	]]>
    </sql-query>

    <sql-query name="updateEntitlementChargeDate">
        <![CDATA[
                UPDATE PSP_ENTITLEMENT PE
                SET PE.NEXT_CHARGE_DATE = trunc(PE.CREATED_DATE )+8/24+365,
                PE.MODIFIER_ID = 'EMSOPS-9096',
                modified_date = SYS_EXTRACT_UTC (SYSTIMESTAMP)
                WHERE pe.next_charge_date < SYSDATE + 30
                AND pe.entitlement_state = 'Enabled'
                AND entitlement_offering_code IN
                ('615772',
                '793995',
                '637648',
                '412719',
                '798665',
                '8760',
                '392156',
                '757262',
                '885433',
                '132926',
