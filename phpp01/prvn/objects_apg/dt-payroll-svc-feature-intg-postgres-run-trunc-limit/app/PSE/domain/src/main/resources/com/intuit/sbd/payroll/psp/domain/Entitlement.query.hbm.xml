                '417051' , '560894', '876826','312726','811968','189271','037893','145279','396360','573166','745110','860626')
	]]>
    </sql-query>

    <sql-query name="updateEntitlementChargeDate_postgres">
        <![CDATA[
              UPDATE PSP_ENTITLEMENT
              SET NEXT_CHARGE_DATE = date_trunc('Day', CREATED_DATE ) + INTERVAL '8 HOURS' + INTERVAL '365 DAYS',
                  MODIFIER_ID = 'EMSOPS-9096',
                  modified_date = timezone('UTC', cast (CURRENT_TIMESTAMP AS timestamptz))
              WHERE next_charge_date < CURRENT_TIMESTAMP + INTERVAL '30 DAYS'
                AND entitlement_state = 'Enabled'
