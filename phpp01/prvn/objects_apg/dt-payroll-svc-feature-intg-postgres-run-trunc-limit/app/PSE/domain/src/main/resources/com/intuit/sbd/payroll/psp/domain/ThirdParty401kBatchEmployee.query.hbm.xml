<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.intuit.sbd.payroll.psp.domain">
	<sql-query name="findCompanyEmployeeLastSendDate">
		<return-scalar column="tp401kBatchId" type="java.lang.Long"/>
		<![CDATA[
		    select outer
		    from ThirdParty401kBatchEmployee outer
		    where batchEmployee.employee.company = :company
		    and batchEmployee.CreatedDate =
		        (select max(CreatedDate)
		         from ThirdParty401kBatchEmployee inner
		         where inner.employee = outer.employee)

		]]>
	</sql-query>
</hibernate-mapping>
