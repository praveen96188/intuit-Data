  <target name="psp-custom-code-generation-before-oracle" depends="clean-target" unless="model-generation.notRequired">
    <exec dir="${model}" executable="java" failonerror="true">
      <arg line="-Ddatabase=&quot;oracle&quot; -DbedlFileName=&quot;${model}/PSP.bedl.xml&quot; -Dagencies.sql=&quot;${initialdata}/populate_agency.sql&quot; -jar ${codegen}/${latest-codegen-jar}"/>
    </exec>
  </target>

  <target name="psp-custom-code-generation-before-postgres" depends="psp-custom-code-generation-before-oracle" unless="model-generation.notRequired">
