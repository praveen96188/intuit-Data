      <xsd:element name="DateReviewed" type="DateType" minOccurs="0"/>
      <xsd:element name="AuthorizeDiscuss" type="CheckboxType" minOccurs="0"/>
      <xsd:element name="PreparerIndicator" type="CheckboxType" minOccurs="0"/>
      <xsd:element name="PreparerSelfEmployIndicator" type="CheckboxType" minOccurs="0"/>
      <xsd:element name="SignatureType" type="PINType" minOccurs="0"/>
      <xsd:element name="Description" type="ShortDescriptionType" minOccurs="0"/>
      <xsd:element name="Notes" type="ExplanationType" minOccurs="0"/>
      <xsd:element name="PhoneType" type="PhoneNumType" minOccurs="0"/>
      <xsd:element name="PhoneExtension" type="String20Type" minOccurs="0"/>
    </xsd:sequence>
  </xsd:complexType>
  <!-- Type for TIN-->
  <xsd:complexType name="TINType">
    <xsd:annotation>
      <xsd:documentation>Defines the primary TIN used</xsd:documentation>
    </xsd:annotation>
    <xsd:sequence>
      <xsd:element name="TypeTIN">
        <xsd:annotation>
          <xsd:documentation>Defines the Federal Taxpayer Identification Number Type.</xsd:documentation>
        </xsd:annotation>
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:enumeration value="FEIN"/>
            <xsd:enumeration value="SSN"/>
            <xsd:enumeration value="ITIN"/>
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="TINTypeValue">
        <xsd:annotation>
          <xsd:documentation>Either Federal Employer Identification Number, Social Security Number, or ITIN.</xsd:documentation>
        </xsd:annotation>
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:pattern value="[0-9]{9}"/>
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:simpleType name="PINTypeState">
    <xsd:annotation>
      <xsd:documentation>Type for Reporting Agent PIN</xsd:documentation>
    </xsd:annotation>
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="[A-Za-z0-9]{1}|[A-Za-z0-9]{2}|[A-Za-z0-9]{3}|[A-Za-z0-9]{4}|[A-Za-z0-9]{5}|[A-Za-z0-9]{6}|[A-Za-z0-9]{7}|[A-Za-z0-9]{8}|[A-Za-z0-9]{9}|[A-Za-z0-9]{10}|[A-Za-z0-9]{11}|[A-Za-z0-9]{12}|[A-Za-z0-9]{13}|[A-Za-z0-9]{14}|[A-Za-z0-9]{15}">
        <xsd:annotation>
          <xsd:documentation>State issued PIN - 15 alphameric maximum</xsd:documentation>
        </xsd:annotation>
      </xsd:pattern>
    </xsd:restriction>
  </xsd:simpleType>
  <!-- ACH Amount Type -->
  <xsd:simpleType name="ACHAmountType">
    <xsd:restriction base="xsd:decimal">
      <xsd:totalDigits value="10"/>
      <xsd:fractionDigits value="2"/>
      <xsd:minInclusive value="0.00"/>
    </xsd:restriction>
  </xsd:simpleType>
  <!-- ACH Identifier Type -->
  <xsd:simpleType name="ACHIdentifierType">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="15"/>
    </xsd:restriction>
  </xsd:simpleType>
  <!-- ACH Name Type -->
  <xsd:simpleType name="ACHNameType">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="22"/>
    </xsd:restriction>
  </xsd:simpleType>
  <!-- FTA Tax Type Code Type-->
  <xsd:complexType name="FTATaxTypeCode">
    <xsd:sequence>
      <xsd:element name="FTACode">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:pattern value="[0-9]{3}"/>
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="StateTaxTypeCode">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:pattern value="[0-9]{2}|[  ]{2}|[0-9][ ]"/>
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
  <!--ACH Entity Detail Type Used for ACH Debit-->
  <xsd:complexType name="ACHEntityDetailType">
    <xsd:sequence>
      <xsd:choice>
        <xsd:element name="Checking" type="CheckboxType">
          <xsd:annotation>
            <xsd:documentation>
              <Description>Checking Account</Description>
            </xsd:documentation>
          </xsd:annotation>
        </xsd:element>
        <xsd:element name="Savings" type="CheckboxType">
          <xsd:annotation>
            <xsd:documentation>
              <Description>Savings Account</Description>
            </xsd:documentation>
          </xsd:annotation>
        </xsd:element>
      </xsd:choice>
      <xsd:element name="RoutingTransitNumber" type="RoutingTransitNumberType"/>
      <xsd:element name="BankAccountNumber" type="BankAccountNumberType"/>
      <xsd:element name="PaymentAmount" type="ACHAmountType"/>
      <xsd:element name="IdentificationNumber" type="ACHIdentifierType" minOccurs="0"/>
      <xsd:element name="AccountHolderName" type="ACHNameType" minOccurs="0"/>
      <xsd:element name="AccountHolderType" type="BankAccountHolderType" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation>"1" for Business or "2" for Personal</xsd:documentation>
        </xsd:annotation>
      </xsd:element>
      <xsd:element name="RequestedPaymentDate" type="DateType" minOccurs="0"/>
      <xsd:element name="AddendaRecord" type="AddendaRecordType" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
  </xsd:complexType>
  <!--ACH Credit Detail Type used for ACH Credit -->
  <xsd:complexType name="ACHCreditDetailType">
    <xsd:sequence>
      <xsd:element name="PaymentAmount" type="ACHAmountType"/>
      <xsd:element name="IdentificationNumber" type="ACHIdentifierType" minOccurs="0"/>
      <xsd:element name="RequestedPaymentDate" type="DateType" minOccurs="0"/>
      <xsd:element name="AddendaRecord" type="AddendaRecordType" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
  </xsd:complexType>
  <!-- State Direct Deposit Type -->
  <xsd:complexType name="StateDirectDepositType">
    <xsd:annotation>
      <xsd:documentation>Content model for State Refund Direct Deposit</xsd:documentation>
    </xsd:annotation>
    <xsd:sequence>
      <xsd:element name="TelephoneNumber" type="PhoneNumberType" minOccurs="0"/>
      <xsd:element name="RoutingTransitNumber" type="RoutingTransitNumberType"/>
      <xsd:element name="BankAccountNumber" type="BankAccountNumberType"/>
      <xsd:element name="Amount" type="ACHAmountType" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation>Amount is only necessary where customer requests direct deposit be split into more than one account</xsd:documentation>
        </xsd:annotation>
      </xsd:element>
      <xsd:choice>
        <xsd:element name="Checking" type="CheckboxType"/>
        <xsd:element name="Savings" type="CheckboxType"/>
      </xsd:choice>
    </xsd:sequence>
  </xsd:complexType>
  <!-- State refund to 529 Tuition Trust Account -->
  <xsd:complexType name="StateDirectDeposit529Type">
    <xsd:annotation>
      <xsd:documentation>Content model for State Refund Direct Deposit into a 529 (Tuition Trust) account</xsd:documentation>
    </xsd:annotation>
    <xsd:sequence>
      <xsd:element name="RoutingTransitNumber" type="RoutingTransitNumberType" minOccurs="0"/>
      <xsd:element name="BankAccountNumber" type="BankAccountNumberType"/>
      <xsd:element name="Amount" type="ACHAmountType" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation>Amount is only necessary where customer requests direct deposit be split into more than one account</xsd:documentation>
        </xsd:annotation>
      </xsd:element>
      <xsd:choice minOccurs="0">
        <xsd:element name="Checking" type="CheckboxType"/>
        <xsd:element name="Savings" type="CheckboxType"/>
      </xsd:choice>
      <xsd:element name="BeneficiaryName" type="IndividualNameType"/>
      <xsd:element name="BeneficiarySSN" type="SSNType" minOccurs="0"/>
    </xsd:sequence>
  </xsd:complexType>
  <!-- Addenda Record Type -->
  <xsd:complexType name="AddendaRecordType">
    <xsd:sequence>
      <xsd:element name="TaxpayerIdentification" type="ACHIdentifierType" minOccurs="0"/>
      <xsd:element name="TaxTypeCode" type="FTATaxTypeCode" minOccurs="0"/>
      <xsd:element name="TaxPeriodEndDate" type="DateType" minOccurs="0"/>
      <xsd:element name="TXPAmount" minOccurs="0" maxOccurs="3">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="SubAmountType">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:maxLength value="1"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="SubAmount" type="ACHAmountType"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="FullIATType">
    <xsd:annotation>
      <xsd:documentation>Comment describing your root element</xsd:documentation>
    </xsd:annotation>
    <xsd:sequence>
      <xsd:element name="ForeignCurrency" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation>If states are only sending to domestic RTN's, then everything in this section can be defaulted, i.e. no currency exchange info</xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="ForeignExchangeIndicator" minOccurs="0">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:enumeration value="FV"/>
                  <xsd:enumeration value="VF"/>
                  <xsd:enumeration value="FF"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="ForeignExchangeRefIndicator" minOccurs="0">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:enumeration value="1"/>
                  <xsd:enumeration value="2"/>
                  <xsd:enumeration value="3"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="ForeignExchangeReference" minOccurs="0">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:maxLength value="15"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="OriginatingCurrencyCode">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:maxLength value="3"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="DestinationCurrencyCode">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:maxLength value="3"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="ForeignPaymentAmount" type="ACHAmountType">
              <xsd:annotation>
                <xsd:documentation/>
              </xsd:annotation>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="PaymentDetail">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="DestinationCountry" type="ISOCountryType"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="ForeignDFI">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="ForeignDFIName" type="String35Type"/>
            <xsd:element name="ForeignDFIIdentifier">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:maxLength value="34"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="ForeignDFICountryCode" type="ISOCountryType"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="Receiver">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="ReceiverName" type="String35Type"/>
            <xsd:element name="ReceiverID" minOccurs="0">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:maxLength value="15"/>
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:element>
            <xsd:element name="ReceiverAddress" type="AddressType"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
