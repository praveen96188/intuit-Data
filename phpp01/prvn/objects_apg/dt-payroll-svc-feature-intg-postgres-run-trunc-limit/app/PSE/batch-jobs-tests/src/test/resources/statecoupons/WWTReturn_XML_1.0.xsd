  <xsd:complexType name="StateLocalTaxGrpType">
    <xsd:annotation>
      <xsd:documentation>
        <Description>State Tax Group</Description>
      </xsd:documentation>
    </xsd:annotation>
    <xsd:sequence>
      <!-- State Tax Withheld -->
      <xsd:element name="StateTaxWithheldAmt" type="USAmountType" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation>
            <Description>State Tax Withheld amount</Description>
          </xsd:documentation>
        </xsd:annotation>
      </xsd:element>
      <!-- State Abbreviation Code -->
      <xsd:element name="StateAbbreviationCd" type="StateType">
        <xsd:annotation>
          <xsd:documentation>
            <Description>State abbreviation code</Description>
          </xsd:documentation>
        </xsd:annotation>
      </xsd:element>
      <!-- Payer State I.D. Number -->
      <xsd:element name="PayerStateIdNumber" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation>
            <Description>Payer state I.D. number</Description>
          </xsd:documentation>
        </xsd:annotation>
        <xsd:simpleType>
          <xsd:restriction base="TextType">
            <xsd:maxLength value="16"/>
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <!-- State Distribution -->
      <xsd:element name="StateDistributionAmt" type="USAmountType" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation>
            <Description>State distribution amount</Description>
          </xsd:documentation>
        </xsd:annotation>
      </xsd:element>
      <!-- Local Tax Withheld -->
      <xsd:element name="StateLocalTaxGrp" minOccurs="0">
        <xsd:annotation>
          <xsd:documentation>
            <Description>State Local Tax Group</Description>
          </xsd:documentation>
        </xsd:annotation>
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="LocalTaxWithheldAmt" type="USAmountType" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation>
                  <Description>Local tax withheld amount</Description>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <!-- Name of Locality -->
            <xsd:element name="NameOfLocality" type="ShortDescriptionType">
              <xsd:annotation>
                <xsd:documentation>
                  <Description>Name of locality</Description>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
            <!-- Local Distribution -->
            <xsd:element name="LocalDistributionAmt" type="USAmountType" minOccurs="0">
              <xsd:annotation>
                <xsd:documentation>
                  <Description>Local distribution amount</Description>
                </xsd:documentation>
              </xsd:annotation>
            </xsd:element>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
</xsd:schema>