	<xs:complexType name="EntitlementDetailsType">
		<xs:annotation>
			<xs:documentation>Entitlement Details</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="EntitlementOffering">
				<xs:annotation>
					<xs:documentation>Entitlement Offering</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="EntitlementId" type="EntitlementIdType">
							<xs:annotation>
								<xs:documentation>Entitlement Id</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="SupportCategory" type="SupportCategoryType" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Support Category</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Item" type="ItemIdType">
				<xs:annotation>
					<xs:documentation>Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EntitlementAttributes" minOccurs="0">
				<xs:annotation>
					<xs:documentation>EntitlementAttribute List</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="EntitlementAttribute" minOccurs="0" maxOccurs="unbounded">
							<xs:complexType>
								<xs:complexContent>
									<xs:extension base="EntitlementAttributeType"/>
								</xs:complexContent>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="EntitlementState" type="StateType">
				<xs:annotation>
					<xs:documentation>Entitlement State</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EntitlementEndDate" type="xs:date" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Entitlement End Date</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="GoodThroughDate" type="xs:date" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The date at which the entitlement will become invalid</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="LastUpdateDate" type="xs:dateTime">
				<xs:annotation>
					<xs:documentation>Last Update Date for the entitlement</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EntitlementUnit" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Represents zero or more Entitlement Units.  This notde is published only for the Activation and Deactivation event</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="IdentifiedResourceValue" type="xs:string" minOccurs="0">
							<xs:annotation>
								<xs:documentation>The Identified Resource Value for the Entitlement Unit</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="UnitState" type="EntitlementUnitStateType">
							<xs:annotation>
								<xs:documentation>Current state of the Entitlement Unit</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Activation" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Container for the details of the Activated Product information</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:sequence>
									<xs:element name="ActivatedProduct" type="EntitlementUnitActivatedProductType">
										<xs:annotation>
											<xs:documentation>Activated Product</xs:documentation>
										</xs:annotation>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="LastUpdateDate" type="xs:dateTime">
							<xs:annotation>
								<xs:documentation>The date/time this Entitlement Unit was last updated</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
