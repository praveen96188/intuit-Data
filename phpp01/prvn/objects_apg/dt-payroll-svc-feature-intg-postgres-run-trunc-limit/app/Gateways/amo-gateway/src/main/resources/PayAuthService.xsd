<?xml version="1.0" encoding="UTF-8"?>
<!-- edited with XMLSpy v2009 sp1 (http://www.altova.com) by XMLSpy 2007 Enterprise Ed., Concurrent for 14 users (with SMP from 2007-04-24 to 2009-04-24) (Intuit) -->
<xs:schema xmlns="http://www.intuit.com/iep/order/payauth/xsd" xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.intuit.com/iep/order/payauth/xsd" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">
	<xs:element name="PayAuthRequest">
		<xs:annotation>
			<xs:documentation>Payment Authorization Request for the Charge Amount</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="DocumentId" type="xs:string">
					<xs:annotation>
						<xs:documentation>The unique Identifier assigned to this business transaction</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="DocumentDateTime" type="xs:dateTime">
					<xs:annotation>
						<xs:documentation>The Date Time at which this service request is created or recorded</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="Parties" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Party Info</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="BillToParty" type="PartyType">
								<xs:annotation>
									<xs:documentation>Bill To Party</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="SalesContext" type="SalesContextType">
					<xs:annotation>
						<xs:documentation>Sales Context</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="Payment">
					<xs:annotation>
						<xs:documentation>Payment Info</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="ChargeAmount" type="AmountType">
								<xs:annotation>
									<xs:documentation>Charge Amount</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="PaymentMethod" type="PaymentMethodType">
								<xs:annotation>
									<xs:documentation>Payment Method</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="CreditCard" type="CreditCardType" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Credit Card Payment</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="EFT" type="BankAccountType" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Electronic Funds Transfer Payment, also known as Wire Transfer.</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="PaperCheck" type="BankAccountType" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Paper Check Payment</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="BillingDestination" type="xs:string" default="Intuit" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Destination receiving the fund</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="AuthorizationInfo" type="AuthorizationInfoType" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Payment Authorization Info</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="PayAuthResponse">
		<xs:annotation>
			<xs:documentation>Payment Authorization Response for the Charge Amount</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="DocumentId" type="xs:string">
					<xs:annotation>
						<xs:documentation>The unique Identifier assigned to this business transaction</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="DocumentDateTime" type="xs:dateTime">
					<xs:annotation>
						<xs:documentation>The Date Time at which this service request is created or recorded</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="AuthorizationApproval" type="xs:boolean">
					<xs:annotation>
						<xs:documentation>Boolean flag indicating if the payment authorization request was approved</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="Error" type="ErrorType" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Error Info</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="Payment">
					<xs:annotation>
						<xs:documentation>Payment Info</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="PaymentMethod" type="PaymentMethodType">
								<xs:annotation>
									<xs:documentation>Payment Method</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="AuthorizationInfo" type="AuthorizationInfoType" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Payment Authorization Info</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="SalesOrderPayAuthRequest">
		<xs:annotation>
			<xs:documentation>Payment Authorization Request for the Sales Order</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Header" type="HeaderType" minOccurs="0">
					<xs:annotation>
						<xs:documentation>metadata</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="DataArea">
					<xs:annotation>
						<xs:documentation>Payment Authorization Data</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="Process">
								<xs:annotation>
									<xs:documentation>Process Info</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:attribute name="operation" type="xs:string">
										<xs:annotation>
											<xs:documentation>Operation Type</xs:documentation>
										</xs:annotation>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:element name="ProcessSalesOrderFulfillment" type="ProcessSalesOrderFulfillmentType">
								<xs:annotation>
									<xs:documentation>Sales Order Fulfillment</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="SalesOrderPayAuthResponse">
		<xs:annotation>
			<xs:documentation>Payment Authorization Response for the Sales Order</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Header" type="HeaderType" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Metadata</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="DataArea">
					<xs:annotation>
						<xs:documentation>Payment Authorization Response Data</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="ProcessSalesOrderFulfillmentResponse">
								<xs:annotation>
									<xs:documentation>Sales Order Fulfillment</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:sequence>
										<xs:element name="PaymentMethodCode" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Payment Method for the Sales Order</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:simpleContent>
													<xs:extension base="xs:string">
														<xs:attribute name="listID" type="xs:string">
															<xs:annotation>
																<xs:documentation>List Id</xs:documentation>
															</xs:annotation>
														</xs:attribute>
													</xs:extension>
												</xs:simpleContent>
											</xs:complexType>
										</xs:element>
										<xs:element name="SalesOrderCreditCardPayment" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Credit Card Payment</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="CreditChargeAuthorizationResponse" type="SalesOrderCreditChargeAuthorizationResponseType" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Credit Card Authorization Response</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
										<xs:element name="BankPayment" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Bank Payment</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="BankPaymentAuthorizationResponse" type="SalesOrderBankPaymentAuthorizationResponseType" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Bank Payment Authorization Response</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
									</xs:sequence>
								</xs:complexType>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:complexType name="AddressType">
		<xs:annotation>
			<xs:documentation>Address</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="AddressId" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A unique Identifier assigned to this Address</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:simpleContent>
						<xs:extension base="xs:string">
							<xs:attribute name="schemeName" use="required">
								<xs:annotation>
									<xs:documentation>Scheme Name</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:enumeration value=""/>
									</xs:restriction>
								</xs:simpleType>
							</xs:attribute>
						</xs:extension>
					</xs:simpleContent>
				</xs:complexType>
			</xs:element>
			<xs:element name="AddressLine" type="xs:string" minOccurs="0" maxOccurs="4">
				<xs:annotation>
					<xs:documentation>The Lines of the Address.  The first Address Line is typically the number and street.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="City" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The City of the Address</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="County" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The County of the Address</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="StateOrProvince" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The State or the Province of the address, depending on which is pertinent.  Required for all US addresses.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Country" type="xs:string" default="US" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Country of the Address</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PostalCode" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Postal Code or Zip Code of the address, if applicable.  An extended zip+4 code includes the five digits of the ZIP code, a hyphen, and four more digits that determine a more precise location than the ZIP code alone.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AmountType">
		<xs:annotation>
			<xs:documentation>Amount</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:decimal">
				<xs:attribute name="currency" use="required">
					<xs:annotation>
						<xs:documentation>Currency in ISO 4217 standard e.g. USD, INR, etc.</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:length value="3"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="AuthorizationInfoType">
		<xs:annotation>
			<xs:documentation>Payment Authorization Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="RefOrderNumber" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The unique number assigned to the authorization transaction. This field is also referred to as PSON (Payment Server Order Number).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AuthorizationCode" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Response Code returned by the Authorization Provider to indicate the outcome of the payment authorization request.  The values are defined in the specifications of the payment gateway.  For Paymentech, refer to the Paymentech Online Processing Spec.pdf.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AuthorizationDate" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Date Time at which the payment was authorized</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AuthorizationUTCTimestamp" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Date Time expressed in UTC at which the payment was authorized</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AuthorizedAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Authorized Charge Amount in the currency of the credit card issuer</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AuthorizationResponseCode" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Pay Auth Service Response Code</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AuthorizationDescription" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Textual Description of the Authorization Response</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AVSResponseCode" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Address Verification Service Response Code for partial or fiull AVS</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CVVResponseCode" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Response Code for the CVV3/4 Verification</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="VoiceAuthorizationInd" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Indicates whether authorization was conducted mannually over phone</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="BankAccountType">
		<xs:annotation>
			<xs:documentation>General bank account information that may be used in various payment method scenarios.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="AccountName" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Full Name of the Account Holder</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AccountType" default="Checking" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Bank Account Type.  This field is required for the EFT Payment Method but optional for paper checks.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Checking"/>
						<xs:enumeration value="Savings"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="AccountNumber" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The International Bank Account Number (IBAN).  This field is required for EFT but is optional for paper checks.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="BankName" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Name of the Bank</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="BranchLocation" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Branch Location of the Bank providing this account</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="BankRoutingNumber" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Bank Routing number.  This field is required for EFT but is optional for paper checks.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="SWIFTCode" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Bank Identification Code, an internationally-recognized system of codes for identifying banks (see ISO 9362). These codes are commonly used to identify the banks involved in an international wire transfer.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CheckNumber" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Check Number associated with the payment.  This field is required for Paper Check PaymentMethods but optional for EFT.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="MethodOption" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Identify whether the payment was Immediate, On-Demand or AutoPay</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="BusinessType">
		<xs:annotation>
			<xs:documentation>Business</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Name" type="xs:string">
				<xs:annotation>
					<xs:documentation>The full Business Name</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="LegalName" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Legal Name of the Business</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Telephone" type="TelephoneType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>The business's telephone number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Fax" type="TelephoneType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The business's fax number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Type" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Type of Business</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ContactType">
		<xs:annotation>
			<xs:documentation>Contact</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PartyId" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A unique Identifier assigned to this Party</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Id" type="PartyIdType">
							<xs:annotation>
								<xs:documentation>A unique Party Id</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="PersonName" type="NameType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Person Name</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Title" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Business or Professional Title</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedTitle" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Free-form Title that may be identified to describe the Contact's Title</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Role" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Role of this Contact e.g. the Primary Contact)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Telephone" type="TelephoneType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>The Contact's telephone number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Fax" type="TelephoneType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The contact's fax number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EmailAddress" type="xs:string" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>The Contact's Email Address.  This field is not validated, but it is highly recommended to be in the canonical format of aaa@aaaaa.aaa</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PreferredCorrespondenceMethod" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Party's Preferred Method of Correspondence.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Email"/>
						<xs:enumeration value="Fax"/>
						<xs:enumeration value="Mail"/>
						<xs:enumeration value="Phone"/>
						<xs:enumeration value="SMS"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CreditCardType">
		<xs:annotation>
			<xs:documentation>Credit Card Account Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="AuthLevel" minOccurs="0" maxOccurs="2">
				<xs:annotation>
					<xs:documentation>The Extended Verifications to be perform beyond the basic authorization.  These includes the fraud deterrant such as the Address Validation Service and the Card Security Verification. Note: The conflicting combination of "Partial AVS" and "Full AVS" is not allowed.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Card Security Verification"/>
						<xs:enumeration value="Partial AVS"/>
						<xs:enumeration value="Full AVS"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="AccountName" type="xs:string">
				<xs:annotation>
					<xs:documentation>The Full Name of the Cardholder, as appeared on the card</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CreditCardType">
				<xs:annotation>
