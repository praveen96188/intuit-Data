					<xsd:documentation>OrderType is set only in certain cases, for e.g. Service Migrations, TAROrder, QBPayrollRenewal, VersionProtection</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Item" type="ItemSpecialDataType" maxOccurs="unbounded"/>
			<xsd:element ref="PaymentMethod" minOccurs="0"/>
			<xsd:element ref="BillToContact"/>
			<xsd:element ref="ShipToContact" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An element to represent ship-to contact info. Only applicable for shippable orders.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OrderAmount">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="Subtotal" type="AmountDataType"/>
						<xsd:element name="Tax" type="AmountDataType"/>
						<xsd:element name="ShippingCharge" type="AmountDataType" minOccurs="0"/>
						<xsd:element name="Total" type="AmountDataType"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="TemplateProperties" type="TemplatePropertiesDataType" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ShipmentConfirmationv1DataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent the information specific to Shipment Confirmation notification.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="OrderNumber" type="OrderNumberDataType"/>
			<xsd:element name="OrderDate" type="OrderDateDataType"/>
			<xsd:element ref="ShipToContact" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>An element to represent ship-to contact info.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Details" maxOccurs="3">
				<xsd:annotation>
					<xsd:documentation>An order can contain more than 1 or more Items; some of the Items may have already been shipped, some of them can be shipped in future and this Shipping Confirmation notice contains tracking information regarding the items which are just shipped. So there will be a seperate Details node for current, future and previous shipments.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="Status" type="ShipConfirmationStatusDataType">
							<xsd:annotation>
								<xsd:documentation>Indicates the status of the shipment. Possible values are current, previous, future.</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<xsd:element name="WayBill" maxOccurs="100">
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="TrackingNumber" type="TrackingNumberDataType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>Tracking number for the current shipment.</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ShowDisclaimer" type="xsd:boolean" minOccurs="0"/>
									<xsd:element name="ExpectedShipDate" type="xsd:string" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>ExpectedShipDate for the current shipment.</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ExpectedDeliveryDate" type="xsd:string" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>ExpectedDeliveryDate for the current shipment.</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ShipMethod" type="ShipMethodDataType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>ShipMethod for the current shipment, it is actually a carrier code which is combination of carrier and shipping type. This code is mapped to a Carrier shipping desciption and tracking URL, which are shown on Shipping confirmation email. e.g. 000001_DHL_L_GND will be mapped to "DHL Lettter Ground" and "http://track.dhl-usa.com/TrackByNbr.asp?ShipmentNumber=TrackingNumber"</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ShipMethodMeaning" type="ShipMethodMeaningDataType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>ShipMethodMeaning for the current shipment, used internally for mapping ShipMethod mapping</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ShipType" type="ShipTypeDataType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>ShipType for the current shipment, used internally for mapping ShipMethod mapping</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="Item" minOccurs="0" maxOccurs="unbounded">
										<xsd:annotation>
											<xsd:documentation>Item details, used for current, previous, future shipment.</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="Name" type="ItemNameDataType" minOccurs="0"/>
												<xsd:element name="Quantity" type="QuantityDataType" minOccurs="0"/>
												<xsd:element name="BusinessUnit" type="BusinessUnitNameDataType" minOccurs="0"/>
												<xsd:element name="TransactionAttributes" type="AttributeType" minOccurs="0" maxOccurs="unbounded">
													<xsd:annotation>
														<xsd:documentation>Transactional attributes for each item</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="TemplateProperties" type="TemplatePropertiesDataType" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ShipmentConfirmationv2DataType">
