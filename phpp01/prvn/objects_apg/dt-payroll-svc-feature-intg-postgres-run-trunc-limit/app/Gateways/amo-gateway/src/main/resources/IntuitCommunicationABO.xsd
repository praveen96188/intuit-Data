		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="EstablishOnlineAccountAccessDataType">
		<xsd:sequence>
			<xsd:element name="SourceSystem" type="SourceSystemDataType">
				<xsd:annotation>
					<xsd:documentation>The source system this event is coming from. Enum possible values: SBL, ESTORE</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ProvisionalId" type="ProvisionalIdDataType">
				<xsd:annotation>
					<xsd:documentation>Provisional IAM Id</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Customer" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Customer account info</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="AccountId" type="IdDataType">
							<xsd:annotation>
								<xsd:documentation>customer MDM account id</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<xsd:element name="ContactId" type="IdDataType">
							<xsd:annotation>
								<xsd:documentation>customer MDM contact Id</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>
					<xsd:attribute name="SchemeName" type="CustomerSchemeDataType" use="required">
						<xsd:annotation>
							<xsd:documentation>possible enum values include: MDM</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="PIN" type="PINNumberDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The PIN number to access account</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ActionType" type="ActionTypeDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The action that was taken on the account. Enum value can be either "NEW" if new online account was created or "EXISTING" when adding new contact to existing account</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DomainContextUrl" type="DomainContextUrlDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The context domain from which the customer originated from. e.g. http://quickbooks.com. It must be in this form http://xxxx.com  DigiComms will concatenate the query parameters to this url.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TemplateProperties" type="TemplatePropertiesDataType" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ServiceRequestDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent the information specific to Billing Failurenotification.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Item" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="ItemId" type="ItemIdDataType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>The item identifier (ItemName) as itâ€™s defined in PIM.  This will drive the branding of the email and is used to derive the item display name.
								If the identifier is not recognized by DigiComms as a valid identifier, the default Intuit brand will be used.</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<xsd:element name="TransactionAttributes" type="AttributeType" minOccurs="0" maxOccurs="unbounded">
							<xsd:annotation>
								<xsd:documentation>Transactional attributes for each item</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="ServiceRequestId" type="ServiceRequestIdDataType">
				<xsd:annotation>
					<xsd:documentation>The SR ID on the service request</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TemplateName">
				<xsd:annotation>
					<xsd:documentation>This must be the exact template name as it is defined in Exact Target for the specific type of service request. Please work with DigiComms engineer to find out name for each service request tempalte name in ET. </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TemplateProperties" type="TemplatePropertiesDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Any additional attributes that you would like to appear in the email template. The names of these attributes MUST be exactly as they are defined in Exact Target. Please note that these attributes names and values will not be validated by digicomms </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:element name="ShipToContact" type="ShipToContactDataType">
		<xsd:annotation>
			<xsd:documentation>An element to represent ship-to info.</xsd:documentation>
		</xsd:annotation>
	</xsd:element>
	<xsd:complexType name="ItemDataType">
		<xsd:sequence>
			<xsd:element name="Name" type="ItemNameDataType" minOccurs="0"/>
			<xsd:element name="Type" type="ItemTypeDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Expected only from GEMS/PIM. Specifies if shippable, download, etc.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BusinessUnit" type="BusinessUnitNameDataType" minOccurs="0"/>
			<xsd:element name="Price" type="AmountDataType" minOccurs="0"/>
			<xsd:element name="Quantity" type="QuantityDataType" minOccurs="0"/>
			<xsd:element name="ShowFutureShipment" type="xsd:boolean" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Set to true if the item is not available yet for delivery.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TransactionAttributes" type="AttributeType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Transactional attributes for each item</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ItemSpecialDataType">
		<xsd:sequence>
			<xsd:element name="ItemId" type="ItemIdDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The item identifier (ItemName) as it’s defined in PIM.  This will drive the branding of the email and is used to derive the item display name.
					If the identifier is not recognized by DigiComms as a valid identifier, the default Intuit brand will be used.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ActionCode" type="ItemActionCodeDataType">
				<xsd:annotation>
					<xsd:documentation>The line item action code</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Price" type="PriceDataType" minOccurs="0"/>
			<xsd:element name="Quantity" type="QuantityDataType" minOccurs="0"/>
			<xsd:element name="FutureProcessing" type="xsd:boolean" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Set to true if the item is not available yet for delivery. First processing date is in the future</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DeliveryMethod" type="OrderDeliveryMethodDataType">
				<xsd:annotation>
					<xsd:documentation>Contains the delivery method for the items in the order. Shippable, Service or Download, Promotion</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExpectedDeliveryDateFrom" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Promise Delivery Date To. Will be used to formulate a range From to To </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExpectedDeliveryDateTo" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Promise Delivery Date To. Will be used to forumulate a range From to To. </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExpectedShipDateFrom" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Promise Ship Date From</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExpectedShipDateTo" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Promise Ship Date To</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ShippingDetails" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Shipping details are included only if one or more items are available for shipping.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="ShipType" type="ShipTypeDataType" minOccurs="0"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="TransactionAttributes" type="AttributeType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>Transactional attributes for each item. Will include Fulfillment Method if exists</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:simpleType name="ShipMethodDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the shipping method.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ShipMethodMeaningDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the shipping method meaning.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ShipTypeDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the shipping type.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="ProvisionalIdDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent a provisional id with the scheme name.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:attribute name="SchemeName" type="ProvsionalIdSchemeDataType" use="required">
					<xsd:annotation>
						<xsd:documentation>Possible enum values include: IAM</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:simpleType name="CustomerSchemeDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent the source system for the Customer</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="MDM"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ContactIdSchemeDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent the source system for the contact Id</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="MDM"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="IdDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the auth id.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PINNumberDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the PIN Number</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="DomainContextUrlDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the Domain Context URL e.g. http://quickbooks.com</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ServiceRequestIdDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the service request id (SR ID).</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="TemplateNameDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the template name.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ItemNameDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the item name.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="ItemIdDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the item id.
			This is the identifier used to drive the branding of the communication, and the pre-defined attributes that are applicable for that brand.  It could be a group code from GEMS (GroupID), an item identifier from BRM (Jasmine support), or an item identifier (ItemName) as it’s defined in PIM.  If the identifier is not recognized by DigiComms as a valid identifier, the default Intuit brand will be used.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:attribute name="SchemeName" type="CommunicationReferenceIdSchemeDataType" use="required"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:simpleType name="ItemTypeDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the item type.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ItemActionCodeDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the item action code</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="ADD"/>
			<xsd:enumeration value="UPDATE"/>
			<xsd:enumeration value="DELETE"/>
			<xsd:enumeration value="RESUME"/>
			<xsd:enumeration value="NONE"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="BusinessUnitNameDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the business unit name.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="QuantityDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the quantity.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:integer"/>
	</xsd:simpleType>
	<xsd:simpleType name="ShipConfirmationStatusDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the ship confirmation status.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="current"/>
			<xsd:enumeration value="previous"/>
			<xsd:enumeration value="future"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="TrackingNumberDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the tracking number.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OrderTypeDataType">
		<xsd:annotation>
			<xsd:documentation>Represents the order type for special cases.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="TAROrder"/>
			<xsd:enumeration value="ServiceMigrations"/>
			<xsd:enumeration value="QBPayrollRenewal"/>
			<xsd:enumeration value="VersionProtection"/>
			<xsd:enumeration value="N/A"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OrderDeliveryMethodDataType">
		<xsd:annotation>
			<xsd:documentation>Contains the delivery method for the items ordered. Shippable, Service or Download.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="Shippable"/>
			<xsd:enumeration value="Service"/>
			<xsd:enumeration value="Download"/>
			<xsd:enumeration value="Promotion"/>
			<xsd:enumeration value="None"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="EmailAddressDataType">
		<xsd:annotation>
			<xsd:documentation>Email address data type with length validation. Max length is 320.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
			<xsd:maxLength value="320"/>
			<xsd:whiteSpace value="collapse"/>
			<!-- <xsd:pattern value=".+@.+\\.[a-z]+"/> -->
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="AddressDataType">
		<xsd:annotation>
			<xsd:documentation>Contains mailing address information.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AddressLine" type="AddressLineDataType" maxOccurs="2">
				<xsd:annotation>
					<xsd:documentation>The lines of the address.  The first AddressLine is typically the number and street.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="City" type="CityDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The city of the address.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StateOrProvince" type="StateOrProvinceDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The state or the province of the address, depending on which is pertinent.  Required for all US addresses.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Country" type="CountryDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The country of the address.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PostalCode" type="PostalCodeDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The postal code or zip code of the address, if applicable.  Required for all US addresses.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PostalCodeExtension" type="PostalCodeExtensionDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The postal code extension of the address, if applicable</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BillToContactDataType">
		<xsd:annotation>
			<xsd:documentation>Contains Customer's contact and address information.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Name" type="NameDataType" minOccurs="0"/>
			<xsd:element name="Telephone" type="TelephoneDataType" minOccurs="0"/>
			<xsd:element name="Address" type="AddressDataType" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PaymentMethodDataType">
		<xsd:annotation>
			<xsd:documentation>Contains informations about different Payment Methods like Credit Card, EFT etc.</xsd:documentation>
		</xsd:annotation>
		<xsd:choice>
			<xsd:element name="CreditCardInfo" type="CreditCardInfoDataType">
				<xsd:annotation>
					<xsd:documentation>The credit card account information provided for authorization and/or payment.  Required if Payment MethodId is Credit Card</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EFTInfo" type="EFTInfoDataType">
				<xsd:annotation>
					<xsd:documentation>The EFT account information provided for authorization and/or payment. Required if Payment MethodId is EFT.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ECheckInfo" type="ECheckInfoDataType">
				<xsd:annotation>
					<xsd:documentation>The ECheck account information provided for authorization and/or payment. Required if Payment MethodId is ECheck.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PaperCheckInfo" type="PaperCheckInfoDataType">
				<xsd:annotation>
					<xsd:documentation>The Paper Check information provided for payment. The CheckNumber is optional as GEMS doesn't provide this.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:choice>
	</xsd:complexType>
	<xsd:complexType name="CreditCardInfoDataType">
		<xsd:annotation>
			<xsd:documentation>The credit card information </xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AccountType" type="AccountTypeDataType">
				<xsd:annotation>
					<xsd:documentation>Credit card account type.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccountNumber" type="AccountNumberDataType">
				<xsd:annotation>
					<xsd:documentation>The credit card account token (PCI Compliant).</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccountName" type="AccountNameDataType">
				<xsd:annotation>
					<xsd:documentation>The full name of the cardcholder, as it appears on the card (Name on Card)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExpirationMonth" type="xsd:positiveInteger">
				<xsd:annotation>
					<xsd:documentation>Expiration month.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExpirationYear" type="xsd:positiveInteger">
				<xsd:annotation>
					<xsd:documentation>Expiration year.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ECheckInfoDataType">
		<xsd:annotation>
			<xsd:documentation>General bank account information that is used for eCheck payment method.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AccountType" type="AccountTypeDataType" default="Checking">
				<xsd:annotation>
					<xsd:documentation>The bank account type. </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccountNumber" type="AccountNumberDataType">
				<xsd:annotation>
					<xsd:documentation>The bank account number.  </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RoutingNumber" type="RoutingNumberDataType">
				<xsd:annotation>
					<xsd:documentation>The bank account's routing number.  </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccountName" type="AccountNameDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The full name of the account holder.  Is this required?</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BankName" type="BankNameDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The name of the bank.  Is this required?</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CheckNumber" type="CheckNumberDataType">
				<xsd:annotation>
					<xsd:documentation>A check number associated with the payment.  </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BranchLocation" type="BranchLocationDataType">
				<xsd:annotation>
					<xsd:documentation>The branch location of the bank providing this account.  </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="EFTInfoDataType">
		<xsd:annotation>
			<xsd:documentation>General bank account information that is used for eCheck payment method.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="AccountNumber" type="AccountNumberDataType">
				<xsd:annotation>
					<xsd:documentation>The bank account number.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RoutingNumber" type="RoutingNumberDataType">
				<xsd:annotation>
					<xsd:documentation>The bank account's routing number.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AccountName" type="AccountNameDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The full name of the account holder.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PaperCheckInfoDataType">
		<xsd:annotation>
			<xsd:documentation>Paper Check information that is used for payment method.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="CheckNumber" type="CheckNumberDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>The bank account number.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PersonNameDataType">
		<xsd:annotation>
			<xsd:documentation>Contains parts of  person's name.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="FirstName" type="NameDataType">
				<xsd:annotation>
					<xsd:documentation>Person's given name or first name.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MiddleName" type="NameDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Person's middle name.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FamilyName" type="NameDataType">
				<xsd:annotation>
					<xsd:documentation>Person's last name or family name.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:simpleType name="NameDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
			<xsd:maxLength value="500"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:element name="PersonName" type="PersonNameDataType"/>
	<xsd:element name="OrganizationName" type="NameDataType"/>
	<xsd:element name="PaymentMethod" type="PaymentMethodDataType"/>
	<xsd:element name="BillToContact" type="BillToContactDataType">
		<xsd:annotation>
			<xsd:documentation>Contains BillTo contact information.</xsd:documentation>
		</xsd:annotation>
	</xsd:element>
	<xsd:simpleType name="CityDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AddressLineDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="StateOrProvinceDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CountryDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PostalCodeDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PostalCodeExtensionDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="TelephoneDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AccountTypeDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AccountNumberDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="InvoiceNumberDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="PurchaseOrderNumberDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AccountNameDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="RoutingNumberDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="BankNameDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="CheckNumberDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="BranchLocationDataType">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="LanguageDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to request content to be displayed in various languages.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="2"/>
			<xsd:maxLength value="4"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="SubscriptionPeriodDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent subscription period with the scheme name.</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:attribute name="Unit" type="SubscriptionPeriodUnitDataType" use="required"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:simpleType name="SubscriptionPeriodUnitDataType">
		<xsd:annotation>
			<xsd:documentation>Contains the unit of the subscription period. Day, Month or Year.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="Day"/>
			<xsd:enumeration value="Month"/>
			<xsd:enumeration value="Year"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:element name="Offering" type="OfferingDataType">
		<xsd:annotation>
			<xsd:documentation> Represent the Offering  information.</xsd:documentation>
		</xsd:annotation>
	</xsd:element>
	<xsd:complexType name="OfferingDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent the Offering information.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Name" type="OfferingNameDataType"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:simpleType name="OfferingNameDataType">
		<xsd:annotation>
			<xsd:documentation>A datatype to represent the offering name.</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="SubscriptionEndingDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent the information specific to Subscription Ending notification.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element ref="MarketOffering" maxOccurs="100"/>
			<xsd:element ref="Offering"/>
			<xsd:element name="NumberOfDaysLeft" type="xsd:integer">
				<xsd:annotation>
					<xsd:documentation>The number of days left to the expiry date</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TemplateProperties" type="TemplatePropertiesDataType" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="AttributeDataType">
		<xsd:annotation>
			<xsd:documentation>Name/Value pair data type</xsd:documentation>
		</xsd:annotation>
		<xsd:all>
			<xsd:element name="Name" type="AttributeNameDataType">
				<xsd:annotation>
					<xsd:documentation>Data type for an attribute name. Attribute names must contain characters only from the character set A-Z, a-Z, 0-9, the period character (.), the underscore character (_), or the hyphen character (-) </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Value" type="AttributeValueDataType">
				<xsd:annotation>
					<xsd:documentation>Data type for an attribute value</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:all>
	</xsd:complexType>
	<xsd:complexType name="PriceDataType">
		<xsd:all>
			<xsd:element name="CurrentPrice" type="AmountDataType">
				<xsd:annotation>
					<xsd:documentation>Current price of line item. This is a net price, not a regular list price.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="RecurringPrice" type="AmountDataType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Recurring price of line item if it exists. This is a list price and not a regular price. </xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:all>
	</xsd:complexType>
	<xsd:simpleType name="AttributeNameDataType">
		<xsd:annotation>
			<xsd:documentation>Data type for an attribute name. Attribute names must contain characters only from the character set A-Z, a-Z, 0-9, the period character (.), the underscore character (_), or the hyphen character (-) </xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[A-Za-z\d\._\-]{1,100}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AttributeValueDataType">
		<xsd:annotation>
			<xsd:documentation>Data type for an attribute value</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
			<xsd:maxLength value="100000"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="TemplatePropertiesDataType">
		<xsd:sequence>
			<xsd:element name="Attributes" type="AttributeDataType" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:simpleType name="MessageTypeDataType">
		<xsd:annotation>
			<xsd:documentation>A data type to represent the type of message (default to business message)</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="Solicited Marketing Message"/>
			<xsd:enumeration value="Unsolicited Marketing Message"/>
			<xsd:enumeration value="Product Message"/>
			<xsd:enumeration value="Business Message"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="TransactionInfoType">
		<xsd:annotation>
			<xsd:documentation>Transaction Info</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="TransactionId" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Transaction Id</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TransactionDatetime" type="xsd:dateTime" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Transaction Datetime</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SalesOrganization" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Sales Organization requesting the service</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="TaxPointDataType">
		<xsd:annotation>
			<xsd:documentation>The tax point from and to dates </xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="TaxPointFromDate" type="xsd:date">
				<xsd:annotation>
					<xsd:documentation>tax point from date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TaxPointToDate" type="xsd:date">
				<xsd:annotation>
					<xsd:documentation>tax point to date.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
</xsd:schema>
