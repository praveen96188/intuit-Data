										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ShipMethod" type="ShipMethodDataType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>ShipMethod for the current shipment, it is actually a carrier code which is combination of carrier and shipping type. This code is mapped to a Carrier shipping desciption and tracking URL, which are shown on Shipping confirmation email. e.g. 000001_DHL_L_GND will be mapped to "DHL Lettter Ground" and "http://track.dhl-usa.com/TrackByNbr.asp?ShipmentNumber=TrackingNumber"</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ShipMethodMeaning" type="ShipMethodMeaningDataType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>ShipMethodMeaning for the current shipment, used internally for mapping ShipMethod mapping</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ShipType" type="ShipTypeDataType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>ShipType for the current shipment, used internally for mapping ShipMethod mapping</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="Item" minOccurs="0" maxOccurs="unbounded">
										<xsd:annotation>
											<xsd:documentation>Item details, used for current, previous, future shipment.</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="ItemId" type="ItemIdDataType" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>The item identifier (ItemName) as it’s defined in PIM.  This will drive the branding of the email and is used to derive the item display name.
														If the identifier is not recognized by DigiComms as a valid identifier, the default Intuit brand will be used.</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="Quantity" type="QuantityDataType" minOccurs="0"/>
												<xsd:element name="TransactionAttributes" type="AttributeType" minOccurs="0" maxOccurs="unbounded">
													<xsd:annotation>
														<xsd:documentation>Transactional attributes for each item</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="TemplateProperties" type="TemplatePropertiesDataType" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
