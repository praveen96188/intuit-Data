 name="UniversalAddressId" type="AddressIdType" minOccurs="0"/>			<xs:element name="PostalAddress" type="PostalAddressType"/>			<xs:element name="ContactMethodRole" type="AddressRoleType" maxOccurs="unbounded">				<xs:annotation>					<xs:documentation>10.1 supported values are: BillTo, ShipTo, Unspecified.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="ActiveStatus" type="xs:string" minOccurs="0"/>		</xs:sequence>	</xs:complexType>	<xs:complexType name="AddressIdType">		<xs:annotation>			<xs:documentation>A data type to represent an id with the scheme name.			</xs:documentation>		</xs:annotation>		<xs:simpleContent>			<xs:extension base="String30Type">				<xs:attribute name="SchemeName" type="AddressIdSchemeType" use="required"/>			</xs:extension>		</xs:simpleContent>	</xs:complexType>	<xs:simpleType name="AddressIdSchemeType">		<xs:restriction base="xs:string">			<xs:enumeration value="MDM"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="AddressRoleType">		<xs:restriction base="xs:string">			<xs:enumeration value="BillTo"/>			<xs:enumeration value="ShipTo"/>			<xs:enumeration value="Unspecified"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="AuthIdType">		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="19"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="AuthIdSchemeType">		<xs:restriction base="xs:string">			<xs:enumeration value="IAM"/>		</xs:restriction>	</xs:simpleType>	<xs:complexType name="BusinessCustomerAccountType">		<xs:sequence>			<xs:element name="CustomerAccountNumber" type="AccountNumberType" minOccurs="0">				<xs:annotation>					<xs:documentation>External Number that is given to the customer and used as a common identifier across the ecosystem.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="CustomerAccountName" type="String255Type">				<xs:annotation>					<xs:documentation>Customer-defined name.  Typically it's the same as the BusinessName.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="AccountSiteName" type="String255Type" minOccurs="0">				<xs:annotation>					<xs:documentation>Same business with multiple physical locations.  </xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="CustomerAccountClass" type="CustomerAccountClassType">				<xs:annotation>					<xs:documentation>Customer, ThirdPartyShipping, Converted? - part of DM</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="Business" type="BusinessType">				<xs:annotation>					<xs:documentation>The business that owns the account.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="PrimaryCustomerAccountContactId" type="ContactIdType" minOccurs="0"/>		</xs:sequence>	</xs:complexType>	<xs:complexType name="BusinessType">		<xs:annotation>			<xs:documentation>Represent the business</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="BusinessName" type="String100Type">				<xs:annotation>					<xs:documentation>The full business name.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="Address" minOccurs="0">				<xs:annotation>					<xs:documentation>per CR#76, address is no longer a required element.</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="PrimaryAddress" type="AccountAddressType" minOccurs="0">							<xs:annotation>								<xs:documentation>Default Primary address</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="PrimaryShipToAddress" type="AccountAddressType" minOccurs="0">							<xs:annotation>								<xs:documentation>Default BillTo address</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="PrimaryBillToAddress" type="AccountAddressType" minOccurs="0">							<xs:annotation>								<xs:documentation>Default  BillTo address</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="Address" type="AddressType" minOccurs="0" maxOccurs="unbounded">							<xs:annotation>								<xs:documentation>Other addresses</xs:documentation>							</xs:annotation>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="PrimaryEmailAddress" type="EmailAddressType" minOccurs="0">				<xs:annotation>					<xs:documentation>The account email address,  This field is not validated, but it is highly recommended to be in the canonical format ofaaa@aaaaa.aaa Email address having the 'Main' role   Note: This email address is noted used for correspondence.  The email address of the Pirmary Contact is used.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="Telephone" minOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:element name="MainPhoneNumber" type="xs:string" minOccurs="0"/>						<xs:element name="MainFaxNumber" type="xs:string" minOccurs="0"/>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ContactIdType">		<xs:annotation>			<xs:documentation>A data type to represent an id with the scheme name.			</xs:documentation>		</xs:annotation>		<xs:simpleContent>			<xs:extension base="String30Type">				<xs:attribute name="SchemeName" type="ContactIdSchemeType" use="required"/>			</xs:extension>		</xs:simpleContent>	</xs:complexType>	<xs:simpleType name="ContactRoleType">		<xs:restriction base="xs:string">			<xs:enumeration value="AccountAdmin"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="ContactIdSchemeType">		<xs:restriction base="xs:string">			<xs:enumeration value="MDM"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="CountryCodeType">		<xs:annotation>			<xs:documentation>A data type used to represent alpha-2 and alpha-3 country codes as defined in ISO_3166-1 standard.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="2"/>		</xs:restriction>	</xs:simpleType>	<xs:complexType name="CustomerAccountType">		<xs:annotation>			<xs:documentation>How the customer wishes to represent themselves to Intuit.  It is the instantiation of a relationship between a Party (Perso or Business) and Intuit for the purposes of doing bussiness, e.g., trying, using, buying Intuit products.</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="CustomerAccount">				<xs:annotation>					<xs:documentation>Thre are three types of Cusotmer  Accounts based onthe type of party who owns the Account: Business Customer Account, Individual Customer Account and Household Customer Account.  				Only BUSINESS CUSTOMER ACCOUNT is supproted in 10.1.</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:choice>						<xs:element name="BusinessCustomerAccount" type="BusinessCustomerAccountType"/>					</xs:choice>				</xs:complexType>			</xs:element>			<xs:element name="CustomerAccountContact" type="CustomerAccountContactType" maxOccurs="unbounded">				<xs:annotation>					<xs:documentation>People who are attached to the Customer Acount and based on their role in that account, have permissions to do certain things</xs:documentation>				</xs:annotation>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="CustomerAccountContactType">		<xs:annotation>			<xs:documentation>Contact on the Account</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="CustomerAccountContactId" type="ContactIdType" minOccurs="0">				<xs:annotation>					<xs:documentation>Unique identifer used as the common identifier for the contact across the ecosystem.  This is an internal identifier and not given to the customer.  					A single person can have a relationship with n different Customer Accounts.  A new CustomerAccountContact exists for each relationship. Roles and PII are managed separately for each relationship.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="ContactPerson">				<xs:complexType>					<xs:sequence>						<xs:element name="UserIdentity" type="UserIdentityType" minOccurs="0">							<xs:annotation>								<xs:documentation>Online identity.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="Person" type="PersonType"/>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="ContactRole" type="CustomerAccountContactRoleType" minOccurs="0" maxOccurs="unbounded">				<xs:annotation>					<xs:documentation>Role  of this contact on the account, determine what the person is allowed to do in the context of this Customer Account. </xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="CommunicationPreferences" type="CommunicationPreferencesType">				<xs:annotation>					<xs:documentation>10.1 limitted support: Delivery=email Language=eng</xs:documentation>				</xs:annotation>			</xs:element>		</xs:sequence>		<xs:attribute name="IsPrimary" type="xs:string"/>	</xs:complexType>	<xs:complexType name="CustomerAccountContactRoleType">		<xs:sequence>			<xs:element name="RoleName" type="xs:string">				<xs:annotation>					<xs:documentation>10.1 supported values are limited to two roles, the actual names will be documented in the user guide once they're finalized (CR#54)</xs:documentation>				</xs:annotation>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:simpleType name="CustomerAccountClassType">		<xs:restriction base="xs:string">			<xs:enumeration value="Customer"/>			<xs:enumeration value="ThirdPartyShipping"/>			<xs:enumeration value="Pending"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="EmailAddressType">		<xs:annotation>			<xs:documentation>Email address data type with length and format validation. Max length is 50.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="255"/>			<xs:whiteSpace value="collapse"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="EmailRoleType">		<xs:restriction base="xs:string">			<xs:enumeration value="Main"/>			<xs:enumeration value="Alternate"/>		</xs:restriction>	</xs:simpleType>	<xs:complexType name="EmailType">		<xs:sequence>			<xs:element name="EmailAddress" type="EmailAddressType">				<xs:annotation>					<xs:documentation>This field is not validated, but it is highly recommended to be in the canonical format of aaa@aaaaa.aaa</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="ContactMethodRole" type="EmailRoleType" maxOccurs="unbounded">				<xs:annotation>					<xs:documentation>10.1 supported values are: Main, Alternate.</xs:documentation>				</xs:annotation>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="PersonType">		<xs:annotation>			<xs:documentation>Represent the person</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="GivenName" type="String150Type" minOccurs="0">				<xs:annotation>					<xs:documentation>First name.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="MiddleName" type="String64Type" minOccurs="0">				<xs:annotation>					<xs:documentation>Middle Name</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="FamilyName" type="String150Type" minOccurs="0">				<xs:annotation>					<xs:documentation>Last name.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="NamePrefix" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:minLength value="1"/>						<xs:maxLength value="75"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="NameSuffix" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:minLength value="1"/>						<xs:maxLength value="40"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="Address" type="ContactAddressType" minOccurs="0" maxOccurs="unbounded">				<xs:annotation>					<xs:documentation>These address don't have contact method role.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="Telephone" minOccurs="0">				<xs:annotation>					<xs:documentation>The contact's telephone number(s).  Phone number is stored after stirpping out hyphens and paranthesis. For example it's stored as  8581113333.</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="MobileNumber" type="xs:string" minOccurs="0"/>						<xs:element name="FaxNumber" type="xs:string" minOccurs="0"/>						<xs:element name="HomeNumber" type="xs:string" minOccurs="0"/>						<xs:element name="WorkNumber" type="xs:string" minOccurs="0"/>						<xs:element name="AlternateNumber" type="xs:string" minOccurs="0"/>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="EmailAddress" minOccurs="0">				<xs:annotation>					<xs:documentation>Email is not validated, but it is highly recommended to be in the canonical format of aaa@aaaaa.aaa</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="MainEmailAddress" type="EmailAddressType" minOccurs="0"/>						<xs:element name="AlternateEmailAddress" type="EmailAddressType" minOccurs="0"/>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="PostalAddressType">		<xs:sequence>			<xs:element name="AddressLine" type="String200Type" maxOccurs="5">				<xs:annotation>					<xs:documentation>The lines of the address.  The first AddressLine is typically the number and street.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="City" type="String64Type" minOccurs="0">				<xs:annotation>					<xs:documentation>The city of the address.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="StateOrProvince" minOccurs="0">				<xs:annotation>					<xs:documentation>The state or the province of the address, depending on which is pertinent.  Required for all US addresses.  Alpha-2 State, and free form Province are supported.  US State is two letter.  Canadian is two letter.  Non-US/Canada is free form.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="50"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="Country">				<xs:annotation>					<xs:documentation>ISO-3166-1 Country code.  e.g. "us" for United States.  Alpha-2 code is supported. </xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="CountryCodeType"/>				</xs:simpleType>			</xs:element>			<xs:element name="PostalCode" type="String30Type" minOccurs="0">				<xs:annotation>					<xs:documentation>The postal code or zip code of the address, if applicable.  Required for all US addresses.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="County" type="xs:string" minOccurs="0"/>		</xs:sequence>	</xs:complexType>	<xs:complexType name="UserIdentityType">		<xs:sequence>			<xs:element name="AuthId" type="AuthIdType"/>		</xs:sequence>	</xs:complexType>	<!-- ====================================================================== -->	<!-- ==============       Communication Preferences Types      ====================== -->	<!-- ====================================================================== -->	<xs:complexType name="CommunicationPreferencesType">		<xs:choice>			<xs:element name="Email">				<xs:complexType>					<xs:sequence>						<xs:element name="Language" type="LanguageType">							<xs:annotation>								<xs:documentation>ISO- 639-3 Language code.   10.1 the only supported value is eng.</xs:documentation>							</xs:annotation>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:choice>	</xs:complexType>	<xs:simpleType name="LanguageType">		<xs:annotation>			<xs:documentation>ISO- 639-3 Language code.  e.g. "eng" for English, "hin" for Hindi.  ISO standard for 2, 3, or 4 char codes are supported. </xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="2"/>			<xs:maxLength value="4"/>		</xs:restriction>	</xs:simpleType>	<!-- ====================================================================== -->	<!-- ==============       Data Types      ====================== -->	<!-- ====================================================================== -->	<xs:simpleType name="String1Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 1</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="1"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String2Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 2.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="2"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String4Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 4.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="4"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String15Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 15.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="55"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String25Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 25.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="25"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String30Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 30.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="30"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String40Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 40.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="40"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String50Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 50.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="50"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String64Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 64.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="64"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String80Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 80.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="80"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String100Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 100.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="100"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String150Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 150.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="150"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String200Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 200.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="200"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String255Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 255.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="255"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="String1050Type">		<xs:annotation>			<xs:documentation>Reperesents the non empty string of max length 1050.</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:minLength value="1"/>			<xs:maxLength value="1050"/>		</xs:restriction>	</xs:simpleType></xs:schema>