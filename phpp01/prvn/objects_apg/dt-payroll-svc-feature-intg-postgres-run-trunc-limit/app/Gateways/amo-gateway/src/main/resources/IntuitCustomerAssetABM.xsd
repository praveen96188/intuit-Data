				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="EventReason" type="AssetChangeReasonType"/>
						<xsd:element name="PaymentFailure" minOccurs="0">
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="FailureType" type="xsd:string">
										<xsd:annotation>
											<xsd:documentation>indicates the PaymentFailureType. Possible values are SOFT and FINAL</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
