	<!-- ====================================================================== -->
	<!-- ==============  Imports and Includes   =============================== -->
	<!-- ====================================================================== -->
	<xsd:include schemaLocation="IntuitCustomerAssetABO.xsd"/>
	<xsd:import namespace="http://www.intuit.com/iep/entitlement/EntitlementService/xsd" schemaLocation="EntitlementServiceBase.xsd"/>
	<!-- ====================================================================== -->
	<xsd:annotation>
		<xsd:documentation>
			<svcdoc:ABO>
				<svcdoc:Description>IntuitCustomerAsset ABM identifies all the service operations that are supported for the CustomerAsset ABO</svcdoc:Description>
				<svcdoc:Type>ABM</svcdoc:Type>
				<svcdoc:Industry/>
				<svcdoc:ABOName>IntuitCustomerAssetABO</svcdoc:ABOName>
			</svcdoc:ABO>
		</xsd:documentation>
	</xsd:annotation>
	<!-- ====================================================================== -->
	<xsd:complexType name="IntuitCustomerAssetABMType">
		<xsd:complexContent>
			<xsd:extension base="IntuitCustomerAssetABOType"/>
		</xsd:complexContent>
	</xsd:complexType>
	<!-- ====================================================================== -->
	<!-- ==================    GetCustomerAsset Service     =================== -->
	<!-- ====================================================================== -->
	<xsd:element name="GetCustomerAssetABM" type="GetCustomerAssetDataAreaType"/>
	<xsd:complexType name="GetCustomerAssetDataAreaType">
		<xsd:sequence>
			<xsd:element name="TransactionInfo" type="TransactionInfoType">
				<xsd:annotation>
					<xsd:documentation>Transaction Info</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element ref="GetCustomerAsset"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="GetCustomerAssetType">
		<xsd:complexContent>
			<xsd:extension base="CustomerAssetRequestType"/>
		</xsd:complexContent>
	</xsd:complexType>
	<xsd:element name="GetCustomerAsset" type="GetCustomerAssetType"/>
	<!-- ====================================================================== -->
	<!-- =============      GetCustomerAsset Response Service     ============= -->
	<!-- ====================================================================== -->
	<xsd:element name="GetCustomerAssetResponseABM" type="GetCustomerAssetResponseDataAreaType"/>
	<xsd:complexType name="GetCustomerAssetResponseDataAreaType">
		<xsd:sequence>
			<xsd:element ref="GetCustomerAssetResponse"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="GetCustomerAssetResponseType">
		<xsd:complexContent>
			<xsd:extension base="CustomerAssetResponseType"/>
		</xsd:complexContent>
	</xsd:complexType>
	<xsd:element name="GetCustomerAssetResponse" type="GetCustomerAssetResponseType"/>
	<!-- ====================================================================== -->
	<!-- =============     CustomerAsset EventService     ============= -->
	<!-- ====================================================================== -->
	<xsd:element name="SyncCustomerAssetABM" type="SyncCustomerAssetDataAreaType"/>
	<xsd:complexType name="SyncCustomerAssetDataAreaType">
		<xsd:sequence>
			<xsd:element name="TransactionInfo" type="TransactionInfoType"/>
