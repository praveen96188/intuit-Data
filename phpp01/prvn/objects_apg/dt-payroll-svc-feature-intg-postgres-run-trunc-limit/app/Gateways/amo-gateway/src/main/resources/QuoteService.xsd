			</xs:element>
			<xs:element name="PromotionCode" type="PromotionCodeType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Promotion Code</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PriceWaterfall" type="PriceWaterfallType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Price Waterfall Info.  A detailled overview of all discounts that have been applied to a product.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CompatibilityType">
		<xs:annotation>
			<xs:documentation>Compatibility / Eligibility of Line items</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="EligibilityStatus" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Eligibility/Compatibility Status (Y or N)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EligibilityReason" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Eligibility Failure Reason</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="PromotionCodeType">
		<xs:annotation>
			<xs:documentation>Promotion Code</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="schemeName" type="xs:string">
					<xs:annotation>
						<xs:documentation>Scheme Name e.g. Type of Promotion Code</xs:documentation>
					</xs:annotation>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="PromotionType">
		<xs:annotation>
			<xs:documentation>Promotion Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="UnitPromotionDiscountAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Unit Promotional Discount Amount</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedPromotionDiscountAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Unit Promotional Discount Amount * Qty</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedNonPromotionPrice" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Extended Net Price + Extended Promotion Discount Amount</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PromotionEndDate" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Promotion End Date</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="QuantityType">
		<xs:annotation>
			<xs:documentation>Quantity</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:nonNegativeInteger">
				<xs:attribute name="uom" use="required">
					<xs:annotation>
						<xs:documentation>Unit of Measure  Count by unit (e.g. Each) or Time-based (e.g. Day, Month and Year).</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="Day"/>
							<xs:enumeration value="Each"/>
							<xs:enumeration value="Month"/>
							<xs:enumeration value="Year"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="ReferredToPartyType">
		<xs:annotation>
			<xs:documentation>Referred To Party</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PartyId" type="PartyIdType">
				<xs:annotation>
					<xs:documentation>Party Id</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Name" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Name of the Parent account</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="RelationshipType" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Relationship Type between the Parent Account and the Child Account</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="RefIdType">
		<xs:annotation>
			<xs:documentation>Reference Id</xs:documentation>
		</xs:annotation>
		<xs:attribute name="schemeName">
			<xs:annotation>
				<xs:documentation>Scheme Name</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="ResultType">
		<xs:annotation>
			<xs:documentation>Service Result</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Status">
				<xs:annotation>
					<xs:documentation>Service Status</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Success"/>
						<xs:enumeration value="Failure"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Error" type="ErrorType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Error Info</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SalesBusinessType">
		<xs:annotation>
			<xs:documentation>Business</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PartyId" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A unique Identifier assigned to this Party</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Id" type="PartyIdType">
							<xs:annotation>
								<xs:documentation>A unique Party Id</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Name" type="xs:string">
				<xs:annotation>
					<xs:documentation>The full Business Name</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="LegalName" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Legal Name of the Business</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Telephone" type="TelephoneType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>The business's telephone number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Fax" type="TelephoneType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The contacts fax number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Type" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Type of Business such as Household, Business or Payroll</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CompanyId" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Company Id that identifies the top-level legal entity for which tax exception may exist.  The Vertex Central User Interface is used to set up any taxability rules that apply at this level.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DivisionId" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Division Id identifies the mid-level legal entity for which tax exceptions may exist.  The Vertex Central User Interface is us used to set up any taxability rules that apply at this level.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxJurisdiction" type="TaxJurisdictionType" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SalesContextType">
		<xs:annotation>
			<xs:documentation>Sales Context</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="SalesOrganization" type="xs:string">
				<xs:annotation>
					<xs:documentation>The Sales Organization (or System) that originated this transaction.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="BizProcessType" default="Quotation" minOccurs="0">
				<xs:annotation>
					<xs:documentation>To indicate whether it is a sales quotation or invoice quotation</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Invoice"/>
						<xs:enumeration value="Quotation"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="TransactionDateTime" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Date Time at which the sales transaction was created or recorded.  This field must be provided if the transaction datetime is different from the document datetime.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TransactionType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>An Identifier for the specific Transaction Type (Purchase order, Sales Order or Prepyament)</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Lease"/>
						<xs:enumeration value="Purchase"/>
						<xs:enumeration value="Rental"/>
						<xs:enumeration value="Sale"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="TransactionSubtype" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Transaction Subtype based on line items on the sales transaction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Channel" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Channel through which the sale took place</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Fax"/>
						<xs:enumeration value="In-Product"/>
						<xs:enumeration value="Mail"/>
						<xs:enumeration value="Mobile"/>
						<xs:enumeration value="Partner"/>
						<xs:enumeration value="Phone"/>
						<xs:enumeration value="Retail"/>
						<xs:enumeration value="Web"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="OrderType" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Order Type to facilitate downstream processing</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="BatchInd" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Indicates if the sale is part of a Batch (as opposed to a single one-time sale).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PartnerInd" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Indicates if the sale originated in a source External to Intuit, i.e. an Outsourced Partner.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="RecurrenceInd" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Indicates if the sale is part of a Recurring Agreement, such as an annual subscription, etc.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ValidateProductCompatability" type="xs:boolean" default="false" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Indicates if the product compatability shall be validated</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxHandlingApproach" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Tax Handling Approach for this Sales Transaction (Standard, Exempt or Require).  A Standard value will base tax exempt handling on the Bill To party information.  An Exempt value may be used when a tax-emempt customer places a tax exempt order.  When stating Exempt, the associated CustomerParty must have tax exempt information.  A Require value may be used when a tax exempt customer places an order that requires taxation.  </xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Exempt"/>
						<xs:enumeration value="Require"/>
						<xs:enumeration value="Standard"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="TaxInfoSpec" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Metadata to specify the behavior of the Global Sales Tax Response</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="JurisdictionLevelDetails" type="xs:boolean" default="false">
							<xs:annotation>
								<xs:documentation>Flag to indicate if the detailed Tax Jurisdiction Levels are required in the Global Sales Tax Response</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="SalesParty" type="SalesPartyType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Sales Party Info</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SalesPartyType">
		<xs:annotation>
			<xs:documentation>Sales Party</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="SalesPerson" type="SalesPersonType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Individual (or Rep) that made the sale</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="SalesBusiness" type="SalesBusinessType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Business that made the sale</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SalesPersonType">
		<xs:annotation>
			<xs:documentation>Sales Person</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PartyId" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A unique Identifier assigned to this Party</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Id" type="PartyIdType">
							<xs:annotation>
								<xs:documentation>A unique Party Id</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="PersonName" type="NameType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Person' Name object.  My be left blank only when this object is used within a SalesPerson object.  For other uses it is required.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Title" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Business or Professional Title</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedTitle" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Free-form Title that may be identified in the call center to describe the Contact's Title</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Role" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Role of this Contact within the context which this object is used.  This field can be used to clarify multi-role contacts.  This field should only be provided on the abstract Contact object (not on any derived forms, such as the Primary Contact)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AuthorizationId" type="AuthorizationIdType" minOccurs="0" maxOccurs="2">
				<xs:annotation>
					<xs:documentation>The Authorization Id or Code for this Individual or Organization.  This field is typically derived from the Uni-Auth system</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxJurisdiction" type="TaxJurisdictionType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Tax Jurisdiction Info</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SalesQuoteHeaderType">
		<xs:annotation>
			<xs:documentation>Quote Header</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="DocumentId" type="xs:string">
				<xs:annotation>
					<xs:documentation>The unique Identifier assigned to this business transaction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DocumentDateTime" type="xs:dateTime">
				<xs:annotation>
					<xs:documentation>The Date Time at which this service request is created or recorded</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Parties">
				<xs:annotation>
					<xs:documentation>Party Info</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="BillToParty" type="PartyType" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Bill To Party</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="ShipToParty" type="PartyType" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Ship To Party</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Pricing" type="PricingHeaderType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Pricing at the header level</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Freight" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Freight Info</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="FreeShipFlag" type="xs:boolean" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Indicates if shiping is free</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="ShipCarrier" type="xs:string" minOccurs="0">
							<xs:annotation>
								<xs:documentation>The specific Carrier for shipping the order</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="BatchNumber" type="xs:string" minOccurs="0">
							<xs:annotation>
								<xs:documentation>A Batch is a logical grouping of orders.  If the order is part of a batch, this field may be used to identify it.</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="ShippingLevelAgreement" type="xs:string" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Shipping Level Agreement</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="SalesContext" type="SalesContextType">
				<xs:annotation>
					<xs:documentation>Sales Context that originiated this transaction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="SalesQuote" type="SalesQuoteType">
				<xs:annotation>
					<xs:documentation>Sales Quote</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SalesQuoteLineType">
		<xs:annotation>
			<xs:documentation>Quote Line</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="LineNumber" type="xs:nonNegativeInteger">
				<xs:annotation>
					<xs:documentation>A unique Serial Number assigned to the line by the source system.  Each line must have a unique value on a given transaction document.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ParentLineNumber" type="xs:nonNegativeInteger" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Parent Line Number for bundle, ensemble, etc.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="RootLineNumber" type="xs:nonNegativeInteger" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Root Line Number for bundle, ensemble, etc.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="OrderItem" type="OrderItemType">
				<xs:annotation>
					<xs:documentation>The Product/Service item information for the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="OrderQuantity" type="QuantityType">
				<xs:annotation>
					<xs:documentation>The Ordered Quantity for the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="UnitPrice" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Unit Price of the Line Item</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:complexContent>
						<xs:extension base="PriceType">
							<xs:sequence>
								<xs:element name="PriceDetails" type="PriceDetailsType" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Price Details</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:sequence>
						</xs:extension>
					</xs:complexContent>
				</xs:complexType>
			</xs:element>
			<xs:element name="LineTotal" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Cost of the Line Item (ExtCurrentCharge + ExtCurrentChargeTax + ExtNetShippingCharge + ExtNetShippingChargeTax + CreditAmount + CreditAmountTax)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Pricing" type="PricingLineType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Pricing for the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Compatibility" type="CompatibilityType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Compatibility / Eligibility rules for the line item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Adjustments" type="AdjustmentsType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Adjustments Info</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Tax" type="TaxType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Tax Info for the Line Item.  It includes the freight and sales tax.  Any tax objects supplied on the GetQuote message will be ignored.  The tax object will be returned on the ShowQuote message.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Freight" type="FreightType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Freight Info for the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ActionType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Action to be performed on the Line Item.  Specifically, it indicates whether the line item is the line item is added, changed, cancelled, refunded, updated, suspended, resumed or deleted.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="ADD"/>
						<xs:enumeration value="Add"/>
						<xs:enumeration value="CANCEL"/>
						<xs:enumeration value="Cancel"/>
						<xs:enumeration value="DELETE"/>
						<xs:enumeration value="Delete"/>
						<xs:enumeration value="REFUND"/>
						<xs:enumeration value="Refund"/>
						<xs:enumeration value="RESUME"/>
						<xs:enumeration value="Resume"/>
						<xs:enumeration value="SUSPEND"/>
						<xs:enumeration value="Suspend"/>
						<xs:enumeration value="UPDATE"/>
						<xs:enumeration value="Update"/>
						<xs:enumeration value="NONE"/>
						<xs:enumeration value="None"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ActionSubtype" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Action Subtype to be performed on the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ActionDateTime" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Date Time at which the action was/will be performed.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Subscription" type="SubscriptionType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Subscription Info</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Fulfillment" type="FulfillmentType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Fulfillment Info for the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DocumentReference" type="DocumentReferenceType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Document Reference</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SalesQuoteType">
		<xs:annotation>
			<xs:documentation>Sales Quote</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="TotalTransaction" type="AmountType">
				<xs:annotation>
					<xs:documentation>Total Transaction Amount.  Total charges (line item price, sales/use tax, freight charge, etc.) - discounts - refunds.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalNRC" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Non-recurring Charge</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalMRC" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Monthly Recurring Charge</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalTax" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Tax Amount.  A sum of the taxes that have been calculated as part of the quotation.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalFreight" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Freight Amount.  A sum of the freight changes that have been calculated as part of the quotation.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalDiscount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Discount Amount.  A sum of the discounts (header and line item discounts) that have been calculated as part of the quotation.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalCredit" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Credit Amount.  A sum of the credits that have been calculated as part of the quotation.  It includes any sales/use tax as well as freight charge refund.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ShippingLevelAgreementType">
		<xs:annotation>
			<xs:documentation>Shipping Level Agreement Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Default" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Default Shipping Level Agreement</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AddressType" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Address Type</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ShippingLevelAgreement" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Shipping Method</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ShippingHandlingLevel" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Shipping and Handling Level</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ShippingRuleHeaderType">
		<xs:annotation>
			<xs:documentation>Shipping Rule Header</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="DocumentId" type="xs:string">
				<xs:annotation>
					<xs:documentation>The unique Identifier assigned to this business transaction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DocumentDateTime" type="xs:dateTime">
				<xs:annotation>
					<xs:documentation>The Date Time at which this service request is created or recorded</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ShipToParty" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Ship To Party</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="PartyId" minOccurs="0">
							<xs:annotation>
								<xs:documentation>A unique Identifier assigned to this Party</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:sequence>
									<xs:element name="Id" type="PartyIdType">
										<xs:annotation>
											<xs:documentation>A unique Party Id</xs:documentation>
										</xs:annotation>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="Address" type="AddressInfoType" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Ship To Address</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Freight" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Freight Info for the Header</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="ShippingLevelAgreement" type="xs:string" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Shipping Level Agreement</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ShippingRuleLineType">
		<xs:annotation>
			<xs:documentation>Shipping Rule Line</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="LineNumber" type="xs:string">
				<xs:annotation>
					<xs:documentation>Line Number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ParentLineNumber" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Parent Line Number for bundle, ensemble, etc.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="OrderItem">
				<xs:annotation>
					<xs:documentation>The Product/Service item information for the Line Item</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="ItemId" type="ItemIdType">
							<xs:annotation>
								<xs:documentation>Item Id</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="ItemAttribute" type="AttributeType" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Item Attribute</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Freight" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Freight Info for the Line Item</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="SmartPartNumber" type="xs:string" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Smart Part Number</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="ShippingLevelAgreement" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Shipping Level Agreement</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:simpleContent>
									<xs:extension base="xs:string">
										<xs:attribute name="isValid" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>True for valid Shipping Level Agreement; false otherwise</xs:documentation>
											</xs:annotation>
										</xs:attribute>
									</xs:extension>
								</xs:simpleContent>
							</xs:complexType>
						</xs:element>
						<xs:element name="ValidShippingZone" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Valid Shipping Zone</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:sequence>
									<xs:element name="ValidShippingLevelAgreement" type="ShippingLevelAgreementType" minOccurs="0" maxOccurs="unbounded">
										<xs:annotation>
											<xs:documentation>Valid Shipping Agreement</xs:documentation>
										</xs:annotation>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="ActionType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Action to be performed on the Line Item.  Specifically, it indicates whether the line item is the line item is added, changed, cancelled, refunded, updated, suspended, resumed or deleted.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="ADD"/>
						<xs:enumeration value="Add"/>
						<xs:enumeration value="CANCEL"/>
						<xs:enumeration value="Cancel"/>
						<xs:enumeration value="DELETE"/>
						<xs:enumeration value="Delete"/>
						<xs:enumeration value="REFUND"/>
						<xs:enumeration value="Refund"/>
						<xs:enumeration value="RESUME"/>
						<xs:enumeration value="Resume"/>
						<xs:enumeration value="SUSPEND"/>
						<xs:enumeration value="Suspend"/>
						<xs:enumeration value="UPDATE"/>
						<xs:enumeration value="Update"/>
						<xs:enumeration value="NONE"/>
						<xs:enumeration value="None"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="SubscriptionType">
		<xs:annotation>
			<xs:documentation>Subscription Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="BillingCycle" type="BillingCycleType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The period for which the bill is generated.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ServiceDate" type="TimePeriodType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Service Date</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="GracePeriod" type="TimePeriodType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Grace Period</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Cancellation" type="CancellationType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Subscription Cancellation</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="TaxExemptType">
		<xs:annotation>
			<xs:documentation>Tax Exemption</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="TaxExemptInd" type="xs:boolean">
				<xs:annotation>
					<xs:documentation>Indicates whether this party is Tax Exempt.  If set to true, the Tax Id and Tax Exempt Reason elements are required</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxExemptionCertId" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Party's Tax Exemption Certificate Number if they are claiming Tax exemption</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxExemptReason" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Reason why the party is claiming tax exempt.  The value of Unknown may only be used for existing data where the reason was not captured and it therefore unknown.  It should not be presented as an option for new orders.  This field is required if TaxExemptInd is true.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="DevelopmentAndResearch"/>
						<xs:enumeration value="Education"/>
						<xs:enumeration value="Government"/>
						<xs:enumeration value="Hospital"/>
						<xs:enumeration value="Non-Profit"/>
						<xs:enumeration value="Manufacturer"/>
						<xs:enumeration value="Resale"/>
						<xs:enumeration value="Unknown"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="TaxExemptExpirationDate" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>If the party is claiming tax exempt, this field must be provided to determine the Valid Period of the Tax Exemption.  This field is required if TaxExemptInd is true.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="TaxJurisdictionType">
		<xs:annotation>
			<xs:documentation>Tax Jurisdiction</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PtOfOriginTaxAreaId" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Point of origin Tax Area Id.  A Vertex-specific number that identifies a Tax Area. If the Tax Area ID exists in your host system, use that data to populate this data element in a request message.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AdminOriginTaxAreaId" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Administrative Origin Tax Area Id. A Vertex-defined term that is equivalent to the following terms: order taken, order acceptance, place of principle negotiation, or place of business.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="TaxType">
		<xs:annotation>
			<xs:documentation>Tax</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ExtendedTaxAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Extended Sales/Use Tax Amount, excluding any freight taxes.  The sum of TaxAmount and FreightTax makes up the total tax for a given line.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="UnitTaxAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Unit Sales/Use Tax Amount, excluding any freight taxes.  The sum of TaxAmount and FreightTax makes up the total tax for a given line.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxRate" type="TaxRateType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Sales/Use Tax Percentage Rate that was used to make the calculation.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxType" default="SalesTax" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Tax Type (Sales/Use tax or Value Added Tax)</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="SalesTax"/>
						<xs:enumeration value="UseTax"/>
						<xs:enumeration value="ValueAddedTax"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="CalculateTaxOverrideInd" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Flag to indicate whether taxing should be overridden to force the calculation of taxes irrespective of the Item Configuration.  If set to true, taxes will be calculated regardless of item configuration.  If set to false (standard taxing), the taxation is driven by item data.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="JurisdictionInfo" type="JurisdictionInfoType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Jurisdiction level tax details</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="TaxRateType">
		<xs:annotation>
			<xs:documentation>Tax Rate</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="NonNegativeDecimal"/>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="TimePeriodType">
		<xs:annotation>
			<xs:documentation>Time Period Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StartDate" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Service Start date</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EndDate" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Service End Date</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="TelephoneType">
		<xs:annotation>
			<xs:documentation>Telephone</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="type">
					<xs:annotation>
						<xs:documentation>Phone Type</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="Day"/>
							<xs:enumeration value="Evening"/>
							<xs:enumeration value="Home"/>
							<xs:enumeration value="Mobile"/>
							<xs:enumeration value="Work"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:simpleType name="ZeroOrNegativeDecimal">
		<xs:annotation>
			<xs:documentation>The zero or negative-decimal type specifies a zero/negative decimal value.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:decimal">
			<xs:maxInclusive value="0"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="ZeroOrNegativeAmountType">
		<xs:annotation>
			<xs:documentation>Zero or negative Amount</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="ZeroOrNegativeDecimal">
				<xs:attribute name="currency" use="required">
					<xs:annotation>
						<xs:documentation>Currency in ISO 4217 standard e.g. USD, INR, etc.</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:length value="3"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="JurisdictionLevelType">
		<xs:annotation>
			<xs:documentation>Tax Jurisdiction Level</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="taxationType" type="xs:string">
					<xs:annotation>
						<xs:documentation>Taxation Type. Eg: GST, HST, General Tax, Sales Tax, Local Tax, etc.</xs:documentation>
					</xs:annotation>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="JurisdictionInfoType">
		<xs:annotation>
			<xs:documentation>Tax Jurisdiction Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="JurisdictionLevel" type="JurisdictionLevelType">
				<xs:annotation>
					<xs:documentation>Tax Jurisdiction Level</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Situs" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The situs of the sale for local sales tax purposes shall be the place where the sale is made</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxRate" type="TaxRateType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Sales/Use Tax Percentage Rate that was used to make the calculation for the given tax jurisdiction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedTaxAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Extended Sales/Use Tax Amount for the given tax jurisdiction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="UnitTaxAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Unit Sales/Use Tax Amount for the given tax jusisdiction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedExemptAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Amount of all exemptions for all units purchased in line</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedGrossAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Amount of all units purchased in line minus any exemptions</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedTaxableAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Amount of all units purchased on line for the given tax jurisdiction</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
</xs:schema>
