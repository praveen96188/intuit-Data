						</xs:element>
						<xs:element name="LatestPromiseDeliveryDateTo" type="xs:dateTime" minOccurs="0">
							<xs:annotation>
								<xs:documentation>The Latest Promise Delivery End Date</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="FulfillmentEstimates" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Fulfillment Estimates for the Line Item</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="InitialPromiseShipDateFrom" type="xs:dateTime" minOccurs="0">
							<xs:annotation>
								<xs:documentation>The Initial Promise Ship Start Date</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="InitialPromiseShipDateTo" type="xs:dateTime" minOccurs="0">
							<xs:annotation>
								<xs:documentation>The Initial Promise Ship End Date</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="LatestPromiseShipDateFrom" type="xs:dateTime" minOccurs="0">
							<xs:annotation>
								<xs:documentation>The Latest Promise Ship Start Date</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="LatestPromiseShipDateTo" type="xs:dateTime" minOccurs="0">
							<xs:annotation>
								<xs:documentation>The Latest Promise Ship End Date</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
