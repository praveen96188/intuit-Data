						<xs:documentation>Manual Adjustment Amount.  This should not be used for self-service</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="ManualDiscountPercentage" type="xs:decimal" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Manual Adjustment Percentage.  This should not be used for self-service</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
			<xs:element name="PolicyDiscountAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Policy Discount for product only (exclude shipping)</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoiceFreightChargeType">
		<xs:annotation>
			<xs:documentation>Invoice Freight Charge</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Amount" type="AmountType">
				<xs:annotation>
					<xs:documentation>The Amount per specified unit of measure</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PerQuantity" type="QuantityType">
				<xs:annotation>
					<xs:documentation>The Quantity for which the unit price applies to</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoiceFreightType">
		<xs:annotation>
			<xs:documentation>Freight</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ShipToPartyId" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Shippable lines will be shipped to this Party.  If the provided Party Id is for a BillTo Party, the PrimaryContact and PrimaryAddress information will be used unless a Secondary Address/Contact is provided.  If the Parties section defines only a BillToParty, then that Party will implicitly be used and this field is not required.  Also, if the Parties section defines a ShipToParty, then that Party will implicitly be used and this field is not required.  If Parties section defines more than 1 ShipToParty, then this field is required (if the line is shippable).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ShipCarrier" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The specific Carrier used to indicate through which carrier this item should be shipped.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ShipSetNumber" type="xs:unsignedInt" minOccurs="0">
				<xs:annotation>
					<xs:documentation>This specifies which Ship Set this line should be part of.  Using this field enables the capability to bundle several lines into one shipment.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="FreightChargeType" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Used in calculating the Freight Charges individual products or a set of products.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ShipZone" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Zone (or General) Region to which the shipment must be sent to.  The value is used for calculating the freight charges.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="FreightCharge" type="InvoiceFreightChargeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Freight Charges applied to the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="FreightTax" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Freight Tax Amount, excluding the sales tax charged for the item.  The sum of TaxAmount and FreightTax make up the total tax for a given line.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="ExtendedTaxAmount" type="AmountType">
							<xs:annotation>
								<xs:documentation>The Freight Tax Amount, excluding the sales tax charged for the item.  The sum of TaxAmount and FreightTax make up the total tax for a given line.</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="UnitTaxAmount" type="AmountType">
							<xs:annotation>
								<xs:documentation>The Unit Freight Tax Amount, excluding the sales tax charged for the item</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="TaxRate" type="TaxRateType" minOccurs="0">
							<xs:annotation>
								<xs:documentation>The Freight Tax Percentage Rate that was used to make the calculation</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="JurisdictionInfo" type="JurisdictionInfoType" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Jurisdiction level tax details</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoiceHeaderFreightType">
		<xs:annotation>
			<xs:documentation>Invoice Header Freight Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="FreeShipFlag" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Indicates if shiping is free</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ShipCarrier" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The specific Carrier for shipping the order</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="BatchNumber" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Batch is a logical grouping of orders.  If the order is part of a batch, this field may be used to identify it.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoiceItemType">
		<xs:annotation>
			<xs:documentation>Item</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ProductClass" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Product class for the item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ProductLine" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Product Line Name for the Item.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ItemCategory" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Code used to represent Groups or Categories of Products or Services with similar taxability</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ItemType" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Type of item e.g. Software product vs. Service</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="SmartPartNumber" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Part number for different combinations of the item attributes</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ItemDefinition" type="AttributeType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Item Definition</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoiceOrderItemType">
		<xs:annotation>
			<xs:documentation>Order Item</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ItemIds">
				<xs:annotation>
					<xs:documentation>The Ids of the items associated with this Quote Line.  It may include item cross references used in other systems, such as legacy systems or external suppliers.  Required for all scenarios except registrations.</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:choice>
							<xs:element name="ItemId" type="ItemIdType">
								<xs:annotation>
									<xs:documentation>The Primary Item Id</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="AlternativeItemId" type="ItemIdType">
								<xs:annotation>
									<xs:documentation>An alternate Item Cross-reference, such as an ItemAlias</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:choice>
						<xs:element name="ParentItemId" type="ItemIdType" minOccurs="0">
							<xs:annotation>
								<xs:documentation>An optioanl Item Id that may be used to determine the Parent or Ensemble/Kit Item this item is part of.  This field will have special uses (for explicit clarification) by systems that explode ensembles into components before passing them to the ERP system.</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Description" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Name or Description of the Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ItemAttributes" type="InvoiceItemType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Item Attributes</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoicePartyType">
		<xs:annotation>
			<xs:documentation>Party Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PartyId" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A unique Identifier assigned to this Party</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Id" type="PartyIdType">
							<xs:annotation>
								<xs:documentation>A unique Party Id</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Business" type="BusinessType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Business-related Information</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TaxExempt" type="TaxExemptType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Tax Exemption Info</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Address" type="AddressInfoType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Addresses pertaining to this Party or Contact.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Contact" type="InvoicePersonType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Contact Info</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ReferredToParties" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Referred To Parties</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="ReferredToParty" type="ReferredToPartyType" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Referred To Party used for tracking if an account was referred by another account (0 to many relationship).</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoicePersonType">
		<xs:annotation>
			<xs:documentation>Person</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="PartyId" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A unique Identifier assigned to this Party</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Id" type="PartyIdType">
							<xs:annotation>
								<xs:documentation>A unique Party Id</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="PersonName" type="NameType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Person Name</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Title" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Business or Professional Title</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedTitle" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Free-form Title that may be identified in the call center to describe the Contact's Title</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Role" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Role of this Contact within the context which this object is used.  This field can be used to clarify multi-role contacts.  This field should only be provided on the abstract Contact object (not on any derived forms, such as the Primary Contact)</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoicePriceDetailsType">
		<xs:annotation>
			<xs:documentation>Price Details</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="UnitCurrentCharge" type="NonNegativeAmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Unit Current Charge after proration to BDOM.  For one-time purchase or no BDOM, it is the same as Unit Price.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedCurrentCharge" type="NonNegativeAmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Extended Current Charge (Unit Curent Charge * Qty)</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoicePromotionType">
		<xs:annotation>
			<xs:documentation>Promotion Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="UnitPromotionDiscountAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Unit Promotional Discount Amount</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedPromotionDiscountAmount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Unit Promotional Discount Amount * Qty</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoiceQuoteHeaderType">
		<xs:annotation>
			<xs:documentation>Invoice Quote Header</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="DocumentId" type="xs:string">
				<xs:annotation>
					<xs:documentation>The unique Identifier assigned to this business transaction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DocumentDateTime" type="xs:dateTime">
				<xs:annotation>
					<xs:documentation>The Date Time at which this service request is created or recorded</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Parties">
				<xs:annotation>
					<xs:documentation>Party Info</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="BillToParty" type="InvoicePartyType" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Bill To Party</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="ShipToParty" type="InvoicePartyType" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Ship To Party</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Freight" type="InvoiceHeaderFreightType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Freight Info</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="SalesContext" type="InvoiceContextType">
				<xs:annotation>
					<xs:documentation>Sales Context that originiated this transaction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="InvoiceQuote" type="InvoiceQuoteType">
				<xs:annotation>
					<xs:documentation>Invoice Quote</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoiceQuoteLineType">
		<xs:annotation>
			<xs:documentation>Quote Line</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="LineNumber" type="xs:nonNegativeInteger">
				<xs:annotation>
					<xs:documentation>A unique Serial Number assigned to the line by the source system.  Each line must have a unique value on a given transaction document.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ParentLineNumber" type="xs:nonNegativeInteger" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Parent Line Number for bundle, ensemble, etc.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="RootLineNumber" type="xs:nonNegativeInteger" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Root Line Number for bundle, ensemble, etc.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="OrderItem" type="InvoiceOrderItemType">
				<xs:annotation>
					<xs:documentation>The Product/Service item information for the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="OrderQuantity" type="QuantityType">
				<xs:annotation>
					<xs:documentation>The Ordered Quantity for the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="UnitPrice" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Unit Price of the Line Item</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:complexContent>
						<xs:extension base="PriceType">
							<xs:sequence>
								<xs:element name="PriceDetails" type="InvoicePriceDetailsType" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Price details</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:sequence>
						</xs:extension>
					</xs:complexContent>
				</xs:complexType>
			</xs:element>
			<xs:element name="LineTotal" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Cost of the Line Item (ExtCurrentCharge + ExtCurrentChargeTax + ExtNetShippingCharge + ExtNetShippingChargeTax + CreditAmount + CreditAmountTax)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Adjustments" type="InvoiceChargeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Adjustment Info</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Tax" type="TaxType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Tax Info for the Line Item.  It includes the freight and sales tax.  Any tax objects supplied on the GetQuote message will be ignored.  The tax object will be returned on the ShowQuote message.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Freight" type="InvoiceFreightType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Freight Info for the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ActionType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Action to be performed on the Line Item.  Specifically, it indicates whether the line item is added, changed, cancelled, refunded, updated, suspended, resumed or deleted.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Add"/>
						<xs:enumeration value="Cancel"/>
						<xs:enumeration value="Delete"/>
						<xs:enumeration value="Refund"/>
						<xs:enumeration value="Resume"/>
						<xs:enumeration value="Suspend"/>
						<xs:enumeration value="Update"/>
						<xs:enumeration value="None"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ActionSubtype" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Action Subtype to be performed on the Line Item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ActionDateTime" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Date Time at which the action was/will be performed</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DocumentReference" type="DocumentReferenceType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Document Reference</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="InvoiceQuoteType">
		<xs:annotation>
			<xs:documentation>Invoice Quote</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="TotalTransaction" type="AmountType">
				<xs:annotation>
					<xs:documentation>Total Transaction Amount.  Total charges (line item price, sales/use tax, freight charge, etc.) - discounts - refunds.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalNRC" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Non-recurring Charge</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalMRC" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Monthly Recurring Charge</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalTax" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Tax Amount.  A sum of the taxes that have been calculated as part of the quotation.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalFreight" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Freight Amount.  A sum of the freight changes that have been calculated as part of the quotation.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalDiscount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Discount Amount.  A sum of the discounts that have been calculated as part of the quotation.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="TotalCredit" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Credit Amount.  A sum of the credit that have been calculated as part of the quotation.  It includes any sales/use tax as well as freight charge refund.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ItemIdType">
		<xs:annotation>
			<xs:documentation>Item Id</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Id">
				<xs:annotation>
					<xs:documentation>Item Id</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:simpleContent>
						<xs:extension base="xs:string">
							<xs:attribute name="schemeName">
								<xs:annotation>
									<xs:documentation>Scheme Name</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:enumeration value="ItemAlias"/>
										<xs:enumeration value="MACS20Byte"/>
										<xs:enumeration value="OracleSKU"/>
										<xs:enumeration value="PIM"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:attribute>
						</xs:extension>
					</xs:simpleContent>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ItemType">
		<xs:annotation>
			<xs:documentation>Item</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ProductClass" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Product class for the item</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ProductLine" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Product Line Name for the Item.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ItemCategory" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A Code used to represent Groups or Categories of Products or Services with similar taxability</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ItemType" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Type of item e.g. Software product vs. Service</xs:documentation>
				</xs:annotation>
			</xs:element>
