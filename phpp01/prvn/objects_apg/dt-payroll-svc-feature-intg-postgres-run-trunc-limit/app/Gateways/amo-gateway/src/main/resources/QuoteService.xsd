	<xs:complexType name="PriceDetailsType">
		<xs:annotation>
			<xs:documentation>Price Details</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="UnitRecurringCharge" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Unit Recurring Charge.  For monthly subscripiton, it is the monthly recurring charge.  For yearly subscription, it is the yearly recurring charge.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedRecurringCharge" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Extended Recurring Charge (Unit Recurring Charge * Qty)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="NRCSubtotal" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>NRC Subtotal (NRC * Qty).  For CPC, this includes the CPC component values</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="MRCSubtotal" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>MRC Subtotal (MRC * Qty).  For CPC, this includes the CPC component values.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="UnitCurrentCharge" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Unit Current Charge after proration to BDOM.  For one-time purchase or no BDOM, it is the same as Unit Price.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedCurrentCharge" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Extended Current Charge (Unit Curent Charge * Qty)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="NetPrice" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Unit item price (either One-Time or Recurring) that includes all the discounts but without proration.   For One-Time, this includes Credit.  For Recurring, the NetPrice does not include Credit.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedNetPrice" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Extended Net Price.  Net Price * Qty.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="OfferingConfigurationPrice" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Offering Configuration Price.  List Price + CPC Adjustment + Attribute Adjustment</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="FinanceListPrice" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Finance List price.  Offering Configuration Price + Customer Price Adjustment (Enttlement Price with Customer Base type).  For VSOE.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="NonPromotionalPrice" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Non-Promotional Price.  For subscription, this is the price that BRM will charge after the promotion ends.  Net Price + Promotional Discount Amount.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ExtendedNonPromotionalPrice" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Extended Non-Promotional Price.  Non-Promotional Price * Qty</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="LineItemTotalDiscount" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Total Line Item Discount.  (Finance List Price - Net Price) *Qty</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CycleForward" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Cycle Forward indicates if the customer will pay for the subscription at the beginning (true) or the end (false) of the billing cycle.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
