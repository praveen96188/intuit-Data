	<xs:complexType name="AccountInfoType">
		<xs:annotation>
			<xs:documentation>Account Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="RefId" type="RefIdType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Reference Id</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Hold" type="xs:boolean">
				<xs:annotation>
					<xs:documentation>This field indicates whether the Party's Account is in a Hold state due to payment, fraud or RPS problems.  This field will only appear on the outgoing message.  If provided on an incoming message, it will be ignored.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AccountStatus" type="xs:string">
				<xs:annotation>
					<xs:documentation>Account Status of the party e.g. Active, Account Hold, Delinquent, Uncollectible, Fraud, or RPS Hold</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AddressInfoType">
		<xs:annotation>
			<xs:documentation>Address Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="AddressId" minOccurs="0">
				<xs:annotation>
					<xs:documentation>A unique Identifier assigned to this Address</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:simpleContent>
						<xs:extension base="xs:string">
							<xs:attribute name="schemeName" use="required">
								<xs:annotation>
									<xs:documentation>Scheme Name</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string"/>
								</xs:simpleType>
							</xs:attribute>
						</xs:extension>
					</xs:simpleContent>
				</xs:complexType>
			</xs:element>
			<xs:element name="AddressType" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Type of Address e.g. PO Box</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AddressLine" type="xs:string" minOccurs="0" maxOccurs="4">
				<xs:annotation>
					<xs:documentation>The Lines of the Address.  The first Address Line is typically the number and street.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="City" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The City of the Address.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="County" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The County of the Address.  The county is used for calculating tax.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="StateOrProvince" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The State or the Province of the address, depending on which is pertinent.  Required for all US addresses.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Country" type="xs:string" default="US" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Country of the Address</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PostalCode" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Postal Code or Zip Code of the address, if applicable.  An extended zip+4 code includes the five digits of the ZIP code, a hyphen, and four more digits that determine a more precise location than the ZIP code alone.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AdjustmentsType">
		<xs:annotation>
			<xs:documentation>Adjustments at the line item level</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Credit" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Credit Adjustments</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:complexContent>
						<xs:extension base="CreditPriceType">
							<xs:sequence>
								<xs:element name="SoftwareConfigurationCredit" type="AmountType" minOccurs="0">
									<xs:annotation>
										<xs:documentation>Software Configuration Credit</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:sequence>
						</xs:extension>
					</xs:complexContent>
				</xs:complexType>
			</xs:element>
			<xs:element name="Discount" type="DiscountPriceType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Discount Adjustments</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Promotion" type="PromotionType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Promotion Adjustments</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Entitlement" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Entitlement-related Adjustments</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="EntitlementPriceAdjustmentAmount" type="AmountType">
							<xs:annotation>
								<xs:documentation>Entitlement Price Adjustment</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Rollup" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Adjustment rollup</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="PricingAdjustmentAmount" type="AmountType">
							<xs:annotation>
								<xs:documentation>EntitlementPriceAdjustmentAmount + UnitPromotionDiscountAmount </xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AmountType">
		<xs:annotation>
			<xs:documentation>Amount</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:decimal">
				<xs:attribute name="currency" use="required">
					<xs:annotation>
						<xs:documentation>Currency in ISO 4217 standard e.g. USD, INR, etc.</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:length value="3"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="AttributeType">
		<xs:annotation>
			<xs:documentation>A collection of attributes</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Name" type="xs:string">
				<xs:annotation>
					<xs:documentation>Attribute Name</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Value" type="xs:string">
				<xs:annotation>
					<xs:documentation>Attribute Value</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="AuthorizationIdType">
		<xs:annotation>
			<xs:documentation>Authorization Id</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="xs:string">
				<xs:attribute name="authType" use="required">
					<xs:annotation>
						<xs:documentation>Auth Type</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:enumeration value="Individual"/>
							<xs:enumeration value="Organization"/>
						</xs:restriction>
					</xs:simpleType>
				</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="BillingCycleType">
		<xs:annotation>
			<xs:documentation>Billing Cycle Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="BillingPeriod" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The period (number of days, weeks, months, or years) for which the bill is generated.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="day"/>
						<xs:enumeration value="week"/>
						<xs:enumeration value="month"/>
						<xs:enumeration value="year"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="BillingFrequency" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The number of billing periods that make up the billing cycle.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:integer">
						<xs:minInclusive value="0"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="NextBillDate" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Next Bill Date</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="BillingDayOfTheMonth" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Billing Day of the Month</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:integer">
						<xs:minInclusive value="1"/>
						<xs:maxInclusive value="31"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="BillingProfileType">
		<xs:annotation>
			<xs:documentation>Billing Profile Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="BillingCycle" type="BillingCycleType">
				<xs:annotation>
					<xs:documentation>Billing Cycle</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="BusinessType">
		<xs:annotation>
			<xs:documentation>Business</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Name" type="xs:string">
				<xs:annotation>
					<xs:documentation>The full Business Name</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="LegalName" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Legal Name of the Business</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Telephone" type="TelephoneType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>The business's telephone number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Fax" type="TelephoneType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The contacts fax number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Type" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Type of Business such as Household, Business or Payroll</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CompanyId" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Company Id that identifies the top-level legal entity for which tax exception may exist.  The Vertex Central User Interface is us used to set up any taxability rules that apply at this level.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DivisionId" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Division Id identifies the mid-level legal entity for which tax exceptions may exist.  The Vertex Central User Interface is us used to set up any taxability rules that apply at this level.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CancellationType">
		<xs:annotation>
			<xs:documentation>Cancellation Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="CancellationDate" type="xs:dateTime" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Cancellation Date</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CancellationReason" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Cancellation Reason</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ContactType">
		<xs:annotation>
			<xs:documentation>Contact</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Type">
				<xs:annotation>
					<xs:documentation>Contact Type (Primary, Billing, Shipping)</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Primary"/>
						<xs:enumeration value="Billing"/>
						<xs:enumeration value="Shipping"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Person" type="PersonType">
				<xs:annotation>
					<xs:documentation>The Person involved in the business transaction</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Telephone" type="TelephoneType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>The Contacts Telephone Number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="EmailAddress" type="xs:string" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>The Contacts Email Address.  This field is not validated, but it is highly recommended to be in the canonical format of aaa@aaaaa.aaa</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Fax" type="TelephoneType" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>The Contacts Fax Number(s).  The canonical format is as follows: [country code][(area code)]number[Ext extension][+#...][(#...)]###...[ Ext #...].  The number portion is required at a minimum, others are optional (but recommended if known).</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="PreferredCorrespondenceMethod" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Party's Preferred Method of Correspondence.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Email"/>
						<xs:enumeration value="Fax"/>
						<xs:enumeration value="Mail"/>
						<xs:enumeration value="Phone"/>
						<xs:enumeration value="SMS"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CreditInfoType">
		<xs:annotation>
			<xs:documentation>Credit Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Hold" type="xs:boolean" minOccurs="0">
				<xs:annotation>
					<xs:documentation>This field indicates whether the Party's Account is in a Hold state due to credit problems.  This field will only appear on the outgoing message.  If provided on an incoming message, it will be ignored.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CreditStatus" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Credit Status of the Party, based on past sales/financial interactions e.g. NSF. There is no default value.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CreditLimit" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Maximum Credit Limit enabled for this party.  If not provided, the default amount will be determined by the back office.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AvailableCredit" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Available Credit a Party has for purchasing products.  If the party has an unpaid balance from aprevious open order, the amount will be reflected on this field.  This field will only appar on the outgoing message.  If provided on an incoming message, it will be ignored.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CollectionStatus" type="xs:string" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Collection Status of the Party, based on most recent sales/financial interactions.  Theer is no default value. </xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="CreditPriceType">
		<xs:annotation>
			<xs:documentation>Credit Price Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="CreditAmount" type="AmountType">
				<xs:annotation>
					<xs:documentation>Credit Amount due to update, modification or migration</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CreditAmountTax" type="AmountType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Tax for the Credit Amount</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="DiscountPriceType">
		<xs:annotation>
			<xs:documentation>Discount Price Info</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:choice>
				<xs:element name="ManualDiscountAmount" type="AmountType">
					<xs:annotation>
						<xs:documentation>Manual Adjustment Amount.  This should not be used for self-service</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="ManualDiscountPercentage" type="xs:decimal">
					<xs:annotation>
						<xs:documentation>Manual Adjustment Percentage.  This should not be used for self-service</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
