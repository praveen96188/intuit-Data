<?xml version="1.0" encoding="UTF-8"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd" xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.intuit.sbg.psp</groupId>
        <artifactId>UI</artifactId>
        <version>2.2.0-SNAPSHOT</version>
    </parent>
    <artifactId>sap</artifactId>
    <packaging>swf</packaging>
    <name>sap</name>
    <properties>
        <incremental>false</incremental>
    </properties>

    <build>
        <sourceDirectory>src/main/flex</sourceDirectory>
        <finalName>SAPApp</finalName>
        <plugins>
            <plugin>
                <groupId>org.sonatype.flexmojos</groupId>
                <artifactId>flexmojos-maven-plugin</artifactId>
                <version>3.2.0</version>
                <extensions>true</extensions>
                <configuration>
                    <includeSources>
                        <param>src/main/flex</param>
                    </includeSources>
                    <showWarnings>false</showWarnings>
                    <configurationReport>true</configurationReport>
                    <contextRoot>/SAP</contextRoot>
                    <services>src/main/resources/services-config.xml</services>
                    <sourceFile>SAPApp.mxml</sourceFile>
                    <incremental>${incremental}</incremental>
                    <targetPlayer>10.0.0</targetPlayer>
                    <!--  <themes>
                        <theme>src/main/resources/global.css</theme>
                    </themes> -->
                    <accessible>false</accessible>
                    <allowSourcePathOverlap>true</allowSourcePathOverlap>
                    <debug>true</debug>
                    <keepAs3Metadatas>
                        <keepAs3Metadata>Bindable</keepAs3Metadata>
                        <keepAs3Metadata>Managed</keepAs3Metadata>
                        <keepAs3Metadata>ChangeEvent</keepAs3Metadata>
                        <keepAs3Metadata>NonCommittingChangeEvent</keepAs3Metadata>
                        <keepAs3Metadata>Transient</keepAs3Metadata>
                        <keepAs3Metadata>BackingProperty</keepAs3Metadata>
                        <keepAs3Metadata>ArrayElementType</keepAs3Metadata>
                    </keepAs3Metadatas>
                    <namespaces>
                        <namespace>
                            <uri>http://www.adobe.com/2006/mxml</uri>
                            <manifest>src/main/resources/mxml-manifest.xml</manifest>
                        </namespace>
                    </namespaces>
                    <optimize>true</optimize>
                    <fonts>
                        <managers>
                            <manager>flash.fonts.JREFontManager</manager>
                            <manager>flash.fonts.BatikFontManager</manager>
                        </managers>
                    </fonts>
                    <metadata>
                        <titles>
                            <title>Adobe Flex 2 Application</title>
                        </titles>
                        <descriptions>
                            <description>http://www.adobe.com/products/flex</description>
                        </descriptions>
                        <publishers>
                            <publisher>unknown</publisher>
                        </publishers>
                        <creator>unknown</creator>
                        <language>EN</language>
                    </metadata>
                    <licenses>
                        <flexbuilder3>1377-4000-3167-0238-7385-4074</flexbuilder3>
                    </licenses>
                </configuration>
                <dependencies>
                    <dependency>
                        <groupId>com.adobe.flex</groupId>
                        <artifactId>license</artifactId>
                        <version>3.2.0.3958</version>
                    </dependency>
                </dependencies>
            </plugin>
        </plugins>
    </build>

    <repositories>
        <repository>
            <id>flex-mojos-repository</id>
            <url>https://artifact.intuit.com/artifactory/SBG.QBO.Intuit-Releases</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </repository>
        <repository>
            <id>flex-mojos-repository-2</id>
            <url>http://repository.sonatype.org/content/groups/flexgroup/</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </repository>
        <repository>
            <id>sonatype-forge</id>
            <url>https://repository.sonatype.org/content/groups/forge/</url>
        </repository>
        <repository>
            <id>servebox</id>
            <url>http://maven.servebox.org/repository/</url>
        </repository>

    </repositories>
    <pluginRepositories>
        <pluginRepository>
            <id>local_flex</id>
            <url>https://artifact.intuit.com/artifactory/SBG.QBO.Intuit-Releases</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </pluginRepository>
        <pluginRepository>
            <id>local_flex_2</id>
            <url>http://repository.sonatype.org/content/groups/flexgroup/</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </pluginRepository>
        <pluginRepository>
            <id>localRepo</id>
            <name>localRepo</name>
            <url>file://${main.dir}</url>
        </pluginRepository>
    </pluginRepositories>

    <dependencies>
        <!--Dependency Read from Maven Repository -->
        <dependency>
            <groupId>com.adobe.flex.framework</groupId>
            <artifactId>datavisualization</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>com.adobe.flex.framework</groupId>
            <artifactId>rpc</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>com.adobe.flex.framework</groupId>
            <artifactId>utilities</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>com.adobe.flex.framework</groupId>
            <artifactId>framework</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>com.adobe.flex.locales.en_US</groupId>
            <artifactId>rpc_rb</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>com.adobe.flex.locales.en_US</groupId>
            <artifactId>framework_rb</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>

        <!--End of Dependency Read from Maven Repository-->

