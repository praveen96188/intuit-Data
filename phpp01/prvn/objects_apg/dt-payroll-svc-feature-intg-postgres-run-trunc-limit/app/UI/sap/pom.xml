        </dependency>
        <dependency>
            <groupId>localRepo.com.adobe.flex.framework</groupId>
            <artifactId>SDK_20349</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>localRepo.com.adobe.flex.framework.mock4AS</groupId>
            <artifactId>mock4as</artifactId>
            <version>1.0</version>
            <type>swc</type>
        </dependency>
        <!--End of Dependency Read from Local Repository-->

        <dependency>
            <groupId>com.adobe.flexunit</groupId>
            <artifactId>flexunit</artifactId>
            <version>0.85</version>
            <type>swc</type>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
