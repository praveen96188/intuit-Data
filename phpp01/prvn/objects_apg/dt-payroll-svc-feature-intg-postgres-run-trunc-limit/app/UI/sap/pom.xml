        <dependency>
            <groupId>localRepo.com.adobe.flex.framework</groupId>
            <artifactId>flexlib</artifactId>
            <version>2.4</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>localRepo.com.adobe.flex.framework</groupId>
            <artifactId>qtp</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>localRepo.com.adobe.flex.framework</groupId>
            <artifactId>automation-agent</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>localRepo.com.adobe.flex.framework</groupId>
            <artifactId>automation-dmv</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>localRepo.com.adobe.flex.framework</groupId>
            <artifactId>automation</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>localRepo.as3commons</groupId>
            <artifactId>reflect</artifactId>
            <version>1.1</version>
            <type>swc</type>
        </dependency>
        <dependency>
            <groupId>localRepo.com.adobe.flex.framework.player</groupId>
            <artifactId>playerglobal</artifactId>
            <version>3.2.0.3958</version>
            <type>swc</type>
        </dependency>
        <dependency>
