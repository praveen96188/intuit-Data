<?xml version="1.0"?>
<mx:VBox xmlns="*"
         xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:pspui="psp.sap.view.*"
         width="100%"
         height="100%"
         creationComplete="onCreationComplete();">
    <mx:Script>
        <![CDATA[
        import psp.sap.application.SAP;
        import psp.sap.model.ACHEnrollmentDetail;
        import psp.sap.viewmodel.ACHEnrollmentsPendingViewModel;
        import psp.app.util.CommonUtil;

        private var mViewModel:ACHEnrollmentsPendingViewModel;
        private var mTempViewModel:ACHEnrollmentsPendingViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():ACHEnrollmentsPendingViewModel {
            return mViewModel;
        }

        public function set viewModel(value:ACHEnrollmentsPendingViewModel):void {
            if (value != null) {
                if (mCreationComplete) {
                    mViewModel = value;
                }
                else {
                    mTempViewModel = value;
                }
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }


        public function showHistory(event:ActionLinkEvent):void {
            viewModel.viewACHHistory(event.data as ACHEnrollmentDetail);
        }

        private function refreshGrid():void {
            viewModel.refresh();
        }

        private function exportResults():void {
            var callString:String = "?report=achEnrollmentReport" +
                    "&statusToFind=PendingEnrollment" +
                    "&token=" + blankIfNull(SAP.instance.session.user.authorizationToken) +
                    "&export=true";

            if(CommonUtil.isDTApp()) {
                CommonUtil.showPrintWindow(callString, "Print");
            } else {
                ExternalInterface.call("showPrintWindow", callString);
            }
        }

        public function blankIfNull(c:*):* {
            return (c == null) ? "" : c;
        }
        ]]>
</mx:Script>
    <mx:VBox width="100%" id="searchResults" paddingTop="0" height="100%"
             styleName="ddDarkGrayMiniBoxStyleOnlyTopPadding">
        <pspui:ACHEnrollmentDataGrid viewModel="{viewModel}" markEnrolledFunction="{viewModel.markAsEnrolled}"/>

        <pspui:ActionLink click="exportResults();" icon="{SAP.instance.icons.exportIcon}" paddingTop="2"
                          labelPlacement="right" label="Export Results"
                          enabled="{viewModel.canExportResults}"/>
    </mx:VBox>
</mx:VBox>
