<?xml version="1.0"?>

<!--
  Created by: mayan
  Description: To Create clear unprocessed request View
  Date: 20/06/2023
 -->
<mx:TitleWindow xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*" close="onClose()"
                showCloseButton="true">
    <mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*"
             xmlns:control="http://www.adobe.com/2006/mxml"
             width="100%" verticalGap="0" creationComplete="onCreationComplete();">


        <mx:Script><![CDATA[
            import mx.controls.Alert;
            import mx.events.CloseEvent;
            import mx.managers.PopUpManager;

            import psp.sap.viewmodel.UnprocessedToProcessedReqViewModel;
            import psp.sap.viewmodel.VMPRealmViewModel;
            import psp.sap.viewmodel.events.ViewModelEvent;
            import psp.sap.viewmodel.events.ViewModelFaultEvent;

            private var mTempViewModel:UnprocessedToProcessedReqViewModel;
            private var mCreationComplete:Boolean = false;
            public var fileRef:FileReference = new FileReference();

            [Bindable]
            private var mViewModel:UnprocessedToProcessedReqViewModel = new UnprocessedToProcessedReqViewModel();

            [Bindable]
            public function get viewModel():UnprocessedToProcessedReqViewModel {
                return mViewModel;
            }

            public function set viewModel(value:UnprocessedToProcessedReqViewModel):void {
                if (mCreationComplete) {
                    mViewModel = value;
                } else {
                    mViewModel = value;
                }
            }

            public function onCreationComplete():void {
                mCreationComplete = true;
                viewModel = mViewModel;
            }

            //If viewModel is closed (currently, if window is closed)
            private function onClose():void {
                PopUpManager.removePopUp(this);
            }

            public function confirmSave():void {
                if (psId.length > 0) {
                    var msgString:String = "Do you want to proceed to clear unprocessed requests?";
                    Alert.show(msgString,
                            "Save Confirmation",
                            Alert.OK | Alert.CANCEL,
                            this,
                            confirmVerifyHandler,
                            null,
                            Alert.OK);
                } else {
                    Alert.show("Company Source Id is mandatory", "Unprocessed to Processed Check Message", null, this);
                }
            }

            private function confirmVerifyHandler(event:CloseEvent):void {
                if (event.detail == Alert.OK) {
                    viewModel.canSave = true;
                    viewModel.save();
                } else if (event.detail == Alert.CANCEL) {
                    Alert.show("Unprocessed Request has been marked as Processed", "Unprocessed to Processed Check Message", null, this);
                }
            }
            ]]></mx:Script>

        <mx:HBox width="100%" height="100%" styleName="expanderBar">

            <mx:VBox id="jobActionDiv" width="35%" styleName="expanderBar">

                <mx:Label text="Clear Unprocessed Requests" paddingLeft="120" styleName="subheading"
                          textAlign="center"/>

                <mx:Form paddingTop="0">

                    <mx:HBox verticalAlign="middle" paddingLeft="20">
                        <controls:RequiredLabel text="PSID:" width="150" horizontalAlign="right"/>
                        <controls:SAPTextInput id="psId" toolTip="Enter company id" width="200"
                                               focusOut="viewModel.fetchCompanyNameAndUnprocessedRequest()"
                                               change="viewModel.clearCompanyName()" tabIndex="1"
                                               restrict="[A-Za-z0-9]"></controls:SAPTextInput>
                    </mx:HBox>
                    <mx:HBox verticalAlign="middle">
                        <mx:Label id="companyUnprocessedRequest" text="{viewModel.companyUnprocessedRequest}" paddingLeft="175"></mx:Label>
                    </mx:HBox>
                    <mx:HBox verticalAlign="middle" paddingLeft="200" paddingTop="10">
                        <mx:Button label="Reset" click="viewModel.clearSourceCompanyId()" width="150"/>
                        <mx:Button label="Process" click="confirmSave()" enabled="{viewModel.canProcess}"
                                   textAlign="center" width="150"/>
                    </mx:HBox>

                </mx:Form>

            </mx:VBox>

        </mx:HBox>

    </mx:VBox>

    <mx:Binding source="psId.text" destination="mViewModel.psId"/>
    <mx:Binding source="mViewModel.psId" destination="psId.text"/>

    <mx:Binding source="companyUnprocessedRequest.text" destination="mViewModel.companyUnprocessedRequest"/>
    <mx:Binding source="mViewModel.companyUnprocessedRequest" destination="companyUnprocessedRequest.text"/>


</mx:TitleWindow>
