<?xml version="1.0" ?>
<mx:VBox xmlns="*"
         xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:pspui="psp.sap.view.*"
         xmlns:controls="psp.sap.view.controls.*" xmlns:view="intuit.sbd.flex.framework.view.*"
         width="100%"
         height="100%"
         creationComplete="onCreationComplete();">
    <mx:Script>
		<![CDATA[
        import mx.core.UIComponent;

        import psp.sap.application.SAP;
        import psp.sap.application.events.SAPEvent;
        import psp.sap.viewmodel.RiskBankAccountSearchViewModel;
        import psp.app.util.CommonUtil;

        [Bindable]
        private var resizeBuffer:int = 0;

        private var mViewModel:RiskBankAccountSearchViewModel;
        private var mTempViewModel:RiskBankAccountSearchViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():RiskBankAccountSearchViewModel {
            return mViewModel;
        }

        public function set viewModel(value:RiskBankAccountSearchViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
                resizeResultsGrid();
            }
            else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;            
        }

        public function resizeResultsGrid():void
        {
            resizeBuffer = mainFilterBox.currentState == "searchCollapsed" ? 283 : 325;
            onGridResize();
        }

        public function onGridResize():void {
            var p:UIComponent = this as UIComponent;

            while (p != null && p.parent != null) {
                if (p.visible && ((p.height - resizeBuffer) > 0)) {
                    searchResultsGrid.results.height = p.height - resizeBuffer;
                }
                else if (p.visible && ((p.explicitHeight - resizeBuffer) > 0)) {
                    searchResultsGrid.results.height = p.explicitHeight - resizeBuffer;
                }
                p = p.parent as UIComponent;
            }
        }

        public function pageDataGridLoadDataFunction():void {
            viewModel.refresh();
        }

        public function exportResults(e:SAPEvent):void {
            var callString:String = "?report=bankAccountSearchReport&" +
                                    "&routingNumber=" + blankIfNull(viewModel.routingNumber) +
                                    "&accountNumber=" + blankIfNull(viewModel.accountNumber) +
                                    "&token=" + blankIfNull(SAP.instance.session.user.authorizationToken) +
                                    "&export=" + true;

            if(CommonUtil.isDTApp()) {
                CommonUtil.showPrintWindow(callString, "Bank_Account_Search.xls");
            } else {
                ExternalInterface.call("showPrintWindow", callString);
            }
        }

        public function blankIfNull(c:*):* {
            return (c == null) ? "" : c;
        }
		]]>
	</mx:Script>

    <!-- width set for 1024x768 -->
    <controls:FilterBox styleName="ddDarkGrayMiniBoxStyleOnlyTopPadding" width="700" id="mainFilterBox"
                        filterStringFunction="{viewModel.getFilterString}"
                        openOnStartup="true"
                        transitionEffectEnd="resizeResultsGrid()"
                        paddingBottom="0" paddingLeft="0" paddingRight="0" paddingTop="0">
        <mx:VBox verticalAlign="bottom" paddingLeft="5">
            <mx:HBox>
                <mx:FormItem label="Routing Number:" labelStyleName="boldText" defaultButton="{filterButton}">
                    <controls:SAPTextInput dataField="routingNumber" width="100" restrict="0-9\-"/>
                </mx:FormItem>
                <mx:FormItem label="Account Number:" labelStyleName="boldText" defaultButton="{filterButton}">
                    <controls:SAPTextInput dataField="accountNumber" width="100"/>
                </mx:FormItem>
                <mx:Button id="filterButton" label="Filter" enabled="{viewModel.canSave}"
                           click="viewModel.search(); mainFilterBox.collapse();"/>
            </mx:HBox>
        </mx:VBox>
    </controls:FilterBox>

    <mx:Spacer height="10"/>

    <pspui:PagingDataGrid
            id="searchResultsGrid"
            width="100%"
            horizontalAlign="right"
            dataProvider="{viewModel.searchResults}"
            height="100%"
            isDataLoading="{viewModel.isDataLoading}"
            loadDataFunction="{pageDataGridLoadDataFunction}"
            paddingBottom="0"
            tabEnabled="false"
            tabChildren="false"
            showExportButton="true"
            export="exportResults(event)">
        <pspui:columns>
            <mx:DataGridColumn
                    minWidth="250"
                    headerText="Legal Name"
                    dataField="companyLegalName"
                    textAlign="left">
                <mx:itemRenderer>
                    <mx:Component>
                        <pspui:ActionLink
                                label="{data.companyLegalName}"
                                click="data.companyKey.display()"
                                data="{data}"/>
                    </mx:Component>
                </mx:itemRenderer>
            </mx:DataGridColumn>
            <mx:DataGridColumn
                    minWidth="110"
                    width="110"
                    headerText="Account Owner{String('\n')}Name"
                    dataField="accountOwnerName"
                    textAlign="left"
                    itemRenderer="mx.controls.Text"/>
            <mx:DataGridColumn
                    minWidth="80"
                    width="80"
                    headerText="Account Type"
                    dataField="accountType"
                    textAlign="left"
                    itemRenderer="mx.controls.Text"/>
            <mx:DataGridColumn
                    minWidth="80"
                    width="80"
                    headerText="Account Status"
                    dataField="accountStatus"
                    textAlign="left"
                    itemRenderer="mx.controls.Text"/>
        </pspui:columns>
    </pspui:PagingDataGrid>

</mx:VBox>

