<?xml version="1.0"?>

<!--
  Created by: smodgil
  Description: To Create Duplication Employee View
  Date:02/08/2019
 -->
<mx:TitleWindow xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*" close="onClose()" showCloseButton="true">
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*"
         xmlns:control="http://www.adobe.com/2006/mxml"
         width="100%" verticalGap="0" creationComplete="onCreationComplete();">



    <mx:Script><![CDATA[
        import mx.controls.Alert;
        import mx.events.CloseEvent;
        import mx.managers.PopUpManager;

        import psp.sap.viewmodel.DupEEViewModel;
        import psp.sap.viewmodel.events.ViewModelEvent;
        import psp.sap.viewmodel.events.ViewModelFaultEvent;

        private var mTempViewModel:DupEEViewModel;
        private var mCreationComplete:Boolean = false;
        public var fileRef:FileReference = new FileReference();

        [Bindable]
        private var mViewModel:DupEEViewModel = new DupEEViewModel();

        [Bindable]
        public function get viewModel():DupEEViewModel {
            return mViewModel;
        }

        public function set viewModel(value:DupEEViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            } else {
                mViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mViewModel;
        }

        //If viewModel is closed (currently, if window is closed)
        private function onClose():void {
            PopUpManager.removePopUp(this);
        }


        public function confirmSave():void {
            if(companyName.text=="EmployeeName: Employee doesn't exist" || oldEmpName.text=="EmployeeName: Employee doesn't exist" || newEmpName.text == "CompanyName: Employee doesn't exist"){
                Alert.show("Unable to proceed as data entered is invalid");
            }else{
                if (oldEmployee.length > 0 && newEmployee.length > 0
                        && psId.length > 0) {
                    var msgString:String = "Do you want to proceed with Duplicate Employee fix?";
                    Alert.show(msgString,
                            "Save Confirmation",
                            Alert.OK | Alert.CANCEL,
                            this,
                            confirmVerifyHandler,
                            null,
                            Alert.OK);
                } else {
                    Alert.show("All fields are mandatory", "DupEE Error Message", null, this);
                }
            }
        }


        private function confirmVerifyHandler(event:CloseEvent):void {
            if (event.detail == Alert.OK) {
                viewModel.canSave = true;
                viewModel.save();
            }
        }
        ]]></mx:Script>

    <mx:HBox width="100%" height="100%" styleName="expanderBar" >

        <mx:VBox id="jobActionDiv" width="35%" styleName="expanderBar" >


            <mx:Label text="Run Duplicate EE Job" paddingLeft="120" styleName="subheading" textAlign="center"/>

            <mx:Form paddingTop="0">

                <mx:HBox verticalAlign="middle" paddingLeft="20">
                    <controls:RequiredLabel text="PSID:" width="150" horizontalAlign="right"/>
                    <controls:SAPTextInput id="psId" toolTip="Enter company id"  width="200" focusOut="viewModel.fetchCompanyName()" change="viewModel.clearCompanyName()"  tabIndex="1"  restrict="[A-Za-z0-9]"></controls:SAPTextInput>

                </mx:HBox>

                <mx:HBox verticalAlign="middle">
                    <mx:Label id="companyName" text="{viewModel.companyName}" paddingLeft="175"></mx:Label>
                </mx:HBox>

                <mx:HBox verticalAlign="middle" paddingLeft="20">
                    <controls:RequiredLabel text="Old Employee:" width="150"  horizontalAlign="right"/>
                    <controls:SAPTextInput id="oldEmployee" width="200" enabled="{viewModel.canEditEmployee}"  toolTip="Enter employee id to deactivate" focusOut="viewModel.fetchOldEmployeeName()" change="viewModel.clearOldEmployeeName()" tabIndex="2"  restrict="[A-Za-z0-9]"></controls:SAPTextInput>
                </mx:HBox>

                <mx:HBox verticalAlign="middle">
                    <mx:Label id="oldEmpName" text="{viewModel.oldEmpName}"  paddingLeft="175"></mx:Label>
                </mx:HBox>

                <mx:HBox verticalAlign="middle" paddingLeft="20">
                    <controls:RequiredLabel text="New Employee:"  width="150" horizontalAlign="right"/>
                    <controls:SAPTextInput id="newEmployee" width="200" enabled="{viewModel.canEditEmployee}"  toolTip="Enter employee id to activate" focusOut="viewModel.fetchNewEmployeeName()" tabIndex="3"  change="viewModel.clearNewEmployeeName()" restrict="[A-Za-z0-9]"></controls:SAPTextInput>
                </mx:HBox>

                <mx:HBox verticalAlign="middle">
                    <mx:Label id="newEmpName" text="{viewModel.newEmpName}" enabled="{viewModel.canEditEmployee}" paddingLeft="175" ></mx:Label>
                </mx:HBox>

                <mx:HBox verticalAlign="middle" paddingLeft="200" paddingTop="10">
                    <mx:Button label="Submit" click="confirmSave()" textAlign="center" width="150"/>
                </mx:HBox>

            </mx:Form>

        </mx:VBox>

    </mx:HBox>

</mx:VBox>

    <mx:Binding source="oldEmployee.text" destination="mViewModel.oldEmployee"/>
    <mx:Binding source="mViewModel.oldEmployee" destination="oldEmployee.text"/>

    <mx:Binding source="newEmployee.text" destination="mViewModel.newEmployee"/>
    <mx:Binding source="mViewModel.newEmployee" destination="newEmployee.text"/>

    <mx:Binding source="psId.text" destination="mViewModel.psId"/>
    <mx:Binding source="mViewModel.psId" destination="psId.text"/>

    <mx:Binding source="oldEmpName.text" destination="mViewModel.oldEmpName"/>
    <mx:Binding source="mViewModel.oldEmpName" destination="oldEmpName.text"/>

    <mx:Binding source="newEmpName.text" destination="mViewModel.newEmpName"/>
    <mx:Binding source="mViewModel.newEmpName" destination="newEmpName.text"/>

    <mx:Binding source="companyName.text" destination="mViewModel.companyName"/>
    <mx:Binding source="mViewModel.companyName" destination="companyName.text"/>

</mx:TitleWindow>
