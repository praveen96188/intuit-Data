<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:pspui="psp.sap.view.*"
         xmlns:controls="psp.sap.view.controls.*">
    <mx:Script>
        <![CDATA[
        import mx.controls.Alert;

        import mx.events.CloseEvent;

        import psp.sap.application.enums.CompanyInspectorPageEnum;
        import psp.sap.viewmodel.EINAddCompanyViewModel;

        [Bindable]
        public var viewModel:EINAddCompanyViewModel;


        private function confirmAdd():void {
            var msgString:String = "Are you sure you want to add this EIN?";

            Alert.show(msgString,
                    "Add Confirmation",
                    Alert.OK | Alert.CANCEL,
                    null,
                    confirmVerifyHandler,
                    null,
                    Alert.OK);
        }

        private function confirmVerifyHandler(e:CloseEvent):void {
            if (e.detail == Alert.OK) {
                viewModel.save();
            }
        }
        ]]>
    </mx:Script>

    <mx:Form paddingLeft="0">
        <mx:FormItem label="License Number">
            <mx:Text text="{viewModel.licenseNumber}"/>
        </mx:FormItem>
        <mx:FormItem label="EOC">
            <mx:Text text="{viewModel.eoc}"/>
        </mx:FormItem>
    </mx:Form>

    <mx:HBox width="100%" height="30" styleName="expanderBar">
        <mx:Label paddingLeft="20" fontWeight="bold" text="Company Information"/>
    </mx:HBox>
    <controls:LoadingBox viewModel="{viewModel}">
        <pspui:CompanyEditLegalInfoPartView id="editCompanyLegalInfoView" paddingLeft="30"
                                            label="{CompanyInspectorPageEnum.COMPANY_LEGAL_INFO}"/>
    </controls:LoadingBox>

    <mx:HBox width="100%" height="30" styleName="expanderBar">
        <mx:Label paddingLeft="20" fontWeight="bold" text="Contact Information"/>
    </mx:HBox>

    <controls:LoadingBox viewModel="{viewModel}">
        <pspui:CompanyEditContactInfoView id="editCompanyContactInfoView" paddingLeft="30"
                                          label="{CompanyInspectorPageEnum.COMPANY_CONTACT_INFO}"/>
    </controls:LoadingBox>

    <mx:VBox paddingBottom="0" paddingLeft="0" paddingRight="0" paddingTop="0" width="100%" height="100%"
             visible="{viewModel.isAssisted}"
             includeInLayout="{viewModel.isAssisted}">
        <mx:Spacer height="10"/>

        <mx:HBox width="100%" height="30" styleName="expanderBar">
            <mx:Label paddingLeft="20" fontWeight="bold" text="Price Type"/>
        </mx:HBox>
        <pspui:CompanyEditPriceType paddingLeft="30" label="{CompanyInspectorPageEnum.PRICE_TYPE}"/>
    </mx:VBox>

    <mx:VBox paddingBottom="0" paddingLeft="0" paddingRight="0" paddingTop="0" width="100%" height="100%"
             visible="{viewModel.canEditSuccessorEntityChange}"
             includeInLayout="{viewModel.canEditSuccessorEntityChange}">
        <mx:Spacer height="10"/>

        <mx:HBox width="100%" height="30" styleName="expanderBar">
            <mx:Label paddingLeft="20" fontWeight="bold" text="Entity Change Info"/>
        </mx:HBox>
        <pspui:EditSuccessorEntityChangeView paddingLeft="30"
                                             label="{CompanyInspectorPageEnum.SUCCESSOR_ENTITY_CHANGE_INFO}"/>
    </mx:VBox>

    <mx:HBox width="100%" horizontalAlign="center">
        <mx:Button label="Cancel" click="viewModel.cancel()"/>
        <mx:Button label="Add" click="confirmAdd()" enabled="{viewModel.canSave}"/>
    </mx:HBox>
</mx:VBox>
