<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*"
         creationComplete="onCreationComplete();"
         minWidth="557"
         verticalGap="0">
    <mx:Script>
        <![CDATA[
        import mx.controls.Alert;
        import mx.events.CloseEvent;
        import mx.events.FlexEvent;
        import mx.validators.Validator;

        import psp.sap.formatters.SAPRateFormatter;

        import psp.sap.model.LawRate;
        import psp.sap.model.QuarterLawRates;
        import psp.sap.viewmodel.EditRatesViewModel;

        private var mViewModel:EditRatesViewModel;
        private var mTempViewModel:EditRatesViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():EditRatesViewModel {
            return mViewModel;
        }

        public function set viewModel(value:EditRatesViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            } else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }

        public function quarterSelectLabelFunction(item:QuarterLawRates):String {
            return item.quarter.label;
        }

        private function confirmSave():void {
            var msgString:String = "Are you sure you want to update these rates?";
            Alert.show(msgString,
                    "Update Rate Confirmation",
                    Alert.YES | Alert.NO,
                    null,
                    function (e:CloseEvent):void {
                        if (e.detail == Alert.YES) {
                            viewModel.save();
                        }
                    },
                    null,
                    Alert.YES);
        }

        private function onInputCreationComplete(event:FlexEvent):void {
            var target:TextInput = TextInput(event.currentTarget);
            if (target.parent == null) {
                return;  //the old ones seem to be sticking around for some reason
            }
            Validator(viewModel.validators[target.repeaterIndex]).listener = target;
        }
        ]]>
    </mx:Script>

    <mx:Label text="Edit Rates for {viewModel.paymentTemplate.getSimplifiedName()}"
              styleName="headerBorder" id="headerLabel" paddingLeft="2" paddingBottom="0"
              paddingTop="5"/>

    <mx:Text text="Rates cannot be changed since selected quarter is under blackout or missed cutoff."
             visible="{viewModel.selectedQuarterLawRate != null &amp;&amp; viewModel.selectedQuarterLawRate.underBlackout &amp;&amp; !viewModel.allowUpdateDuringBlackout}"
             styleName="errorMessageStyle"
             paddingTop="0"
             paddingBottom="0"/>

    <mx:HBox verticalAlign="middle" paddingBottom="3">
        <mx:Label text="Quarter: " styleName="boldText"/>
        <controls:SAPComboBox dataField="selectedQuarterLawRate"
                              dataProvider="{viewModel.quarterLawRates}"
                              labelFunction="quarterSelectLabelFunction"
                              enabled="{viewModel.userCanEditNonCurrentQuarter}"/>
        <mx:LinkButton label="Edit multiple quarters"
                       visible="{viewModel.userHasRateSuperPermissions}"
                       includeInLayout="{viewModel.userHasRateSuperPermissions}"
                       styleName="inlineLinkButtonStyle"
                       paddingBottom="0"
                       click="viewModel.editMultipleRates();"/>
    </mx:HBox>
    <mx:Grid paddingBottom="3">
        <mx:GridRow>
            <mx:GridItem>
                <mx:Label text="Law" styleName="boldText"/>
            </mx:GridItem>
            <mx:GridItem>
                <mx:Label text="Selected Value" styleName="boldText"/>
            </mx:GridItem>
            <mx:GridItem>
                <mx:Label text="New Value" styleName="boldText"/>
            </mx:GridItem>
        </mx:GridRow>
        <mx:Repeater id="lawRateRepeater" dataProvider="{viewModel.selectedQuarterLawRate.lawRates}">
            <mx:GridRow>
                <mx:GridItem>
                    <mx:Label text="{LawRate(lawRateRepeater.currentItem).law.name}"/>
                </mx:GridItem>
                <mx:GridItem>
                    <mx:Label text="{LawRate(lawRateRepeater.currentItem).hasCurrentRate ? SAPRateFormatter.formatPercentage(LawRate(lawRateRepeater.currentItem).currentPercentage) : ''}"/>
                </mx:GridItem>
                <mx:GridItem>
                    <mx:TextInput width="90"
                                  restrict="-0-9."
                                  text="{LawRate(lawRateRepeater.currentItem).newPercentageText}"
                                  change="LawRate(TextInput(event.currentTarget).getRepeaterItem()).newPercentageText = (TextInput(event.currentTarget).text)"
                                  creationComplete="onInputCreationComplete(event)"/>
                    <mx:Label text="%"/>
                </mx:GridItem>
            </mx:GridRow>
        </mx:Repeater>
    </mx:Grid>

    <mx:VBox visible="{viewModel.userHasRateSuperPermissions}"
             includeInLayout="{viewModel.userHasRateSuperPermissions}">
        <controls:SAPCheckBox label="Push to QuickBooks" dataField="pushToQuickBooks"/>
        <controls:SAPCheckBox label="Allow update during blackout" dataField="allowUpdateDuringBlackout" visible="false" includeInLayout="false" /> <!-- Not yet implemented-->
        <controls:SAPCheckBox label="Allow rates outside of boundaries" dataField="allowUpdateOutsideOfBoundaries"/>
    </mx:VBox>

    <mx:HBox horizontalAlign="right" width="500">
        <mx:Button id="cancelButton" label="Cancel" click="viewModel.cancel()"/>
        <mx:Button id="saveButton" label="Save" click="confirmSave()" enabled="{viewModel.canSave}"/>
    </mx:HBox>



</mx:VBox>
