<?xml version="1.0" encoding="utf-8"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:controls="psp.sap.view.controls.*"
         width="100%" height="100%"
         creationComplete="onCreationComplete()">

    <mx:Script>
		<![CDATA[
        import mx.controls.Alert;
        import mx.events.CloseEvent;
        import mx.managers.PopUpManager;
        import mx.utils.StringUtil;

        import psp.sap.application.SAP;
        import psp.sap.application.enums.OperationsEnum;

        import psp.sap.viewmodel.CompanyQuickBooksInfoEditViewModel;

        private const COLUMN_1_WIDTH:int = 225;
        private const COLUMN_2_WIDTH:int = 350;

        private var mViewModel:CompanyQuickBooksInfoEditViewModel;
        private var mTempViewModel:CompanyQuickBooksInfoEditViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():CompanyQuickBooksInfoEditViewModel {
            return mViewModel;
        }

        public function set viewModel(value:CompanyQuickBooksInfoEditViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            }
            else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }

        private var popup:CaseIdSave;

        // method to open the PopUp Window on creationComplete
        private function openPopUpWindow():void {
            // open the PopUp Window as a modal popup window
            // and store it in a variable for later use
            popup = PopUpManager.createPopUp(this, CaseIdSave, true) as CaseIdSave;
            popup.heading.label = "Are you sure you want to edit this company's Quickbooks Chart Of Accounts info? If yes please provide caseId";
            popup.addEventListener("close", removeMe);
            popup.cancel.addEventListener("click", removeMe);
            popup.save.addEventListener("click", submitData);
            PopUpManager.centerPopUp(popup);

        }

        private function removeMe(event:Event):void {
            PopUpManager.removePopUp(popup);
        }

        private function submitData(event:Event):void {
            if (popup.caseIdInput.text == null || StringUtil.trim(popup.caseIdInput.text) == "") {
                popup.caseIdMandatoryItem.visible = true;
            } else {
                viewModel.caseId = popup.caseIdInput.text;
                PopUpManager.removePopUp(popup);
                viewModel.save();
            }
        }

        private function confirmSave():void {
            if (viewModel.fileIdInitially!=viewModel.quickbooksInfo.fileId) {
                openPopUpWindow()
            } else {
                var msgString:String = "Are you sure you want to edit this company's Quickbooks Chart Of Accounts info?";

                Alert.show(msgString,
                        "Save Confirmation",
                        Alert.OK | Alert.CANCEL,
                        this,
                        confirmVerifyHandler,
                        null,
                        Alert.OK);
            }
        }

        private function confirmClearVmp():void {
            var msgString:String = "Are you sure you want to clear all vmp paystub data?";

            Alert.show(msgString,
                    "VMP clear Confirmation",
                    Alert.OK | Alert.CANCEL,
                    this,
                    confirmVmpVerifyHandler,
                    null,
                    Alert.OK);
        }


        private function confirmVmpVerifyHandler(evt_obj:CloseEvent):void {
            if (evt_obj.detail == Alert.OK) {
                viewModel.clearVmpData();
            }
        }

        private function confirmVerifyHandler(evt_obj:CloseEvent):void {
            if (evt_obj.detail == Alert.OK) {
                viewModel.save();
            }
        }
        ]]>
    </mx:Script>

    <mx:HBox>
        <mx:Label text="Registration #:" styleName="fieldLabel" width="{COLUMN_1_WIDTH}"/>
        <mx:Text text="{viewModel.quickbooksInfo.licenseNumber}"/>
    </mx:HBox>

    <mx:HBox>
        <mx:Label text="Version #:" styleName="fieldLabel" width="{COLUMN_1_WIDTH}"/>
        <mx:Text text="{viewModel.quickbooksInfo.applicationVersion}"
                 color="{viewModel.isDiscoing ? 0xFF0000 : 0x000000}"
                 toolTip="{viewModel.isDiscoing ? 'Company\'s version of Quickbooks is being discontinued or has been discontinued. \'' + viewModel.minSupportedQBVersion + '\' is the minimum supported version' : ''}"/>
    </mx:HBox>

    <mx:HBox>
        <mx:Label text="Tax Table #:" styleName="fieldLabel" width="{COLUMN_1_WIDTH}"/>
        <mx:Text text="{viewModel.quickbooksInfo.taxTable}"/>
    </mx:HBox>

    <mx:HBox>
        <controls:RequiredLabel
                dataField="coFeeCOA"
                text="Fee Chart of Accounts:"
                styleName="fieldLabel"
                width="{COLUMN_1_WIDTH}"/>
        <controls:SAPTextInput dataField="quickbooksInfo.coaFeeAccountName"
                               maxChars="50"
                               width="{COLUMN_2_WIDTH}"
                               enabled="{SAP.canPerformOperation(OperationsEnum.EDIT_CHART_OF_ACCOUNTS)}"/>
    </mx:HBox>

    <mx:HBox>
        <controls:RequiredLabel
                dataField="coSalesTaxCOA"
                text="Sales Tax Chart of Accounts:"
                styleName="fieldLabel"
                width="{COLUMN_1_WIDTH}"/>
        <controls:SAPTextInput dataField="quickbooksInfo.coaSalesTaxAccountName"
                               maxChars="50"
                               width="{COLUMN_2_WIDTH}"
                               enabled="{SAP.canPerformOperation(OperationsEnum.EDIT_CHART_OF_ACCOUNTS)}"/>
    </mx:HBox>

    <mx:HBox>
        <mx:Label text="File ID:" styleName="fieldLabel" width="{COLUMN_1_WIDTH}"/>
        <controls:SAPTextInput dataField="quickbooksInfo.fileId"
                               maxChars="50"
                               width="{COLUMN_2_WIDTH}"
                               change="viewModel.onFileIdChanged();"
                               enabled="{SAP.canPerformOperation(OperationsEnum.EDIT_QB_FILE_ID)}"/>
        <mx:Button id="clearVmpButton" label="Clear VMP Data" click="confirmClearVmp()"
                   enabled="{SAP.canPerformOperation(OperationsEnum.EDIT_QB_FILE_ID)}"
                   visible="{viewModel.isOnVmpService()}"/>

    </mx:HBox>

    <mx:HBox paddingLeft="25">
        <mx:Label text="Select existing File ID" styleName="fieldLabel" width="{COLUMN_1_WIDTH}"/>
        <controls:SAPComboBox dataField="selectedFileId"
                              dataProvider="{viewModel.fileIds}"
                              labelField="label"
                              width="450"
                              enabled="{SAP.canPerformOperation(OperationsEnum.EDIT_QB_FILE_ID)}"/>
    </mx:HBox>

    <mx:Spacer height="10"/>

    <mx:HBox horizontalAlign="right" width="100%">
        <mx:Button id="cancelButton" label="Cancel" click="viewModel.cancel()"/>
        <mx:Button id="saveButton" label="Save" click="confirmSave()" enabled="{viewModel.canSave}"/>
    </mx:HBox>

</mx:VBox>
