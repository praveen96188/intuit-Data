<?xml version="1.0" encoding="utf-8"?>
<mx:Application 
	xmlns:mx="http://www.adobe.com/2006/mxml" 
	layout="absolute"
	paddingTop="20"
	paddingBottom="20"
	paddingLeft="20"
	paddingRight="20"
	creationComplete="doCreationComplete()">
	
	<mx:Script>
		<![CDATA[
			import mx.managers.PopUpManager;
			import test.generation.BedlReader;
			
			private var mPanelWidth:Number;
			private var mPanelHeight:Number;
			
			[Bindable]
			public var bedlReader:BedlReader;
			
			private function generateEnumerations():void {
				bedlReader = new BedlReader(bedlArea.text);
				bedlReader.processXML();
				removePopup();
			}
			
			private function generateEnumeration():void {
				var retText:String = bedlReader.generateEnumeration(enumList.selectedItem as String);
				textArea.text = retText;
			}
			
			private function doCreationComplete():void {
				panelWidth = screen.width / 2;
				panelHeight = screen.height / 2;
			}
			
			private function popupPasteBEDL():void {
				BEDLPastePanel.visible = true;
				PopUpManager.addPopUp(BEDLPastePanel, this, true);
				PopUpManager.centerPopUp(BEDLPastePanel);
			}
			
			private function removePopup():void {
				PopUpManager.removePopUp(BEDLPastePanel);
			}
			
			[Bindable]
			public function get panelWidth():Number {
				return mPanelWidth;
			}
			
			public function set panelWidth(value:Number):void {
				mPanelWidth = value;
			}

			[Bindable]
			public function get panelHeight():Number {
				return mPanelHeight;
			}
			
			public function set panelHeight(value:Number):void {
				mPanelHeight = value;
			}
		]]>
	</mx:Script>
	<mx:VBox width="50%" height="50%" includeInLayout="false">
		<mx:Panel id="BEDLPastePanel" label="Paste BEDL in." width="{panelWidth}" height="{panelHeight}" visible="false">	
			<mx:HBox>
				<mx:Label text="Paste BEDL text below:" fontWeight="bold"/>
			</mx:HBox>
			
			<mx:TextArea id="bedlArea" height="100%" width="100%"/>
			
			<mx:HBox>			
				<mx:Button label="Load BEDL" click="generateEnumerations()"/>
				<mx:Spacer width="10"/>
				<mx:Button label="Close" click="removePopup()"/>
			</mx:HBox>
		</mx:Panel>	
	</mx:VBox>
	
	<mx:VBox 
		height="100%" 
		width="100%"
		paddingTop="20"
		paddingBottom="20"
		paddingLeft="20"
		paddingRight="20"
		verticalGap="0">			
		<mx:HBox backgroundColor="white" width="100%" 
			paddingTop="5" 
			paddingBottom="5"
			paddingLeft="5"
			paddingRight="5">
			<mx:Button label="Load BEDL" click="popupPasteBEDL()"/>
		</mx:HBox>
		<mx:VBox 
			height="100%" 
			width="100%" 
			backgroundColor="#F4F4F4"
			paddingTop="5" 
			paddingBottom="5"
			paddingLeft="5"
			paddingRight="5">
			<mx:Label text="BEDL Enumeration Generator" fontWeight="bold"/>
			<mx:HBox width="100%" height="100%">
				<mx:VBox width="250">
				<mx:List id="enumList" dataProvider="{bedlReader.enumKeys}" width="100%">
					
				</mx:List>
				<mx:Button label="Generate Enum" click="generateEnumeration()"/>
				</mx:VBox>
				<mx:TextArea id="textArea" height="100%" width="100%"/>
			</mx:HBox>
			
		</mx:VBox>
	</mx:VBox>	
</mx:Application>
