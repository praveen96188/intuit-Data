<?xml version="1.0"?>
<mx:VBox
        xmlns:pspui="psp.sap.view.*"
        xmlns="*" xmlns:mx="http://www.adobe.com/2006/mxml"
        width="100%" height="100%">
    <mx:Script>
        <![CDATA[
        import psp.sap.model.VMPEmployeeInfo;
        import psp.sap.viewmodel.VMPEmployeeListViewModel;

        private var mViewModel:VMPEmployeeListViewModel;

        [Bindable]
        public function get viewModel():VMPEmployeeListViewModel {
            return mViewModel;
        }

        public function set viewModel(value:VMPEmployeeListViewModel):void {
            if (value != null) {
                mViewModel = value;
            }
        }

        public function viewVMPEmployeeInfo(link:ActionLinkEvent):void {
            viewModel.viewVMPEmployeeInfo(link.data as VMPEmployeeInfo);
        }

        ]]>
    </mx:Script>

    <mx:VBox styleName="standardTabbedBody" width="100%" verticalGap="0" paddingBottom="0">

        <mx:Spacer height="10"/>
        <!--No Result-->
        <mx:VBox visible="{!viewModel.isDataLoading &amp;&amp; viewModel.employeesSearchResult.length == 0}"
                 includeInLayout="{!viewModel.isDataLoading &amp;&amp; viewModel.employeesSearchResult.length == 0}"
                 verticalGap="0" width="70%" height="30"
                 verticalAlign="middle" horizontalAlign="center" backgroundColor="#b7b7b7" borderStyle="none"
                 color="#000000" fontWeight="normal" dropShadowEnabled="false" paddingTop="10">
            <mx:Text id="noDataFoundText" text="No employees found."/>
        </mx:VBox>
        <!--Search Result-->
        <pspui:PagingDataGrid dataProvider="{viewModel.employeesSearchResult}"
                              visible="{!viewModel.isDataLoading &amp;&amp; viewModel.employeesSearchResult.length > 0}"
                              includeInLayout="{!viewModel.isDataLoading &amp;&amp; viewModel.employeesSearchResult.length > 0}"
                              textAlign="center"
                              rowCount="{viewModel.employeesSearchResult.pageSize}"
                              maxRows="{viewModel.employeesSearchResult.pageSize}"
                              width="100%"
                              fixWidths="true"
                              paddingRight="10"
                              paddingBottom="0"
                              horizontalAlign="right"
                              verticalGap="0"
                              isDataLoading="{viewModel.isDataLoading}"
                              loadDataFunction="{viewModel.pageDataGridLoadDataFunction}">
            <pspui:columns>
                <mx:DataGridColumn
                        headerText="Employee Name"
                        dataField="fullNameForward"
                        width="100">
                    <mx:itemRenderer>
                        <mx:Component>
                            <mx:VBox width="100%"
                                     horizontalAlign="left"
                                     verticalGap="0"
                                     paddingTop="0"
                                     paddingBottom="0"
                                     verticalScrollPolicy="off"
                                     horizontalScrollPolicy="off">
                                <pspui:ActionLink
                                        paddingTop="0"
                                        paddingBottom="0"
                                        label="{VMPEmployeeInfo(data).fullNameForward}"
                                        action="{VMPEmployeeInfo(data).fullNameForward}"
                                        actionClick="outerDocument.viewVMPEmployeeInfo"
                                        data="{data}"/>
                                <mx:Script><![CDATA[
                                    import psp.sap.model.VMPEmployeeInfo;
                                    ]]></mx:Script>
                            </mx:VBox>
                        </mx:Component>
                    </mx:itemRenderer>
                </mx:DataGridColumn>
                <mx:DataGridColumn
                        headerText="SSN"
                        dataField="socialSecurityNumber"
                        width="84"/>
                <mx:DataGridColumn
                        headerText="Email"
                        dataField="emailAddress"
                        width="42"
                        sortable="false"/>
                <mx:DataGridColumn
                        headerText="User ID"
                        dataField="userId"
                        width="42"
                        sortable="false"/>
                <mx:DataGridColumn
                        headerText="Consumer ID"
                        dataField="consumerId"
                        width="76"/>
            </pspui:columns>
        </pspui:PagingDataGrid>

    </mx:VBox>
</mx:VBox>
