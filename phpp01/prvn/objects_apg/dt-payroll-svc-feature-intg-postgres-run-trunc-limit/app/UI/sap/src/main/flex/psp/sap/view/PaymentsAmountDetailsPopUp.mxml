<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:pspui="psp.sap.view.*"
         xmlns:controls="psp.sap.view.controls.*"
         width="760"
         creationComplete="onCreationComplete();"
         verticalGap="0"
         paddingLeft="5"
         paddingRight="5">
    <mx:Script>
        <![CDATA[

        import mx.controls.dataGridClasses.DataGridColumn;

        import psp.sap.formatters.SAPCurrencyFormatters;
        import psp.sap.formatters.SAPDateFormatters;
        import psp.sap.model.Payment;
        import psp.sap.viewmodel.PaymentsAmountDetailsViewModel;
        import psp.sap.viewmodel.PaymentsHoldsHistoryViewModel;

        private var mViewModel:PaymentsAmountDetailsViewModel;
        private var mTempViewModel:PaymentsAmountDetailsViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():PaymentsAmountDetailsViewModel {
            return mViewModel;
        }

        public function set viewModel(value:PaymentsAmountDetailsViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            }
            else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }

        public function getFormattedDate(item:Object, column:DataGridColumn):String {
            return SAPDateFormatters.dateFormatMedium.format(item[column.dataField]);
        }
        public function getCurrency(item:Object, column:DataGridColumn):String {
            return SAPCurrencyFormatters.defaultFormatter.format(item[column.dataField]);
        }
        ]]>
    </mx:Script>
    <mx:Label text="Payment Amount Details" styleName="heading" id="headerLabel" paddingLeft="2" paddingBottom="3"
              paddingTop="5"/>
    <mx:HRule width="100%" height="13"/>

    <mx:HBox height="10"/>
    <mx:HBox>
        <mx:VBox verticalGap="0">
            <mx:Label text="EIN: " fontWeight="bold"/>
            <mx:Label text="Legal Name: " fontWeight="bold"></mx:Label>
            <mx:Label text="PSID: " fontWeight="bold"></mx:Label>
            <mx:Label text="Settlement Date:" fontWeight="bold" paddingLeft="0"/>
        </mx:VBox>

        <mx:VBox verticalGap="0">
            <mx:Label text="{Payment(viewModel.payment).ein}"/>
            <mx:Label text="{Payment(viewModel.payment).companyName}"/>
            <mx:Label text="{Payment(viewModel.payment).psId}"/>
            <mx:HBox>
                <mx:Label text="{SAPDateFormatters.dateFormatMedium.format(Payment(viewModel.payment).settlementDate)}"/>
                <mx:Label text="Due Date:" fontWeight="bold" paddingLeft="10"></mx:Label>
                <mx:Label text="{SAPDateFormatters.dateFormatMedium.format(Payment(viewModel.payment).dueDate)}" paddingLeft="-10"/>
                <mx:Label text="Payment Template:" fontWeight="bold" paddingLeft="10"></mx:Label>
                <mx:Label text="{Payment(viewModel.payment).paymentType}" paddingLeft="-10"/>
            </mx:HBox>
        </mx:VBox>
    </mx:HBox>
    <mx:HBox height="10"/>

    <controls:SAPDataGrid id="statusChangesGrid"   maxRows="10"
                          dataProvider="{viewModel.paymentDetails}"
                          width="100%" selectable="false">
        <controls:columns>
            <mx:DataGridColumn sortable="true"
                               headerText="Created Date"
                               width="50"
                               dataField="createdDate"
                               itemRenderer="mx.controls.Text"
                               paddingLeft="5"
                               labelFunction="getFormattedDate"
                               draggable="false" />
            <mx:DataGridColumn sortable="false"
                               headerText="Check date"
                               width="50"
                               dataField="checkDate"
                               itemRenderer="mx.controls.Text"
                               paddingLeft="5"
                               labelFunction="getFormattedDate"
                               draggable="false"/>
            <mx:DataGridColumn sortable="false"
                               headerText="Amount"
                               width="50"
                               dataField="amount"
                               labelFunction="getCurrency"
                               itemRenderer="mx.controls.Text"
                               paddingLeft="5"
                               draggable="false"/>
            <mx:DataGridColumn sortable="false"
                               headerText="Law"
                               width="50"
                               dataField="law"
                               itemRenderer="mx.controls.Text"
                               paddingLeft="5"
                               draggable="false"/>
            <mx:DataGridColumn sortable="false"
                               headerText="Txn Type"
                               width="50"
                               dataField="txnType"
                               itemRenderer="mx.controls.Text"
                               paddingLeft="5"
                               draggable="false"/>
        </controls:columns>
    </controls:SAPDataGrid>
    <mx:HBox height="5"/>
    <mx:HBox width="100%" horizontalAlign="center">
        <mx:Label text="Total Payment " fontWeight="bold" ></mx:Label>
        <mx:Label text="{SAPCurrencyFormatters.defaultFormatter.format(viewModel.payment.amount)}" fontWeight="bold"/>
    </mx:HBox>
    <mx:HBox height="5"/>
</mx:VBox>
