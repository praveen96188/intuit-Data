<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:controls="psp.sap.view.controls.*"
         creationComplete="onCreationComplete();"
         verticalGap="0"
         paddingLeft="5"
         paddingRight="5">
    <mx:Script>
        <![CDATA[
        import psp.sap.application.SAP;
        import psp.sap.application.enums.OperationsEnum;
        import psp.sap.model.ACHEnrollmentHistoryItem;
        import psp.sap.viewmodel.ACHEnrollmentHistoryViewModel;

        private var mViewModel:ACHEnrollmentHistoryViewModel;
        private var mTempViewModel:ACHEnrollmentHistoryViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():ACHEnrollmentHistoryViewModel {
            return mViewModel;
        }

        public function set viewModel(value:ACHEnrollmentHistoryViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            }
            else {
                mTempViewModel = value;
            }
        }

        public function deleteEnrollment(event:Event):void {
            viewModel.deleteEnrollment(ACHEnrollmentHistoryItem(Button(event.target).getRepeaterItem()).enrollmentId);
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }
        ]]>
    </mx:Script>
    <mx:Label text="ACH Enrollment History" styleName="heading" id="headerLabel" paddingLeft="2" paddingBottom="3"
              paddingTop="5"/>
    <mx:Button label="Initiate Re-enrollment"
               click="viewModel.initiateReEnrollment()"
               paddingLeft="4"
               visible="{viewModel.canSave}"
               includeInLayout="{viewModel.canSave}"
               enabled="{SAP.canPerformOperation(OperationsEnum.MANAGE_RAF_ENROLLMENT)}"/>
    <mx:HBox height="10"/>

    <mx:Repeater id="enrollmentsRepeater" dataProvider="{viewModel.enrollments}">
        <mx:HRule width="100%" height="13"/>
        <mx:HBox>
            <mx:VBox verticalGap="0">
                <mx:HBox>
                    <mx:Label text="EIN: " fontWeight="bold"/>
                    <mx:Label text="{ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).ein}"
                              paddingLeft="5"/>
                </mx:HBox>
                <mx:HBox>
                    <mx:Label text="Legal Name: " fontWeight="bold"></mx:Label>
                    <mx:Label text="{ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).legalName}"/>
                </mx:HBox>
                <mx:HBox>
                    <mx:Label text="Agency ID: " fontWeight="bold"/>
                    <mx:Label text="{ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).agencyId}"
                              paddingLeft="5"/>
                </mx:HBox>
                <mx:HBox visible="{(ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).rejectedReason) != null}"
                         includeInLayout="{(ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).rejectedReason) != null}">
                    <mx:Label text="Status:" fontWeight="bold"/>
                    <mx:Label text="{ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).rejectedReason}"
                              paddingLeft="5" fontWeight="bold"/>
                </mx:HBox>
            </mx:VBox>
            <mx:Spacer width="180"/>
            <mx:Button label="Delete" click="{deleteEnrollment(event)}"
                       enabled="{SAP.canPerformOperation(OperationsEnum.MANAGE_RAF_ENROLLMENT)}"
                       visible="{ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).canDelete}"
                       includeInLayout="{ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).canDelete}"/>
        </mx:HBox>
        <controls:SAPDataGrid
                dataProvider="{ACHEnrollmentHistoryItem(enrollmentsRepeater.currentItem).statusChanges}"
                width="550"
                maxRows="5"
                selectable="false"
                draggableColumns="false">
            <controls:columns>
                <mx:DataGridColumn headerText="Change Date"
                                   width="100"
                                   dataField="changeDate"
                                   itemRenderer="mx.controls.Text"
                                   paddingLeft="5"
                                   labelFunction="SAPDataGrid.formatDateTimeMedium"/>
                <mx:DataGridColumn headerText="Status"
                                   dataField="status"
                                   itemRenderer="mx.controls.Text"
                                   paddingLeft="5"/>
                <mx:DataGridColumn headerText="Modified By"
                                   width="230"
                                   dataField="modifiedBy"
                                   itemRenderer="mx.controls.Text"
                                   paddingLeft="5"/>
            </controls:columns>
        </controls:SAPDataGrid>
    </mx:Repeater>
</mx:VBox>
