<?xml version="1.0" encoding="utf-8"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:pspui="psp.sap.view.*"
         width="100%"
         height="100%">

    <mx:Script>
		<![CDATA[
			import psp.sap.viewmodel.PayrollSettlementViewModel;
            import mx.events.CloseEvent;
            import mx.controls.Alert;
            import psp.sap.model.SettlementTypeEnum;
            import psp.sap.model.SettlementType;
            import psp.sap.application.SAP;

            [Bindable]
            public var showSettlementType:Boolean = true;

            [Bindable]
            public var showSettlementDate:Boolean = true;

            [Bindable]
            public var showAmount:Boolean = true;

            [Bindable]
            public var saveConfirmationMessage:String = "Are you sure you want to issue a refund for this transaction?";

            private var mViewModel:PayrollSettlementViewModel;


            [Bindable]
            public function get viewModel():PayrollSettlementViewModel {
                return mViewModel;
            }

            public function set viewModel(value:PayrollSettlementViewModel):void {
                if(value != null) {
                    mViewModel = value;
                }
            }

            public function save():void {
                Alert.show(	saveConfirmationMessage,
                        SAP.instance.applicationTitle,
                        Alert.OK | Alert.CANCEL,
                        this,
                        function(e:CloseEvent):void {
                            if(e.detail == Alert.OK) {
                                viewModel.save();
                            }
                        },
                        null,
                        Alert.OK);
            }
        ]]>
	</mx:Script>
	
	<pspui:ActionLink 
			    	label="Go to Company Payroll Transactions" 
			    	click="viewModel.goToPayrollTransactions()" 
			    	paddingTop="10" paddingLeft="0" 
			    	tabEnabled="false"/>

    <pspui:PayrollSettlementView
            id="payrollSettlementView"
            width="100%"
            showSettlementType="{showSettlementType}"
            showAmount="{showAmount}"
            showSettlementDate="{showSettlementDate}"
            viewModel="{this.viewModel}" styleName="standardTabbedBody"/>

    <mx:Spacer height="5"/>

    <mx:HBox horizontalAlign="right" width="400">
        <mx:Button id="cancelButton" label="Cancel" click="viewModel.cancel()"/>
        <mx:Button id="saveButton" label="Save" click="save()" enabled="{viewModel.canSave}" width="{cancelButton.width}"/>
    </mx:HBox>

</mx:VBox>
