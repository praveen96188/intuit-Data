<?xml version="1.0"?><!--  Created by anandp233 on 2/11/14.--><mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*"         xmlns:control="http://www.adobe.com/2006/mxml"         width="100%" verticalGap="0" creationComplete="onCreationComplete();">    <mx:Script><![CDATA[        import mx.controls.Alert;        import psp.sap.viewmodel.DecryptTextViewModel;        private var mViewModel:DecryptTextViewModel;        private var mTempViewModel:DecryptTextViewModel;        private var mCreationComplete:Boolean = false;        [Bindable]        public function get viewModel():DecryptTextViewModel {            return mViewModel;        }        public function set viewModel(value:DecryptTextViewModel):void {            if (mCreationComplete) {                mViewModel = value;            }            else {                mTempViewModel = value;            }        }        public function onCreationComplete():void {            mCreationComplete = true;            viewModel = mTempViewModel;        }        private function copyToClipBoard():void {            System.setClipboard(decryptedText.text);        }        private function confirmSave():void {            if (encryptedText != null && encryptedText.text != null && encryptedText.text.length > 0) {                viewModel.encryptedText = encryptedText.text;                viewModel.decryptedText = ""; //clear the old decryptedText before we decrypt the new text                viewModel.decryptText();            } else {                Alert.show("Please enter your text to be decrypted.");            }        }        ]]></mx:Script>    <mx:HBox width="100%">        <mx:Label text="Decrypt your text here :" styleName="subheading"/>        <mx:Form paddingTop="30" textAlign="left">            <mx:HBox paddingTop="30">                <mx:VBox paddingLeft="20">                    <controls:RequiredLabel text="Enter your encrypted text"/>                    <mx:TextArea id="encryptedText" editable="true" text="{viewModel.encryptedText}" height="200" width="500"></mx:TextArea>                    <mx:Button label="Decrypt" click="confirmSave()"/>                </mx:VBox>                <mx:VBox paddingLeft="20">                    <mx:Label text="Decrypted text"/>                    <mx:TextArea id="decryptedText" editable="false" text="{viewModel.decryptedText}" height="200" width="500"></mx:TextArea>                    <mx:Button label="Copy to Clip Board"  click="copyToClipBoard()"/>                </mx:VBox>            </mx:HBox>        </mx:Form>    </mx:HBox></mx:VBox>