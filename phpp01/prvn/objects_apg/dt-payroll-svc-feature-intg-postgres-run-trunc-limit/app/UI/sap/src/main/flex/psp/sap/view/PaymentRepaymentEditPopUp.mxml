<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:pspui="psp.sap.view.*"
         xmlns:controls="psp.sap.view.controls.*"
         width="670"
         creationComplete="onCreationComplete();"
         verticalGap="0"
         paddingLeft="5"
         paddingRight="5">
    <mx:Script>
        <![CDATA[

        import psp.sap.formatters.SAPCurrencyFormatters;
        import psp.sap.formatters.SAPDateFormatters;
        import psp.sap.model.Payment;
        import psp.sap.viewmodel.PaymentRepaymentInitiateViewModel;

        private var mViewModel:PaymentRepaymentInitiateViewModel;
        private var mTempViewModel:PaymentRepaymentInitiateViewModel;
        private var mCreationComplete:Boolean = false;

        private const TRUNC_TEXT_HEIGHT:int = 20;
        private const TRUNC_TEXT_WIDTH:int = 210;

        [Bindable]
        public function get viewModel():PaymentRepaymentInitiateViewModel {
            return mViewModel;
        }

        public function set viewModel(value:PaymentRepaymentInitiateViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            }
            else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }
        ]]>
    </mx:Script>
    <mx:Label text="Initiate Repayment" styleName="heading" id="headerLabel" paddingLeft="2"
              paddingBottom="3"
              paddingTop="5"/>
    <mx:HRule width="100%" height="13"/>

    <mx:Label text="Selected Payment" styleName="subheading"/>
    <mx:HBox>
        <mx:VBox verticalGap="0">
            <mx:Label text="EIN: " fontWeight="bold"/>
            <mx:Label text="Legal Name: " fontWeight="bold"/>
            <mx:Label text="PSID: " fontWeight="bold"/>
            <mx:Label text="Payment Template: " fontWeight="bold"/>
            <mx:Label text="Amount: " fontWeight="bold"/>
            <mx:Label text="Due Date: " fontWeight="bold"/>
            <mx:Label text="Payment Method: " fontWeight="bold"/>
            <mx:Label text="Rejection Reason: " fontWeight="bold"/>
        </mx:VBox>
        <mx:VBox verticalGap="0">
            <mx:Label text="{viewModel.payment.ein}"/>
            <pspui:TruncatedText
                    id="legalNameText"
                    text="{viewModel.payment.companyName}"
                    height="{TRUNC_TEXT_HEIGHT}"
                    width="{TRUNC_TEXT_WIDTH}"
                    includeInLayout="{viewModel.payment.companyName != null}"
                    visible="{viewModel.payment.companyName != null}"/>
            <mx:Label text="{viewModel.payment.psId}"/>
            <mx:Label text="{viewModel.payment.paymentType}"/>
            <mx:Label text="{SAPCurrencyFormatters.defaultFormatter.format(viewModel.payment.amount)}"/>
            <mx:Label text="{SAPDateFormatters.dateFormatShort.format(viewModel.payment.dueDate)}"/>
            <mx:Label text="{viewModel.payment.paymentMethod}"/>
            <mx:Label text="{viewModel.payment.status}"/>
        </mx:VBox>
    </mx:HBox>

    <mx:Label text="Repayment Options" styleName="subheading"/>

    <mx:HBox verticalAlign="middle" styleName="noPadding">
        <controls:SAPCheckBox dataField="updatePaymentMethod" label="Update payment method to"/>
        <controls:SAPComboBox dataField="newPaymentMethod" dataProvider="{viewModel.paymentMethodList}" labelField="paymentMethodName" paddingLeft="0" width="150" enabled="{viewModel.updatePaymentMethod}"/>
    </mx:HBox>
    <controls:SAPCheckBox dataField="initiateAll" label="Initiate repayment on all {viewModel.payment.paymentMethod} {viewModel.payment.paymentType} payments having a settlement date of {SAPDateFormatters.dateFormatShort.format(viewModel.payment.settlementDate)}"/>
    <controls:SAPCheckBox dataField="recreate" label="Recreate payment(s) using current agency info"/>

    <mx:HBox paddingBottom="15" paddingTop="5" width="100%" horizontalAlign="right">
        <mx:Button label="Cancel" click="viewModel.cancel()"/>
        <mx:Button label="Initiate Repayment" click="viewModel.save()" paddingLeft="10"
                   enabled="{viewModel.canSave}"/>
    </mx:HBox>


</mx:VBox>

