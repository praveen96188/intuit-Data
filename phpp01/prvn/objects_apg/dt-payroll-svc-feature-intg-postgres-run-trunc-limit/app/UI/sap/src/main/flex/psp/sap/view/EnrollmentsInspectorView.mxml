<?xml version="1.0" encoding="utf-8"?>
<pspui:AbstractInspectorView
        xmlns:mx="http://www.adobe.com/2006/mxml"
        xmlns:pspui="psp.sap.view.*">

    <mx:Script>
		<![CDATA[
        import psp.sap.application.enums.EnrollmentsPageEnum;

		]]>
	</mx:Script>

    <pspui:pages>
        <pspui:SinglePartPageView baseLabel="{EnrollmentsPageEnum.EFTPS}">
            <pspui:EnrollmentsView/>
        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{EnrollmentsPageEnum.RAF}">
            <pspui:RAFView/>
        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{EnrollmentsPageEnum.ACH_PAGE}">
            <pspui:ACHEnrollmentsView/>
        </pspui:SinglePartPageView>
    </pspui:pages>
</pspui:AbstractInspectorView>
