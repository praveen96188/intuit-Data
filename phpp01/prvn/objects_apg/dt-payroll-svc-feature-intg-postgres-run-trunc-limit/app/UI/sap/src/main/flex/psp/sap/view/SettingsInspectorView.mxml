<?xml version="1.0" encoding="utf-8"?>
<pspui:AbstractInspectorView
	xmlns:mx="http://www.adobe.com/2006/mxml"
	xmlns:pspui="psp.sap.view.*">

	<mx:Script>
		<![CDATA[
        import psp.sap.application.enums.SettingsInspectorPageEnum;
		]]>
	</mx:Script>

    <pspui:pages>
        <pspui:SinglePartPageView baseLabel="{SettingsInspectorPageEnum.USER_SETTINGS}">
            <pspui:UserSettingsView/>
        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{SettingsInspectorPageEnum.ADVANCED_SETTINGS}">
            <pspui:UserSettingsAdvancedView/>
        </pspui:SinglePartPageView>
    </pspui:pages>

</pspui:AbstractInspectorView>
