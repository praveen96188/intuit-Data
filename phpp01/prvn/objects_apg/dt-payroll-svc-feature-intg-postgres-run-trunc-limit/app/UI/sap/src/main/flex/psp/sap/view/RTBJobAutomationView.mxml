  Description: To Create Duplication Automation View
  Date:02/08/2019
-->
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*"
         xmlns:control="http://www.adobe.com/2006/mxml"
         width="100%" verticalGap="0" creationComplete="onCreationComplete();">

    <mx:Script><![CDATA[
        import mx.controls.Alert;

        import psp.sap.view.*;
        import psp.sap.view.DupPIView;

        import psp.sap.viewmodel.RTBViewModel;

        import mx.events.CloseEvent;
        import mx.managers.PopUpManager;
        private var mViewModel:RTBViewModel;
        private var mTempViewModel:RTBViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():RTBViewModel {
            return mViewModel;
        }

        protected static var mRTBJobAutomationPopup:DupEEView;

        protected static var mVMPRealmViewPopup:VMPRealmView;

        protected static var mRTBPIJobAutomationPopup:DupPIView;

        protected static var mRTBUPRJobAutomationPopup:UnprocessedToProcessedReqView;

        protected static function getDupEEView():DupEEView {
            if (mRTBJobAutomationPopup == null) mRTBJobAutomationPopup = new DupEEView();
            return mRTBJobAutomationPopup;
        }

        protected static function getVMPRealmView():VMPRealmView {
            if (mVMPRealmViewPopup == null) mVMPRealmViewPopup = new VMPRealmView();
            return mVMPRealmViewPopup;
        }

        protected static function getUnprocessedToProcessedReqView():UnprocessedToProcessedReqView {
            if (mRTBUPRJobAutomationPopup == null) mRTBUPRJobAutomationPopup = new UnprocessedToProcessedReqView();
            return mRTBUPRJobAutomationPopup;
        }

        protected static function getDupPIView():DupPIView {
            if (mRTBPIJobAutomationPopup == null) mRTBPIJobAutomationPopup = new DupPIView();
            return mRTBPIJobAutomationPopup;
        }

        public function set viewModel(value:RTBViewModel):void {
            if (mCreationComplete) {
                mViewModel=value;
            } else {
                mTempViewModel=value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
            viewModel.canSave=true;
        }

        private function confirmVerifyHandler(event:CloseEvent):void {
            if (event.detail == Alert.OK) {
                viewModel.save();
            }
        }

        // method to open the TitleWindow on creationComplete
        private function openPopupWindow():void {

            if (viewModel.selectedJob != null && viewModel.selectedJob.jobName != "" && viewModel.selectedJob.shortDescription == "Update Duplicate Employee") {
                PopUpManager.addPopUp(getDupEEView(), this, true);
                PopUpManager.centerPopUp(mRTBJobAutomationPopup);
                mRTBJobAutomationPopup.oldEmployee.text = "";
                mRTBJobAutomationPopup.newEmployee.text = "";
                mRTBJobAutomationPopup.psId.text = "";
                mRTBJobAutomationPopup.oldEmpName.text = "";
                mRTBJobAutomationPopup.newEmpName.text = "";
                mRTBJobAutomationPopup.companyName.text = "";
            } else if (viewModel.selectedJob != null && viewModel.selectedJob.jobName != "" && viewModel.selectedJob.shortDescription == "Update Duplicate Pitem") {
                PopUpManager.addPopUp(getDupPIView(), this, true);
                PopUpManager.centerPopUp(mRTBPIJobAutomationPopup);
                mRTBPIJobAutomationPopup.oldPitemID.text = "";
                mRTBPIJobAutomationPopup.newPitemID.text = "";
                mRTBPIJobAutomationPopup.psId.text = "";
                mRTBPIJobAutomationPopup.oldPitemName.text = "";
                mRTBPIJobAutomationPopup.newPitemName.text = "";
                mRTBPIJobAutomationPopup.companyName.text = "";
            } else if (viewModel.selectedJob != null && viewModel.selectedJob.jobName != "" && viewModel.selectedJob.shortDescription == "Cancel Realm ID") {
                PopUpManager.addPopUp(getVMPRealmView(), this, true);
                PopUpManager.centerPopUp(mVMPRealmViewPopup);
                mVMPRealmViewPopup.psId.text = "";
            } else if (viewModel.selectedJob != null && viewModel.selectedJob.jobName != "" && viewModel.selectedJob.shortDescription == "Clear Unprocessed Requests") {
                PopUpManager.addPopUp(getUnprocessedToProcessedReqView(), this, true);
                PopUpManager.centerPopUp(mRTBUPRJobAutomationPopup);
                mRTBUPRJobAutomationPopup.psId.text = "";
            } else {
                Alert.show("No Job selected to execute");
                Alert.show(viewModel.selectedJob.jobName);
            }

        }

        // method to close the TitleWindow targeted by a close event
        private function closeTitleWindow(evt:CloseEvent):void {

            PopUpManager.removePopUp(mRTBJobAutomationPopup);
        }

        ]]></mx:Script>



    <mx:HBox width="100%" >
        <mx:VBox id="jobActionDiv" width="100%">
            <mx:Form paddingTop="0">
                <mx:HBox verticalAlign="middle" paddingLeft="20">
                    <controls:RequiredLabel text="Select Automation Job:" width="150" horizontalAlign="right"/>
                    <controls:SAPComboBox  dataProvider="{viewModel.automationJobList}"  dataField="selectedJob"
                                          labelField="shortDescription"/>
                </mx:HBox>

                <mx:HBox paddingLeft="175" paddingBottom="20" paddingTop="10">
                    <mx:PopUpButton label="Execute" click="openPopupWindow();"/>
                </mx:HBox>


            </mx:Form>
        </mx:VBox>
    </mx:HBox>

</mx:VBox>
