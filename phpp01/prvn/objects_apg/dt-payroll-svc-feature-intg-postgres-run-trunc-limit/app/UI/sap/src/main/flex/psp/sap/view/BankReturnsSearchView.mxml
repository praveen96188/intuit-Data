               xmlns:flexlib="flexlib.controls.*"
               backgroundColor="white"
               width="100%"
               styleName="standardTabContainer"
               show="onShow(event)"
               hide="removeEventListeners()"
               verticalScrollPolicy="off"
               horizontalScrollPolicy="auto"
               creationComplete="onCreationComplete()">

    <mx:Script>
		<![CDATA[
			import psp.sap.view.controls.ProgressDisplayManager;
			import mx.automation.AutomationManager;
			import psp.sap.viewmodel.BankReturnsSearchAllReturnsViewModel;
            import mx.controls.DataGrid;
            import mx.collections.Sort;
            import mx.collections.SortField;
            import mx.controls.DateField;
            import mx.events.CloseEvent;
            import mx.controls.SWFLoader;
            import mx.controls.Image;
            import psp.sap.application.enums.BankReturnsSearchTypeEnum;
            import psp.sap.viewmodel.BankReturnsSearchBaseViewModel;
            import psp.sap.model.BankReturn;
            import mx.printing.FlexPrintJob;
            import mx.events.ValidationResultEvent;
            import psp.sap.application.SAP;
            import psp.sap.viewmodel.BankReturnsSearchViewModel;
            import mx.states.SetStyle;
            import mx.controls.Alert;
            import mx.controls.dataGridClasses.DataGridColumn;
            import psp.app.util.CommonUtil;

            import mx.events.DataGridEvent;
            import mx.events.ListEvent;

            private var mViewModel:BankReturnsSearchViewModel = new BankReturnsSearchViewModel();

            private var mCreationComplete:Boolean = false;
            private var mTempViewModel:BankReturnsSearchViewModel;

            private function onCreationComplete():void {
                mCreationComplete = true;
                viewModel = mTempViewModel;
            }

            [Bindable]
            public function get viewModel():BankReturnsSearchViewModel {
                return mViewModel;
            }

            public function set viewModel(value:BankReturnsSearchViewModel):void {
                if (!mCreationComplete) {
                    mTempViewModel = value;
                    return;
                }

                if (mViewModel != null) {
                    mViewModel.allReturnsViewModel.einValidator.listener = null;
                    mViewModel.allReturnsViewModel.startDateValidator.listener = null;
                    mViewModel.allReturnsViewModel.endDateValidator.listener = null;
                    mViewModel.allReturnsViewModel.achReturnValidator.listener = null;

                    mViewModel.financialResolutionsViewModel.einValidator.listener = null;
                    mViewModel.financialResolutionsViewModel.startDateValidator.listener = null;
                    mViewModel.financialResolutionsViewModel.endDateValidator.listener = null;
                    mViewModel.financialResolutionsViewModel.achReturnValidator.listener = null;

                    mViewModel.riskAssessmentViewModel.einValidator.listener = null;
                    mViewModel.riskAssessmentViewModel.startDateValidator.listener = null;
                    mViewModel.riskAssessmentViewModel.endDateValidator.listener = null;
                    mViewModel.riskAssessmentViewModel.achReturnValidator.listener = null;

                    mViewModel.riskCollectionsViewModel.einValidator.listener = null;
                    mViewModel.riskCollectionsViewModel.startDateValidator.listener = null;
                    mViewModel.riskCollectionsViewModel.endDateValidator.listener = null;
                    mViewModel.riskCollectionsViewModel.achReturnValidator.listener = null;
                }

                mViewModel = value;

                if (mViewModel != null) {
                    mViewModel.allReturnsViewModel.einValidator.listener = einInput;
                    mViewModel.allReturnsViewModel.startDateValidator.listener = startDateInput;
                    mViewModel.allReturnsViewModel.endDateValidator.listener = endDateInput;
                    mViewModel.allReturnsViewModel.achReturnValidator.listener = achReturnInput;

                    mViewModel.financialResolutionsViewModel.einValidator.listener = FinancialResolutions_einInput;
                    mViewModel.financialResolutionsViewModel.startDateValidator.listener = FinancialResolutions_startDateInput;
                    mViewModel.financialResolutionsViewModel.endDateValidator.listener = FinancialResolutions_endDateInput;
                    mViewModel.financialResolutionsViewModel.achReturnValidator.listener = FinancialResolutions_achReturnInput;

                    mViewModel.riskAssessmentViewModel.einValidator.listener = RiskAssessment_einInput;
                    mViewModel.riskAssessmentViewModel.startDateValidator.listener = RiskAssessment_startDateInput;
                    mViewModel.riskAssessmentViewModel.endDateValidator.listener = RiskAssessment_endDateInput;
                    mViewModel.riskAssessmentViewModel.achReturnValidator.listener = RiskAssessment_achReturnInput;

                    mViewModel.riskCollectionsViewModel.einValidator.listener = RiskCollections_einInput;
                    mViewModel.riskCollectionsViewModel.startDateValidator.listener = RiskCollections_startDateInput;
                    mViewModel.riskCollectionsViewModel.endDateValidator.listener = RiskCollections_endDateInput;
                    mViewModel.riskCollectionsViewModel.achReturnValidator.listener = RiskCollections_achReturnInput;
                }
            }

            public function onShow(e:Event):void {
                try {
                    einInput.setFocus();
                    focusManager.showFocus();
                } catch (e:Error){
                    // ignore
                }
                addEventListeners();

                    //@TODO: Fix this!!
                searchTabBar.selectedIndex = 0;
            }

            public function addEventListeners():void {
                if(viewModel != null){
                    //@TODO: hookup
                    viewModel.allReturnsViewModel.addEventListener(ValidationResultEvent.INVALID, onInvalidValidation, false, 0, true);
                    viewModel.allReturnsViewModel.addEventListener(ValidationResultEvent.VALID, onInvalidValidation, false, 0, true);

                    viewModel.financialResolutionsViewModel.addEventListener(ValidationResultEvent.INVALID, onInvalidValidation, false, 0, true);
                    viewModel.financialResolutionsViewModel.addEventListener(ValidationResultEvent.VALID, onInvalidValidation, false, 0, true);

                    viewModel.riskAssessmentViewModel.addEventListener(ValidationResultEvent.INVALID, onInvalidValidation, false, 0, true);
                    viewModel.riskAssessmentViewModel.addEventListener(ValidationResultEvent.VALID, onInvalidValidation, false, 0, true);

                    viewModel.riskCollectionsViewModel.addEventListener(ValidationResultEvent.INVALID, onInvalidValidation, false, 0, true);
                    viewModel.riskCollectionsViewModel.addEventListener(ValidationResultEvent.VALID, onInvalidValidation, false, 0, true);
                }
            }

            public function removeEventListeners():void {
                if(viewModel != null){
                    //@TODO: hookup
                    viewModel.allReturnsViewModel.removeEventListener(ValidationResultEvent.INVALID, onInvalidValidation);
                    viewModel.allReturnsViewModel.removeEventListener(ValidationResultEvent.VALID, onInvalidValidation);

                    viewModel.financialResolutionsViewModel.removeEventListener(ValidationResultEvent.INVALID, onInvalidValidation);
                    viewModel.financialResolutionsViewModel.removeEventListener(ValidationResultEvent.VALID, onInvalidValidation);

                    viewModel.riskAssessmentViewModel.removeEventListener(ValidationResultEvent.INVALID, onInvalidValidation);
                    viewModel.riskAssessmentViewModel.removeEventListener(ValidationResultEvent.VALID, onInvalidValidation);

                    viewModel.riskCollectionsViewModel.removeEventListener(ValidationResultEvent.INVALID, onInvalidValidation);
                    viewModel.riskCollectionsViewModel.removeEventListener(ValidationResultEvent.VALID, onInvalidValidation);
                }
            }
	
            private function getStartDateField():DateField {
                switch(viewModel.selectedSearchType) {
                    case BankReturnsSearchTypeEnum.ALL_RETURNS:
                        return startDateInput;
                    case BankReturnsSearchTypeEnum.FINANCIAL_RESOLUTIONS:
                        return FinancialResolutions_startDateInput;
                    case BankReturnsSearchTypeEnum.RISK_COLLECTIONS:
                        return RiskCollections_startDateInput;
                    case BankReturnsSearchTypeEnum.RISK_ASSESSMENT:
                        return RiskAssessment_startDateInput;
                    default:
                        return null;
                }
            }

            private function getEndDateField():DateField {
                switch(viewModel.selectedSearchType) {
                    case BankReturnsSearchTypeEnum.ALL_RETURNS:
                        return endDateInput;
                    case BankReturnsSearchTypeEnum.FINANCIAL_RESOLUTIONS:
                        return FinancialResolutions_endDateInput;
                    case BankReturnsSearchTypeEnum.RISK_COLLECTIONS:
                        return RiskCollections_endDateInput;
                    case BankReturnsSearchTypeEnum.RISK_ASSESSMENT:
                        return RiskAssessment_endDateInput;
                    default:
                        return null;
                }
            }

            public function onInvalidValidation(e:ValidationResultEvent):void {
                if (e.type == ValidationResultEvent.INVALID) {
                    getStartDateField().validationResultHandler(e);
                    getEndDateField().validationResultHandler(e);
                }
                else {
                    getStartDateField().validationResultHandler(viewModel.selectedSearchViewModel.startDateValidator.validate(null, false));
                    getEndDateField().validationResultHandler(viewModel.selectedSearchViewModel.endDateValidator.validate(null, false));
                }
            }

            public function pageDataGridLoadDataFunction():void {
                viewModel.selectedSearchViewModel.searchBankReturnsWithSameCritera();
            }

            public function goToPayrollTransactions(event:ActionLinkEvent):void
            {
                var link:ActionLink = event.currentTarget as ActionLink;
                viewModel.goToPayrollTransactions( 	link.data.companySourceSystemCd,
                        link.data.companyId,
                        link.data.sourcePayRunId);
            }

            public function goToBankReturnsUpdate(event:ActionLinkEvent):void
            {
                var link:ActionLink = event.currentTarget as ActionLink;
                viewModel.goToBankReturnsUpdate(link.data as BankReturn);
            }

            public function goToCompanyPayrolls(event:ActionLinkEvent):void
            {
                var link:ActionLink = event.currentTarget as ActionLink;
                viewModel.goToCompanyPayrolls( 	link.data.companySourceSystemCd,
                        link.data.companyId);
            }

            public function findBankReturns():void {
                viewModel.findBankReturns();
            }


            public function determineScale(value:Image, pageWidth:Number, pageHeight:Number):Number {
                var tempImage:Image = value;
                var totalScale:Number = 1.0;
                var tempMeasuredWidth:Number = tempImage.source.width;

                while(tempMeasuredWidth > pageWidth)
                {
                    totalScale-= 0.01;
                    tempImage.scaleX = totalScale;
                    tempMeasuredWidth = tempImage.source.width * totalScale;
                }

                return totalScale;

            }

            private function printResultsConfirmation(event:Event):void
            {
                var estimateTime:Number = viewModel.selectedSearchViewModel.searchResults.totalRecords/100;
                if(estimateTime > 1) {
                    var seconds:Number = Math.round((estimateTime - Math.floor(estimateTime))*60);
                    var msgString:String = "Are you sure you want to print this return set? \n";
                    msgString += "Estimated Time to print: " + Math.floor(estimateTime) + " min " + seconds + " sec";

                    Alert.show(	msgString,
                            "Print Confirmation",
                            Alert.OK | Alert.CANCEL,
                            this,
                            printResultsVerifyHandler,
                            null,
                            Alert.OK);
                }
                else {
                    printResults();
                }
            }

            public function printResultsVerifyHandler(evt_obj:CloseEvent):void {
                if(evt_obj.detail == Alert.OK)
                {
                    printResults();
                }
            }

            public function printResults(isForExport:Boolean = false):void {
                var reportType:String = viewModel.selectedSearchViewModel.getReportTypeCode();

                var callString:String = "?report=bankreturnsreport&" +
                                        "&fein=" + blankIfNull(viewModel.selectedSearchViewModel.ein) +
                                        "&from=" + blankIfNull(viewModel.selectedSearchViewModel.startDate) +
                                        "&to=" + blankIfNull(viewModel.selectedSearchViewModel.endDate) +
                                        "&achAmount=" + blankIfNull(viewModel.selectedSearchViewModel.achReturn) +
                                        "&token=" + blankIfNull(SAP.instance.session.user.authorizationToken) +
                                        "&reportType=" + blankIfNull(reportType) +
                                        "&export=" + isForExport;

                if(viewModel.selectedSearchType == BankReturnsSearchTypeEnum.ALL_RETURNS)
                {
                    viewModel.allReturnsViewModel.setupAllReturnSearch();
                    callString+= "&showOpen=" + blankIfNull(viewModel.allReturnsViewModel.showOpenReturns) +
                                 "&showResolved=" + blankIfNull(viewModel.allReturnsViewModel.showResolvedReturns) +
                                 "&transactionType=" + blankIfNull(viewModel.allReturnsViewModel.transactionType) +
                                 "&transactionCategory=" + blankIfNull(viewModel.allReturnsViewModel.transactionCategory) +
                                 "&exclude5DayFunding=" + blankIfNull(viewModel.allReturnsViewModel.exclude5DayFunding) +
                                 "&excludeCode=" + blankIfNull(viewModel.allReturnsViewModel.excludeCReturnCodes ? "R" : "");
                }

                if(CommonUtil.isDTApp()) {
                    CommonUtil.showPrintWindow(callString, "Print");
                } else {
                    ExternalInterface.call("showPrintWindow", callString);
                }
            }

            public function blankIfNull(c:*):* {
                return (c == null) ? "" : c;
            }


            public function determineExpectedResolutionColor(value:Date):uint {
                value.setHours(0, 0, 0, 0);
                if(value < SAP.instance.PSPDate) {
                    return UIUtils.COLOR_RED;
                } else {
                    return UIUtils.COLOR_BLACK;
                }
            }
            
            
            public function exportResults():void {
            	printResults(true);
            }
            
		]]>
	</mx:Script>
