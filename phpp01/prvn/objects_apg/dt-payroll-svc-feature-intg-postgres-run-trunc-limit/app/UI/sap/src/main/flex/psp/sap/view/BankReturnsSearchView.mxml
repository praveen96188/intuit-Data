                    </controls:SAPDataGridColumn>
                    <controls:SAPDataGridColumn   id="allReturnsDataColumn"
                                         visible="{viewModel.selectedSearchType == BankReturnsSearchTypeEnum.ALL_RETURNS}"
                                         headerText="Transaction{String('\n')}Type"
                                         minWidth="120"
                                         dataField="transactionType"
                                         itemRenderer="mx.controls.Text"
                                         paddingLeft="5"
                                         draggable="false"/>
                    <controls:SAPDataGridColumn
                            minWidth="190"
                            dataField="companyName"
                            exportTitle="Company Name (And EE name if EE return)"
                            draggable="false">
                        <controls:headerRenderer>
                            <mx:Component>
                                <mx:VBox
                                        verticalGap="0"
                                        horizontalAlign="left"
                                        verticalScrollPolicy="off"
                                        horizontalScrollPolicy="off">
                                    <mx:Label text="Company Name" styleName="padderLeftRight"/>
                                    <mx:Label
                                            text="And EE name if EE return"
                                            fontWeight="normal"
                                            fontSize="9"
                                            styleName="padderLeftRight"/>
                                </mx:VBox>
                            </mx:Component>
                        </controls:headerRenderer>
                        <controls:itemRenderer>
                            <mx:Component>
                                <mx:VBox
                                        width="100%"
                                        horizontalAlign="left"
                                        verticalGap="0"
                                        verticalScrollPolicy="off"
                                        horizontalScrollPolicy="off">
                                    
                                    <controls:SAPColumnData displayData="{data.companyName + ' ' + data.employeeName}"/>
                                    
                                    <pspui:ActionLink
                                            id="companyNameLink"
                                            label="{data.companyName}"
                                            actionClick="outerDocument.goToCompanyPayrolls"
                                            data="{data}"/>
                                    <mx:HBox visible="{data.employeeName != ''}" horizontalGap="0">
                                        <mx:Label text="EE: " paddingLeft="5"/>
                                        <mx:Text id="employeeNameText" text="{data.employeeName}" paddingRight="5"/>
                                    </mx:HBox>
                                </mx:VBox>
                            </mx:Component>
                        </controls:itemRenderer>
                    </controls:SAPDataGridColumn>
                    <controls:SAPDataGridColumn
                            headerText="EIN"
                            width="80"
                            resizable="false"
                            dataField="fein"
                            itemRenderer="mx.controls.Text"
                            paddingLeft="5"
                            draggable="false"/>
                    <controls:SAPDataGridColumn
                            minWidth="90"
                            headerText="Account #{String('\n')}Routing #"
                            exportTitle="Account # / Routing #"
                            dataField="bankAccountNumber"
                            draggable="false">
                        <controls:itemRenderer>
                            <mx:Component>
                                <mx:VBox
                                        width="100%"
                                        horizontalAlign="left"
                                        verticalGap="0"
                                        verticalScrollPolicy="off"
                                        horizontalScrollPolicy="off">
                                    <controls:SAPColumnData displayData="{UIUtils.maskBankAccountNumbers(data.bankAccountNumber) + ' / ' + data.bankRoutingNumber}"/>
                                    
                                    <mx:Text
                                            id="bankAccountNumberText"
                                            text="{UIUtils.maskBankAccountNumbers(data.bankAccountNumber)}"
                                            styleName="padderLeftRight"/>
                                    <mx:Text
                                            id="bankRoutingNumberText"
                                            text="{data.bankRoutingNumber}"
                                            styleName="padderLeftRight"/>
                                </mx:VBox>
                            </mx:Component>
                        </controls:itemRenderer>
                    </controls:SAPDataGridColumn>
                    <controls:SAPDataGridColumn
                            minWidth="90"
                            dataField="returnDateTime"
                            exportTitle="Return Date / Check Date"
                            draggable="false">
                        <controls:headerRenderer>
                            <mx:Component>
                                <mx:VBox
                                        verticalGap="0"
                                        horizontalAlign="left"
                                        verticalScrollPolicy="off"
                                        horizontalScrollPolicy="off">
                                    <mx:Label text="Return Date" styleName="padderLeftRight"/>
                                    <mx:Label text="Check Date" styleName="padderLeftRight"/>
                                </mx:VBox>
                            </mx:Component>
                        </controls:headerRenderer>
                        <controls:itemRenderer>
                            <mx:Component>
                                <mx:VBox
                                        width="100%"
                                        horizontalAlign="left"
                                        verticalGap="0"
                                        verticalScrollPolicy="off"
                                        horizontalScrollPolicy="off">
                                    <mx:Script>
										<![CDATA[
											import psp.sap.application.enums.BankReturnsSearchTypeEnum;
										]]>
									</mx:Script>
									<controls:SAPColumnData displayData="{outerDocument.dateFormatter.format(data.returnDate)} / {outerDocument.dateFormatter.format(data.checkDate)}"/>
                                    <mx:Text id="returnDateText" text="{outerDocument.dateFormatter.format(data.returnDate)}" styleName="padderLeftRight"/>
                                    <mx:Text id="checkDateText" text="{outerDocument.dateFormatter.format(data.checkDate)}" styleName="padderLeftRight"/>
                                    <mx:HBox
                                            id="canUpdateReturnsHBox"
                                            width="100%"
                                            horizontalAlign="center"
                                            horizontalGap="0"
                                            visible="{data.canUpdateReturns() ? outerDocument.viewModel.selectedSearchType == BankReturnsSearchTypeEnum.ALL_RETURNS : false}"
                                            includeInLayout="{data.canUpdateReturns() ? outerDocument.viewModel.selectedSearchType == BankReturnsSearchTypeEnum.ALL_RETURNS : false}">
                                        <pspui:ActionLink
                                                id="reOpenReturnLink"
                                                label="Reopen Return"
                                                paddingLeft="5"
                                                visible="{data.canReopenReturn()}"
                                                includeInLayout="{data.canReopenReturn()}"
                                                actionClick="outerDocument.goToBankReturnsUpdate"
                                                data="{data}"/>
                                        <pspui:ActionLink
                                                id="resolveReturnLink"
                                                label="Resolve Return"
                                                paddingLeft="5"
                                                visible="{!data.canReopenReturn()}"
                                                includeInLayout="{!data.canReopenReturn()}"
                                                actionClick="outerDocument.goToBankReturnsUpdate"
                                                data="{data}"/>
                                    </mx:HBox>
                                </mx:VBox>
                            </mx:Component>
                        </controls:itemRenderer>
                    </controls:SAPDataGridColumn>
                    <controls:SAPDataGridColumn
                            headerText="ACH{String('\n')}Return"
                            minWidth="80"
                            textAlign="right"
                            dataField="amount"
                            draggable="false">
                        <controls:itemRenderer>
                            <mx:Component>
                            	<mx:VBox
                                        width="100%"
                                        horizontalAlign="right"
                                        verticalGap="0"
                                        verticalScrollPolicy="off"
                                        horizontalScrollPolicy="off">
                                    <controls:SAPColumnData displayData="{outerDocument.currencyFormatter.format(data.amount)}"/>    
                                    <mx:Text id="amountText" text="{outerDocument.currencyFormatter.format(data.amount)}" styleName="padderLeftRight"/>
                                </mx:VBox>
                            </mx:Component>
                        </controls:itemRenderer>
                    </controls:SAPDataGridColumn>
                    <controls:SAPDataGridColumn
                            headerText="Balance"
                            textAlign="right"
                            minWidth="80"
                            dataField="payrollBalanceDue"
                            draggable="false"
                            sortable="false">
                        <controls:itemRenderer>
                            <mx:Component>
                            	<mx:VBox
                                        width="100%"
                                        horizontalAlign="right"
                                        verticalGap="0"
                                        verticalScrollPolicy="off"
                                        horizontalScrollPolicy="off">
                                    <controls:SAPColumnData  displayData="{outerDocument.currencyFormatter.format(data.bankReturnExtendedInfo.payrollBalanceDue)}"/>
                                
                                    <mx:Text
                                            id="payrollBalanceDueText"
                                            color="{data.bankReturnExtendedInfo == null ? 0xCCCCCC : data.bankReturnExtendedInfo.payrollBalanceDue == 0 ? 0x000000 : 0xFF0000}"
                                            text="{data.bankReturnExtendedInfo != null ? outerDocument.currencyFormatter.format(data.bankReturnExtendedInfo.payrollBalanceDue) : 'Loading...'}"
                                            styleName="padderLeftRight"/>
                                </mx:VBox>
                            </mx:Component>
                        </controls:itemRenderer>
                    </controls:SAPDataGridColumn>
                    <controls:SAPDataGridColumn
                            headerText="Rtn{String('\n')}Cd"
                            dataField="returnCd"
                            textAlign="left"
                            minWidth="35"
                            itemRenderer="mx.controls.Text"
                            paddingLeft="5"
                            draggable="false"/>
                    <controls:SAPDataGridColumn
                            headerText="Expected{String('\n')}Resolution"
                            dataField="expectedResolutionDate"
                            textAlign="left"
                            minWidth="90"
                            draggable="false"
                            sortable="false">
                        <controls:itemRenderer>
                            <mx:Component>
                                <mx:VBox
                                        width="100%"
                                        horizontalAlign="left"
                                        verticalGap="0"
                                        verticalScrollPolicy="off"
                                        horizontalScrollPolicy="off">
                                    <controls:SAPColumnData displayData="{outerDocument.expectedResolutionDateFormatter.format(data.bankReturnExtendedInfo.expectedResolutionDate)}"/>
                                    
                                    <mx:Text
                                            id="expectedResolutionDateText"
                                            color="{data.bankReturnExtendedInfo != null ? outerDocument.determineExpectedResolutionColor(data.bankReturnExtendedInfo.expectedResolutionDate) : 0xCCCCCC}"
                                            text="{data.bankReturnExtendedInfo != null ? outerDocument.expectedResolutionDateFormatter.format(data.bankReturnExtendedInfo.expectedResolutionDate) : 'Loading...'}"
                                            styleName="padderLeftRight"/>
                                </mx:VBox>
                            </mx:Component>
                        </controls:itemRenderer>
                    </controls:SAPDataGridColumn>
                </pspui:columns>
            </pspui:PagingDataGrid>
            <mx:Spacer height="10"/>
            
            <mx:HBox width="100%" horizontalAlign="left">
            	 
            	<pspui:ActionLink click="exportResults()" icon="{SAP.instance.icons.exportIcon}" labelPlacement="right" label="Export Results" enabled="{viewModel.selectedSearchViewModel.searchResults.length > 0}"/>
            	<pspui:ActionLink id="printBankReturnsLink" label="Print Bank Returns"
                                      icon="{SAP.instance.icons.printIcon}" labelPlacement="right" enabled="{viewModel.selectedSearchViewModel.searchResults.length > 0}"
                                      click="printResultsConfirmation(event)" />
            </mx:HBox>
        
        </mx:VBox>




    <!-- ALL RETURNS -->

    <!-- ein bindings -->
    <mx:Binding source="einInput.text" destination="viewModel.allReturnsViewModel.ein" />
    <mx:Binding source="viewModel.allReturnsViewModel.ein" destination="einInput.text" />

    <!-- start date bindings -->
    <mx:Binding source="startDateInput.text" destination="viewModel.allReturnsViewModel.startDate" />
    <mx:Binding source="viewModel.allReturnsViewModel.startDate" destination="startDateInput.text" />

    <!-- end date bindings -->
    <mx:Binding source="endDateInput.text" destination="viewModel.allReturnsViewModel.endDate" />
    <mx:Binding source="viewModel.allReturnsViewModel.endDate" destination="endDateInput.text" />

    <!-- exclude CReturnCodes-->
    <mx:Binding source="excludeCReturnCodes.selected" destination="viewModel.allReturnsViewModel.excludeCReturnCodes"/>
    <mx:Binding source="viewModel.allReturnsViewModel.excludeCReturnCodes" destination="excludeCReturnCodes.selected"/>

    <!-- exclude 5DayFunding -->
    <mx:Binding source="exclude5DayFunding.selected" destination="viewModel.allReturnsViewModel.exclude5DayFunding"/>
    <mx:Binding source="viewModel.allReturnsViewModel.exclude5DayFunding" destination="exclude5DayFunding.selected"/>

    <!-- ach return binding -->
    <mx:Binding source="achReturnInput.text" destination="viewModel.allReturnsViewModel.achReturn"/>
    <mx:Binding source="viewModel.allReturnsViewModel.achReturn" destination="achReturnInput.text"/>


    <!-- FINANCIAL RESOLUTIONS -->

    <!-- ein bindings -->
    <mx:Binding source="FinancialResolutions_einInput.text" destination="viewModel.financialResolutionsViewModel.ein" />
    <mx:Binding source="viewModel.financialResolutionsViewModel.ein" destination="FinancialResolutions_einInput.text" />

    <!-- start date bindings -->
    <mx:Binding source="FinancialResolutions_startDateInput.text" destination="viewModel.financialResolutionsViewModel.startDate" />
    <mx:Binding source="viewModel.financialResolutionsViewModel.startDate" destination="FinancialResolutions_startDateInput.text" />

    <!-- end date bindings -->
    <mx:Binding source="FinancialResolutions_endDateInput.text" destination="viewModel.financialResolutionsViewModel.endDate" />
    <mx:Binding source="viewModel.financialResolutionsViewModel.endDate" destination="FinancialResolutions_endDateInput.text" />

    <!-- ach return binding -->
    <mx:Binding source="FinancialResolutions_achReturnInput.text" destination="viewModel.financialResolutionsViewModel.achReturn"/>
    <mx:Binding source="viewModel.financialResolutionsViewModel.achReturn" destination="FinancialResolutions_achReturnInput.text"/>


    <!-- RISK ASSESSMENT -->

    <!-- ein bindings -->
    <mx:Binding source="RiskAssessment_einInput.text" destination="viewModel.riskAssessmentViewModel.ein" />
    <mx:Binding source="viewModel.riskAssessmentViewModel.ein" destination="RiskAssessment_einInput.text" />

    <!-- start date bindings -->
    <mx:Binding source="RiskAssessment_startDateInput.text" destination="viewModel.riskAssessmentViewModel.startDate" />
    <mx:Binding source="viewModel.riskAssessmentViewModel.startDate" destination="RiskAssessment_startDateInput.text" />

    <!-- end date bindings -->
    <mx:Binding source="RiskAssessment_endDateInput.text" destination="viewModel.riskAssessmentViewModel.endDate" />
    <mx:Binding source="viewModel.riskAssessmentViewModel.endDate" destination="RiskAssessment_endDateInput.text" />

    <!-- ach return binding -->
    <mx:Binding source="RiskAssessment_achReturnInput.text" destination="viewModel.riskAssessmentViewModel.achReturn"/>
    <mx:Binding source="viewModel.riskAssessmentViewModel.achReturn" destination="RiskAssessment_achReturnInput.text"/>


    <!-- RISK COLLECTIONS -->

    <!-- ein bindings -->
    <mx:Binding source="RiskCollections_einInput.text" destination="viewModel.riskCollectionsViewModel.ein" />
    <mx:Binding source="viewModel.riskCollectionsViewModel.ein" destination="RiskCollections_einInput.text" />

    <!-- start date bindings -->
    <mx:Binding source="RiskCollections_startDateInput.text" destination="viewModel.riskCollectionsViewModel.startDate" />
    <mx:Binding source="viewModel.riskCollectionsViewModel.startDate" destination="RiskCollections_startDateInput.text" />

    <!-- end date bindings -->
    <mx:Binding source="RiskCollections_endDateInput.text" destination="viewModel.riskCollectionsViewModel.endDate" />
    <mx:Binding source="viewModel.riskCollectionsViewModel.endDate" destination="RiskCollections_endDateInput.text" />

    <!-- ach return binding -->
    <mx:Binding source="RiskCollections_achReturnInput.text" destination="viewModel.riskCollectionsViewModel.achReturn"/>
    <mx:Binding source="viewModel.riskCollectionsViewModel.achReturn" destination="RiskCollections_achReturnInput.text"/>

    <!-- Search filter 1 -->
    <mx:Binding source="BankReturnsSearchAllReturnsViewModel.SEARCH_FILTER_1" destination="showOnlyCombo1.dataProvider"/>
    <mx:Binding source="viewModel.allReturnsViewModel.searchFilter1" destination="showOnlyCombo1.selectedItem"/>

    <!-- Search filter 2 -->
    <mx:Binding source="viewModel.allReturnsViewModel.searchFilter2" destination="showOnlyCombo2.selectedItem"/>
    <mx:Binding source="BankReturnsSearchAllReturnsViewModel.SEARCH_FILTER_2" destination="showOnlyCombo2.dataProvider"/>

	
	
	
    <!-- Global viewModel settings -->

    <!-- error message -->
    <mx:Binding source="viewModel.selectedSearchViewModel.errorString" destination="saveMessage.text" />
    <mx:Binding source="viewModel.selectedSearchViewModel.isError" destination="saveMessage.isError" />

    <!-- Tab Bar -->
    <mx:Binding source="viewModel.selectedSearchIndex" destination="searchTabBar.selectedIndex"/>
    <mx:Binding source="searchTabBar.selectedIndex" destination="viewModel.selectedSearchIndex"/>
</mx:Canvas>
