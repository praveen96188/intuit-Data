der):void {            var remoteToken:AsyncToken =                    AsyncToken(rtbRemoteService.getProcessMassCanFileList());            remoteToken.addResponder(responder);        }        public function executeMassCancellation(selectedMassCnFile:String,responder:IResponder):void {            var remoteToken:AsyncToken =                    AsyncToken(rtbRemoteService.executeMassCancellation(selectedMassCnFile));            remoteToken.addResponder(responder);        }        public function getAutoMassCanFlag(responder:IResponder):void {            var remoteToken:AsyncToken =                    AsyncToken(rtbRemoteService.getAutoMassCanFlag());            remoteToken.addResponder(responder);        }    }}