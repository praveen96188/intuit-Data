<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml">
    <mx:Script>
    <![CDATA[

        import psp.sap.viewmodel.CompanyEditPriceTypeViewModel;

        [Bindable] public var viewModel:CompanyEditPriceTypeViewModel;

    ]]>
    </mx:Script>
    <mx:Form paddingLeft="0" paddingTop="0">
        <mx:FormItem label="Price Type:" labelStyleName="fieldLabel">
            <mx:Label text="{viewModel.priceType}"/>
