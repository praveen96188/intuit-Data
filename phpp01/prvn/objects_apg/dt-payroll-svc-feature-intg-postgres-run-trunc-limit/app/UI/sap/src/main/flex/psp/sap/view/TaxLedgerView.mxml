<?xml version="1.0" encoding="utf-8"?>
<mx:VBox xmlns="*"
         xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:pspui="psp.sap.view.*"
         xmlns:controls="psp.sap.view.controls.*"
         width="100%"
         height="100%"
         creationComplete="onCreationComplete();" xmlns:containers="flexlib.containers.*">
    <mx:Script>
		<![CDATA[
        import flexlib.controls.tabBarClasses.SuperTab;

        import mx.collections.ArrayCollection;
        import mx.core.ContainerCreationPolicy;
        import mx.events.CollectionEvent;
        import mx.events.CollectionEventKind;

        import psp.sap.application.enums.CompanyInspectorPageEnum;
        import psp.sap.application.enums.PaymentsPageEnum;
        import psp.sap.model.LawTransactions;
        import psp.sap.viewmodel.TaxLedgerTabViewModel;
        import psp.sap.viewmodel.TaxLedgerViewModel;

        use namespace mx_internal;

        private static const COL_1:int = 120;
        private static const COL_2:int = 140;
        private static const COL_3:int = 120;
        private static const COL_4:int = 115;
        private static const COL_5:int = 70;
        private static const COL_6:int = 100;

        private var mViewModel:TaxLedgerViewModel;
        private var mTempViewModel:TaxLedgerViewModel;
        private var mCreationComplete:Boolean = false;

        private var mPreviousSelectedTab:String = null;

        private var selectedTabIndex:int = 0;

        private var mTaxpayerId:String;

        public var pageLabel:String = "Ledger";

        [Bindable]
        public function get viewModel():TaxLedgerViewModel {
            return mViewModel;
        }

        public function set viewModel(value:TaxLedgerViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;

                mViewModel.taxLedgerTabViewModelCollection.addEventListener(CollectionEvent.COLLECTION_CHANGE, onTaxLedgerCollectionChanged, false, 0, true);
                syncToViewModel();
                taxLedgerTab.addEventListener(Event.CHANGE, tabSelectionChanged, false, 0, true);
            }
            else {
                mTempViewModel = value;
            }
        }

        public function onTaxLedgerCollectionChanged(e:CollectionEvent):void {
            if (!mCreationComplete)
                return;

            if (e.kind == CollectionEventKind.ADD) {
                addTaxLedgerTabViews(new ArrayCollection(e.items));
            } else if (e.kind == CollectionEventKind.REMOVE) {
                for each (var taxLedgerTabViewModel:TaxLedgerTabViewModel in e.items) {
                    for each (var aTaxLedgerTabView:TaxLedgerTabView in taxLedgerViewStack.getChildren()) {
                        if (aTaxLedgerTabView.viewModel == taxLedgerTabViewModel) {
                            taxLedgerViewStack.removeChild(aTaxLedgerTabView);
                            break;
                        }
                    }
                }
            } else if (e.kind == CollectionEventKind.RESET) {
                taxLedgerViewStack.removeAllChildren();
            } else if (e.kind == CollectionEventKind.REFRESH) {
                updateTaxLedgerTab();
            }
        }

        private function syncToViewModel():void {
            addTaxLedgerTabViews(mViewModel.taxLedgerTabViewModelCollection);
        }

        private function addTaxLedgerTabViews(taxLedgerTabViewModels:ArrayCollection):void {
            for each (var taxLedgerTabViewModel:TaxLedgerTabViewModel in taxLedgerTabViewModels) {
                var taxLedgerTabView:TaxLedgerTabView = new TaxLedgerTabView();
                taxLedgerTabView.viewModel = taxLedgerTabViewModel;
                taxLedgerTabView.id = taxLedgerTabViewModel.lawTransactions.label();
                taxLedgerTabView.name = taxLedgerTabViewModel.lawTransactions.label();
                taxLedgerTabView.label = taxLedgerTabViewModel.lawTransactions.label();
                taxLedgerTabView.creationPolicy = ContainerCreationPolicy.NONE;
                taxLedgerViewStack.addChild(taxLedgerTabView);
            }
        }

        public function tabSelectionChanged(e:Event):void {
            var selectedTab:String = SuperTabNavigator(e.currentTarget).selectedChild.label;
            mPreviousSelectedTab = selectedTab;
            selectedTabIndex = taxLedgerTab.selectedIndex;
            taxLedgerViewStack.selectedIndex = taxLedgerViewStack.getChildIndex(taxLedgerViewStack.getChildByName(selectedTab));
        }

        public function updateTaxLedgerTab():void {
            if (mPreviousSelectedTab != null) {
                if (taxLedgerViewStack.getChildByName(mPreviousSelectedTab) != null) {
                    taxLedgerViewStack.selectedIndex = taxLedgerViewStack.getChildIndex(taxLedgerViewStack.getChildByName(mPreviousSelectedTab));
                    resetTabIndex();
                    return;
                }
            }
            taxLedgerViewStack.selectedIndex = 0;
            selectedTabIndex = 0;
            resetTabIndex();
        }

        public function resetTabIndex():void {
            if (taxLedgerTab.getChildren().length > 0) {
                taxLedgerTab.getTabBar().selectedIndex = -1;
                callLater(function():void {
                                taxLedgerTab.getTabBar().selectedIndex = selectedTabIndex;
                            });
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }

        ]]>
	</mx:Script>

    	<!-- Main content -->

	<mx:Box id="mainBox" height="100%" width="100%">
        <mx:VBox paddingLeft="10">
            <!-- width set for 1024x768 -->
            <controls:FilterBox styleName="ddDarkGrayMiniBoxStyleOnlyTopPadding" width="810" id="mainFilterBox"
                            filterStringFunction="{viewModel.getFilterString}"
                            openOnStartup="true"
                            paddingBottom="0" paddingLeft="0" paddingRight="0" paddingTop="0"
                            visible="{viewModel.taxYears.source.length != 0}"
                            includeInLayout="{viewModel.taxYears.source.length != 0}">
            <mx:VBox horizontalAlign="right">
                <mx:HBox>
                    <mx:VBox>
                        <mx:HBox>
                            <mx:Label text="Agency" width="{COL_1}" textAlign="right" fontWeight="bold"/>
                            <controls:SAPComboBox dataField="selectedAgency" dataProvider="{viewModel.agencyList}" labelField="agencyAbbrev" width="{COL_2}"/>
                        </mx:HBox>
                        <mx:HBox>
                            <mx:Label text="Payment Type" width="{COL_1}" textAlign="right" fontWeight="bold"/>
                            <controls:SAPComboBox
                                    dataField="selectedPaymentTemplate"
                                    dataProvider="{viewModel.paymentTemplates}"
                                    labelField="paymentTemplateName"
                                    enabled="{viewModel.paymentTemplates != null ? viewModel.paymentTemplates.length > 0 : false}"
                                    width="{COL_2}"/>
                        </mx:HBox>
                        <mx:HBox>
                            <mx:Label text="Tax Type" width="{COL_1}" textAlign="right" fontWeight="bold"/>
                            <controls:SAPComboBox
                                    dataField="selectedLawItem"
                                    dataProvider="{viewModel.lawItems}"
                                    labelField="name"
                                    enabled="{viewModel.lawItems != null ? viewModel.lawItems.length > 0 : false}"
                                    width="{COL_2}"/>
                        </mx:HBox>
                    </mx:VBox>
                    <mx:VBox>
                        <mx:HBox>
                            <mx:Label text="Type" width="{COL_3}" textAlign="right" fontWeight="bold"/>
                            <controls:SAPComboBox dataField="selectedTransactionDescription"
                                         dataProvider="{viewModel.transactionTypes}"
                                         width="{COL_4}"/>
                        </mx:HBox>
                        <mx:HBox>
                            <mx:Label text="Payment Method" width="{COL_3}" textAlign="right" fontWeight="bold"/>
                            <controls:SAPComboBox dataField="selectedPaymentMethod" width="{COL_4}" dataProvider="{viewModel.paymentMethods}"/>
                        </mx:HBox>
                        <mx:HBox horizontalAlign="right" width="100%">
                            <controls:SAPCheckBox dataField="includeNotPostedPayments" label="Include pending transactions"/>
                        </mx:HBox>
                    </mx:VBox>
                    <mx:VBox>
                        <mx:HBox
                                horizontalGap="2"
                                verticalAlign="middle">
                            <mx:Label text="Year" textAlign="right" fontWeight="bold"/>
                            <controls:SAPComboBox
                                    id="yearCombo"
                                    dataField="selectedYear"
                                    dataProvider="{viewModel.taxYears}"
                                    width="{COL_6}"/>
                            <mx:Label text="Quarter" textAlign="right" fontWeight="bold"/>
                            <controls:SAPComboBox
                                    dataField="selectedQuarter"
                                    dataProvider="{viewModel.quarters}"
                                    width="75"
                                    enabled="{yearCombo.selectedItem != ''}"/>
                        </mx:HBox>
                    </mx:VBox>
                </mx:HBox>
                <mx:Button label="Filter" enabled="{viewModel.canSave}" click="viewModel.findTaxTransactions(); mainFilterBox.collapse();"/>
            </mx:VBox>
        </controls:FilterBox>
        </mx:VBox>
        <mx:VBox
        styleName="standardTabbedBody"
        id="dataContainer"
        visible="{!viewModel.isDataLoading}"
        includeInLayout="{!viewModel.isDataLoading}"
        width="100%"
        height="100%"
        paddingRight="0"
        paddingLeft="0"
        paddingTop="0"
        paddingBottom="0"
        >
            <mx:Spacer height="10"></mx:Spacer>
            <containers:SuperTabNavigator id="taxLedgerTab"
                    width="100%" resizeToContent="true"
                    visible="{viewModel.taxTransactions != null ? viewModel.taxTransactions.length > 0 : false}"
                    includeInLayout="{viewModel.taxTransactions != null ? viewModel.taxTransactions.length > 0 : false}"
                    horizontalGap="4"
                    minTabWidth="80"
                    closePolicy="{SuperTab.CLOSE_NEVER}"
                    borderSides="top" tabHeight="20">
                <mx:Repeater
                        id="lawTransactionsRepeater"
                        dataProvider="{viewModel.taxTransactions}"
                        recycleChildren="true">
                    <mx:VBox width="100%" verticalGap="0" paddingTop="0" paddingBottom="0"
                             label="{LawTransactions(lawTransactionsRepeater.currentItem).label()}" verticalScrollPolicy="off"/>
                </mx:Repeater>
            </containers:SuperTabNavigator>

            <mx:ViewStack id="taxLedgerViewStack" width="100%" height="100%" resizeToContent="true" paddingLeft="10" paddingRight="10" verticalScrollPolicy="off"/>

        </mx:VBox>
    </mx:Box>

    <controls:PopUpPart id="paymentsHoldsHistoryModal" label="{CompanyInspectorPageEnum.TAX_LEDGER_HOLDS_POPUP+'_pup'}" showCloseButton="true"
                        resizeToContent="true" accountForVerticalScrollBar="true" horizontalResizeEnabled="false" verticalResizeEnabled="false">
        <pspui:PaymentsHoldsHistoryPopUp id="paymentsHoldsHistory" label="{CompanyInspectorPageEnum.TAX_LEDGER_HOLDS_POPUP}"/>
    </controls:PopUpPart>
    <controls:PopUpPart id="paymentsStatusHistoryModal" label="{PaymentsPageEnum.STATUS_POPUP+'_pup'}" showCloseButton="true"
                        resizeToContent="true" accountForVerticalScrollBar="true" horizontalResizeEnabled="false" verticalResizeEnabled="false">
        <pspui:PaymentsStatusHistoryPopUp id="paymentsStatusHistory" label="{PaymentsPageEnum.STATUS_POPUP}"/>
    </controls:PopUpPart>
    <controls:PopUpPart id="paymentsPayDateHistoryModal" label="{PaymentsPageEnum.PAYDATE_POPUP+'_pup'}" showCloseButton="true"
                        resizeToContent="true" accountForVerticalScrollBar="true" horizontalResizeEnabled="false" verticalResizeEnabled="true">
        <pspui:PaymentsPayDateHistoryPopUp id="paymentsPayDateHistory" label="{PaymentsPageEnum.PAYDATE_POPUP}"/>
    </controls:PopUpPart>

    <controls:PopUpPart id="ledgerDetailPopUpPart" showCloseButton="true"
                        horizontalResizeEnabled="false" verticalResizeEnabled="false" resizeToContent="true"
                        label="{CompanyInspectorPageEnum.TAX_LEDGER_DETAIL+'_pup'}">
        <pspui:TaxLedgerDetailView label="{CompanyInspectorPageEnum.TAX_LEDGER_DETAIL}"/>
    </controls:PopUpPart>

</mx:VBox>
