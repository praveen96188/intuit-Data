<?xml version="1.0" encoding="utf-8"?>
<mx:VBox
        xmlns:pspui="psp.sap.view.*"
        xmlns="*" xmlns:mx="http://www.adobe.com/2006/mxml"
        xmlns:controls="psp.sap.view.controls.*"
        xmlns:flexlib="flexlib.controls.*"
        width="100%" height="100%"        
        creationComplete="onCreationComplete()">
    <mx:Script>
		<![CDATA[
        import mx.controls.Alert;
        import mx.events.CloseEvent;

        import psp.sap.model.CompanyBankAccount;
        import psp.sap.viewmodel.CompanyBankViewModel;

        private var companyBankAccountToVerify:CompanyBankAccount;

        private var mViewModel:CompanyBankViewModel;
        private var mTempViewModel:CompanyBankViewModel;
        private var mCreationComplete:Boolean = false;


        [Bindable]
        public function get viewModel():CompanyBankViewModel {
            return mViewModel;
        }

        public function set viewModel(value:CompanyBankViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
                mViewModel.addEventListener("onReinitiateSucceeded", onReinitiateSucceeded, false, 0, true);
            } else {
                mTempViewModel = value;
            }
        }


        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }


        public function resetAttemptsConfirm(event:ActionLinkEvent):void {
            Alert.show("Attempts have been reset",
                    null,
                    Alert.OK,
                    this,
                    function (evt_obj:CloseEvent):void {
                        if (evt_obj.detail == Alert.OK) {
                            viewModel.resetAttempts();
                        }
                    },
                    null,
                    Alert.OK);
        }

        public function onReinitiateSucceeded(e:Event):void {
            Alert.show("Random debits created", null, Alert.OK,
                    null,
                    null,
                    null,
                    Alert.OK);
        }

        public function createRandomDebitTransactions(event:ActionLinkEvent):void {
            viewModel.createRandomDebits();
        }
        ]]>
    </mx:Script>
    
    <controls:DataLoadFade id="postLoadFadeIn" target="{dataContainer}" isLoading="{viewModel.isDataLoading}" />

    <mx:HBox 
    	width="100%"
    	id="dataContainer"
    	visible="{!viewModel.isDataLoading}"
    	includeInLayout="{!viewModel.isDataLoading}">
        <mx:VBox width="40%">
            <mx:HBox>
                <mx:Label text="Company Banks" styleName="heading" width="190"/>
                <mx:Button id="editBankButton"
                           label="Edit Bank"
                           width="100"
                           click="viewModel.showEditAccount()"
                           visible="{viewModel.canAddEdit}"
                           includeInLayout="{viewModel.canAddEdit}"
                           enabled="{viewModel.mayAddEdit}"/>
                <mx:Button id="addBankButton"
                           label="Add Bank"
                           width="100"
                           click="viewModel.showAddAccount()"
                           visible="{viewModel.canAddEdit}"
                           includeInLayout="{viewModel.canAddEdit}"
                           enabled="{viewModel.mayAddEdit}"/>
            </mx:HBox>
            
            <mx:VBox id="companyBox" width="100%"
                     horizontalGap="0" verticalGap="0"
                     verticalScrollPolicy="off" horizontalScrollPolicy="off">                         
                <mx:VBox
                        paddingLeft="2"
                        paddingTop="2"
                        paddingRight="2"
                        backgroundColor="#f4f4f4"
                        cornerRadius="9"
                        borderColor="#000000"
                        borderThickness="1"
                        borderStyle="solid"
                        width="400"
                        visible="{!viewModel.bankAccountExists}"
                        includeInLayout="{!viewModel.bankAccountExists}"
                        horizontalAlign="center">
                    <mx:Label id="noActiveBankAccountLabel" text="No active or pending bank accounts "/>
                </mx:VBox>
                <mx:HBox styleName="companyInformationBoxStyle" paddingLeft="0" horizontalGap="0"
                         includeInLayout="{viewModel.bankAccountExists}"
                         visible="{viewModel.bankAccountExists}">
                    <mx:VBox verticalGap="0" name="bankInfoBox">
                        <mx:HBox styleName="upperSubCompanyInfoBoxStyle" width="400">
                            <mx:HBox verticalAlign="middle">
                                <mx:Label text="Routing Number" width="150" paddingLeft="5"/>
                            </mx:HBox>

                            <mx:HBox verticalAlign="middle" styleName="dataBoxStyle" width="100%">
                                <mx:Text id="routingNumberText" text="{viewModel.bankAccount.routingNumber}" paddingLeft="5"/>
                            </mx:HBox>
                        </mx:HBox>
                        <mx:HBox styleName="upperSubCompanyInfoBoxStyle" width="400">
                            <mx:HBox verticalAlign="middle">
                                <mx:Label text="Account Number" width="150" paddingLeft="5"/>
                            </mx:HBox>

                            <mx:HBox verticalAlign="middle" styleName="dataBoxStyle" width="100%">
                                <mx:Text id="accountNumberText" text="{UIUtils.maskBankAccountNumbers(viewModel.bankAccount.accountNumber)}" paddingLeft="5"/>
                            </mx:HBox>
                        </mx:HBox>
                        <mx:HBox styleName="upperSubCompanyInfoBoxStyle" width="400">
                            <mx:HBox verticalAlign="middle">
                                <mx:Label text="Account Type" width="150" paddingLeft="5"/>
                            </mx:HBox>

                            <mx:HBox verticalAlign="middle" styleName="dataBoxStyle" width="100%">
                                <mx:Text id="accountTypeText" text="{viewModel.bankAccount.accountType}" paddingLeft="5"/>
                            </mx:HBox>
                        </mx:HBox>
                        <mx:HBox styleName="upperSubCompanyInfoBoxStyle" width="400">
                            <mx:HBox verticalAlign="middle">
                                <mx:Label text="Bank Name" width="150" paddingLeft="5"/>
                            </mx:HBox>

                            <mx:HBox verticalAlign="middle" styleName="dataBoxStyle" width="100%">
                                <mx:Text id="bankNameText" text="{viewModel.bankAccount.bankName}" paddingLeft="5" width="245" />
                            </mx:HBox>
                        </mx:HBox>
                        <mx:HBox styleName="upperSubCompanyInfoBoxStyle" width="400">
                            <mx:HBox verticalAlign="middle">
                                <mx:Label text="QB Account Name" width="150" paddingLeft="5"
                                	visible="{viewModel.showQBAccount}"
                                	includeInLayout="{viewModel.showQBAccount}"/>
                            </mx:HBox>
                            <mx:HBox verticalAlign="middle" styleName="dataBoxStyle" width="100%">
                                <mx:Text id="QBAccountNameText" text="{viewModel.bankAccount.sourceBankAccountName}" paddingLeft="5" width="245"
                                	visible="{viewModel.showQBAccount}"
                                	includeInLayout="{viewModel.showQBAccount}"/>
                            </mx:HBox>
                        </mx:HBox>
                        <mx:HBox width="400">
                            <mx:HBox verticalAlign="middle">
                                <mx:Label text="Bank Account Status" width="142" paddingLeft="5"/>
                            </mx:HBox>

                            <mx:HBox verticalAlign="middle" styleName="dataBoxStyle" width="100%">
                                <mx:Text id="bankAccountStatusText"
                                         text="{viewModel.bankAccountStatusText}"
                                         color="{viewModel.bankAccountStatusColor}"
                                         paddingLeft="5"/>
                                <pspui:ActionLink id="verifyLink"
                                                  label="Verify Account"
                                                  enabled="{viewModel.mayVerifyBank}"
                                                  click="viewModel.verifyAccount();"
                                                  visible="{viewModel.isPendingVerification || viewModel.isPendingRandomDebit}"
                                                  includeInLayout="{viewModel.isPendingVerification || viewModel.isPendingRandomDebit}"/>
                            </mx:HBox>
                        </mx:HBox>                            
                    </mx:VBox>
                </mx:HBox>
                <mx:Spacer height="5"/>
                <mx:HBox width="400" horizontalAlign="right">                    	                    
                	<pspui:ActionLink label="History" automationName="companyBankHistoryLink" click="viewModel.goToCompanyBankHistory();"/>
                </mx:HBox>
                	
                <mx:Spacer height="20"/>

                <!-- second set -->
                <mx:VBox verticalGap="0" styleName="companyInformationBoxStyle"
                         name="bankInfoBox" visible="{viewModel.isPendingVerification}"
                         includeInLayout="{viewModel.isPendingVerification}">
                    <mx:HBox styleName="upperSubCompanyInfoBoxStyle" width="400" verticalAlign="top" visible="{viewModel.isPendingVerification}" includeInLayout="{viewModel.isPendingVerification}">
                        <mx:HBox verticalAlign="top">
                            <mx:Label text="Failed Verification Account" width="188" paddingLeft="5" paddingTop="5"/>
                        </mx:HBox>

                        <mx:HBox verticalAlign="top" styleName="dataBoxStyle" width="38" horizontalAlign="left">
                            <mx:Text  id="verifyRetryCountText"
                                      text="{viewModel.bankAccount.verifyRetryCount}"
                                      paddingLeft="3"
                                      paddingTop="5"/>
                        </mx:HBox>
                        <mx:HBox verticalAlign="top" styleName="dataBoxStyle" horizontalAlign="left">
                            <pspui:ActionLink
                                id="resetAttemptsLink"
                                label="Reset Attempts"
                                paddingTop="5"
                                actionClick="{resetAttemptsConfirm}"
                                visible="{viewModel.canResetAttempts}"                                
                                enabled="{viewModel.mayResetAttempts}"/>                                
                        </mx:HBox>
                    </mx:HBox>

                    <mx:HBox  width="400" verticalAlign="top" visible="{viewModel.isPendingVerification}" includeInLayout="{viewModel.isPendingVerification}">
                        <mx:HBox verticalAlign="top">
                            <mx:Label text="Pending Random Debit" width="180" paddingLeft="5"  paddingTop="5"/>
                        </mx:HBox>

                        <mx:HBox styleName="dataBoxStyle" horizontalAlign="left" width="30" verticalAlign="top">
                            <mx:Label id="pendingRandomDebitLabel" text="{viewModel.isPendingRandomDebitString}" paddingLeft="3"  paddingTop="5"/>

                        </mx:HBox>
                        <mx:HBox styleName="dataBoxStyle"  horizontalAlign="left" verticalAlign="top">
                            <pspui:ActionLink 	id="linkAction"
                                                          label="Create Random Debits"
                                                          actionClick="{createRandomDebitTransactions}"
                                                          visible="{viewModel.canGenerateDebits}"
                                                          enabled="{viewModel.mayGenerateDebits}"/>
                        </mx:HBox>
                    </mx:HBox>
                </mx:VBox>

                <mx:VBox verticalGap="0"
                         visible="{viewModel.verificationDebitsVisible}"
                         includeInLayout="{viewModel.verificationDebitsVisible}">
                    <mx:Spacer height="30"/>
                    <mx:Label id="randomDebitLogLabel"
                              text="Random Debit Transaction Log"
                              fontSize="20" paddingLeft="5"/>
                    <mx:Spacer height="5"/>
                    <mx:HBox width="100%"
                             height="100%"
                             paddingLeft="5"
                             paddingRight="5">
                        <mx:DataGrid
                                paddingRight="18"
                                id="results"
                                width="500"
                                rowCount="7"
                                selectable="false"
                                dataProvider="{viewModel.randomVerificationTxns}"
                                height="250"
                                textAlign="left">
                            <mx:columns>
                                 <mx:DataGridColumn
									 minWidth="60"
							 		 dataField="offloadedDate"
							 		 headerText="Offloaded Date"
                                     textAlign="center">							
									<mx:itemRenderer>		
										<mx:Component>
										<mx:VBox>																							
											<mx:Script>
												<![CDATA[
                                                import psp.sap.model.RandomDebitTransaction;
                                                import psp.sap.viewmodel.CompanyBankViewModel;
                                                ]]>
											</mx:Script>
												<mx:Label
													id="offloadedDateLabel"
                                                    text="{CompanyBankViewModel.formatOffloadDate(data)}"
													color="{UIUtils.getTransactionStatusColor(RandomDebitTransaction(data).offloadedDate)}"
													data="{data}"/>
											</mx:VBox>
										</mx:Component>
									</mx:itemRenderer>
								</mx:DataGridColumn>
                                 
                                <mx:DataGridColumn
                                        headerText="Settlement Date"
                                        textAlign="center"
                                        minWidth="60"
                                        labelFunction="{CompanyBankViewModel.formatSettlementDate}"
                                        dataField="settlementDate"/>

                                <mx:DataGridColumn
                                        headerText="Amount 1"
                                        textAlign="center"
                                        minWidth="60"
                                        labelFunction="{CompanyBankViewModel.formatAmount1}"
                                        dataField="amount1"/>

                                <mx:DataGridColumn
                                        headerText="Amount 2"
                                        textAlign="center"
                                        minWidth="60"
                                        labelFunction="{CompanyBankViewModel.formatAmount2}"
                                        dataField="amount2"/>
                            </mx:columns>
                        </mx:DataGrid>
                    </mx:HBox>
                </mx:VBox>
            </mx:VBox>
        </mx:VBox>

        <mx:VBox>
            <mx:VBox>
                <mx:Label text="Employee Accounts" styleName="heading"/>
                <mx:VBox paddingBottom="2" id="employeeBox"
                         paddingLeft="2"
                         paddingTop="0"
                         paddingRight="2"
                         backgroundColor="#f4f4f4"
                         cornerRadius="9"
                         borderColor="#000000"
                         borderThickness="1"
                         borderStyle="solid">

                    <mx:VBox
                            width="400"
                            visible="{viewModel.employees.length == 0}"
                            includeInLayout="{viewModel.employees.length == 0}"
                            horizontalAlign="center">
                        <mx:Label id="noEEBankAccountsLabel" text="No employee bank accounts "/>
                    </mx:VBox>
                    <mx:Label visible="{viewModel.employees.length == 1000}"
                              includeInLayout="{viewModel.employees.length == 1000}"
                              text="More employees may be present.  Results limited to 1000."/>
                    <controls:SAPDataGrid
                            id="employeesData"
                            borderStyle="none"
                            visible="{viewModel.employees.length > 0}"
                            includeInLayout="{viewModel.employees.length > 0}"
                            dataProvider="{viewModel.employees}"  borderColor="#cccccc"
                            width="400"
                            backgroundColor="#cccccc"
                            headerColors="[#e0e0e0, #e0e0e0]"
                            alternatingItemColors="[#f4f4f4, #f4f4f4]"
                            selectionColor="#f4f4f4"
                            rollOverColor="#e9e9e9"
                            maxRows="10">
                        <controls:columns>
                            <mx:DataGridColumn
                                    id="eeDataColumn"
                                    draggable="false"
                                    headerText="{viewModel.employeeHeaderText}"
                                    textAlign="left"
                                    dataField="lastName">
                                <mx:itemRenderer>
                                    <mx:Component id="viewEEBAHistoryLink">
                                        <pspui:ActionLink paddingTop="0" paddingBottom="0"  rollOverColor="#e9e9e9" selectionColor="#e9e9e9" label="{CompanyBankViewModel.getFullNameDisplay(data)}" click="outerDocument.viewModel.goToEmployeeBankHistory(data);">
                                            <mx:Script><![CDATA[
                                                import psp.sap.viewmodel.CompanyBankViewModel;
                                                ]]></mx:Script>
                                        </pspui:ActionLink>
                                    </mx:Component>
                                </mx:itemRenderer>
                            </mx:DataGridColumn>
                        </controls:columns>
                    </controls:SAPDataGrid>
                </mx:VBox>
            </mx:VBox>

            <mx:VBox
                    visible="{viewModel.vendors.length > 0}"
                    includeInLayout="{viewModel.vendors.length > 0}">
                <mx:Label text="Vendor Accounts" styleName="heading"/>
                <mx:VBox paddingBottom="2"
                         paddingLeft="2"
                         paddingTop="0"
                         paddingRight="2"
                         backgroundColor="#f4f4f4"
                         cornerRadius="9"
                         borderColor="#000000"
                         borderThickness="1"
                         borderStyle="solid">

                    <controls:SAPDataGrid
                            borderStyle="none"
                            dataProvider="{viewModel.vendors}"  borderColor="#cccccc"
                            width="400"
                            backgroundColor="#cccccc"
                            headerColors="[#e0e0e0, #e0e0e0]"
                            alternatingItemColors="[#f4f4f4, #f4f4f4]"
                            selectionColor="#f4f4f4"
                            rollOverColor="#e9e9e9"
                            maxRows="10">
                        <controls:columns>
                            <mx:DataGridColumn
                                    draggable="false"
                                    headerText="{viewModel.vendorHeaderText}"
                                    textAlign="left"
                                    dataField="name">
                                <mx:itemRenderer>
                                    <mx:Component>
                                        <pspui:ActionLink
                                                paddingTop="0"
                                                paddingBottom="0"
                                                rollOverColor="#e9e9e9"
                                                selectionColor="#e9e9e9"
                                                label="{data.name}"
                                                click="outerDocument.viewModel.goToVendorBankHistory(data);"/>
                                    </mx:Component>
                                </mx:itemRenderer>
                            </mx:DataGridColumn>
                        </controls:columns>
                    </controls:SAPDataGrid>
                </mx:VBox>
            </mx:VBox>
        </mx:VBox>
    </mx:HBox>

    
</mx:VBox>
