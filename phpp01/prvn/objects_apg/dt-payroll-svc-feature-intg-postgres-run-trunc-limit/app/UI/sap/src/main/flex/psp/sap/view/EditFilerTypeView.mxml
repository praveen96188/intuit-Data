<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*"
         creationComplete="onCreationComplete();"
         minWidth="557"
         verticalGap="0">
    <mx:Script>
        <![CDATA[
        import mx.controls.Alert;
        import mx.events.CloseEvent;

        import psp.sap.viewmodel.EditFilerTypeViewModel;

        private var mViewModel:EditFilerTypeViewModel;
        private var mTempViewModel:EditFilerTypeViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():EditFilerTypeViewModel {
            return mViewModel;
        }

        public function set viewModel(value:EditFilerTypeViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            } else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }

        private function confirmSave():void {
            var msgString:String = "Are you sure you want to update the filer type?";
            Alert.show(msgString,
                    "Update Filer Type Confirmation",
                    Alert.YES | Alert.NO,
                    null,
                    function (e:CloseEvent):void {
                        if (e.detail == Alert.YES) {
                            viewModel.save();
                        }
                    },
                    null,
                    Alert.YES);
        }
        ]]>
    </mx:Script>

    <mx:Label text="Edit Filer Type"
              styleName="headerBorder" id="headerLabel" paddingLeft="2" paddingBottom="0"
              paddingTop="5"/>


    <mx:Form>
        <mx:FormItem label="Filer Type">
            <controls:SAPComboBox dataField="filerType.filerType"
                                  dataProvider="{viewModel.filerTypes}"/>
        </mx:FormItem>
        <mx:FormItem label="Effective Quarter" direction="horizontal">
            <controls:SAPComboBox dataField="filerType.effectiveQuarter.year"
                                  dataProvider="{viewModel.taxYears}"/>
            <controls:SAPComboBox dataField="selectedQuarter"
                                  dataProvider="{viewModel.taxQuarters}"
                                  labelField="label"/>

        </mx:FormItem>
    </mx:Form>


    <mx:HBox horizontalAlign="right" width="500">
        <mx:Button id="cancelButton" label="Cancel" click="viewModel.cancel()"/>
        <mx:Button id="saveButton" label="Save" click="confirmSave()" enabled="{viewModel.canSave}"/>
    </mx:HBox>



</mx:VBox>
