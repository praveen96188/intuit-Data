<?xml version="1.0" encoding="utf-8"?>
<mx:VBox xmlns="*"
         xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:pspui="psp.sap.view.*"
         xmlns:controls="psp.sap.view.controls.*"
         width="100%"
         height="100%"
         creationComplete="onCreationComplete();" xmlns:formatters="psp.sap.formatters.*">
    <mx:Script>
		<![CDATA[
        import psp.sap.application.SAP;
        import mx.controls.dataGridClasses.DataGridColumn;
        import mx.controls.DataGrid;
        import psp.sap.formatters.SAPCurrencyFormatters;
        import psp.sap.service.AMFSerializer;
        import psp.sap.viewmodel.TaxLedgerDetailViewModel;
        import psp.app.util.CommonUtil;

        private var mViewModel:TaxLedgerDetailViewModel;
        private var mTempViewModel:TaxLedgerDetailViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():TaxLedgerDetailViewModel {
            return mViewModel;
        }

        public function set viewModel(value:TaxLedgerDetailViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            }
            else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }

        private function formatNumber(item:Object, dgc:DataGridColumn):String {
            return SAPCurrencyFormatters.currencyFormatterNoSymbol.format(item[dgc.dataField]);
        }

        public function totalWages(dataGrid:DataGrid, col:DataGridColumn):String {
            if(viewModel != null){
                return SAPCurrencyFormatters.currencyFormatterNoSymbol.format(viewModel.totalWagesTotal);
            }

            return "0.00";
        }

        public function taxableWages(dataGrid:DataGrid, col:DataGridColumn):String {
            if(viewModel != null){
                return SAPCurrencyFormatters.currencyFormatterNoSymbol.format(viewModel.taxableWagesTotal);
            }

            return "0.00";
        }

        public function taxTips(dataGrid:DataGrid, col:DataGridColumn):String {
            if(viewModel != null){
                return SAPCurrencyFormatters.currencyFormatterNoSymbol.format(viewModel.taxTipsTotal);
            }
            return "0.00";
        }

        public function taxAmount(dataGrid:DataGrid, col:DataGridColumn):String {
            if(viewModel != null){
                return SAPCurrencyFormatters.currencyFormatterNoSymbol.format(viewModel.taxAmountTotal);
            }

            return "0.00";
        }

        private function formatSSN(item:Object, dgc:DataGridColumn):String {
            return UIUtils.maskSSN(item[dgc.dataField]);
        }

        public function exportResults():void {
            var callString:String = "?report=taxLedgerItemDetailsReport" +
                    "&detailsCriterion=" + new AMFSerializer().serializeToString(viewModel.ledgerItemDetailsCriterion) +
                    "&token=" + blankIfNull(SAP.instance.session.user.authorizationToken) +
                    "&export=true";
            if(CommonUtil.isDTApp()) {
                CommonUtil.showPrintWindow(callString, "Print");
            } else {
                ExternalInterface.call("showPrintWindow", callString);
            }
        }

        public function blankIfNull(c:*):* {
            return (c == null) ? "" : c;
        }

		]]>
	</mx:Script>
    <mx:DateFormatter id="dateFormatter" formatString="{SAP.instance.configuration.dateFormatShort}" />
    <formatters:SSNFormatter id="ssnFormatter"/>

    <mx:VBox
            id="content"
            styleName="grayDataGridVBox"
            width="708" visible="{!viewModel.isDataLoading}" includeInLayout="{!viewModel.isDataLoading}">
        <mx:HBox width="100%" textAlign="left" verticalAlign="middle">
            <mx:Label
                    text="Ledger Item Detail - {viewModel.ledgerItemDetailsCriterion.isQTD || viewModel.ledgerItemDetailsCriterion.isYTD ? '' : 'Payroll'}{viewModel.ledgerItemDetailsCriterion.isQTD ? 'QTD as of' : ''}{viewModel.ledgerItemDetailsCriterion.isYTD ? 'YTD as of' : ''} {dateFormatter.format(viewModel.ledgerItemDetailsCriterion.payrollDate)}"
                    styleName="grayDataGridHeading"/>
        </mx:HBox>
        <controls:FooterDataGrid
                id="employeeList"
                dataProvider="{viewModel.employeeLedgerItems}"
                width="700"
                selectable="false">
            <controls:columns>
                <controls:FooterDataGridColumn
                        headerText="Employee Name"
                        dataField="employeeName"
                        textAlign="left">
                    <mx:DataGridColumn
                            dataField="employeeName"
                            textAlign="right"
                            headerText=""/>
                </controls:FooterDataGridColumn>
                <controls:FooterDataGridColumn
                        headerText="SSN"
                        dataField="socialSecurityNumber"
                        labelFunction="formatSSN"
                        textAlign="center"
                        minWidth="100"
                        resizable="false">
                    <mx:DataGridColumn
                            dataField="socialSecurityNumber"
                            textAlign="right"
                            headerText="Total:"/>
                </controls:FooterDataGridColumn>
                <controls:FooterDataGridColumn
                        headerText="Total Wages"
                        dataField="totalWages"
                        labelFunction="formatNumber"
                        textAlign="right"
                        minWidth="100"
                        resizable="false">
                    <mx:DataGridColumn
                            labelFunction="totalWages"
                            dataField="totalWages"
                            textAlign="right"
                            headerText="todo"/>
                </controls:FooterDataGridColumn>
                <controls:FooterDataGridColumn
                        headerText="Taxable Wages"
                        dataField="taxableWages"
                        labelFunction="formatNumber"
                        textAlign="right"
                        minWidth="100"
                        resizable="false">
                    <mx:DataGridColumn
                            labelFunction="taxableWages"
                            dataField="taxableWages"
                            textAlign="right"
                            headerText="todo"/>
                </controls:FooterDataGridColumn>
                <controls:FooterDataGridColumn
                        headerText="Tips"
                        dataField="taxTips"
                        labelFunction="formatNumber"
                        textAlign="right"
                        minWidth="100"
                        visible="{viewModel.showTaxTips}"
                        resizable="false">
                    <mx:DataGridColumn
                            visible="{viewModel.showTaxTips}"
                            labelFunction="taxTips"
                            dataField="taxTips"
                            textAlign="right"
                            headerText="todo"/>
                </controls:FooterDataGridColumn>
                <controls:FooterDataGridColumn
                        headerText="Tax Amount"
                        dataField="taxAmount"
                        labelFunction="formatNumber"
                        textAlign="right"
                        minWidth="100"
                        resizable="false">
                    <mx:DataGridColumn
                            labelFunction="taxAmount"
                            dataField="taxAmount"
                            textAlign="right"
                            headerText="todo"/>
                </controls:FooterDataGridColumn>
            </controls:columns>
        </controls:FooterDataGrid>
        <pspui:ActionLink click="exportResults();" icon="{SAP.instance.icons.exportIcon}" paddingTop="2"
                          labelPlacement="right" label="Export Results" enabled="{viewModel.employeeLedgerItems.length > 0}"/>
    </mx:VBox>
</mx:VBox>
