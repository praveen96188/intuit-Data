<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*"
         creationComplete="onCreationComplete();"
         minWidth="557"
         verticalGap="0">
    <mx:Script>
        <![CDATA[
        import mx.controls.Alert;
        import mx.events.CloseEvent;
        import mx.events.FlexEvent;
        import mx.validators.Validator;

        import psp.sap.model.CompanyFilingAmount;
        import psp.sap.model.QuarterCompanyFilingAmounts;
        import psp.sap.viewmodel.EditAdditionalFilingAmountsViewModel;

        private var mViewModel:EditAdditionalFilingAmountsViewModel;
        private var mTempViewModel:EditAdditionalFilingAmountsViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():EditAdditionalFilingAmountsViewModel {
            return mViewModel;
        }

        public function set viewModel(value:EditAdditionalFilingAmountsViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            } else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }

        public function quarterSelectLabelFunction(item:QuarterCompanyFilingAmounts):String {
            return item.quarter.label;
        }

        private function confirmSave():void {
            var msgString:String = "Are you sure you want to update these additional amounts?";
            Alert.show(msgString,
                    "Update Rate Confirmation",
                    Alert.YES | Alert.NO,
                    null,
                    function (e:CloseEvent):void {
                        if (e.detail == Alert.YES) {
                            viewModel.save();
                        }
                    },
                    null,
                    Alert.YES);
        }

        private function onInputCreationComplete(event:FlexEvent):void {
            var target:TextInput = TextInput(event.currentTarget);
            if (target.parent == null) {
                return;  //the old ones seem to be sticking around for some reason
            }
            Validator(viewModel.validators[target.repeaterIndex]).listener = target;
        }
        ]]>
    </mx:Script>

    <mx:Label text="Edit Additional Filing Amounts/Rates for {viewModel.paymentTemplate.getSimplifiedName()}"
              styleName="headerBorder" id="headerLabel" paddingLeft="2" paddingBottom="0"
              paddingTop="5"/>

    <mx:HBox verticalAlign="middle" paddingBottom="3">
        <mx:Label text="Quarter: " styleName="boldText"/>
        <controls:SAPComboBox dataField="selectedQuarterCompanyFilingAmount"
                              dataProvider="{viewModel.quarterFilingAmounts}"
                              labelFunction="quarterSelectLabelFunction"
                              enabled="{viewModel.userCanEditNonCurrentQuarter}"/>
    </mx:HBox>
    <mx:Grid paddingBottom="3">
        <mx:GridRow>
            <mx:GridItem>
                <mx:Label text="Name" styleName="boldText"/>
            </mx:GridItem>
            <mx:GridItem>
                <mx:Label text="Selected Value" styleName="boldText"/>
            </mx:GridItem>
            <mx:GridItem>
                <mx:Label text="New Value" styleName="boldText"/>
            </mx:GridItem>
        </mx:GridRow>
        <mx:Repeater id="filingAmountRepeater" dataProvider="{viewModel.selectedQuarterCompanyFilingAmount.amounts}">
            <mx:GridRow>
                <mx:GridItem>
                    <mx:Label text="{CompanyFilingAmount(filingAmountRepeater.currentItem).name}"/>
                </mx:GridItem>
                <mx:GridItem>
                    <mx:Label text="{CompanyFilingAmount(filingAmountRepeater.currentItem).formattedValue()}"/>
                </mx:GridItem>
                <mx:GridItem>
                    <mx:TextInput width="90"
                                  restrict="-0-9."
                                  text="{CompanyFilingAmount(filingAmountRepeater.currentItem).newValue}"
                                  change="CompanyFilingAmount(TextInput(event.currentTarget).getRepeaterItem()).newValue = (TextInput(event.currentTarget).text)"
                                  creationComplete="onInputCreationComplete(event)"/>
                    <mx:Label text="%"
                              visible="{CompanyFilingAmount(filingAmountRepeater.currentItem).isRate}"/>
                </mx:GridItem>
            </mx:GridRow>
        </mx:Repeater>
    </mx:Grid>

    <mx:HBox horizontalAlign="right" width="500">
        <mx:Button id="cancelButton" label="Cancel" click="viewModel.cancel()"/>
        <mx:Button id="saveButton" label="Save" click="confirmSave()" enabled="{viewModel.canSave}"/>
    </mx:HBox>



</mx:VBox>
