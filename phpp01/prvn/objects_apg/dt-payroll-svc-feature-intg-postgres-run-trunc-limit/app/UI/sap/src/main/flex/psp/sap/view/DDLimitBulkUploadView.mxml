<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*"
         creationComplete="onCreationComplete();">
    <mx:Script>
		<![CDATA[
        import psp.sap.viewmodel.DDLimitBulkUploadViewModel;

        private var mViewModel:DDLimitBulkUploadViewModel;
        private var mTempViewModel:DDLimitBulkUploadViewModel;
        private var mCreationComplete:Boolean = false;

        private static const fileType:FileFilter = new FileFilter("CSV (Comma delimited) (*.csv)", "*.csv");
        private var fileRef:FileReference;

        [Bindable]
        public function get viewModel():DDLimitBulkUploadViewModel {
            return mViewModel;
        }

        public function set viewModel(value:DDLimitBulkUploadViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
            }
            else {
                mTempViewModel = value;
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;

            fileRef = new FileReference();
            fileRef.addEventListener(Event.SELECT, onFileSelect, false, 0, false);
            fileRef.addEventListener(IOErrorEvent.IO_ERROR, onLoadError, false, 0, true);
            fileRef.addEventListener(Event.COMPLETE, onLoadComplete, false, 0, true);
        }

        public function loadFile():void {
            fileRef.browse([fileType]);
        }

        public function onFileSelect(e:Event):void {
            fileRef.load();
        }

        public function onLoadComplete(e:Event):void {
            viewModel.fileName = fileRef.name;
            viewModel.fileContents = fileRef.data.toString();
        }

        public function onLoadError(e:IOErrorEvent):void {
            viewModel.saveFaulted = true;
            viewModel.saveMsg = "Error loading file: " + e.text;
        }
        ]]>
    </mx:Script>

    <mx:Label text="Upload a file" styleName="h3"/>
    <mx:HBox verticalAlign="middle" paddingLeft="20">
        <controls:RequiredLabel text="File Name:" dataField="fileData"/>
        <mx:TextInput text="{viewModel.fileName}" minWidth="200" click="loadFile()"/>
        <mx:Button label="Browse" click="loadFile()"/>
    </mx:HBox>
    <mx:HBox paddingLeft="20" paddingBottom="20">
        <mx:Button label="Upload" enabled="{viewModel.canSave}" click="viewModel.save();"/>
    </mx:HBox>


</mx:VBox>
