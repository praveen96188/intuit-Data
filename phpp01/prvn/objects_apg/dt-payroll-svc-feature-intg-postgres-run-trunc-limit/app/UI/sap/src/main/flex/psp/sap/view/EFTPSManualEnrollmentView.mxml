<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.sap.view.controls.*">
    <mx:Script>
        <![CDATA[
        import mx.controls.Alert;
        import mx.events.CloseEvent;

        import psp.sap.viewmodel.EFTPSManualEnrollmentViewModel;

        [Bindable]
        public var viewModel:EFTPSManualEnrollmentViewModel;

        private function confirmSave():void {
            var msgString:String = "Are you sure you want to create this manual EFTPS enrollment?";
            Alert.show(msgString,
                    "Save Confirmation",
                    Alert.OK | Alert.CANCEL,
                    null,
                    function (e:CloseEvent):void {
                        if (e.detail == Alert.OK) {
                            viewModel.save();
                        }
                    },
                    null,
                    Alert.OK);
        }
        ]]>
    </mx:Script>
    <mx:Label text="Create Manual EFTPS Enrollment" styleName="subheading" paddingLeft="2" paddingBottom="0"/>
    <mx:Form paddingTop="0">
        <mx:FormItem label="EIN:">
            <controls:SAPTextInput dataField="ein" width="120"/>
        </mx:FormItem>
        <mx:FormItem label="Legal Name:">
            <controls:SAPTextInput dataField="legalName" width="350"/>
        </mx:FormItem>
        <mx:FormItem label="Legal Zip:">
            <controls:SAPTextInput restrict="0-9" dataField="legalZip" width="60"/>
        </mx:FormItem>
        <mx:FormItem direction="horizontal">
            <mx:Button label="Cancel" click="viewModel.cancel()" />
            <mx:Button label="Save" click="confirmSave()" enabled="{viewModel.canSave}"/>
        </mx:FormItem>
    </mx:Form>

</mx:VBox>
