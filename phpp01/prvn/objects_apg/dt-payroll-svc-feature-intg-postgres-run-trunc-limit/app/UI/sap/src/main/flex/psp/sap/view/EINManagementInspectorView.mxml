        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{EINManagementInspectorPageEnum.ADD_EIN}">
            <pspui:EINAddCompanyView/>
        </pspui:SinglePartPageView>
    </pspui:pages>

</pspui:AbstractInspectorView>