	xmlns:pspui="psp.sap.view.*">

	<mx:Script>
		<![CDATA[
        import psp.sap.application.enums.EINManagementInspectorPageEnum;        
		]]>
	</mx:Script>

    <pspui:pages>
        <pspui:SinglePartPageView baseLabel="{EINManagementInspectorPageEnum.EINS}">
