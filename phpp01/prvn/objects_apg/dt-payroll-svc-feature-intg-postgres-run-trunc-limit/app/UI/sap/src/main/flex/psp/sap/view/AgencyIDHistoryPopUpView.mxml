<?xml version="1.0"?>
<mx:VBox xmlns:mx="http://www.adobe.com/2006/mxml"
         xmlns:controls="psp.sap.view.controls.*"
         width="620"
         creationComplete="onCreationComplete();"
         verticalGap="0"
         paddingLeft="5"
         paddingRight="5">
    <mx:Script>
        <![CDATA[
        import psp.sap.viewmodel.AgencyIDHistoryPopUpViewModel;

        private var mViewModel:AgencyIDHistoryPopUpViewModel;
        private var mTempViewModel:AgencyIDHistoryPopUpViewModel;
        private var mCreationComplete:Boolean = false;

        [Bindable]
        public function get viewModel():AgencyIDHistoryPopUpViewModel {
            return mViewModel;
        }

        public function set viewModel(value:AgencyIDHistoryPopUpViewModel):void {
            if (value != null) {
                if (mCreationComplete) {
                    mViewModel = value;
                }
                else {
                    mTempViewModel = value;
                }
            }
        }

        public function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;
        }
        ]]>
    </mx:Script>
    <mx:Label text="Agency ID History" styleName="heading" id="headerLabel" paddingLeft="2" paddingBottom="13" paddingTop="5"/>

    <controls:SAPDataGrid dataProvider="{viewModel.agencyIds}"
                          width="100%" maxRows="10"
                          selectable="false"
                          draggableColumns="false">
        <controls:columns>
            <mx:DataGridColumn sortable="true"
                               headerText="Changed On"
                               width="150"
                               dataField="createdDate"
                               labelFunction="SAPDataGrid.formatDateTimeMedium"
                               paddingLeft="5"/>
            <mx:DataGridColumn sortable="true"
                               headerText="Old Agency Id"
                               width="120"
                               dataField="oldPropertyValue"
                               paddingLeft="5"/>
            <mx:DataGridColumn sortable="true"
                               headerText="New Agency Id"
                               width="120"
                               dataField="newPropertyValue"
                               paddingLeft="5"/>
            <mx:DataGridColumn sortable="true"
                               headerText="Modified By"
                               width="120"
                               dataField="userId"
                               paddingLeft="5"/>
        </controls:columns>
    </controls:SAPDataGrid>
</mx:VBox>