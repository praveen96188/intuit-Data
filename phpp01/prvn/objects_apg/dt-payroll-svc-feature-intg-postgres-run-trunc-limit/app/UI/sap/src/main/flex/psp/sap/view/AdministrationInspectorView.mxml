        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{AdministrationInspectorPageEnum.DD_EDIT_ROLES}">
            <pspui:DDEditRoleView/>
        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{AdministrationInspectorPageEnum.SYSTEM_PARAMETERS}">
            <pspui:SystemParametersView/>
        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{AdministrationInspectorPageEnum.SQL_ADMINISTRATION}">
            <pspui:SqlAdministrationView/>
        </pspui:SinglePartPageView>
    </pspui:pages>

</pspui:AbstractInspectorView>
