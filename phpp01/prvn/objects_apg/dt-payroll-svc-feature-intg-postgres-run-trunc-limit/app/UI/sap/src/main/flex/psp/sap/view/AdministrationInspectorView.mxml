<?xml version="1.0" encoding="utf-8"?>
<pspui:AbstractInspectorView
        xmlns:mx="http://www.adobe.com/2006/mxml"
        xmlns:pspui="psp.sap.view.*">

    <mx:Script>
		<![CDATA[
        import psp.sap.application.enums.AdministrationInspectorPageEnum;
		]]>
	</mx:Script>

    <pspui:pages>

        <pspui:SinglePartPageView baseLabel="{AdministrationInspectorPageEnum.SETTINGS}">
            <pspui:AdministrationSettingsPageView/>
        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{AdministrationInspectorPageEnum.SETTINGS_EDIT}">
            <pspui:AdministrationSettingsEditPageView/>
        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{AdministrationInspectorPageEnum.FRAUD_SETTINGS}">
            <pspui:FraudSettingsPageView/>
