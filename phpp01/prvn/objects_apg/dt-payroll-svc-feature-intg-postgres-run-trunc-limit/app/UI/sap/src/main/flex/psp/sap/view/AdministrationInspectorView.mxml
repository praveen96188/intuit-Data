        <pspui:SinglePartPageView baseLabel="{AdministrationInspectorPageEnum.FRAUD_SETTINGS_EDIT}">
            <pspui:FraudSettingsEditPageView/>
        </pspui:SinglePartPageView>

        <pspui:SinglePartPageView baseLabel="{AdministrationInspectorPageEnum.MANAGE_ROLES}">
