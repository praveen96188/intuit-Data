                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYCHECK_LINE_ITEMS}">
                        <pspui:EmployeeLineItemsView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_TRANSACTION_LIST}">
                        <pspui:PayrollTransactionsListView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_VENDOR_TRANSACTION_LIST}">
                        <pspui:PayrollTransactionsListView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_TRANSACTION_CANCEL}">
                        <pspui:PayrollTransactionCancelView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_TRANSACTION_REVERSE}">
