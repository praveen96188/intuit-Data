                        <pspui:CompanyLimitViolationsView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.COMPANY_OFFERS}">
                        <pspui:CompanyOffersView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.COMPANY_OFFERINGS}">
                        <pspui:CompanyOfferingsView/>
