                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.VIEW_MY_PAYCHECK_INFO}">
                        <pspui:VMPEmployeeListView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.VIEW_MY_PAYCHECK_EMPLOYEE_INFO}">
                        <pspui:VMPEmployeeView/>
                    </pspui:SinglePartPageView>

                </pspui:ViewStackControlEx>

                <pspui:GradientBox
                        gradientDirection="horizontal"
                        colors="[#F4F4F4, #CED5E5]"
                        direction="horizontal"
                        id="noteBar"
                        width="{inspectorCanvas.width}"
                        includeInLayout="false"
                        visible="false"
                        styleName="notesBox"
                        minHeight="100"
                        verticalScrollPolicy="off"
                        show="{noteText.setFocus()}">

                    <mx:HBox width="100%" height="100%" horizontalAlign="right" paddingBottom="10" paddingLeft="10"
                             paddingRight="10">
                        <mx:TextArea id="noteText" height="100%" width="100%" maxChars="3998"/>
                        <mx:VBox height="100%" width="100" horizontalAlign="right">
                            <mx:Button label="Save" width="100%" click="viewModel.saveNote()"
                                       enabled="{noteText.text != ''}"/>
                            <mx:Button label="Clear" width="100%" click="viewModel.clearNote()"/>
                            <mx:HBox verticalAlign="middle" styleName="noPadding">
                                <mx:CheckBox id="alertCheckBox" label="Alert" toolTip="Show a link to this note in the company banner"/>
                                <mx:Image source="{SAP.instance.icons.bell}" toolTip="{alertCheckBox.toolTip}"/>
                            </mx:HBox>
                        </mx:VBox>
                    </mx:HBox>
                </pspui:GradientBox>

            </pspui:GradientVDividedBox>

            <pspui:GradientBox
                    gradientDirection="horizontal"
                    colors="[#F4F4F4, #CED5E5]"
                    direction="horizontal"
                    id="fakePanel"
                    width="100%"
                    height="5"
                    styleName="fakePanel"/>

            <mx:HBox height="20" id="notesFakeTab" styleName="fakeTab" click="{viewModel.openOrCloseNote();}"
                     paddingLeft="2" paddingRight="2" paddingTop="1">
                <mx:Label text="{viewModel.company.legalName} Notes"
                          fontWeight="{noteText.text == '' ? 'normal' : 'bold'}"/>
                <mx:Image source="{SAP.instance.icons.addNote}"
                          filters="{noteText.text == '' ? [] : [new GlowFilter(0x7CFC00,1,6,6,4)]}"/>
            </mx:HBox>

        </mx:Canvas>
    </mx:HBox>

    <mx:Binding source="companyInspectorPagesControl.selectedChild" destination="this.selectedChild"/>
    <mx:Binding source="viewModel.activePageLabel" destination="companyInspectorPagesControl.selectedChildLabel"/>
    <mx:Binding source="companyInspectorPagesControl.selectedChildLabel" destination="viewModel.activePageLabel"/>

    <mx:Binding source="viewModel.topics" destination="topicNavigationMenu.dataProvider"/>
    <mx:Binding source="viewModel.activeTopic" destination="topicNavigationMenu.selectedItem"/>

    <mx:Binding source="viewModel.noteViewState" destination="currentState"/>
    <mx:Binding source="topicNavigationMenu.width" destination="companyBanner.contentSpacer.width"/>

    <mx:Binding source="viewModel.noteText" destination="noteText.text"/>
    <mx:Binding source="noteText.text" destination="viewModel.noteText"/>

    <mx:Binding source="viewModel.alert" destination="alertCheckBox.selected"/>
    <mx:Binding source="alertCheckBox.selected" destination="viewModel.alert"/>

    <!-- This keeps the fake "notes" tab where it ought to be, sorry that it's ugly, Raffi, but you work with what you have -->
    <mx:Binding source="{inspectorCanvas.height-fakePanel.height}" destination="fakePanel.y"/>
    <mx:Binding source="{inspectorCanvas.width-notesFakeTab.width - 20}" destination="notesFakeTab.x"/>
    <mx:Binding
            source="{inspectorCanvas.height - notesFakeTab.height - (noteBar.visible ? noteBar.height + 4 : fakePanel.height)}"
            destination="notesFakeTab.y"/>
</mx:VBox>
