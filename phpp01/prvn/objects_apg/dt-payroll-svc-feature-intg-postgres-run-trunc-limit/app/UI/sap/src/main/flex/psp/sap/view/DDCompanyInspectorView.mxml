                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_LEDGER_RECOVER_BAD_DEBT}">
                        <pspui:PayrollLedgerRecoverBadDebtView
