                    <!--pspui:SinglePartPageView
                         label="{CompanyInspectorPageEnum.EMPLOYEES}"
                         id="employeesView"
                         styleName="companyInspector"
                         pageLabel="">
                         <pspui:EmployeesView/>
                     </pspui:SinglePartPageView-->

