<?xml version="1.0" encoding="utf-8"?>
<mx:VBox
        xmlns:mx="http://www.adobe.com/2006/mxml"
        xmlns:intuit="intuit.sbd.flex.framework.view.*"
        xmlns:view="psp.sap.view.*"
        xmlns:pspui="psp.sap.view.*"
        width="100%" height="100%"
        paddingTop="0" paddingLeft="0" paddingBottom="0" paddingRight="0"
        creationComplete="onCreationComplete();"
        verticalGap="0"
        verticalScrollPolicy="off">

    <mx:Script>
		<![CDATA[
        import mx.containers.ViewStack;
        import mx.core.Container;
        import mx.events.FlexEvent;
        import mx.events.ItemClickEvent;
        import mx.logging.ILogger;

        import psp.sap.application.ClientLoggingTarget;
        import psp.sap.application.SAP;
        import psp.sap.application.ViewModelSync;
        import psp.sap.application.enums.CompanyInspectorPageEnum;
        import psp.sap.application.enums.PartsEnum;
        import psp.sap.model.SettlementTypeEnum;
        import psp.sap.viewmodel.AbstractPartViewModel;
        import psp.sap.viewmodel.CompanyInspectorTopicViewModel;
        import psp.sap.viewmodel.CompanyInspectorViewModel;

        private var logger:ILogger = ClientLoggingTarget.getLogger(this);

        private var mCreationComplete:Boolean = false;

        protected var mTempViewModel:CompanyInspectorViewModel;

        /**
         * The ViewModel this view is visually represents.
         */
        protected var mViewModel:CompanyInspectorViewModel;

        [Bindable]
        public function get viewModel():CompanyInspectorViewModel {
            return mViewModel;
        }

        /**
         * When the ViewModel is set, synchronize UI view with viewmodel state.
         * Add listeners so that UI view can track viewmodel state.
         */
        public function set viewModel(value:CompanyInspectorViewModel):void {
            if (mCreationComplete) {
                mViewModel = value;
                this.label = mViewModel.label;
            }
            else
                mTempViewModel = value;

            if (mViewModel != null && mCreationComplete) {
                syncToViewModel();
                showAddNoteState();
            }
        }

        protected function onCreationComplete():void {
            mCreationComplete = true;
            viewModel = mTempViewModel;

        }

        private function syncToViewModel():void {
            for each (var part:AbstractPartViewModel in viewModel.getAllPages()) {
                var pageView:Container = companyInspectorPagesControl.getChildByLabel(part.label);
                if (pageView != null) {
                    pageView["viewModel"] = part;
                    ViewModelSync.associatePageViewModels(pageView, part);
                }
            }

            ViewModelSync.associatePageViewModels(this, viewModel.partHost);
            viewModel.partHost.activate();

        }


        private function onTopicClicked(e:ItemClickEvent):void {
            viewModel.activeTopic = CompanyInspectorTopicViewModel(e.item);
        }


        private function showAddNoteState():void {
            currentState = "addNoteCollapsed";
        }


        public function set selectedChild(value:Container):void {
            var part:AbstractPartViewModel = mViewModel.findPart(value.label);

            if (value.initialized) {
                //value["viewModel"] = page;
                ViewModelSync.associatePageViewModels(value, part);
            } else {
                value.addEventListener(FlexEvent.CREATION_COMPLETE, function (e:FlexEvent):void {
                    ViewModelSync.associatePageViewModels(value, part);
                }, false, 0, false);
            }

        }
        ]]>
    </mx:Script>

    <mx:transitions>
        <mx:Transition fromState="addNoteExpanded" toState="addNoteCollapsed">
            <mx:Sequence>
                <mx:SetPropertyAction target="{viewModel}" name="noteScreenHeight" value="{noteBar.height}"/>
                <mx:Resize target="{noteBar}" duration="200" heightTo="0" widthFrom="{contentArea.width}"
                           widthTo="{contentArea.width}"/>
                <mx:SetPropertyAction target="{noteBar}" name="includeInLayout" value="false"/>
                <mx:SetPropertyAction target="{noteBar}" name="visible" value="false"/>
            </mx:Sequence>
        </mx:Transition>
        <mx:Transition fromState="addNoteCollapsed" toState="addNoteExpanded">
            <mx:Sequence>
                <mx:SetPropertyAction target="{noteBar}" name="includeInLayout" value="true"/>
                <mx:SetPropertyAction target="{noteBar}" name="visible" value="true"/>
                <mx:Resize target="{noteBar}" duration="200" heightFrom="0" heightTo="{viewModel.noteScreenHeight}"
                           widthFrom="{contentArea.width}" widthTo="{contentArea.width}"/>
            </mx:Sequence>
        </mx:Transition>
    </mx:transitions>

    <mx:states>
        <mx:State name="addNoteCollapsed">
            <mx:AddChild relativeTo="{notesFakeTab}" position="lastChild">
                <mx:LinkButton id="openNote" width="20" paddingTop="0" icon="{SAP.instance.icons.upArrowWithBar}"
                               toolTip="Add Note" tabEnabled="false"/>
            </mx:AddChild>
        </mx:State>
        <mx:State name="addNoteExpanded">
            <mx:AddChild relativeTo="{notesFakeTab}" position="lastChild">
                <mx:LinkButton id="closeNote" width="20" paddingTop="0" icon="{SAP.instance.icons.downArrowWithBar}"
                               toolTip="Close Note" tabEnabled="false"/>
            </mx:AddChild>
        </mx:State>

    </mx:states>

    <pspui:CompanyBannerView id="companyBanner" tabEnabled="false" tabChildren="false"
