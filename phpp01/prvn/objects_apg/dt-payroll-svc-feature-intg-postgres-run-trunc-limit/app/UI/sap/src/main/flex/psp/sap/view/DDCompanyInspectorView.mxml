                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_TRANSACTION_CREATE_FEE}">
                        <pspui:PayrollTransactionCreateFeeView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView
                            baseLabel="{CompanyInspectorPageEnum.PAYROLL_TRANSACTION_ISSUE_REISSUE_REFUND}">
                        <pspui:PayrollTransactionIssueReissueRefundView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_LEDGER_FEE_TRANSFER}">
                        <pspui:PayrollLedgerFeeTransfer/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_LEDGER_DD_REFUND}">
                        <pspui:PayrollSettlementPageView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_LEDGER_EE_RETURN_REFUND}">
                        <pspui:PayrollSettlementPageView
                                saveConfirmationMessage="Are you sure you want to issue Refund?"/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_LEDGER_ER_RETURN_REFUND}">
                        <pspui:PayrollSettlementPageView
                                saveConfirmationMessage="Are you sure you want to issue Refund?"/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_TRANSACTION_REFUND_REBILL}">
                        <pspui:PayrollRefundRebillView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.COMPANY_CONNECTIONS}">
                        <pspui:CompanyConnectionsView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_CREATE_EXPECTED_WIRE_DATE}">
                        <pspui:PayrollExpectedWireView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_PREFUNDING}">
                        <pspui:PayrollMultiItemEnteringPageView
                                settlementTypes="{SettlementTypeEnum.non_ach_values}"
                                defaultSettlementType="{SettlementTypeEnum.WIRE}"
                                saveString="Are you sure you want to record Prefunding Transactions?"
                                column1Header="Amount Due"
                                column2Header="Prefunding"/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.DATA_SYNC_SEARCH_VIEW}">
                        <pspui:DataSyncSearchView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.DATA_SYNC_MANAGE_VIEW}">
                        <pspui:DataSyncManageView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.COMPANY_LEDGER}">
                        <pspui:LedgerView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.COURTESY_REFUND}">
                        <pspui:CourtesyRefundView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.COMPANY_LEDGER_ACCOUNT_ENTRIES}">
                        <pspui:LedgerEntriesView/>
                    </pspui:SinglePartPageView>


                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLLS_PITEM_TAXABILITY}">
                        <pspui:PayrollPItemsTaxabilityView/>
                    </pspui:SinglePartPageView>

                    <!-- Banks -->

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.COMPANY_BANK}">
                        <pspui:CompanyBankView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.BANKS_COMPANY_ACCOUNT_HISTORY}">
                        <pspui:BanksCompanyAccountHistoryView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.BANKS_EMPLOYEE_ACCOUNT_HISTORY}">
                        <pspui:BanksEmployeeAccountHistoryView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.BANKS_VENDOR_ACCOUNT_HISTORY}">
                        <pspui:BanksVendorAccountHistoryView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.BANKS_ADD_ACCOUNT}">
                        <pspui:BanksAddBankAccountView/>
                    </pspui:SinglePartPageView>


                    <!-- Connection Log -->

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_CONNECTION_LOG}">
                        <pspui:PayrollConnectionLogView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_CONNECTION_OFX}">
                        <pspui:PayrollConnectionOFXView/>
                    </pspui:SinglePartPageView>


                    <!-- Event Log -->

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.EVENT_LOG}">
