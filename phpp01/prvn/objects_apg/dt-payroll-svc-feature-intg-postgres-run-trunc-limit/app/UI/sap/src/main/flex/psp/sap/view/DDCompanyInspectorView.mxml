                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.CHASE_REPORT}">
                        <pspui:ChaseReportView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.PAYROLL_APPLY_ER_PAYABLE}">
