                        minWidth="100"
                        id="topicNavigationMenu"
                        trackSelectionState="true" separatorWidth="0"
                        height="100%" itemClick="onTopicClicked(event)"
                        direction="vertical"
                        linkButtonStyleName="leftNavigation" paddingRight="0"
                        paddingLeft="10" paddingTop="10" width="115" buttonMinWidth="115" buttonPercentWidth="100"
                        visible="{viewModel.company != null}"/>
                <mx:VBox verticalGap="0" height="100%" id="topicMenuBox">
                    <pspui:GradientBox
                            width="5"
                            verticalAlign="middle"
                            gradientDirection="horizontal"
                            colors="[#F4F4F4, #000000]"
                            direction="horizontal"
                            height="{ViewStack(companyInspectorPagesControl).height > (topicNavigationMenu.selectedChild.y - topicMenuBox.y) ? (topicNavigationMenu.selectedChild.y - topicMenuBox.y) : ViewStack(companyInspectorPagesControl).height}"
                            cornerRadius="3"/>
                    <mx:VBox
                            width="5"
                            height="{topicNavigationMenu.selectedChild.height}"
                            backgroundColor="#FFFFFF"
                            borderStyle="solid"
                            borderColor="#EEEEEE"
                            borderSides="top, bottom"
                            borderThickness="1"/>
                    <pspui:GradientBox
                            width="5"
                            verticalAlign="middle"
                            gradientDirection="horizontal"
                            colors="[#F4F4F4, #000000]"
                            cornerRadius="3"
                            direction="horizontal"
                            height="{ViewStack(companyInspectorPagesControl).height - (topicNavigationMenu.selectedChild.y + topicNavigationMenu.selectedChild.height + 15) > 0 ? ViewStack(companyInspectorPagesControl).height - (topicNavigationMenu.selectedChild.y + topicNavigationMenu.selectedChild.height + 15) : 0}"/>
                </mx:VBox>
            </mx:HBox>
        </mx:VBox>

        <mx:Canvas id="inspectorCanvas" height="100%" width="100%">

            <pspui:GradientVDividedBox
                    gradientDirection="horizontal"
                    colors="[#F4F4F4, #CED5E5]"
                    direction="horizontal"
                    id="contentArea"
                    height="100%"
                    width="100%"
                    liveDragging="false"
                    styleName="dividedVBox">

                <pspui:ViewStackControlEx
