                        <pspui:MmtView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.FINANCIAL_LEDGER_ADJUSTMENT}">
                        <pspui:FinancialLedgerAdjustmentView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView
                            baseLabel="{CompanyInspectorPageEnum.FINANCIAL_LEDGER_ADJUSTMENT_PAYROLL}">
                        <pspui:FinancialLedgerAdjustmentView/>
                    </pspui:SinglePartPageView>

                    <pspui:SinglePartPageView baseLabel="{CompanyInspectorPageEnum.TAX_PENALTIES_AND_INTEREST}">
