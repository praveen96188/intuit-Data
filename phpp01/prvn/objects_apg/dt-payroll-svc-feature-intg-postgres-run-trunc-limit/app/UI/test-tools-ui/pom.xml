    <build>
        <finalName>testtools-${psp.project.version}</finalName>
        <plugins>
            <plugin>
                <artifactId>maven-war-plugin</artifactId>
                <version>2.6</version>
                <configuration>
                    <archiveClasses>true</archiveClasses>
                    <packagingExcludes>WEB-INF/classes/**</packagingExcludes>
                    <packagingExcludes>WEB-INF/lib/payroll-services-api-${psp.project.version}.jar</packagingExcludes>
                    <webResources>
                        <resource>
                            <directory>../../</directory>
                            <targetPath>/</targetPath>
                            <filtering>true</filtering>
                            <includes>
                                <include>appversion.html</include>
                            </includes>
                        </resource>
                    </webResources>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.jvnet.jax-ws-commons</groupId>
                <artifactId>jaxws-maven-plugin</artifactId>
                <version>2.1</version>
                <executions>
                    <execution>
                        <id>test-adapter class gen</id>
                        <configuration>  
                            <packageName>com.intuit.sbd.payroll.psp.webservices.client</packageName>                                 
                            <wsdlDirectory>${project.test-ws.wsdl.uri}</wsdlDirectory>
                            <wsdlFiles>
                                <wsdlFile>PSPDateWSService.wsdl</wsdlFile>
                                <wsdlFile>CompanyWSService.wsdl</wsdlFile>
                                <wsdlFile>OffloadGroupWSService.wsdl</wsdlFile>
                                <wsdlFile>TransactionsWSService.wsdl</wsdlFile>
                                <wsdlFile>TestDataWSService.wsdl</wsdlFile>
                                <wsdlFile>BatchJobsWSService.wsdl</wsdlFile>
                                <wsdlFile>SourceSystemWSService.wsdl</wsdlFile>
                                <wsdlFile>EDIPaymentsWSService.wsdl</wsdlFile>
                                <wsdlFile>EntitlementWSService.wsdl</wsdlFile>
                            </wsdlFiles>
                            <sourceDestDir>${project.target.generated.sources}</sourceDestDir>
                            <verbose>true</verbose>
                        </configuration>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>wsimport</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>ews adapter class gen</id>
                        <configuration>  
                            <packageName>com.intuit.sbd.payroll.psp.webservices.client</packageName>                                 
                            <wsdlDirectory>${project.ews.wsdl.uri}</wsdlDirectory>
                            <wsdlFiles>
                                <wsdlFile>EWSAdapterService.wsdl</wsdlFile>
                            </wsdlFiles>
                            <sourceDestDir>${project.target.generated.sources}</sourceDestDir>
                            <verbose>true</verbose>
                        </configuration>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>wsimport</goal>
                        </goals>
                    </execution>
                </executions>
                <!--if you want to use a specific version of JAX-WS, you can do so like this--> 
                <dependencies>
                    <dependency>
                        <groupId>com.sun.xml.ws</groupId>
                        <artifactId>jaxws-tools</artifactId>
                        <version>2.2.7</version>
                    </dependency>
                </dependencies>
            </plugin>
            <plugin>
                <artifactId>maven-resources-plugin</artifactId>
                <version>2.7</version>
                <executions>
                    <execution>
                        <id>copy-resource-one</id>
                        <phase>install</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>

                        <configuration>
                            <outputDirectory>${project.wars.dir}</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>target</directory>
                                    <includes>
                                        <include>${project.build.finalName}.war</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
