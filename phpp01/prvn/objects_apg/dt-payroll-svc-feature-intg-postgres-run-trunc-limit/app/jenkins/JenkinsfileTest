def sendSlackNotification(Map parameters) {
    def attachments = [
            [
                    "fallback": "Failed - Job '${parameters.jobName} [${parameters.buildNumber}]' (${parameters.buildUrl})",
                    "author_name": "Built by ${parameters.buildUser} [${parameters.buildUserId}]",
                    "author_icon": "https://platform.slack-edge.com/img/default_application_icon.png",
                    "title": "${parameters.buildStatus} - ${parameters.jobName} #${parameters.buildNumber}",
                    "title_link": "${parameters.buildUrl}",
                    "fields": [
                            [
                                    "title": "Branch",
                                    "value": "${parameters.branch}",
                                    "short": true
                            ],
                            [
                                    "title": "Build Duration",
                                    "value": "${parameters.buildDuration}",
                                    "short": true
                            ],
                            [
                                    "title": "Full Build?",
                                    "value": "${parameters.fullBuild}",
                                    "short": true
                            ]
                    ],
                    "color": "${parameters.statusColor}"
            ]
    ]
    slackSend (attachments: attachments)
}

def execute(Integer suiteId,String groupId, String mvnString, String monolithDb, String auditDb){
    build(mvnString, monolithDb, auditDb)
    def intgConfig = load "./app/jenkins/IntgConfig.groovy"
    def arr = intgConfig.getSuite(suiteId)
    for(i in arr){
        runSuite("${groupId}:${i}", mvnString, monolithDb, auditDb)
    }
}


def build(String mvnString, String monolithDb, String auditDb){
    sh """
        chmod 775 ./app/jenkins/check_db_connection.sh
        ./app/jenkins/check_db_connection.sh
    """
    sh """
        echo "PSP build"
        cd app;
        curl https://artifact.intuit.com/artifactory/maven-proxy-cache/org/aspectj/aspectjweaver/1.8.13/aspectjweaver-1.8.13.jar -o aspectjweaver.jar
        mvn ${mvnString} clean install -Ddatabase.monolith=${monolithDb} -Ddatabase.audit=${auditDb} -DskipTests -T 2C
    """
}


def runSuite(String suite, String mvnString, String monolithDb, String auditDb){

    sh """
        echo "Running test suite ${suite}"
        cd app;
        curl https://artifact.intuit.com/artifactory/maven-proxy-cache/org/aspectj/aspectjweaver/1.8.13/aspectjweaver-1.8.13.jar -o aspectjweaver.jar
        mvn ${mvnString} -Ddatabase.monolith=${monolithDb} -Ddatabase.audit=${auditDb} test -pl '${suite}'

    """
}
