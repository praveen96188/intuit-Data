podYaml="""
apiVersion: v1
kind: Pod
metadata:
    name: psp-maven-sql
labels:
name: "psp-maven-sql"
spec:
    containers:
    - name: mavencorrettopspsqlplus
      image: ${dockerUrl}/${imageCorrettoPathMavenSql}:0.0.3
      env:
        - name: HOSTNAME_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
      command:
      - cat
      tty: true
    - name: dbbuild
      image: ${dockerRegistryName}/${OracleimagePath}:0.0.2
    - name: dbbuildpostgres
      image: ${dockerRegistryName}/${PostgresimagePath}:feature-postgres-build-image-limit-191
