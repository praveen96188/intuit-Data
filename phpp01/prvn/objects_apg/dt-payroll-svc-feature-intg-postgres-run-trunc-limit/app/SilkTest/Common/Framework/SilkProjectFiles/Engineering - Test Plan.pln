[-] eaDDM Tests
	[-] Account Name Change Tests
		[-] Account Name Change Test
			[-] Launch IE
				[ ] testcase: LaunchIE
				[ ] script: IntuitSetup.t
			[-] Setup Component Test Type
				[ ] testcase: SetupTestType("COMPONENT")
				[ ] script: IntuitSetup.t
			[-] Run Test
				[ ] script: IntuitTestRunner.g.t
				[ ] ddatestcase: DD_RunDDTest
				[ ] ddatestdata: {"SELECT * FROM SILK_TEST_TABLE WHERE TEST_GROUP_ID='Activations Queue Screen Checklist Validation' AND (TEST_CASE_ID='Activations Queue Notes Valdation' OR SILK_TEST_TABLE.TEST_TYPE_ID='SETUP') ORDER BY TEST_GROUP_STEP_NUM"}
				[ ] //ddatestdata: {"SELECT * FROM SILK_TEST_TABLE WHERE TEST_TYPE_ID='COMPONENT' ORDER BY TEST_GROUP_ID,TEST_GROUP_STEP_NUM"}
			[-] Finalize Component Test Type
				[ ] testcase: FinalizeTestType("COMPONENT")
				[ ] script: IntuitTeardown.t
			[-] Close Browser
				[ ] testcase: CloseDownIE
				[ ] script: IntuitTeardown.t
				[ ] 
