[-] eaDDM Tests
	[-] Account Name Change Tests
		[-] Account Name Change Test
			[-] Launch IE
				[ ] testcase: LaunchIE
				[ ] script: IntuitSetup.t
			[-] Setup Component Test Type
				[ ] testcase: SetupTestType("COMPONENT")
				[ ] script: IntuitSetup.t
			[-] Run Test COA Payroll Expenses
				[ ] script: IntuitTestRunner.g.t
				[ ] ddatestcase: DD_RunDDTest
				[ ] ddatestdata: {"SELECT * FROM SILK_TEST_TABLE WHERE TEST_TYPE_ID='COMPONENT' AND NVL(VERIFIED,'Y')='Y' ORDER BY OVERALL_STEP_NUMBER"}
			[-] Finalize Component Test Type
				[ ] testcase: FinalizeTestType("COMPONENT")
				[ ] script: IntuitTeardown.t
			[-] Close Browser
				[ ] testcase: CloseDownIE
				[ ] script: IntuitTeardown.t
