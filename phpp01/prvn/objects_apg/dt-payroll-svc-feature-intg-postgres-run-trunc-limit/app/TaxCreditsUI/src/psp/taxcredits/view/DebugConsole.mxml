<?xml version="1.0"?>
<mx:TitleWindow xmlns:mx="http://www.adobe.com/2006/mxml" width="500" height="600" showCloseButton="true" close="onClose();" creationComplete="onCreationComplete();" alpha=".8" title="Debug Console">
    <mx:Script><![CDATA[
        import mx.events.CollectionEvent;
        import mx.utils.ObjectUtil;

        import psp.taxcredits.model.Benefits;
        import psp.taxcredits.model.ModelUtils;
        import psp.taxcredits.model.TaxCreditsEvent;
        import psp.taxcredits.model.TaxCreditsModel;
        import psp.taxcredits.model.TaxCreditsPageEnum;
        import psp.taxcredits.view.controls.WindowManager;

        public var model:TaxCreditsModel = TaxCreditsModel.instance;

        private var lastError:int=0;

        public function onClose():void {
            WindowManager.remove(this);
        }

        public function onCreationComplete():void {
            console.text = "PSP Date=" + model.pspDate.toString();

            model.addEventListener(TaxCreditsEvent.CATEGORIES_LOADED, function(e:Event):void {
                console.text+= "\n" + ObjectUtil.toString(model.eligibleCategories);
            });

            model.errors.addEventListener(CollectionEvent.COLLECTION_CHANGE, function(e:Event):void {
                while (model.errors.length > lastError){
                    console.text += "\n" + "Error: " + model.errors.getItemAt(lastError);
                    lastError++;
                }
            });

        }

        private function preEligibility():void {
            model.company.businessType = model.company.profitLabel;
            model.employee.majorityOwnerSet = true;
            model.employee.majorityOwner = false;
            model.employee.relativeSet = true;
            model.employee.relative = false;
            model.employee.previouslyHiredSet = true;
            model.employee.previouslyHired = false;
            model.employee.hireDate = ModelUtils.addDays(model.pspDate, -5);
            model.dispatchEvent(TaxCreditsEvent.createEligibilityChangeEvent());            
        }

        private function personalInfo():void {
            model.employee.firstName = "John";
            model.employee.middleInitial = "T";
            model.employee.lastName = "Tester";
            model.employee.dobMonth="4";
