            model.employee.county = "Washoe";
            model.employee.phone1 = "775";
            model.employee.phone2 = "555";
            model.employee.phone3 = "1234";
            model.employee.phoneX = "654321";
        }

        private function ineligibleQuestions():void {
            model.employee.snapEverSet = true;
            model.employee.snapEver = false;
            model.employee.tanfEverSet = true;
            model.employee.tanfEver = false;
            model.employee.referralRehabSet = true;
            model.employee.referralRehab = false;
