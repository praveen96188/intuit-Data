        private function setCT():void {
            model.employee.workState = "CT";
        }

        private function getAllDY():void {
            preEligibility();
            personalInfo();
            ineligibleQuestions();
            model.employee.dobYear = "1990";
            model.employee.disconnectedEver = true;
            model.employee.disconnectedAttendSet = true;
            model.employee.disconnectedAttend = false;
            model.employee.disconnectedAdmittedSet = true;
            model.employee.disconnectedAdmitted = false;
            model.employee.disconnectedHighSchoolSet = true;
            model.employee.disconnectedHighSchool = true;
            model.employee.disconnectedJob6Set = true;
            model.employee.disconnectedJob6 = false;            
            extraEEInfo();
            ERInfo();
        }

        private function getAllSNAP():void {
            preEligibility();
            personalInfo();
            ineligibleQuestions();
            model.employee.snapEver = true;
            model.employee.snapLast6Set = true;
            model.employee.snapLast6 = true;
            model.employee.snap3Benefits = new Benefits();
            model.employee.snap3Benefits.city = "Paris";
            model.employee.snap3Benefits.state = "TX";
