            model.employee.conditionalSet = true;
            model.employee.conditional = false;
            model.employee.unemployed60Set = true;
            model.employee.unemployed60 = false;
        }

        private function ezRC():void {
            model.employee.address = "100 E 5th Ave";
            model.employee.zip = "43210";
        }

        private function RRC():void {
            model.employee.county = "Crawford";
            model.employee.state = "OH";
        }

        private function noHUD():void {
            model.employee.address = "100 Made Up St";
        }

        private function extraEEInfo():void {            
            model.employee.offeredDate = ModelUtils.addDays(model.pspDate, -20);
            model.employee.startDate = ModelUtils.addDays(model.pspDate, -3);
            model.employee.ssn = "123456789";
            model.employee.startingWage = "$10";
            model.employee.position = "Chief Umbrella Repairman";
            model.employee.workState = "CA";
        }

        private function ERInfo():void {
