            model.employee.zip = "92111";
            model.employee.county = "San Diego";
            model.employee.phone1 = "111";
            model.employee.phone2 = "111";
            model.employee.phone3 = "1111";
            model.employee.phoneX = "";

            model.employee.snapEverSet = true;
            model.employee.snapEver = false;
            model.employee.tanfEverSet = true;
            model.employee.tanfEver = false;
            model.employee.referralRehabSet = true;
            model.employee.referralRehab = false;
            model.employee.referralNetworkSet = true;
            model.employee.referralNetwork = false;
            model.employee.referralDvaSet = true;
            model.employee.referralDva = false;
