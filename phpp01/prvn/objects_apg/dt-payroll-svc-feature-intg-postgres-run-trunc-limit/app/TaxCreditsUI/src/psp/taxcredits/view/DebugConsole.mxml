        }

        private function getAll():void {
            preEligibility();
            personalInfo();
            RRC();
            ineligibleQuestions();
            extraEEInfo();
            ERInfo();
        }

        private function loadResults():void {
            model.getCategories();
        }

        private function gotoEstimator():void {
            model.pageManager.switchPage(TaxCreditsPageEnum.ESTIMATE);
        }

        private function gotoFinalSteps():void {
            model.pageManager.switchPage(TaxCreditsPageEnum.FINAL_STEPS);
        }

        private function HIRE():void {
            model.employee.unemployed60 = true;
        }


        ]]></mx:Script>
    <mx:HBox>
        <mx:Button label="View EE Info" click="console.text += '\nemployeeInfo=' + ObjectUtil.toString(model.createEmployeeInfo())"/>
        <mx:Button label="View ER Info" click="console.text += '\nemployerInfo=' + ObjectUtil.toString(model.createEmployerInfo())"/>
        <mx:Button label="View Elig. Info" click="console.text += '\neligibilityInfo=' + ObjectUtil.toString(model.createEligibilityInfo())"/>
        <mx:Button label="View Errors" click="console.text += '\nErrors=' + ObjectUtil.toString(model.errors)"/>
    </mx:HBox>
    <mx:HBox>
        <mx:Button label="Pre-eligibility" click="preEligibility();"/>
        <mx:Button label="Personal Info" click="personalInfo();"/>
        <mx:Button label="+EZ/RC" click="ezRC();"/>
        <mx:Button label="+RRC" click="RRC();"/>
        <mx:Button label="+No HUD" click="noHUD();"/>
    </mx:HBox>
    <mx:HBox>
        <mx:Button label="Questions (Inelg.)" click="ineligibleQuestions();"/>
        <mx:Button label="Extra EE Info" click="extraEEInfo();"/>
        <mx:Button label="ER Info" click="ERInfo();"/>
        <mx:Button label="HIRE" click="HIRE();"/>
    </mx:HBox>
    <mx:HBox>
        <mx:Button label="CT" click="setCT();"/>
        <mx:Button label="SNAP++" click="getAllSNAP();"/>
        <mx:Button label="DY++" click="getAllDY();"/>
        <mx:Button label="RRC++" click="getAll();"/>
    </mx:HBox>
    <mx:HBox>
        <mx:Button label="Load Results" click="loadResults();"/>
        <mx:Button label="->Estimate" click="gotoEstimator();"/>
        <mx:Button label="->Final Steps" click="gotoFinalSteps();"/>
        <!--mx:Button label="AMF Error" click="testAmfError();"/-->        
    </mx:HBox>
    <mx:Canvas height="100%" width="100%" verticalLineScrollSize="20">
        <mx:Text id="console" width="100%"/>
    </mx:Canvas>
</mx:TitleWindow>
