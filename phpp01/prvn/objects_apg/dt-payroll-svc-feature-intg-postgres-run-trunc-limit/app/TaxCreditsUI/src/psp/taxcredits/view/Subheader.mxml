<?xml version="1.0"?>
<mx:Canvas xmlns:mx="http://www.adobe.com/2006/mxml" xmlns:controls="psp.taxcredits.view.controls.*" creationComplete="onCreationComplete();">
    <mx:Script>
        <![CDATA[
        import mx.utils.StringUtil;

        import psp.taxcredits.model.PageChangeEvent;
        import psp.taxcredits.model.TaxCreditsEvent;
        import psp.taxcredits.model.TaxCreditsModel;
        import psp.taxcredits.view.controls.WindowManager;


        [Bindable]
        public var model:TaxCreditsModel = TaxCreditsModel.instance;

        [Bindable]
        public var title:String;
        [Bindable]
        public var breadCrumbText:String = "";
        [Bindable]
        public var ribbonText:String = "";

        private function onCreationComplete():void {
            model.pageManager.addEventListener(PageChangeEvent.PAGE_CHANGE, onPageChange, false);
            model.employee.addEventListener(TaxCreditsEvent.ELIGIBILITY_CHANGE, function(e:Event):void {
                updateRibbonText();
            });
            updateRibbonText();

        }

        private function onPageChange(e:PageChangeEvent):void {
            if (e.taxCreditsPage.subIndex > -1 || e.taxCreditsPage.index == 0) {
                return;
            }

            title = resourceManager.getString('pages', e.page);

            var newBreadCrumbText:String = "";

            for each (var breadCrumbPage:String in model.pageManager.buildBreadCrumbList(e.page)) {
                if (breadCrumbPage != e.page) {
                    newBreadCrumbText += "<a href='event:" + breadCrumbPage + "'>" + resourceManager.getString('pages', breadCrumbPage) + "</a> <font color='#999999'> &gt; </font>";
                } else {
                    newBreadCrumbText += resourceManager.getString('pages', breadCrumbPage);
                }
            }

            breadCrumbText = newBreadCrumbText;

        }


        private function updateRibbonText():void {
            var newRibbonText:String = resourceManager.getString('header', 'application_received_dont_wait_alt') + " ";
            if (model.employee.hireDate != null) {
                newRibbonText += StringUtil.substitute(resourceManager.getString('header', 'application_received_date'), [model.employee.getPostmarkedByDate()]);
            } else {
                newRibbonText += resourceManager.getString('header', 'application_received');

            }

            ribbonText = newRibbonText;
        }

        public function whyLimit():void {
            model.tracker.trackEvent("Navigation","Click Time Limit","Ribbon");
            //pop-up
            var window:TimeLimit = new TimeLimit();
            WindowManager.add(window, DisplayObject(this.parentApplication), true);
            WindowManager.centerWindow(window);
            window.move(window.x, window.y - 75);
        }

        private function onLink(event:TextEvent):void {
            model.tracker.trackEvent("Navigation","Click Breadcrumb",event.text);
            model.pageManager.switchPage(event.text);
        }



        ]]>
    </mx:Script>
    <controls:SupText x="20" y="14" linkColor="#003399" htmlText="{breadCrumbText}" styleName="breadCrumb" link="onLink(event);"/>

    <mx:Text x="20" y="46"
             selectable="false" styleName="frontTagLine"
             filters="{[new DropShadowFilter(2,45,0xFFFFFF,0.65)]}"
             text="{title}"/>

    <mx:Image x="655" y="10"
              source="psp/taxcredits/view/assets/Eligibility_OrangeBox.png"/>

    <mx:Text x="665" y="20" width="270"
             selectable="false" styleName="ribbonText"
             htmlText="{ribbonText}"/>
    <controls:SupText x="665" y="55"
                      linkColor="#003399"
                      selectable="true" styleName="ribbonText" link="whyLimit();"
                      htmlText="{resourceManager.getString('header','why_time_limit')}"/>


    <mx:Image x="12" y="90"
              source="psp/taxcredits/view/assets/bg_InnerContainer.png"/>


</mx:Canvas>
