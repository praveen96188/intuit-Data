                    </execution>
                </executions>
            </plugin>
            
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>jaxws-maven-plugin</artifactId>
                <version>2.4.1</version>
                <executions>
                    <execution>
                        <id>DISAdapter V7 wsdl</id>
                        <phase>process-classes</phase>
                        <goals>
                            <goal>wsgen</goal>
                        </goals>
                        <configuration>
                            <sei>com.intuit.sbd.payroll.psp.adapters.dis.v1_7.DISAdapter</sei>
                            <genWsdl>true</genWsdl>
                            <resourceDestDir>${project.genWSDL.resourceDestDir}</resourceDestDir>
                        </configuration>
                    </execution>
                    <execution>
                        <id>DISAdapter V8 wsdl</id>
                        <phase>process-classes</phase>
                        <goals>
                            <goal>wsgen</goal>
                        </goals>
                        <configuration>
                            <sei>com.intuit.sbd.payroll.psp.adapters.dis.v1_8.DISAdapter</sei>
                            <genWsdl>true</genWsdl>
                            <resourceDestDir>${project.target.generated.sources}/v8</resourceDestDir>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>1.8</version>
            
                <executions>
                    <execution>
                        <id>Renaming DisAdapter V8 xsd</id>
                        <phase>prepare-package</phase>
                        <configuration>
                            <target>
                                <rename src="${project.genWSDL.resourceDestDir}/DISAdapterService_schema1.xsd" dest="${project.genWSDL.resourceDestDir}/DISAdapterService_schema7.xsd"></rename>
                                <copy todir="${project.genWSDL.resourceDestDir}" overwrite="true">
                                    <fileset dir="${project.target.generated.sources}/v8" />
                                </copy>
                                <rename src="${project.genWSDL.resourceDestDir}/DISAdapterService_schema1.xsd" dest="${project.genWSDL.resourceDestDir}/DISAdapterService_schema8.xsd"></rename>
                            </target>
                        </configuration>
                        <goals>
                            <goal>run</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <artifactId>maven-resources-plugin</artifactId>
                <version>2.7</version>
                <executions>
                    <execution>
                        <id>copy-wars</id>
                        <phase>install</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>

                        <configuration>
                            <outputDirectory>${project.wars.dir}</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>target</directory>
                                    <includes>
                                        <include>${project.build.finalName}.war</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                    <execution>
                        <id>copy-test-resources</id>
                        <phase>process-test-resources</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.target.test.classes}</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${project.target.test.resources}/resources/scripts</directory>
                                    <includes>
                                        <includes>**/*.sql</includes>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
