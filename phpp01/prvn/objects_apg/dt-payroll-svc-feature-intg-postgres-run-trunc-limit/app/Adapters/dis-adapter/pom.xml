        		<targetPath>${project.target.classes.dir}/resources</targetPath>
        	</resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <includes>
                        <include>com/intuit/sbd/payroll/psp/adapters/dis/**</include>
                    </includes>
                    <classifier>classes</classifier>
                </configuration>
                <executions>
                    <execution>
                        <id>make-dis-adapter-jar</id>
                        <phase>prepare-package</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-war-plugin</artifactId>
                <version>2.6</version>
                <configuration>
                    <packagingExcludes>WEB-INF/wsdl/**, %regex[WEB-INF/lib/(utils|tfs-gateway|testutils|salestax-gateway|processes-core|payroll-services-api-impl|payroll-services-api|ofx|iop-gateway|filter|ers-gateway|email-gateway|efe-gateway|echo-sign-gateway|domain-secondary|domain|dd-gateway|configuration-manager|common-gateway|brm-gateway|amo-gateway|aia-gateway|agency-rules|account-service-gateway)-${psp.project.version}.jar], %regex[WEB-INF/lib/(sap-adapter|ade-adapter|batch-jobs|ews-adapter|qbdt-adapter)-${psp.project.version}-classes.jar], %regex[WEB-INF/classes/META-INF/(?!.*\.factories).*]</packagingExcludes>
                    <webResources>
                        <resource>
                            <directory>../../</directory>
                            <targetPath>/</targetPath>
                            <filtering>true</filtering>
                            <includes>
                                <include>appversion.html</include>
                            </includes>
                        </resource>
                    </webResources>
                </configuration>
            </plugin>
            <!-- For tests only to access truncateTables.sql--> 
