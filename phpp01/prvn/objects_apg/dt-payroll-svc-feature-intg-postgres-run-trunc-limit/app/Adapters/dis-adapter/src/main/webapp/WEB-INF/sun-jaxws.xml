<?xml version="1.0" encoding="UTF-8"?>

<endpoints xmlns='http://java.sun.com/xml/ns/jax-ws/ri/runtime'
           xmlns:javaee="http://java.sun.com/xml/ns/javaee" version='2.0'>

    <endpoint
            name='DISAdapterService_v1_7'
            implementation='com.intuit.sbd.payroll.psp.adapters.dis.v1_7.DISAdapter'
            url-pattern='/services/DISAdapterService/v1_7'>
            <javaee:handler-chains>
                <javaee:handler-chain>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbd.payroll.psp.adapters.dis.v1_7.handlers.SchemaValidationHandler</javaee:handler-class>
                    </javaee:handler>
                </javaee:handler-chain>
            </javaee:handler-chains>
    </endpoint>

    <endpoint
            name='DISAdapterService_v1_8'
            implementation='com.intuit.sbd.payroll.psp.adapters.dis.v1_8.DISAdapter'
            url-pattern='/services/DISAdapterService/v1_8'>
            <javaee:handler-chains>
                <javaee:handler-chain>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbd.payroll.psp.adapters.dis.v1_8.handlers.PspUserAuthZHandler</javaee:handler-class>
