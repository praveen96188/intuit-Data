<?xml version="1.0" encoding="UTF-8"?>
<xs:schema 
	xmlns:xs="http://www.w3.org/2001/XMLSchema" 
	xmlns:orr="http://offer.xsd.wsapi.dd.pse.osp.intuit" 
	xmlns:rs="http://responsestatus.xsd.wsapi.dd.pse.osp.intuit" 
	targetNamespace="http://offerqueryrs.xsd.wsapi.dd.pse.osp.intuit" 
	elementFormDefault="qualified">
	<xs:import namespace="http://responsestatus.xsd.wsapi.dd.pse.osp.intuit" schemaLocation="ResponseStatus.xsd"/>
	<xs:import namespace="http://offer.xsd.wsapi.dd.pse.osp.intuit" schemaLocation="Offer.xsd"/>
	<xs:element name="OfferQueryRs">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Offer" type="orr:Offer" nillable="true" minOccurs="0" maxOccurs="unbounded"/>
				<xs:element name="ResponseStatus" type="rs:ResponseStatus" nillable="false"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
</xs:schema>