<?xml version="1.0" encoding="UTF-8"?>
<schema
	targetNamespace="http://eefinancialtxadd.xsd.wsapi.dd.pse.osp.intuit"
	elementFormDefault="qualified" xmlns="http://www.w3.org/2001/XMLSchema"
	xmlns:eefta="http://eefinancialtxadd.xsd.wsapi.dd.pse.osp.intuit" xmlns:dd="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit">

	<import namespace="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit" schemaLocation="PSEDDCommonTypes.xsd"></import>
	<element name="EEFinancialTxAdd"
		type="eefta:EEFinancialTxAddType">
	</element>

	<complexType name="EEFinancialTxAddType">
		<sequence>
			<element name="SourceSystemCd" type="dd:SourceSystemType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="CompanyID" type="dd:IDType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="EEFinancialTx" type="eefta:EEFinancialTxType" nillable="false" minOccurs="1" maxOccurs="unbounded">
			</element>
		</sequence>
	</complexType>

	<complexType name="EEFinancialTxType">
		<sequence>
			<element name="DDTxBatchID" type="dd:IDType" nillable="false" minOccurs="1"	maxOccurs="1"></element>
			<element name="TxTypeCd" type="dd:TxType" nillable="false" minOccurs="1"	maxOccurs="1"></element>
			<element name="TxSettlementTypeCd" type="dd:TxSettlementType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="TxDate" type="date" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="FinancialTxAmt" type="dd:AmountType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="EmployeeID" type="dd:IDType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="EEBankAccountID" type="dd:IDType" minOccurs="0" maxOccurs="1"></element>
		</sequence>
	</complexType>
</schema>