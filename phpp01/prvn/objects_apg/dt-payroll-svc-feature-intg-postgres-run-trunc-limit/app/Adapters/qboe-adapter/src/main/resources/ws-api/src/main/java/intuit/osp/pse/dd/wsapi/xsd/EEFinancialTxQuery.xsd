<?xml version="1.0" encoding="UTF-8"?>
<schema
	targetNamespace="http://eefinancialtxquery.xsd.wsapi.dd.pse.osp.intuit"
	elementFormDefault="qualified" xmlns="http://www.w3.org/2001/XMLSchema"
	xmlns:eeftq="http://eefinancialtxquery.xsd.wsapi.dd.pse.osp.intuit" xmlns:dd="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit">

	<import namespace="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit" schemaLocation="PSEDDCommonTypes.xsd"></import>
	<element name="EEFinancialTxQuery"
		type="eeftq:EEFinancialTxQueryType">
	</element>

	<complexType name="EEFinancialTxQueryType">
		<sequence>
			<element name="SourceSystemCd" type="dd:SourceSystemType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="CompanyID" type="dd:IDType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="DDTxBatchID" type="dd:IDType" minOccurs="0" maxOccurs="1"></element>
			<element name="TxTypeCd" type="dd:EETxType" minOccurs="0"	maxOccurs="1"></element>
			<element name="TxDateFrom" type="date" minOccurs="0" maxOccurs="1"></element>
			<element name="TxDateTo" type="date" minOccurs="0" maxOccurs="1"></element>
			<element name="EmployeeID" type="dd:IDType"	minOccurs="0" maxOccurs="1"></element>
			<element name="EEBankAccountID" type="dd:IDType" minOccurs="0" maxOccurs="1"></element>
		</sequence>
	</complexType>
</schema>