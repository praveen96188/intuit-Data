<?xml version="1.0" encoding="UTF-8"?>
<schema
	targetNamespace="http://ddrefund.xsd.wsapi.dd.pse.osp.intuit"
	elementFormDefault="qualified" xmlns="http://www.w3.org/2001/XMLSchema"
	xmlns:ddr="http://ddrefund.xsd.wsapi.dd.pse.osp.intuit" xmlns:dd="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit">

	<import namespace="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit" schemaLocation="PSEDDCommonTypes.xsd"/>
	<element name="DDRefund" type="ddr:DDRefundType"/>

	<complexType name="DDRefundType">
		<sequence>
			<element name="SourceSystemCd" type="dd:SourceSystemType" nillable="false" minOccurs="1" maxOccurs="1"/>
			<element name="CompanyID" type="dd:IDType" nillable="false" minOccurs="1" maxOccurs="1"/>
			<element name="DDTxBatchID" type="dd:IDType" nillable="false" minOccurs="1" maxOccurs="1"/>
			<element name="TxSettlementTypeCd" type="dd:TxSettlementType" nillable="false" minOccurs="1" maxOccurs="1"/>
			<element name="FinancialTxAmt" type="dd:AmountType" nillable="true" minOccurs="0" maxOccurs="1"/>
			<element name="TxDate" type="date" nillable="true" minOccurs="0" maxOccurs="1"/>
			<element name="CompanyBankAccountID" type="dd:IDType" nillable="true" minOccurs="0" maxOccurs="1"/>
		</sequence>
	</complexType>
</schema>