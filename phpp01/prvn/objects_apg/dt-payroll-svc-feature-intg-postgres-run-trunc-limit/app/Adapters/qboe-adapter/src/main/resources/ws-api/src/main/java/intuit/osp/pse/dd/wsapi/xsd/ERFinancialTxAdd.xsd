<?xml version="1.0" encoding="UTF-8"?>
<schema
	targetNamespace="http://erfinancialtxadd.xsd.wsapi.dd.pse.osp.intuit"
	elementFormDefault="qualified" xmlns="http://www.w3.org/2001/XMLSchema"
	xmlns:erfta="http://erfinancialtxadd.xsd.wsapi.dd.pse.osp.intuit" xmlns:dd="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit">
	<import namespace="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit" schemaLocation="PSEDDCommonTypes.xsd"></import>

	<element name="ERFinancialTxAdd"
		type="erfta:ERFinancialTxAddType" nillable="false">
	</element>

	<complexType name="ERFinancialTxAddType">
		<sequence>
			<element name="SourceSystemCd" type="dd:SourceSystemType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="CompanyID" type="dd:IDType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="ERFinancialTx" type="erfta:ERFinancialTxType" nillable="false" minOccurs="1" maxOccurs="unbounded"></element>
		</sequence>
	</complexType>

	<complexType name="ERFinancialTxType">
		<sequence>
			<element name="DDTxBatchID" type="dd:IDType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="TxTypeCd" type="dd:TxType" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="TxSettlementTypeCd" type="dd:TxSettlementType" nillable="false" minOccurs="1" maxOccurs="1">
			</element>
			<element name="TxDate" type="date" nillable="false" minOccurs="1" maxOccurs="1"></element>
			<element name="CompanyBankAccountID" type="dd:IDType" minOccurs="0" maxOccurs="1"></element>
			<element name="FinancialTxAmt" type="dd:AmountType" nillable="false" minOccurs="1" maxOccurs="1"></element>
		</sequence>
	</complexType>
</schema>