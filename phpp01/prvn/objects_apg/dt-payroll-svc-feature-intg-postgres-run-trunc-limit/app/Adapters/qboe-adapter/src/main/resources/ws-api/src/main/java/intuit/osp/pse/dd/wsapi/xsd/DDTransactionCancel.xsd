<?xml version="1.0" encoding="UTF-8"?>
<schema
	targetNamespace="http://ddtransactioncancel.xsd.wsapi.dd.pse.osp.intuit"
	elementFormDefault="qualified" xmlns="http://www.w3.org/2001/XMLSchema"
	xmlns:ns="http://ddtransactioncancel.xsd.wsapi.dd.pse.osp.intuit" xmlns:dd="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit">

	<import namespace="http://pseddcommontypes.xsd.wsapi.dd.pse.osp.intuit" schemaLocation="PSEDDCommonTypes.xsd"></import>
	<element name="DDTransactionCancel"
		type="ns:DDTransactionCancelType">
	</element>

	<complexType name="DDTransactionCancelType">
		<sequence>
			<element name="SourceSystemCd" type="dd:SourceSystemType"
				nillable="false" minOccurs="1" maxOccurs="1">
			</element>
			<element name="CompanyID" type="dd:IDType" nillable="false"
				minOccurs="1" maxOccurs="1">
			</element>
			<element name="DDTxBatchID" type="dd:IDType"
				nillable="false" minOccurs="1" maxOccurs="1">
			</element>
			<element name="DDTransactionID" type="dd:IDType"
				minOccurs="0" maxOccurs="unbounded">
			</element>
		</sequence>
	</complexType>
	
</schema>