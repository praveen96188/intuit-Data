<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
		  http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
         version="2.5">
    <filter>
        <filter-name>SystemPrincipalFilter</filter-name>
        <filter-class>com.intuit.sbd.payroll.psp.adapters.cdmadapter.util.SystemPrincipalFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SystemPrincipalFilter</filter-name>
        <url-pattern>/resource/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>InitSpcfServlet</servlet-name>
        <servlet-class>com.intuit.sbd.payroll.psp.web.InitSpcfServlet</servlet-class>
        <load-on-startup>100</load-on-startup>
    </servlet>
    <servlet>
        <servlet-name>Jersey REST Service</servlet-name>
        <servlet-class>com.sun.jersey.spi.container.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>com.sun.jersey.config.property.packages</param-name>
            <param-value>com.intuit.ems.dataservice.v1.resource;com.intuit.sbd.payroll.psp.adapters.cdmadapter.workerscomp.resource</param-value>
        </init-param>
        <init-param>
            <param-name>com.sun.jersey.spi.container.ContainerRequestFilters</param-name>
            <param-value>com.intuit.ems.dataservice.v1.filter.PayrollDataServiceLoggingFilter;
                com.intuit.ems.dataservice.v1.filter.AcceptsHeaderFilter</param-value>
        </init-param>
        <init-param>
            <param-name>com.sun.jersey.spi.container.ContainerResponseFilters</param-name>
            <param-value>com.intuit.ems.dataservice.v1.filter.PayrollDataServiceLoggingFilter</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>Jersey REST Service</servlet-name>
        <url-pattern>/resource/*</url-pattern>
    </servlet-mapping>

    <!-- V4 paystubs enpoint -->
    <listener>
        <listener-class>
            org.springframework.web.context.request.RequestContextListener
        </listener-class>
    </listener>
    <listener>
	<listener-class>
            com.intuit.sbd.payroll.psp.adapters.cdmadapter.util.CdmAdapterStartup
        </listener-class>
    </listener>
    <servlet>
        <servlet-name>Jersey REST Service version</servlet-name>
        <servlet-class>com.sun.jersey.spi.container.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>com.sun.jersey.config.property.packages</param-name>
            <param-value>com.intuit.ems.dataservice</param-value>
        </init-param>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>Jersey REST Service version</servlet-name>
        <url-pattern>/rest4/*</url-pattern>
    </servlet-mapping>

    <!-- Log Enhancing Filter start-->
    <filter>
        <filter-name>LogEnhancingFilter</filter-name>
        <filter-class>com.intuit.sbg.psp.filter.LogEnhancingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LogEnhancingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <!-- end Log Enhancing Filter -->

    <filter>
		<filter-name>LMAFilter</filter-name>
		<filter-class>com.intuit.sbg.psp.filter.LastMileAuthenticationFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>LMAFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

</web-app>