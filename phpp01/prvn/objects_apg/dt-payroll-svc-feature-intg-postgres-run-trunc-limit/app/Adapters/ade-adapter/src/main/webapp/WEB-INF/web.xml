<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://java.sun.com/xml/ns/javaee"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
		  http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
           version="2.5">


    <servlet>
         <servlet-name>InitSpcfServlet</servlet-name>
         <servlet-class>com.intuit.sbd.payroll.psp.web.InitSpcfServlet</servlet-class>
         <load-on-startup>100</load-on-startup>
     </servlet>
    <servlet>
        <servlet-name>ADE Rest Services</servlet-name>
        <servlet-class>com.sun.jersey.spi.container.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>com.sun.jersey.config.property.packages</param-name>
            <param-value>com.intuit.sbd.payroll.psp.adapters.ade.providers;com.intuit.ems.cep.company.v1.resource;com.intuit.ems.cep.paycheck.v1.resource;com.intuit.ems.cep.employee.v1.resource;com.intuit.ems.cep.contractor.v1.resource;com.intuit.ems.cep.contractorpayment.v1.resource;org.codehaus.jackson.jaxrs;com.wordnik.swagger.jaxrs.listing</param-value>
        </init-param>
        <init-param>
            <param-name>com.sun.jersey.spi.container.ContainerRequestFilters</param-name>
            <param-value>com.intuit.ems.cep.filters.InitializeServiceContext;com.intuit.ems.cep.filters.AcceptsHeaderFilter;com.intuit.ems.cep.filters.RequestFilter;com.intuit.ems.cep.filters.LoggingFilter</param-value>
        </init-param>
        <init-param>
            <param-name>com.sun.jersey.spi.container.ContainerResponseFilters</param-name>
            <param-value>com.intuit.ems.cep.filters.LoggingFilter</param-value>
        </init-param>

        <init-param>

            <param-name>com.sun.jersey.api.json.POJOMappingFeature</param-name>
            <param-value>true</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>ADE Rest Services</servlet-name>
        <url-pattern>/rest/*</url-pattern>
        <url-pattern>/private/rest/*</url-pattern>
    </servlet-mapping>

    <!-- Log Enhancing Filter start-->
    <filter>
        <filter-name>LogEnhancingFilter</filter-name>
        <filter-class>com.intuit.sbg.psp.filter.LogEnhancingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LogEnhancingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <!-- end Log Enhancing Filter -->

    <filter>
		<filter-name>LMAFilter</filter-name>
		<filter-class>com.intuit.sbg.psp.filter.LastMileAuthenticationFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>LMAFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

    <filter>
        <filter-name>PSPRequestContextFilter</filter-name>
        <filter-class>com.intuit.sbg.psp.filter.PSPRequestContextFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>PSPRequestContextFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
</web-app>
