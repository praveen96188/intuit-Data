<?xml version="1.0" encoding="UTF-8"?>

<endpoints xmlns='http://java.sun.com/xml/ns/jax-ws/ri/runtime'
           xmlns:javaee="http://java.sun.com/xml/ns/javaee" version='2.0'>

    <endpoint
            name='EWSAdapter_v1_9'
            implementation='com.intuit.sbd.payroll.psp.adapters.ews.v1_9.webservices.EWSAdapter'
            url-pattern='/services/EWSAdapter/v1_9'>
            <javaee:handler-chains>
                <javaee:handler-chain>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbd.payroll.psp.adapters.ews.v1_9.handlers.SchemaValidationHandler</javaee:handler-class>
                    </javaee:handler>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbg.psp.soap.handler.RequestContextCreateHandler</javaee:handler-class>
                    </javaee:handler>
                </javaee:handler-chain>
            </javaee:handler-chains>
    </endpoint>

    <endpoint
            name='EWSAdapter_v1_10'
            implementation='com.intuit.sbd.payroll.psp.adapters.ews.v1_10.webservices.EWSAdapter'
            url-pattern='/services/EWSAdapter/v1_10'>
            <javaee:handler-chains>
                <javaee:handler-chain>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbg.payroll.authorization.soap.handler.PayrollSOAPAuthorizationHandler</javaee:handler-class>
                    </javaee:handler>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbg.payroll.authorization.soap.handler.PayrollSOAPAuthenticationHandler</javaee:handler-class>
                    </javaee:handler>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbg.psp.soap.handler.PayloadExtractingHandler</javaee:handler-class>
                    </javaee:handler>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbg.psp.soap.handler.RequestContextCreateHandler</javaee:handler-class>
                    </javaee:handler>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbd.payroll.psp.adapters.ews.v1_10.handlers.RequestHeaderHandler</javaee:handler-class>
                    </javaee:handler>
                    <javaee:handler>
                        <javaee:handler-class>com.intuit.sbd.payroll.psp.adapters.ews.v1_10.handlers.SchemaValidationHandler</javaee:handler-class>
                    </javaee:handler>
                </javaee:handler-chain>
            </javaee:handler-chains>
    </endpoint>

</endpoints>
