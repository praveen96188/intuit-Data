<?xml version="1.0" encoding="UTF-8"?>

<endpoints xmlns='http://java.sun.com/xml/ns/jax-ws/ri/runtime' version='2.0'
           xmlns:javaee="http://java.sun.com/xml/ns/javaee">

    <endpoint
            name='BillPaymentWebServices'
            implementation='com.intuit.sbd.payroll.psp.adapters.qbdtws.webservices.BillPaymentWebServices'
            url-pattern='/services/BillPaymentWebServices'>
        <javaee:handler-chains>
            <javaee:handler-chain>
                <javaee:handler>
                    <javaee:handler-class>com.intuit.sbd.payroll.psp.adapters.qbdtws.handlers.SchemaValidationHandler
                    </javaee:handler-class>
                </javaee:handler>
                <javaee:handler>
                    <javaee:handler-class>com.intuit.sbg.psp.soap.handler.RequestContextCreateHandler</javaee:handler-class>
                </javaee:handler>
            </javaee:handler-chain>
        </javaee:handler-chains>
    </endpoint>

    <endpoint
            name='QBPayrollWebServices'
            implementation='com.intuit.sbd.payroll.psp.adapters.qbdtws.webservices.QBPayrollWebServices'
            url-pattern='/services/QBPayrollWebServices'>
        <javaee:handler-chains>
            <javaee:handler-chain>
                <javaee:handler>
                    <javaee:handler-class>com.intuit.sbd.payroll.psp.adapters.qbdtws.handlers.SchemaValidationHandler
                    </javaee:handler-class>
                </javaee:handler>
                <javaee:handler>
                    <javaee:handler-class>com.intuit.sbg.psp.soap.handler.RequestContextCreateHandler</javaee:handler-class>
                </javaee:handler>
            </javaee:handler-chain>
        </javaee:handler-chains>
    </endpoint>

</endpoints>
