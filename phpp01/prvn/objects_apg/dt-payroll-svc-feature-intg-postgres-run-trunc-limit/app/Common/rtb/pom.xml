<?xml version="1.0"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd" xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.intuit.sbg.psp</groupId>
        <artifactId>Common</artifactId>
        <version>2.2.0-SNAPSHOT</version>
    </parent>
    <artifactId>rtb</artifactId>
    <name>rtb</name>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.intuit.sbg.psp</groupId>
                <artifactId>sap-adapter</artifactId>
                <version>${psp.project.version}</version>
                <classifier>classes</classifier>
            </dependency>
            <dependency>
                <groupId>com.intuit.sbg.psp</groupId>
                <artifactId>cdm-adapter</artifactId>
                <version>${psp.project.version}</version>
                <classifier>classes</classifier>
            </dependency>
            <dependency>
                <groupId>com.intuit.sbg.psp</groupId>
                <artifactId>ptc-adapter</artifactId>
                <version>${psp.project.version}</version>
                <classifier>classes</classifier>
            </dependency>
            <dependency>
                <groupId>com.intuit.sbg.psp</groupId>
                <artifactId>dis-adapter</artifactId>
                <version>${psp.project.version}</version>
                <classifier>classes</classifier>
            </dependency>
            <dependency>
                <groupId>com.intuit.sbg.psp</groupId>
                <artifactId>ews-adapter</artifactId>
                <version>${psp.project.version}</version>
                <classifier>classes</classifier>
            </dependency>
            <dependency>
                <groupId>com.intuit.sbg.psp</groupId>
                <artifactId>ade-adapter</artifactId>
                <version>${psp.project.version}</version>
                <classifier>classes</classifier>
            </dependency>
            <dependency>
                <groupId>com.intuit.sbg.psp</groupId>
                <artifactId>brm-adapter</artifactId>
                <version>${psp.project.version}</version>
                <classifier>classes</classifier>
            </dependency>
            <dependency>
                <groupId>com.intuit.sbg.psp</groupId>
                <artifactId>qbdtws-adapter</artifactId>
                <version>${psp.project.version}</version>
                <classifier>classes</classifier>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>ade-adapter</artifactId>
            <classifier>classes</classifier>
        </dependency>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>ews-adapter</artifactId>
            <classifier>classes</classifier>
        </dependency>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>qbdtws-adapter</artifactId>
            <classifier>classes</classifier>
        </dependency>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>brm-adapter</artifactId>
            <classifier>classes</classifier>
        </dependency>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>sap-adapter</artifactId>
            <classifier>classes</classifier>
            <exclusions>
				<exclusion>
					<groupId>com.intuit.sbg.psp</groupId>
					<artifactId>batch-jobs</artifactId>
				</exclusion>
			</exclusions>
        </dependency>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>cdm-adapter</artifactId>
            <classifier>classes</classifier>
        </dependency>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>testutils</artifactId>
            <exclusions>
				<exclusion>
					<groupId>com.intuit.sbg.psp</groupId>
					<artifactId>batch-jobs</artifactId>
				</exclusion>
			</exclusions>
        </dependency>
        <dependency>
			<groupId>com.intuit.sbg.psp</groupId>
			<artifactId>batch-jobs</artifactId>
			<classifier>jss</classifier>
		</dependency>
		<dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>ptc-adapter</artifactId>
            <classifier>classes</classifier>
        </dependency>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>dis-adapter</artifactId>
            <classifier>classes</classifier>
        </dependency>
		<dependency>
			<groupId>com.intuit.sbg</groupId>
			<artifactId>job-scheduling-framework</artifactId>
			<optional>true</optional>
		</dependency>
		<dependency>
			<groupId>org.apache.commons</groupId>
			<artifactId>commons-collections4</artifactId>
		</dependency>
		<dependency>
			<groupId>com.google.guava</groupId>
			<artifactId>guava</artifactId>
			<version>20.0</version>
		</dependency>

		<dependency>
		    <groupId>com.splunk</groupId>
		    <artifactId>splunk</artifactId>
		    <version>1.6.3.0</version>
		</dependency>

		<dependency>
		    <groupId>org.quartz-scheduler</groupId>
		    <artifactId>quartz</artifactId>
		</dependency>

        <dependency>
            <groupId>io.github.resilience4j</groupId>
            <artifactId>resilience4j-ratelimiter</artifactId>
            <version>1.6.1</version>
        </dependency>

        <dependency>
            <groupId>com.intuit.sbg</groupId>
            <artifactId>workflow-finder</artifactId>
        </dependency>
    </dependencies>

    <build>
        <finalName>RTB-${psp.project.version}</finalName>
        <resources>
            <resource>
                <directory>resources/shell</directory>
                <excludes>
                    <exclude>**/*.*</exclude>
                </excludes>
            </resource>
            <resource>
                <directory>${project.resources.dir}</directory>
                <includes>
                    <include>META-INF/**</include>
                    <include>*.yaml</include>
                </includes>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <artifactId>maven-resources-plugin</artifactId>
                <version>2.7</version>
                <executions>
                    <execution>
                        <id>copy-jars</id>
                        <phase>install</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>

                        <configuration>
                            <outputDirectory>${project.jars.dir}</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>target</directory>
                                    <includes>
                                        <include>${project.build.finalName}.jar</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>