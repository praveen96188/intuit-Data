<?xml version="1.0"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd" xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.intuit.sbg.psp</groupId>
        <artifactId>Common</artifactId>
        <version>2.2.0-SNAPSHOT</version>
    </parent>
    <artifactId>pgp</artifactId>
    <name>pgp</name>
  
    <dependencies>
        <dependency>
            <groupId>com.intuit.sbg.psp</groupId>
            <artifactId>payroll-services-api-impl</artifactId>
        </dependency>
    </dependencies>
    
    <build>
        <resources>
            <resource>
                <directory>${project.resources.dir}</directory>
                <excludes>
                    <exclude>**/*.*</exclude>
                </excludes>          
            </resource>
        </resources>
        <testResources>
            <testResource>
                <directory>${project.test.resource.dir}</directory>
                <includes>
                    <include>**/*.*</include>
                </includes>
            </testResource>
        </testResources>        
    </build>
    
</project>
