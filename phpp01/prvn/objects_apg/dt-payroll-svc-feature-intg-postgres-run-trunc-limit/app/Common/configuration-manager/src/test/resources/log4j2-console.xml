<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="debug">

    <Properties>
        <Property name="layout">%d{yyyy-MM-dd'T'HH:mm:ss,SSSZ} %-5p [%t] %X{intuit_tid} %c{1} - %m%n</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${layout}"/>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="info" includeLocation="false">
            <AppenderRef ref="Console"/>
        </Root>
        <Logger name="com.intuit.identity.exptplatform" level="error"/>
    </Loggers>
</Configuration>