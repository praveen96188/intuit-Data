<?xml version="1.0"?>
<Resource handler="com.paycycle.gui.ResourceHandler">
  <!-- Record Templates -->
  <!-- ****************** EFT Payment Addenda Record For ND ACH Credit ****************** -->
  <Component class="com.paycycle.delimlen.DelimRecordTemplate" id="Txp_ND_UI">
      <Property name="Name" value="Payment Addenda Record"/>
      <Property name="Id" constant="com.paycycle.eft.RecordId.Txp_ND_UI"/>
      <Property name="Delimiter" value="*"/>

    <!-- ND does not use the 'TXP' segment identifier. -->
    
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="Employer Account Number"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.TAXPAYER_EIN"/>
        <Property name="ValueType" value="alpha"/>
        <Property name="Size" value="7"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="DelimiterReqd" value="0"/>
        <Description>First 7 digits of tax ID (no delimiter).</Description>
    </Field>

    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="Tax Amount"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_AMOUNT"/>
        <Property name="ValueType" value="numeric"/> <!-- $$$$$$$$cc -->
        <Property name="Size" value="10"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="DelimiterReqd" value="0"/>
        <Description>Tax Amount (no delimiter)</Description>
    </Field>

    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="FEIN"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.TAXPAYER_FEIN"/>
        <Property name="ValueType" value="alpha"/>
        <Property name="Size" value="9"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="DelimiterReqd" value="0"/>
        <Description>FEIN without hyphen (no delimiter)</Description>
    </Field>

    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="Employer Name"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.FILING_NAME"/>
        <Property name="ValueType" value="newLine"/>
        <Property name="Size" value="15"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="DelimiterReqd" value="0"/>
        <Description>First 15 chars of Employer Name (no delimiter)</Description>
    </Field>
        
  </Component>
</Resource>
