<?xml version="1.0"?>
<Resource handler="com.paycycle.gui.ResourceHandler">
    <!-- ****************** EFT Payment Addenda Record For MA (withholding) ****************** -->
    <Component class="com.paycycle.delimlen.DelimRecordTemplate" id="Txp_MA_WH">
        <Property name="Name" value="Payment Addenda Record"/>
        <Property name="Id" constant="com.paycycle.eft.RecordId.Txp_MA_WH"/>
        <Property name="Delimiter" value="*"/>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Tax Payment ID"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.SEGMENT_IDENTIFIER"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="3"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="TXP"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Tax Payment ID.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Taxpayer ID #"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAXPAYER_EIN"/>
            <Property name="ValueType" value="alphanumeric"/>
            <Property name="Size" value="15"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Taxpayer ID #.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Tax Type Code"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_TYPE_CODE"/>
            <Property name="ValueType" value="alphanumeric"/>
            <Property name="Size" value="5"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="0166D"/>
            <Property name="DelimiterReqd" value="1"/>
            <Property name="EnableFormatting" value="1"/>
            <Description>Tax Type Code.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Period End Date"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_PERIOD_END_DATE"/>
            <Property name="ValueType" value="numeric"/>
            <!-- YYMMDD -->
            <Property name="Size" value="6"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Period End Date.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Amount Type"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_AMOUNT_TYPE"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="1"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="T"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Amount Type.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Payment Amount"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_AMOUNT"/>
            <Property name="ValueType" value="numeric"/>
            <!-- ddddddddcc -->
            <Property name="Size" value="10"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Property name="EnableFormatting" value="1"/>
            <Description>Payment Amount.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Unused"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.RECORD_SEPARATOR"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="0"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Unused.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Unused"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.RECORD_SEPARATOR"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="0"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Unused.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Unused"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.RECORD_SEPARATOR"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="0"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Unused.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Unused"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.RECORD_SEPARATOR"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="0"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Unused.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Taxpayer Name Check"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.FILING_NAME"/>
            <Property name="ValueType" value="alphanumeric"/>
            <Property name="Size" value="6"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="0"/>
            <Description>Taxpayer Name Check.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Terminator"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TERMINATOR"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="1"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="\"/>
            <Property name="DelimiterReqd" value="0"/>
            <Description>Terminator.</Description>
        </Field>
    </Component>

    <!-- ****************** EFT Payment Addenda Record For MA (UI) ****************** -->
    <Component class="com.paycycle.delimlen.DelimRecordTemplate" id="Txp_MA_UI">
        <Property name="Name" value="Payment Addenda Record"/>
        <Property name="Id" constant="com.paycycle.eft.RecordId.Txp_MA_UI"/>
        <Property name="Delimiter" value="*"/>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Discretionary Data"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.DISCRETIONARY_DATA"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="3"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="TXP"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Reserved(Numeric)</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="MA DUA Account Number"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAXPAYER_EIN"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="9"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>MA DUA Account Number (No decimal, hyphen or check digit. Left fill with zeros. ex: 999999999)</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="FEIN"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAXPAYER_FEIN"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="9"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>FEIN(Omit hyphen. Fill with 9's if not yet available. ex: 999999999)</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Amount of Payment"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_AMOUNT"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="10"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Amount of Payment($$$$$$$$cc - Dollars and cents, no decimal. No comma. Left fill with zeros. ex: 0000987612)</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Reserved Data"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.DEFAULT_VALUE_NUM_1"/>
            <Property name="ValueType" value="blank"/>
            <Property name="Size" value="43"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="ConstantValue" value="0000000000000000000000000000000000000000000"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Reserved Data(Numeric)</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Terminator"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TERMINATOR"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="1"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="\"/>
            <Property name="DelimiterReqd" value="0"/>
            <Description>Terminator</Description>
        </Field>
    </Component>
</Resource>
