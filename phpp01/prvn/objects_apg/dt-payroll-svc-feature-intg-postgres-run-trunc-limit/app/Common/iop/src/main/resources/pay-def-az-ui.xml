<?xml version="1.0"?>
<Resource handler="com.paycycle.gui.ResourceHandler">
  <!-- Record Templates -->
  <!-- ****************** EFT Payment Addenda Record For CO DOR ****************** -->
  <Component class="com.paycycle.delimlen.DelimRecordTemplate" id="Txp_AZ_UI">
    <Property name="Name" value="Payment Addenda Record"/>
    <Property name="Id" constant="com.paycycle.eft.RecordId.Txp_AZ_UI"/>
    <Property name="Delimiter" value="*"/>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
      <Property name="Name" value="Segment Identifier"/>
      <Property name="Id" constant="com.paycycle.eft.FieldId.SEGMENT_IDENTIFIER"/>
      <Property name="ValueType" value="alpha"/>
      <Property name="Size" value="3"/>
      <Property name="Inclusion" value="mandatory"/>
      <Property name="Value" value="TXP"/>
      <Property name="DelimiterReqd" value="1"/>
      <Description>Segment Identifier</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="State Tax ID"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.TAXPAYER_EIN"/>
        <Property name="ValueType" value="alpha"/>
        <Property name="Size" value="7"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="DelimiterReqd" value="1"/>
        <Description>First 7 digits of State Tax ID</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
      <Property name="Name" value="Federal EIN"/>
      <Property name="Id" constant="com.paycycle.eft.FieldId.TAXPAYER_FEIN"/>
      <Property name="ValueType" value="alpha"/>
      <Property name="Size" value="15"/>
      <Property name="Inclusion" value="mandatory"/>
      <Property name="DelimiterReqd" value="1"/>
      <Description>Federal EIN without the hyphen</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
      <Property name="Name" value="Tax Type Code"/>
      <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_TYPE_CODE"/>
      <Property name="ValueType" value="alphanumeric"/>
      <Property name="Size" value="1"/>
      <Property name="Value" value="0"/>
      <Property name="Inclusion" value="mandatory"/>
      <Property name="DelimiterReqd" value="1"/>
      <Description>Tax Type Code is always 0</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
      <Property name="Name" value="Tax Period Year"/>
      <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_YEAR"/>
      <Property name="ValueType" value="numeric"/>
      <Property name="Size" value="4"/>
      <Property name="Inclusion" value="mandatory"/>
      <Property name="DelimiterReqd" value="1"/>
      <Description>4 digit tax period year</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
      <Property name="Name" value="Tax Period Quarter"/>
      <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_QUARTER"/>
      <Property name="ValueType" value="numeric"/>
      <Property name="Size" value="1"/>
      <Property name="Inclusion" value="mandatory"/>
      <Property name="DelimiterReqd" value="1"/>
      <Description>1 digit tax period quarter</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
      <Property name="Name" value="Arizona Terminating Constant"/>
      <Property name="ValueType" value="alphanumeric"/>
      <Property name="Size" value="7"/>
      <Property name="Inclusion" value="mandatory"/>
      <Property name="Value" value="7265100"/>
      <Property name="DelimiterReqd" value="1"/>
      <Description>Arizona Terminating Constant</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
      <Property name="Name" value="Terminator"/>
      <Property name="Id" constant="com.paycycle.eft.FieldId.TERMINATOR"/>
      <Property name="ValueType" value="alpha"/>
      <Property name="Size" value="1"/>
      <Property name="Inclusion" value="mandatory"/>
      <Property name="Value" value="\"/>
      <Property name="DelimiterReqd" value="0"/>
      <Description>Terminator</Description>
    </Field>
  </Component>
</Resource>
