        <Property name="Size" value="1"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="DelimiterReqd" value="1"/>
        <Description>TAX_QUARTER</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="Tax Year"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_YEAR"/>
        <Property name="ValueType" value="numeric"/>
        <Property name="Size" value="4"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="DelimiterReqd" value="1"/>
        <Description>TAX_YEAR</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="Payment Amount"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_AMOUNT"/>
        <Property name="ValueType" value="numeric"/> <!-- ddddddddcc -->
        <Property name="Size" value="11"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="DelimiterReqd" value="1"/>
        <Description>Payment Amount.</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="Payroll Service Provider"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.SERVICE_PROVIDER"/>
        <Property name="ValueType" value="alpha"/> <!-- ddddddddcc -->
        <Property name="Size" value="20"/>
        <Property name="Value" value="CRI                 "/>
        <Property name="Inclusion" value="mandatory"/>
        <Description>Payment Amount.</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="Terminator"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.TERMINATOR"/>
        <Property name="ValueType" value="alpha"/>
        <Property name="Size" value="1"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="Value" value="\"/>
        <Property name="DelimiterReqd" value="0"/>
        <Description>end of line</Description>
    </Field>
    <Field class="com.paycycle.delimlen.DelimFieldTemplate">
        <Property name="Name" value="Filler"/>
        <Property name="Id" constant="com.paycycle.eft.FieldId.FILLER"/>
        <Property name="ValueType" value="alpha"/>
        <Property name="Size" value="21"/>
        <Property name="Inclusion" value="mandatory"/>
        <Property name="Value" value="                     "/>
        <Property name="DelimiterReqd" value="0"/>
        <Description>end of line</Description>
    </Field>
