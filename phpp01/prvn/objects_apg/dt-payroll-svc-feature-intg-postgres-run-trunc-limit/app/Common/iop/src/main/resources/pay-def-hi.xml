<?xml version="1.0"?>
<Resource handler="com.paycycle.gui.ResourceHandler">
    <!-- ****************** EFT Payment Addenda Record For HI (withholding) ****************** -->
    <Component class="com.paycycle.delimlen.DelimRecordTemplate" id="Txp_HI_WH">
        <Property name="Name" value="Payment Addenda Record"/>
        <Property name="Id" constant="com.paycycle.eft.RecordId.Txp_HI_WH"/>
        <Property name="Delimiter" value="*"/>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Tax Payment ID"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.SEGMENT_IDENTIFIER"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="3"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="TXP"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Tax Payment ID.</Description>
        </Field>
        <!-- Hawaii Taxpayer ID and Suffix has replaced the General Excise Number, however if the Hawaii Taxpayer ID is not known, use General Excise Number.   -->
        <!-- Hawaii prefers the Taxpayer ID and Suffix, but it will accept the General Excise Number until further notice.                                      -->
        <!-- Hawaii Taxpayer ID and General Excise Number are mutually exclusive within the record - use one or the other (Hawaii Taxpayer ID starts with a W). -->
        <!-- Note: The Payment Amount is no longer on the Addenda record, since it already appears in Field #6 of the Entry Detail '6' record.                  -->
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="General Excise Number"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.GENERAL_EXCISE_NUMBER"/>
            <Property name="ValueType" value="numeric"/>
            <Property name="Size" value="8"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>General Excise Number - Set to all zeros (00000000) if Hawaii Taxpayer ID is known (preferred), else set to General Excise Number and state will cross reference.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Tax Type Code"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_TYPE_CODE"/>
            <Property name="ValueType" value="alphanumeric"/>
            <Property name="Size" value="5"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="01130"/>
            <Property name="DelimiterReqd" value="1"/>
             <Property name="EnableFormatting" value="1"/>
            <Description>Tax Payment Type Code.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Period End Date"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_PERIOD_END_DATE"/>
            <Property name="ValueType" value="numeric"/>
            <!-- YYMMDD -->
            <Property name="Size" value="6"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Tax Period End Date.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Period Start Date"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TAX_PERIOD_START_DATE"/>
            <Property name="ValueType" value="numeric"/>
            <!-- YYMMDD -->
            <Property name="Size" value="6"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Tax Period Start Date.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Hawaii Taxpayer ID"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.HAWAII_TAX_ID"/>
            <Property name="ValueType" value="alphanumeric"/>
            <Property name="Size" value="12"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Hawaii Taxpayer ID - If the Hawaii Taxpayer ID is known (it starts with a W), use it since it is preferred by the state; else leave blank and populate the General Excise Number.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Hawaii Taxpayer ID Suffix"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.HAWAII_TAX_ID_SUFFIX"/>
            <Property name="ValueType" value="numeric"/>
            <Property name="Size" value="2"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Hawaii Taxpayer ID Suffix - Required if using Hawaii Taxpayer ID, else leave blank.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Annual Period Indicator"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.ANNUAL_PERIOD_INDICATOR"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="1"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="DelimiterReqd" value="1"/>
            <Description>Annual Period Indicator - 'Y' = Payment is for an annual period, 'N' = Payment is for a non-annual period.</Description>
        </Field>
        <Field class="com.paycycle.delimlen.DelimFieldTemplate">
            <Property name="Name" value="Terminator"/>
            <Property name="Id" constant="com.paycycle.eft.FieldId.TERMINATOR"/>
            <Property name="ValueType" value="alpha"/>
            <Property name="Size" value="1"/>
            <Property name="Inclusion" value="mandatory"/>
            <Property name="Value" value="\"/>
            <Property name="DelimiterReqd" value="0"/>
            <Description>Terminator.</Description>
        </Field>
    </Component>
</Resource>
