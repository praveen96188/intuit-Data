def getJiraList(String previous_tag , String current_tag) {
    	def commitLog=getDetailedMessage(previous_tag,current_tag)
    	echo "jira are ${commitLog}"
	def matcher = commitLog =~ /\w+-\d+/

 
   	for(String it:matcher){
		jira_id=it.substring(it.lastIndexOf(":") + 1, it.length())
		jiraList.add(jira_id)
	}
    	echo "Jira tickets: ${jiraList}"
    	return jiraList.unique()
}
def getDetailedMessage(String previous_tag , String current_tag){

	sh '''
                git log --pretty=\"%s (%an)\" '''+previous_tag+'''...'''+current_tag+''' --no-merges | sort --unique >/tmp/detaiedMessage
        '''
        return sh (script: "cat /tmp/detaiedMessage",returnStdout: true).trim()

}

def getCommitersEmail(String previous_tag , String current_tag){

	sh '''
                git log --pretty="%ae" '''+previous_tag+'''...'''+current_tag+''' --no-merges | sort --unique | grep -v svc-ibp@intuit.com >/tmp/commiterEmail
        '''
	return sh (script: "cat /tmp/commiterEmail",returnStdout: true).trim()
}

def getContributors(String previous_tag , String current_tag){

        def commitLog=getCommitersEmail(previous_tag,current_tag)
        def matcher = commitLog =~ /.*@.*/

	def contributer = ""

        for(String commiter:matcher){

                contributer = contributer + commiter
                contributer = contributer + "<br>"

        }
        echo "contributer: ${contributer}"
        return contributer


}
def getReleaseInfo(){

        for(String info:"${RELEASE_NOTES}".split("\n")){
                releaseInfo = releaseInfo + info + "<br>"
        }
        echo "releaseInfo: ${releaseInfo}"
        return releaseInfo

}
def getPreviousTag(){

	sh '''
                git describe --tags $(git rev-list --tags --max-count=1) > /tmp/previoustag
        '''
	return sh (script: "cat /tmp/previoustag",returnStdout: true).trim()
}

def getVersion() {
        echo "branch type is ${BRANCH_TYPE}"
	sh '''
		mvn -Denvironment=build -s ./jenkins/settings.xml help:evaluate -Dexpression=project.version -q -DforceStdout > /tmp/version
	'''
	currentVersion = sh (script: "cat /tmp/version",returnStdout: true).trim()
        
	echo "current version of artifact was ${currentVersion}" 
	def version = currentVersion.split('-SNAPSHOT')[0]
        
	def majorVersion = version.tokenize(".")[0] as int
	def minorVersion = version.tokenize(".")[1] as int
	def patchVersion = version.tokenize(".")[2] as int
     
        if (params.BRANCH_TYPE == 'MAJOR'){
		majorVersion = majorVersion + 1
		minorVersion = 0
		patchVersion = 0
	   
	} 	
        if (params.BRANCH_TYPE == 'MINOR'){
		minorVersion = minorVersion + 1
		patchVersion = 0
	   
	} 	

	return "${majorVersion}.${minorVersion}.${patchVersion}"
}

def getNextVersion(String version) {

        def majorVersion = version.tokenize(".")[0] as int
        def minorVersion = version.tokenize(".")[1] as int
        def patchVersion = version.tokenize(".")[2] as int
        patchVersion = patchVersion + 1
        return "${majorVersion}.${minorVersion}.${patchVersion}-SNAPSHOT"
}

def updatePOMVersion(String pomVersion,String commitMessage) {
sh '''	
	mvn -Denvironment=build -s ./jenkins/settings.xml versions:set -DnewVersion='''+pomVersion+'''
	mvn -Denvironment=build -s ./jenkins/settings.xml versions:set-property -Dproperty=psp.project.version -DnewVersion='''+pomVersion+'''
        
	git add -u
        git commit -m "'''+commitMessage+'''"
        git push origin HEAD:${BRANCH}
'''
}
def createReleaseNotes(String version) {
        releaseVersion = "v${version}"
	withCredentials([usernamePassword(credentialsId: 'SCM-GitHub-Token', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]){
        container('maven') {
	    jiraList = getJiraList(latestReleaseTag,"HEAD")
            def jira_list =  getJiraNotes()
	    releaseDiff = "https://github.intuit.com/${repo}/compare/${latestReleaseTag}...v${version}"
	    releaseDiffShortUrl = "${latestReleaseTag}...v${version}"
	    releaseInfo = getReleaseInfo()
	    releaseNotes = """
                curl -X POST \
                  -u ${GIT_USERNAME}:${GIT_PASSWORD} \
                  https://github.intuit.com/api/v3/repos/${repo}/releases \
                  -H 'Content-Type: application/vnd.github.v3.html+json' \
                  -H 'cache-control: no-cache' \
                  -d '{
                  "tag_name":"v${version}",
                  "name":"v${version}",
                  "body":"Changes between ${latestReleaseTag} and v${version}\\n \\n ${releaseDiff} \\n \\n Contributors \\n \\n ${contributorsEmail}  \\n \\n ${jira_list} \\n \\n Release Notes \\n \\n ${releaseInfo}",
		  "target_commitish":"${BRANCH}",
		  "draft":false,
		  "prerelease":false
                }
                    '
            """
            def response = sh(returnStdout: true, script: "${releaseNotes}").trim()
            def responseJson = readJSON text: response
            echo "Release notes URL: ${responseJson.url}"  
        }
    }
}
def getLatestRelease(){
    withCredentials([usernamePassword(credentialsId: 'SCM-GitHub-Token', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]){
        container('maven') {
            latestRelease = """
                curl -X GET \
                  -u ${GIT_USERNAME}:${GIT_PASSWORD} \
                  https://github.intuit.com/api/v3/repos/${repo}/releases/latest \
                  -H 'Content-Type: application/json' \
                  -H 'cache-control: no-cache' \
            """
            def response = sh(returnStdout: true, script: "${latestRelease}").trim()
            def responseJson = readJSON text: response
            echo "response.tag_name: ${responseJson.tag_name}"                 
            return responseJson.tag_name
        }
    }    
}

def sendSlackNotification(Map parameters) {
    def attachments = [
        [
            "fallback": "Failed - Job '${parameters.jobName} [${parameters.buildNumber}]' (${parameters.buildUrl})",
            "author_name": "Built by ${parameters.buildUser} [${parameters.buildUserId}]",
            "author_icon": "https://platform.slack-edge.com/img/default_application_icon.png",
            "title": "${parameters.buildStatus} - ${parameters.jobName} #${parameters.buildNumber}",
            "title_link": "${parameters.buildUrl}",
            "fields": [
                [
                    "title": "Branch",
                    "value": "${parameters.branch}",
                    "short": true
                ],
                [
                    "title": "Build Duration",
                    "value": "${parameters.buildDuration}",
                    "short": true
                ],
                [
                    "title": "Version",
                    "value": "${parameters.releaseVersion}",
                    "short": true
                ],
                [
                    "title": "Release Diff",
                    "value": "<${parameters.releaseDiff}| ${parameters.releaseDiffShortUrl}>",
                    "short": true
                ]
            ],
            "color": "${parameters.statusColor}"
        ]
    ]
    slackSend (attachments: attachments)
}
