			releaseVersion: "${releaseVersion}",
			releaseDiff: "${releaseDiff}",
			releaseDiffShortUrl : "${releaseDiffShortUrl}", 
                        statusColor: '#b50911'
                    )
                 }
             }
        }
    }

}


