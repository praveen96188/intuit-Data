02:45:31 SQL> DECLARE
02:45:31   2  	  RECORD_COUNT	    INTEGER := 0;
02:45:31   3  	  MAX_RECORDS	    INTEGER := 200000;
02:45:31   4  	  PROCESSED_RECORDS INTEGER := 0;
02:45:31   5  	  MAX_FETCH_RECORDS INTEGER := 25000;
02:45:31   6  BEGIN
02:45:31   7  	  SELECT count(*) INTO RECORD_COUNT FROM PSPADM.PSP_PAYEE WHERE PUBLISH_STATUS <> '0000000000000000';
02:45:31   8  
02:45:31   9  	  DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
02:45:31  10  
02:45:31  11  	  WHILE RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS
02:45:31  12  	      LOOP
02:45:31  13  		  UPDATE PSPADM.PSP_PAYEE
02:45:31  14  		  SET PUBLISH_STATUS = '0000000000000000'
02:45:31  15  		  WHERE payee_seq IN (SELECT payee_seq
02:45:31  16  					FROM PSPADM.PSP_PAYEE
02:45:31  17  					WHERE PUBLISH_STATUS <> '0000000000000000' AND ROWNUM <= MAX_FETCH_RECORDS);
02:45:31  18  		  COMMIT;
02:45:31  19  		  PROCESSED_RECORDS := PROCESSED_RECORDS + MAX_FETCH_RECORDS;
02:45:31  20  		  DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
02:45:31  21  	      END LOOP;
02:45:31  22  EXCEPTION
02:45:31  23  	  WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error updating the record');
02:45:31  24  END;
