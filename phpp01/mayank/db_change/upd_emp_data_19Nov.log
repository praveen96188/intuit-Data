02:45:14 SQL> DECLARE
02:45:14   2  	  RECORD_COUNT	    INTEGER := 0;
02:45:14   3  	  MAX_RECORDS	    INTEGER := 250000;
02:45:14   4  	  PROCESSED_RECORDS INTEGER := 0;
02:45:14   5  	  MAX_FETCH_RECORDS INTEGER := 25000;
02:45:14   6  BEGIN
02:45:14   7  	  SELECT count(*) INTO RECORD_COUNT FROM PSPADM.PSP_EMPLOYEE WHERE PUBLISH_STATUS is not null AND PUBLISH_STATUS not like '_0%';
02:45:14   8  
02:45:14   9  	  DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
02:45:14  10  
02:45:14  11  	  WHILE RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS
02:45:14  12  	      LOOP
02:45:14  13  		  UPDATE PSPADM.PSP_EMPLOYEE
02:45:14  14  		  SET PUBLISH_STATUS = (substr(PUBLISH_STATUS, 1, 1) || '0' || substr(PUBLISH_STATUS, 3))
02:45:14  15  		  WHERE employee_seq IN (SELECT employee_seq
02:45:14  16  					FROM PSPADM.PSP_EMPLOYEE
02:45:14  17  					WHERE PUBLISH_STATUS is not null AND PUBLISH_STATUS not like '_0%' AND ROWNUM <= MAX_FETCH_RECORDS);
02:45:14  18  		  COMMIT;
02:45:14  19  		  PROCESSED_RECORDS := PROCESSED_RECORDS + MAX_FETCH_RECORDS;
02:45:14  20  		  DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
02:45:14  21  	      END LOOP;
02:45:14  22  EXCEPTION
02:45:14  23  	  WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error updating the record');
02:45:14  24  END;
