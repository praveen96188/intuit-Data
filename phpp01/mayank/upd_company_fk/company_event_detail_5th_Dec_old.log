06:08:45 SQL> 
06:08:45 SQL> DECLARE
06:08:45   2  
06:08:45   3  	RECORD_COUNT	   INTEGER   := 0;
06:08:45   4  	MAX_RECORDS	   INTEGER   := 1100000;
06:08:45   5  	PROCESSED_RECORDS  INTEGER   := 0;
06:08:45   6  	ERROR_RECORDS	   INTEGER   := 0;
06:08:45   7  	MAX_FETCH_RECORDS  INTEGER   := 100;
06:08:45   8  	BATCH_COUNT	   INTEGER   := 0;
06:08:45   9  	START_DATE	   DATE := TO_DATE('2011-08-22', 'yyyy-mm-dd');
06:08:45  10  	END_DATE	   DATE := TO_DATE('2011-09-30', 'yyyy-mm-dd');
06:08:45  11  	PARTITION_END_DATE DATE := START_DATE + 1;
06:08:45  12  
06:08:45  13  BEGIN
06:08:45  14  	SELECT count(*) INTO RECORD_COUNT from PSPADM.PSP_COMPANY_EVENT_DETAIL WHERE COMPANY_FK IS NULL;
06:08:45  15  
06:08:45  16  	DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
06:08:45  17  
06:08:45  18  	WHILE (START_DATE < END_DATE AND RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
06:08:45  19  
06:08:45  20  	  LOOP
06:08:45  21  	    DBMS_OUTPUT.PUT_LINE('OUTER LOOP');
06:08:45  22  	    BATCH_COUNT := 1; --TO ENTER THE LOOP AT LEAST ONCE FOR A DAY.
06:08:45  23  
06:08:45  24  	    WHILE (BATCH_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
06:08:45  25  
06:08:45  26  	      LOOP
06:08:45  27  		BEGIN
06:08:45  28  		  DBMS_OUTPUT.PUT_LINE('INNER LOOP');
06:08:45  29  
06:08:45  30  		  MERGE INTO PSPADM.PSP_COMPANY_EVENT_DETAIL ced
06:08:45  31  		  using (SELECT cedi.COMPANY_EVENT_DETAIL_SEQ, cei.COMPANY_FK
06:08:45  32  			 FROM PSPADM.PSP_COMPANY_EVENT_DETAIL cedi,
06:08:45  33  			      PSPADM.PSP_COMPANY_EVENT cei
06:08:45  34  			 WHERE cei.EVENT_TIME_STAMP between START_DATE and PARTITION_END_DATE
06:08:45  35  			   AND cedi.COMPANY_EVENT_FK = cei.COMPANY_EVENT_SEQ
06:08:45  36  			   AND cedi.COMPANY_FK is null
06:08:45  37  			   and ROWNUM <= MAX_FETCH_RECORDS) ce
06:08:45  38  		  on (ced.COMPANY_EVENT_DETAIL_SEQ = ce.COMPANY_EVENT_DETAIL_SEQ)
06:08:45  39  		  when matched then
06:08:45  40  		    update set ced.COMPANY_FK = ce.COMPANY_FK, ced.modified_date=sys_extract_utc(systimestamp);
06:08:45  41  		  BATCH_COUNT := SQL%ROWCOUNT;
06:08:45  42  		  COMMIT;
06:08:45  43  
06:08:45  44  		  PROCESSED_RECORDS := PROCESSED_RECORDS + BATCH_COUNT;
06:08:45  45  
06:08:45  46  		  DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
06:08:45  47  
06:08:45  48  		EXCEPTION
06:08:45  49  		  WHEN OTHERS THEN
06:08:45  50  		    ERROR_RECORDS := ERROR_RECORDS + BATCH_COUNT;
06:08:45  51  		    DBMS_OUTPUT.PUT_LINE('Failed ' || ERROR_RECORDS || ' records');
06:08:45  52  		END;
06:08:45  53  	      END LOOP;
06:08:45  54  	    START_DATE := START_DATE + 1;
06:08:45  55  	    PARTITION_END_DATE := START_DATE + 1;
06:08:45  56  	    DBMS_OUTPUT.PUT_LINE('START-DATE : ' || TO_DATE(START_DATE, 'yyyy-mm-dd') || ' PARTITION-END-DATE : ' || TO_DATE(PARTITION_END_DATE, 'yyyy-mm-dd'));
06:08:45  57  	  END LOOP;
06:08:45  58  
06:08:45  59  EXCEPTION
06:08:45  60  
06:08:45  61  	WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error in Procedure');
06:08:45  62  
06:08:45  63  END;
