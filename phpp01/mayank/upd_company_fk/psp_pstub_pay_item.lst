23:28:03 SQL> 
23:28:03 SQL> DECLARE
23:28:03   2  	  RECORD_COUNT	     INTEGER   := 2794030097;
23:28:03   3  	  MAX_RECORDS	     INTEGER   := 10000000;
23:28:03   4  	  PROCESSED_RECORDS  INTEGER   := 0;
23:28:03   5  	  ERROR_RECORDS      INTEGER   := 0;
23:28:03   6  	  MAX_FETCH_RECORDS  INTEGER   := 50000;
23:28:03   7  	  BATCH_COUNT	     INTEGER   := 0;
23:28:03   8  	  START_DATE	     DATE := TO_DATE('2022-11-21', 'yyyy-mm-dd');
23:28:03   9  	  END_DATE	     DATE := TO_DATE('2022-11-22', 'yyyy-mm-dd');
23:28:03  10  	  PARTITION_START_DATE DATE := END_DATE - 1;
23:28:03  11  BEGIN
23:28:03  12  
23:28:03  13  	  DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
23:28:03  14  
23:28:03  15  	  WHILE (RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
23:28:03  16  
23:28:03  17  	      LOOP
23:28:03  18  		  DBMS_OUTPUT.PUT_LINE('OUTER LOOP');
23:28:03  19  		  BATCH_COUNT := 1; --TO ENTER THE LOOP AT LEAST ONCE FOR A DAY.
23:28:03  20  
23:28:03  21  		  WHILE (BATCH_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
23:28:03  22  
23:28:03  23  		      LOOP
23:28:03  24  			  BEGIN
23:28:03  25  			      DBMS_OUTPUT.PUT_LINE('INNER LOOP');
23:28:03  26  
23:28:03  27  			      MERGE INTO PSPADM.PSP_PSTUB_PAY_ITEM ppio
23:28:03  28  			      using (SELECT ppi.PSTUB_PAY_ITEM_SEQ, p.COMPANY_FK
23:28:03  29  				     FROM PSPADM.PSP_PSTUB_PAY_ITEM ppi,
23:28:03  30  					  PSPADM.PSP_PAYSTUB ps,
23:28:03  31  					  PSPADM.PSP_PAYCHECK p
23:28:03  32  				     WHERE p.created_date BETWEEN START_DATE and START_DATE + 1
23:28:03  33  				       and ps.PAYCHECK_FK = p.PAYCHECK_SEQ
23:28:03  34  				       and ppi.PAYSTUB_FK = ps.PAYSTUB_SEQ
23:28:03  35  				       and ppi.COMPANY_FK is null
23:28:03  36  				       and ROWNUM <= MAX_FETCH_RECORDS) ppii
23:28:03  37  			      ON (ppio.PSTUB_PAY_ITEM_SEQ = ppii.PSTUB_PAY_ITEM_SEQ)
23:28:03  38  			      when matched then
23:28:03  39  				  update set ppio.COMPANY_FK = ppii.COMPANY_FK;
23:28:03  40  
23:28:03  41  			      BATCH_COUNT := SQL%ROWCOUNT;
23:28:03  42  			      COMMIT;
23:28:03  43  
23:28:03  44  			      PROCESSED_RECORDS := PROCESSED_RECORDS + BATCH_COUNT;
23:28:03  45  
23:28:03  46  			      DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
23:28:03  47  
23:28:03  48  			      if BATCH_COUNT < MAX_FETCH_RECORDS then
23:28:03  49  				  exit;
23:28:03  50  			      end if;
23:28:03  51  
23:28:03  52  			  EXCEPTION
23:28:03  53  			      WHEN OTHERS THEN
23:28:03  54  				  ERROR_RECORDS := ERROR_RECORDS + BATCH_COUNT;
23:28:03  55  				  DBMS_OUTPUT.PUT_LINE('Failed ' || ERROR_RECORDS || ' records');
23:28:03  56  			  END;
23:28:03  57  		      END LOOP;
23:28:03  58  		  exit;
23:28:03  59  		  END_DATE := END_DATE - 1;
23:28:03  60  		  PARTITION_START_DATE := END_DATE - 1;
23:28:03  61  		  DBMS_OUTPUT.PUT_LINE('PARTITION-START-DATE : ' || TO_DATE(PARTITION_START_DATE, 'yyyy-mm-dd') || ' END-DATE : ' || TO_DATE(END_DATE, 'yyyy-mm-dd'));
23:28:03  62  	      END LOOP;
23:28:03  63  EXCEPTION
23:28:03  64  	  WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error in Procedure');
23:28:03  65  END;
23:28:03  66  /
