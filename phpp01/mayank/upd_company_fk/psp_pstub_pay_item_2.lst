19:46:55 SQL> 
19:46:55 SQL> DECLARE
19:46:55   2  	  RECORD_COUNT	     INTEGER   := 2794030097;
19:46:55   3  	  MAX_RECORDS	     INTEGER   := 10000000;
19:46:55   4  	  PROCESSED_RECORDS  INTEGER   := 0;
19:46:55   5  	  ERROR_RECORDS      INTEGER   := 0;
19:46:55   6  	  MAX_FETCH_RECORDS  INTEGER   := 50000;
19:46:55   7  	  BATCH_COUNT	     INTEGER   := 0;
19:46:55   8  	  START_DATE	     DATE := TO_DATE('2022-11-1', 'yyyy-mm-dd');
19:46:55   9  	  END_DATE	     DATE := TO_DATE('2022-11-2', 'yyyy-mm-dd');
19:46:55  10  	  PARTITION_START_DATE DATE := END_DATE - 1;
19:46:55  11  BEGIN
19:46:55  12  
19:46:55  13  	  DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
19:46:55  14  
19:46:55  15  	  WHILE (RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
19:46:55  16  
19:46:55  17  	      LOOP
19:46:55  18  		  DBMS_OUTPUT.PUT_LINE('OUTER LOOP');
19:46:55  19  		  BATCH_COUNT := 1; --TO ENTER THE LOOP AT LEAST ONCE FOR A DAY.
19:46:55  20  
19:46:55  21  		  WHILE (BATCH_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
19:46:55  22  
19:46:55  23  		      LOOP
19:46:55  24  			  BEGIN
19:46:55  25  			      DBMS_OUTPUT.PUT_LINE('INNER LOOP');
19:46:55  26  
19:46:55  27  			      MERGE INTO PSPADM.PSP_PSTUB_PAY_ITEM ppio
19:46:55  28  			      using (SELECT ppi.PSTUB_PAY_ITEM_SEQ, p.COMPANY_FK
19:46:55  29  				     FROM PSPADM.PSP_PSTUB_PAY_ITEM ppi,
19:46:55  30  					  PSPADM.PSP_PAYSTUB ps,
19:46:55  31  					  PSPADM.PSP_PAYCHECK p
19:46:55  32  				     WHERE p.created_date BETWEEN START_DATE and START_DATE + 1
19:46:55  33  				       and ps.PAYCHECK_FK = p.PAYCHECK_SEQ
19:46:55  34  				       and ppi.PAYSTUB_FK = ps.PAYSTUB_SEQ
19:46:55  35  				       and ppi.COMPANY_FK is null
19:46:55  36  				       and ROWNUM <= MAX_FETCH_RECORDS) ppii
19:46:55  37  			      ON (ppio.PSTUB_PAY_ITEM_SEQ = ppii.PSTUB_PAY_ITEM_SEQ)
19:46:55  38  			      when matched then
19:46:55  39  				  update set ppio.COMPANY_FK = ppii.COMPANY_FK;
19:46:55  40  
19:46:55  41  			      BATCH_COUNT := SQL%ROWCOUNT;
19:46:55  42  			      COMMIT;
19:46:55  43  
19:46:55  44  			      PROCESSED_RECORDS := PROCESSED_RECORDS + BATCH_COUNT;
19:46:55  45  
19:46:55  46  			      DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
19:46:55  47  
19:46:55  48  			      if BATCH_COUNT < MAX_FETCH_RECORDS then
19:46:55  49  				  exit;
19:46:55  50  			      end if;
19:46:55  51  
19:46:55  52  			  EXCEPTION
19:46:55  53  			      WHEN OTHERS THEN
19:46:55  54  				  ERROR_RECORDS := ERROR_RECORDS + BATCH_COUNT;
19:46:55  55  				  DBMS_OUTPUT.PUT_LINE('Failed ' || ERROR_RECORDS || ' records');
19:46:55  56  			  END;
19:46:55  57  		      END LOOP;
19:46:55  58  		  exit;
19:46:55  59  		  END_DATE := END_DATE - 1;
19:46:55  60  		  PARTITION_START_DATE := END_DATE - 1;
19:46:55  61  		  DBMS_OUTPUT.PUT_LINE('PARTITION-START-DATE : ' || TO_DATE(PARTITION_START_DATE, 'yyyy-mm-dd') || ' END-DATE : ' || TO_DATE(END_DATE, 'yyyy-mm-dd'));
19:46:55  62  	      END LOOP;
19:46:55  63  EXCEPTION
19:46:55  64  	  WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error in Procedure');
19:46:55  65  END;
19:46:55  66  /
