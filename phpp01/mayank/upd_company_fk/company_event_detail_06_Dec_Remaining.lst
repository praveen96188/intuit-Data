00:15:41 SQL> 
00:15:41 SQL> DECLARE
00:15:41   2  
00:15:41   3  	RECORD_COUNT	   INTEGER   := 0;
00:15:41   4  	MAX_RECORDS	   INTEGER   := 1100000;
00:15:41   5  	PROCESSED_RECORDS  INTEGER   := 0;
00:15:41   6  	ERROR_RECORDS	   INTEGER   := 0;
00:15:41   7  	MAX_FETCH_RECORDS  INTEGER   := 100;
00:15:41   8  	BATCH_COUNT	   INTEGER   := 0;
00:15:41   9  	START_DATE	   DATE := TO_DATE('2011-07-22', 'yyyy-mm-dd');
00:15:41  10  	END_DATE	   DATE := TO_DATE('2011-09-30', 'yyyy-mm-dd');
00:15:41  11  	PARTITION_END_DATE DATE := START_DATE + 1;
00:15:41  12  
00:15:41  13  BEGIN
00:15:41  14  	SELECT count(*) INTO RECORD_COUNT from PSPADM.PSP_COMPANY_EVENT_DETAIL WHERE COMPANY_FK IS NULL;
00:15:41  15  
00:15:41  16  	DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
00:15:41  17  
00:15:41  18  	WHILE (START_DATE < END_DATE AND RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
00:15:41  19  
00:15:41  20  	  LOOP
00:15:41  21  	    DBMS_OUTPUT.PUT_LINE('OUTER LOOP');
00:15:41  22  	    BATCH_COUNT := 1; --TO ENTER THE LOOP AT LEAST ONCE FOR A DAY.
00:15:41  23  
00:15:41  24  	    WHILE (BATCH_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
00:15:41  25  
00:15:41  26  	      LOOP
00:15:41  27  		BEGIN
00:15:41  28  		  DBMS_OUTPUT.PUT_LINE('INNER LOOP');
00:15:41  29  
00:15:41  30  		  MERGE INTO PSPADM.PSP_COMPANY_EVENT_DETAIL ced
00:15:41  31  		  using (SELECT cedi.COMPANY_EVENT_DETAIL_SEQ, cei.COMPANY_FK
00:15:41  32  			 FROM PSPADM.PSP_COMPANY_EVENT_DETAIL cedi,
00:15:41  33  			      PSPADM.PSP_COMPANY_EVENT cei
00:15:41  34  			 WHERE cei.EVENT_TIME_STAMP between START_DATE and PARTITION_END_DATE
00:15:41  35  			   AND cedi.COMPANY_EVENT_FK = cei.COMPANY_EVENT_SEQ
00:15:41  36  			   AND cedi.COMPANY_FK is null
00:15:41  37  			   and ROWNUM <= MAX_FETCH_RECORDS) ce
00:15:41  38  		  on (ced.COMPANY_EVENT_DETAIL_SEQ = ce.COMPANY_EVENT_DETAIL_SEQ)
00:15:41  39  		  when matched then
00:15:41  40  		    update set ced.COMPANY_FK = ce.COMPANY_FK, ced.modified_date=sys_extract_utc(systimestamp);
00:15:41  41  		  BATCH_COUNT := SQL%ROWCOUNT;
00:15:41  42  		  COMMIT;
00:15:41  43  
00:15:41  44  		  PROCESSED_RECORDS := PROCESSED_RECORDS + BATCH_COUNT;
00:15:41  45  
00:15:41  46  		  DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
00:15:41  47  
00:15:41  48  		EXCEPTION
00:15:41  49  		  WHEN OTHERS THEN
00:15:41  50  		    ERROR_RECORDS := ERROR_RECORDS + BATCH_COUNT;
00:15:41  51  		    DBMS_OUTPUT.PUT_LINE('Failed ' || ERROR_RECORDS || ' records');
00:15:41  52  		END;
00:15:41  53  	      END LOOP;
00:15:41  54  	    START_DATE := START_DATE + 1;
00:15:41  55  	    PARTITION_END_DATE := START_DATE + 1;
00:15:41  56  	    DBMS_OUTPUT.PUT_LINE('START-DATE : ' || TO_DATE(START_DATE, 'yyyy-mm-dd') || ' PARTITION-END-DATE : ' || TO_DATE(PARTITION_END_DATE, 'yyyy-mm-dd'));
00:15:41  57  	  END LOOP;
00:15:41  58  
00:15:41  59  EXCEPTION
00:15:41  60  
00:15:41  61  	WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error in Procedure');
00:15:41  62  
00:15:41  63  END;
00:15:41  64  /
