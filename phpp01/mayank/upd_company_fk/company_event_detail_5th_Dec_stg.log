06:57:24 SQL> 
06:57:24 SQL> DECLARE
06:57:24   2  
06:57:24   3  	RECORD_COUNT	   INTEGER   := 0;
06:57:24   4  	MAX_RECORDS	   INTEGER   := 1100000;
06:57:24   5  	PROCESSED_RECORDS  INTEGER   := 0;
06:57:24   6  	ERROR_RECORDS	   INTEGER   := 0;
06:57:24   7  	MAX_FETCH_RECORDS  INTEGER   := 100;
06:57:24   8  	BATCH_COUNT	   INTEGER   := 0;
06:57:24   9  	START_DATE	   DATE := TO_DATE('2011-07-22', 'yyyy-mm-dd');
06:57:24  10  	END_DATE	   DATE := TO_DATE('2011-09-30', 'yyyy-mm-dd');
06:57:24  11  	PARTITION_END_DATE DATE := START_DATE + 1;
06:57:24  12  
06:57:24  13  BEGIN
06:57:24  14  	SELECT count(*) INTO RECORD_COUNT from PSPADM.PSP_COMPANY_EVENT_DETAIL WHERE COMPANY_FK IS NULL;
06:57:24  15  
06:57:24  16  	DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
06:57:24  17  
06:57:24  18  	WHILE (START_DATE < END_DATE AND RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
06:57:24  19  
06:57:24  20  	  LOOP
06:57:24  21  	    DBMS_OUTPUT.PUT_LINE('OUTER LOOP');
06:57:24  22  	    BATCH_COUNT := 1; --TO ENTER THE LOOP AT LEAST ONCE FOR A DAY.
06:57:24  23  
06:57:24  24  	    WHILE (BATCH_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS)
06:57:24  25  
06:57:24  26  	      LOOP
06:57:24  27  		BEGIN
06:57:24  28  		  DBMS_OUTPUT.PUT_LINE('INNER LOOP');
06:57:24  29  
06:57:24  30  		  MERGE INTO PSPADM.PSP_COMPANY_EVENT_DETAIL ced
06:57:24  31  		  using (SELECT cedi.COMPANY_EVENT_DETAIL_SEQ, cei.COMPANY_FK
06:57:24  32  			 FROM PSPADM.PSP_COMPANY_EVENT_DETAIL cedi,
06:57:24  33  			      PSPADM.PSP_COMPANY_EVENT cei
06:57:24  34  			 WHERE cei.EVENT_TIME_STAMP between START_DATE and PARTITION_END_DATE
06:57:24  35  			   AND cedi.COMPANY_EVENT_FK = cei.COMPANY_EVENT_SEQ
06:57:24  36  			   AND cedi.COMPANY_FK is null
06:57:24  37  			   and ROWNUM <= MAX_FETCH_RECORDS) ce
06:57:24  38  		  on (ced.COMPANY_EVENT_DETAIL_SEQ = ce.COMPANY_EVENT_DETAIL_SEQ)
06:57:24  39  		  when matched then
06:57:24  40  		    update set ced.COMPANY_FK = ce.COMPANY_FK, ced.modified_date=sys_extract_utc(systimestamp);
06:57:24  41  		  BATCH_COUNT := SQL%ROWCOUNT;
06:57:24  42  		  COMMIT;
06:57:24  43  
06:57:24  44  		  PROCESSED_RECORDS := PROCESSED_RECORDS + BATCH_COUNT;
06:57:24  45  
06:57:24  46  		  DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
06:57:24  47  
06:57:24  48  		EXCEPTION
06:57:24  49  		  WHEN OTHERS THEN
06:57:24  50  		    ERROR_RECORDS := ERROR_RECORDS + BATCH_COUNT;
06:57:24  51  		    DBMS_OUTPUT.PUT_LINE('Failed ' || ERROR_RECORDS || ' records');
06:57:24  52  		END;
06:57:24  53  	      END LOOP;
06:57:24  54  	    START_DATE := START_DATE + 1;
06:57:24  55  	    PARTITION_END_DATE := START_DATE + 1;
06:57:24  56  	    DBMS_OUTPUT.PUT_LINE('START-DATE : ' || TO_DATE(START_DATE, 'yyyy-mm-dd') || ' PARTITION-END-DATE : ' || TO_DATE(PARTITION_END_DATE, 'yyyy-mm-dd'));
06:57:24  57  	  END LOOP;
06:57:24  58  
06:57:24  59  EXCEPTION
06:57:24  60  
06:57:24  61  	WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error in Procedure');
06:57:24  62  
06:57:24  63  END;
