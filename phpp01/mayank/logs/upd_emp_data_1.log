23:10:58 SQL> DECLARE
23:10:58   2  	  RECORD_COUNT	    INTEGER := 0;
23:10:58   3  	  MAX_RECORDS	    INTEGER := 1000000;
23:10:58   4  	  PROCESSED_RECORDS INTEGER := 0;
23:10:58   5  	  MAX_FETCH_RECORDS INTEGER := 25000;
23:10:58   6  BEGIN
23:10:58   7  	  SELECT count(*) INTO RECORD_COUNT FROM PSPADM.PSP_EMPLOYEE WHERE LENGTH(PUBLISH_STATUS) <> 16;
23:10:58   8  
23:10:58   9  	  DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
23:10:58  10  
