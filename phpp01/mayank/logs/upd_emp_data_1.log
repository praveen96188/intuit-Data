23:10:58  13  		  UPDATE PSPADM.PSP_EMPLOYEE
23:10:58  14  		  SET PUBLISH_STATUS = '0000000000000000'
23:10:58  15  		  WHERE employee_seq IN (SELECT employee_seq
23:10:58  16  					FROM PSPADM.PSP_EMPLOYEE
23:10:58  17  					WHERE LENGTH(PUBLISH_STATUS) <> 16 AND ROWNUM <= MAX_FETCH_RECORDS);
23:10:58  18  		  COMMIT;
23:10:58  19  		  PROCESSED_RECORDS := PROCESSED_RECORDS + MAX_FETCH_RECORDS;
23:10:58  20  		  DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
23:10:58  21  	      END LOOP;
23:10:58  22  EXCEPTION
23:10:58  23  	  WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error updating the record');
23:10:58  24  END;
