00:39:33 SQL> DECLARE
00:39:33   2  	  RECORD_COUNT	    INTEGER := 0;
00:39:33   3  	  MAX_RECORDS	    INTEGER := 12000000;
00:39:33   4  	  PROCESSED_RECORDS INTEGER := 0;
00:39:33   5  	  MAX_FETCH_RECORDS INTEGER := 25000;
00:39:33   6  BEGIN
00:39:33   7  	  SELECT count(*) INTO RECORD_COUNT FROM PSPADM.PSP_EMPLOYEE WHERE LENGTH(PUBLISH_STATUS) <> 16;
00:39:33   8  
00:39:33   9  	  DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
00:39:33  10  
00:39:33  11  	  WHILE RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS
00:39:33  12  	      LOOP
00:39:33  13  		  UPDATE PSPADM.PSP_EMPLOYEE
00:39:33  14  		  SET PUBLISH_STATUS = '0000000000000000'
00:39:33  15  		  WHERE employee_seq IN (SELECT employee_seq
00:39:33  16  					FROM PSPADM.PSP_EMPLOYEE
00:39:33  17  					WHERE LENGTH(PUBLISH_STATUS) <> 16 AND ROWNUM <= MAX_FETCH_RECORDS);
00:39:33  18  		  COMMIT;
00:39:33  19  		  PROCESSED_RECORDS := PROCESSED_RECORDS + MAX_FETCH_RECORDS;
00:39:33  20  		  DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
00:39:33  21  	      END LOOP;
00:39:33  22  EXCEPTION
00:39:33  23  	  WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error updating the record');
00:39:33  24  END;
