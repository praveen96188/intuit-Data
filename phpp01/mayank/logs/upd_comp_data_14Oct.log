02:18:24 SQL> DECLARE
02:18:24   2  	RECORD_COUNT	  INTEGER := 0;
02:18:24   3  	MAX_RECORDS	  INTEGER := 4000000;
02:18:24   4  	PROCESSED_RECORDS INTEGER := 0;
02:18:24   5  	MAX_FETCH_RECORDS INTEGER := 25000;
02:18:24   6  BEGIN
02:18:24   7  	SELECT count(*) INTO RECORD_COUNT FROM PSPADM.PSP_COMPANY WHERE PUBLISH_STATUS is not null AND PUBLISH_STATUS not like '0%';
02:18:24   8  
02:18:24   9  	DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
02:18:24  10  
02:18:24  11  	WHILE RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS
02:18:24  12  	  LOOP
02:18:24  13  	    UPDATE PSPADM.PSP_COMPANY
02:18:24  14  	    SET PUBLISH_STATUS = ('0' || substr(PUBLISH_STATUS, 2))
02:18:24  15  	    WHERE company_seq IN (SELECT company_seq
02:18:24  16  				  FROM PSPADM.PSP_COMPANY
02:18:24  17  				  WHERE PUBLISH_STATUS is not null AND PUBLISH_STATUS not like '0%' AND ROWNUM <= MAX_FETCH_RECORDS);
02:18:24  18  	    COMMIT;
02:18:24  19  	    PROCESSED_RECORDS := PROCESSED_RECORDS + MAX_FETCH_RECORDS;
02:18:24  20  	    DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
02:18:24  21  	  END LOOP;
02:18:24  22  EXCEPTION
02:18:24  23  	WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error updating the record');
02:18:24  24  END;
