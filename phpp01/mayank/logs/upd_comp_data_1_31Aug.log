01:56:54 SQL> DECLARE
01:56:54   2  	  RECORD_COUNT	    INTEGER := 0;
01:56:54   3  	  MAX_RECORDS	    INTEGER := 500000;
01:56:54   4  	  PROCESSED_RECORDS INTEGER := 0;
01:56:54   5  	  MAX_FETCH_RECORDS INTEGER := 25000;
01:56:54   6  BEGIN
01:56:54   7  	  SELECT count(*) INTO RECORD_COUNT FROM PSPADM.PSP_COMPANY WHERE PUBLISH_STATUS <> '0000000000000000';
01:56:54   8  
01:56:54   9  	  DBMS_OUTPUT.PUT_LINE('Found ' || RECORD_COUNT || ' Records');
01:56:54  10  
01:56:54  11  	  WHILE RECORD_COUNT > 0 AND PROCESSED_RECORDS < MAX_RECORDS
01:56:54  12  	      LOOP
01:56:54  13  		  UPDATE PSPADM.PSP_COMPANY
01:56:54  14  		  SET PUBLISH_STATUS = '0000000000000000'
01:56:54  15  		  WHERE company_seq IN (SELECT company_seq
01:56:54  16  					FROM PSPADM.PSP_COMPANY
01:56:54  17  					WHERE PUBLISH_STATUS <> '0000000000000000' AND ROWNUM <= MAX_FETCH_RECORDS);
01:56:54  18  		  COMMIT;
01:56:54  19  		  PROCESSED_RECORDS := PROCESSED_RECORDS + MAX_FETCH_RECORDS;
01:56:54  20  		  DBMS_OUTPUT.PUT_LINE('Processed ' || PROCESSED_RECORDS || ' records successfully');
01:56:54  21  	      END LOOP;
01:56:54  22  EXCEPTION
01:56:54  23  	  WHEN OTHERS THEN DBMS_OUTPUT.PUT_LINE('Error updating the record');
01:56:54  24  END;
