    "resource": "DBInstance",
    "period": "5",
    "threshold": "70",
    "datapointsToAlarm": "1",
    "comparisonOperator": "GREATER_THAN_THRESHOLD",
    "statistic": "AVERAGE",
    "treatMissingData": "MISSING",
    "numEvaluationPeriods": "1",
