-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*- Top N redo generating sessions -*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-

SQL> set pages 10000
SQL> set lines 300
SQL> --col machine for a35
SQL> --col username for a10
SQL> column sid_serial for a13;
SQL> select b.username,
  2        machine,
  3        b.osuser,
  4        b.status,
  5        a.redo_mb,
  6        lpad((b.sid || ',' || lpad(b.serial#,5)),11) sid_serial
  7  from (select n.inst_id, sid,
  8              round(value/1024/1024/1024,2) redo_mb
  9          from gv$statname n, gv$sesstat s
 10          where n.inst_id=s.inst_id
 11                and n.name = 'redo size'
 12                and s.statistic# = n.statistic#
 13          order by value desc
 14      ) a,
 15      gv$session b
 16  where b.inst_id=a.inst_id
 17    and a.sid = b.sid
 18  and  rownum <= 10;

