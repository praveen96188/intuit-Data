SQL> set trimspool on
SQL> set lines 300
SQL> set pages 3000
SQL> col event for a30 trunc
SQL> col machine for a15 trunc
SQL> col username for a22
SQL> col osuser for a11
SQL> col module for a15 trunc
SQL> col tablespace format a15
SQL> col CLIENT_IDENTIFIER for a20
SQL> col company_id for a20
SQL> col jvm for a15 trunc
SQL> col LOGONTIME for a12 trunc
SQL> col Status for a1 trunc
SQL> col sql_id for a15
SQL> column sid_serial for a13
SQL> set long 10000
SQL> SET TRIMSPOOL ON
SQL> set pages 0
SQL> select ' ' from dual;


SQL> select lpad(rpad(' SQL_ID/SQLTEXT with > 5 active sessions ',105,'-*'),150,'-*') from dual;
-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*- SQL_ID/SQLTEXT with > 5 active sessions -*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*

SQL> set pages 1000
SQL> select s.sql_id, count(1) count
  2    from v$session s
  3   where s.status='ACTIVE' and s.SQL_ID is not null
  4   group by s.sql_id
  5   having count(1) > 5
  6   order by 2 desc;

