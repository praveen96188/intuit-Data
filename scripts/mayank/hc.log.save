-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*- Database/System Metrics -*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*

SQL> set pages 10000
SQL> col "Metric" for a45
SQL> col "Metric Unit" for a30
SQL> select m.metric_name "Metric" ,
  2         round(m.value,2)	"Current Value",
  3         round(s.average,2) "Average Value",
  4         round(s.MAXVAL,2) "Max Value",
  5         m.metric_unit "Metric Unit"
  6   FROM v$sysmetric	   m,
  7        v$sysmetric_summary s
  8  WHERE m.group_id=s.group_id
  9    AND m.METRIC_ID=s.METRIC_ID
 10    AND s.average > 0
 11    AND s.metric_name IN ('Redo Allocation Hit Ratio',
