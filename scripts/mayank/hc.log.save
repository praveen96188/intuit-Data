-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*- Sessions sorting data on disk -*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*-*

SQL> set pages 10000
SQL> SELECT tablespace,
  2         s.username,
  3         s.sql_id sql_id,
  4         substr(s.module,1,15) module,
  5         client_identifier,
  6         sum((u.blocks * (select value from v$parameter where name='db_block_size')))/1024/1024/1024 "Size(GB)",
  7         lpad((s.sid || ',' || lpad(s.serial#,5)),11) sid_serial,
  8         p.spid os_process
  9  FROM gv$session s, gv$sort_usage u, gv$process p
 10  WHERE s.saddr=u.session_addr
 11  and p.addr = s.paddr
 12  and u.extents > 10
 13  and u.inst_id = s.inst_id
 14  and TABLESPACE like '%TEMP%'
 15  group by tablespace,
 16           s.username,
 17           s.sql_id,
 18           substr(s.module,1,15),
 19           client_identifier,
 20           lpad((s.sid || ',' || lpad(s.serial#,5)),11),
 21           p.spid;

