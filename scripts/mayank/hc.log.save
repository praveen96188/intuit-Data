SQL> select sql_id, sql_fulltext
  2    from v$sql
  3   where sql_id in (select s.sql_id
  4                      from v$session s
  5                     where s.status='ACTIVE'
  6                       and s.SQL_ID is not null
  7                     group by s.sql_id
  8                      having count(1) > 5)
  9     and rownum < 2 ;

