 21  to_char(sum(decode(to_char(first_time,'HH24'),'19',(BLOCKS*BLOCK_SIZE)/1024/1024/1024,0)),'999.9') "19",
 22  to_char(sum(decode(to_char(first_time,'HH24'),'20',(BLOCKS*BLOCK_SIZE)/1024/1024/1024,0)),'999.9') "20",
 23  to_char(sum(decode(to_char(first_time,'HH24'),'21',(BLOCKS*BLOCK_SIZE)/1024/1024/1024,0)),'999.9') "21",
 24  to_char(sum(decode(to_char(first_time,'HH24'),'22',(BLOCKS*BLOCK_SIZE)/1024/1024/1024,0)),'999.9') "22",
 25  to_char(sum(decode(to_char(first_time,'HH24'),'23',(BLOCKS*BLOCK_SIZE)/1024/1024/1024,0)),'999.9') "23"
 26  from
 27  v$archived_log
 28  where dest_id=1 and to_date(first_time) > sysdate -14
 29  group by
 30  to_char(first_time,'YYYY-MON-DD'), to_date(first_time)
 31  order by to_date(first_time);

