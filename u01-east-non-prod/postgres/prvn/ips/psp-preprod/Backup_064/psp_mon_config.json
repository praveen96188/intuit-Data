{
  "id": "ppsp",
  "description": "PSP Monolith Cluster",
  "bu": "SBSEG",
  "dbName": "pdsmondb",
  "multiAZ": "false",
  "region": "us-west-2",
  "deployMonitoring": "true",
  "enableEnhancedMonitoring": "true",
  "enableAutoMinorVersionUpgrade": "false",
  "cloudwatchLogsRetention": "180",
  "metricSetId": "defaultMetricSetRef",
  "backupWindow":"05:00-05:30",
  "maintenanceWindow":"Mon:07:00-Mon:07:30",
  "backupRetention" : "35",
  "clusterParameterGroupRef": "ppsp:mon-pg14-cluster",
  "instanceParameterGroupRef": "ppsp:mon-pg14-instance",
  "subnetGroupRef": "ppsp:pspmondbsubnetgrp",
  "securityGroupRef" : "ppsp:pspmondbsecuritygrp",
  "engineMajorVersion" : "14",
  "engineMinorVersion" : "3",
  "tags": {
    "intuit:billing:component": "PSP",
    "intuit:billing:appenv": "ppd",
    "intuit:billing:service_assetid": "6847740825712235356",
    "intuit:billing:bu": "SBSEG",
    "intuit:billing:fp": "PSP"
  },
  "environments": [
    {
      "name": "pds",
      "splunkIndex": "lambda_logs",
      "splunkEnv": "E2E",
      "groups": [
        {
          "name": "primary-pds-mon",      
      "clusters": [
        {
          "id": "mon",
          "engineMajorVersion" : "14",
          "engineMinorVersion" : "3",
          "instanceType": "r6g.2xlarge"
        }
      ]
    }
  ]
   }
  ],
 "metrics": {
    "ipsMetrics": [
      {
        "metricName": [
          "num_active_connections",
          "active_conn_by_wait_event",
          "long_running_transactions",
          "locks",
          "vacuum_efficiency",
          "global_replication_lag",
          "uptime"
        ],
        "schedule": "*/5 * * * *"
      },
      {
        "metricName": [
          "buffer_cache_by_database", 
          "buffer_cache_breakup" 
        ],
        "schedule": "0 9 * * *"
      },
      {
        "metricName": [
          "growth_trends_by_db",
          "growth_trends_by_schema",
          "growth_trends_by_object",
        ],
        "schedule": "0 6 * * *"
      }
    ],
    "customMetrics": [
      {
        "metricName": [
          "num_active_connections"
        ],
        "schedule": "*/5 * * * *"
      }
    ],
    "splunkMetrics": [
      {
        "metricName": [
          "top_sql"
        ],
        "schedule": "*/5 * * * *"
      },
      {
        "metricName": [
          "vacuum_run_history",
          "list_extentions",
          "table_bloat",
          "index_bloat",
          "list_unused_indexes",
          "qpm_data"
        ],
        "schedule": "0 0 * * *"
      }
    ]
   }
}